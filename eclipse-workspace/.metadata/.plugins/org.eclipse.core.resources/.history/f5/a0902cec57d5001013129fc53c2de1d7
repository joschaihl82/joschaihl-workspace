void error(char* msg, ...) {
    fprintf(stderr, "%d:%d: error: ", line_number, cursor_pos);
    va_list args;
    va_start(args, msg);
    vfprintf(stderr, msg, args);
    va_end(args);
    fprintf(stderr, "\n");
    exit(1);
}

void output(char* msg, ...) {
    va_list args;
    va_start(args, msg);
    vfprintf(dst_file, msg, args);
    va_end(args);
}

