/* -------------------------
   init / load
   ------------------------- */
int funIniCpu(void) {
    if (!ptrMem) {
        ptrMem = malloc(VAL_RAM_SIZ);
        if (!ptrMem) return -1;
        memset(ptrMem, 0, VAL_RAM_SIZ);
    }
    objCpu.arrGpr[4] = VAL_RAM_SIZ - 0x1000; /* rsp */
    return 0;
}

/* -------------------------
   memory access (required for fetch32)
   ------------------------- */
uint32_t funMemR32(uint64_t valAdr) {
    uint8_t *ptr = ptrGetPtr(valAdr);
    uint32_t val = 0; if (ptr) memcpy(&val, ptr, 4); return val;
}

int funLodBin(const char *strPth) {
    FILE *ptrF = fopen(strPth, "rb");
    if (!ptrF) return -1;
    fseek(ptrF, 0, SEEK_END);
    long valSz = ftell(ptrF);
    fseek(ptrF, 0, SEEK_SET);
    if (valSz > VAL_RAM_SIZ) { fclose(ptrF); return -1; }
    fread(ptrMem, 1, valSz, ptrF);
    fclose(ptrF);
    printf("sys: loaded %ld bytes\n", valSz);
    return 0;
}

/* -------------------------
   sdl / fb logic (minimal version)
   ------------------------- */
typedef struct {
    SDL_Window *ptrWin;
    SDL_Renderer *ptrRen;
    SDL_Texture *ptrTex;
    int valW, valH;
} ObjFb;
static ObjFb objFb;

int funIniFb(int valW, int valH) {
    if (SDL_Init(SDL_INIT_VIDEO) != 0) return -1;
    objFb.valW = valW; objFb.valH = valH;
    objFb.ptrWin = SDL_CreateWindow("x64 mega-emu", SDL_WINDOWPOS_CENTERED, SDL_WINDOWPOS_CENTERED, valW, valH, SDL_WINDOW_SHOWN);
    if (!objFb.ptrWin) return -1;
    objFb.ptrRen = SDL_CreateRenderer(objFb.ptrWin, -1, SDL_RENDERER_ACCELERATED);
    objFb.ptrTex = SDL_CreateTexture(objFb.ptrRen, -1, SDL_TEXTUREACCESS_STREAMING, valW, valH);
    ptrFb = malloc(valW * valH * 4);
    if (!ptrFb) { SDL_DestroyWindow(objFb.ptrWin); SDL_Quit(); return -1; }
    return 0;
}
void funEndFb(void) {
    if (ptrFb) free(ptrFb);
    SDL_Quit();
}

/* -------------------------
   main entry point
   ------------------------- */
int main(int numArg, char **arrArg) {
    if (numArg < 2) {
        fprintf(stderr, "usage: %s <bin>\n", arrArg[0]);
        return 1;
    }
    if (funIniCpu() != 0) return 1;
    if (funIniFb(640, 480) != 0) return 1; /* init a basic framebuffer */
    if (funLodBin(arrArg[1]) != 0) return 1;

    printf("sys: running mega-expanded core...\n");
    funExec();

    funEndFb();
    return 0;
}
