/* Helper: read little-endian from guest memory */
static uint16_t read_u16(uint8_t *p) { uint16_t v; memcpy(&v, p, 2); return v; }
static uint32_t read_u32(uint8_t *p) { uint32_t v; memcpy(&v, p, 4); return v; }
static uint64_t read_u64(uint8_t *p) { uint64_t v; memcpy(&v, p, 8); return v; }

/* Resolve import names to local stubs (very small set) */
static void *resolve_import_symbol(const char *name) {
    if (!name) return NULL;
    /* Map a few common UEFI helper names to our stubs */
    if (strcmp(name, "ue_output_string") == 0) return (void*)ue_output_string;
    if (strcmp(name, "ue_stall") == 0) return (void*)ue_stall;
    if (strcmp(name, "ue_set_watchdog_timer") == 0) return (void*)ue_set_watchdog_timer;
    /* Add more mappings as needed */
    /* If not found, return NULL (unresolved) */
    return NULL;
}

/* Load a PE/COFF image from guest RAM at 'image_addr' and return entry point pointer.
   Returns NULL on failure. Allocates memory via ue_allocate_pages. */
void *pe_load_image(uint64_t image_addr, uint64_t *out_image_base, uint64_t *out_image_size) {
    uint8_t *base = get_memory_ptr(image_addr);
    if (!base) return NULL;
    IMAGE_DOS_HEADER dos;
    memcpy(&dos, base, sizeof(dos));
    if (dos.e_magic != 0x5A4D) { /* 'MZ' */
        trace_msg("pe_load_image: not MZ");
        return NULL;
    }
    uint32_t nt_off = dos.e_lfanew;
    uint8_t *nt_ptr = base + nt_off;
    uint32_t sig = read_u32(nt_ptr);
    if (sig != 0x00004550) { /* 'PE\0\0' */
        trace_msg("pe_load_image: no PE signature");
        return NULL;
    }
    IMAGE_FILE_HEADER fh;
    memcpy(&fh, nt_ptr + 4, sizeof(fh));
    if (fh.Machine != 0x8664) { /* AMD64 */
        trace_msg("pe_load_image: not x86_64");
        return NULL;
    }
    IMAGE_OPTIONAL_HEADER64 opt;
    memcpy(&opt, nt_ptr + 4 + sizeof(fh), sizeof(opt));
    uint64_t preferred_base = opt.ImageBase;
    uint32_t size_of_image = opt.SizeOfImage;
    uint32_t size_of_headers = opt.SizeOfHeaders;
    uint16_t num_sections = fh.NumberOfSections;
    IMAGE_SECTION_HEADER *sections = malloc(sizeof(IMAGE_SECTION_HEADER) * num_sections);
    if (!sections) return NULL;
    memcpy(sections, nt_ptr + 4 + sizeof(fh) + fh.SizeOfOptionalHeader, sizeof(IMAGE_SECTION_HEADER) * num_sections);

    /* Allocate pages for image */
    uint64_t pages = (size_of_image + PAGE_SIZE - 1) / PAGE_SIZE;
    EFI_PHYSICAL_ADDRESS alloc_addr = 0;
    if (ue_allocate_pages(0, 0, pages, &alloc_addr) != EFI_SUCCESS) {
        trace_msg("pe_load_image: allocate pages failed");
        free(sections);
        return NULL;
    }
    uint8_t *image_mem = (uint8_t*)(uintptr_t)alloc_addr;
    /* Zero image memory */
    memset(image_mem, 0, pages * PAGE_SIZE);

    /* Copy headers */
    memcpy(image_mem, base, size_of_headers);

    /* Copy sections */
    for (int i = 0; i < num_sections; ++i) {
        IMAGE_SECTION_HEADER *sh = &sections[i];
        if (sh->SizeOfRawData == 0) continue;
        uint8_t *src = base + sh->PointerToRawData;
        uint8_t *dst = image_mem + sh->VirtualAddress;
        memcpy(dst, src, sh->SizeOfRawData);
    }

    /* Apply base relocations if image loaded at different base */
    uint64_t delta = (uint64_t)(uintptr_t)image_mem - preferred_base;
    if (delta != 0) {
        /* Locate base relocation directory */
        uint8_t *data_dirs = (uint8_t*)&opt + offsetof(IMAGE_OPTIONAL_HEADER64, NumberOfRvaAndSizes) + 4;
        /* But easier: compute pointer to data directories: optional header begins at nt_ptr+4+sizeof(fh) */
        uint8_t *opt_base = nt_ptr + 4 + sizeof(fh);
        IMAGE_DATA_DIRECTORY *dirs = (IMAGE_DATA_DIRECTORY*)(opt_base + offsetof(IMAGE_OPTIONAL_HEADER64, NumberOfRvaAndSizes) + 4 - 4);
        /* Actually simpler: read directory at offset (opt + 16*8?) We'll compute offset: in PE32+ the data directories start immediately after OptionalHeader fields.
           For safety, compute pointer to data directories as opt_base + sizeof(IMAGE_OPTIONAL_HEADER64) - (NumberOfRvaAndSizes * sizeof(IMAGE_DATA_DIRECTORY)) ??? Simpler: use known offset: in our struct, after NumberOfRvaAndSizes field, data directories follow. We'll compute pointer: */
        uint8_t *dir_ptr = opt_base + sizeof(IMAGE_OPTIONAL_HEADER64);
        IMAGE_DATA_DIRECTORY *reloc_dir = (IMAGE_DATA_DIRECTORY*)(dir_ptr + IMAGE_DIRECTORY_ENTRY_BASERELOC * sizeof(IMAGE_DATA_DIRECTORY));
        uint32_t reloc_rva = reloc_dir->VirtualAddress;
        uint32_t reloc_size = reloc_dir->Size;
        if (reloc_rva && reloc_size) {
            uint8_t *reloc_base = image_mem + reloc_rva;
            uint8_t *reloc_end = reloc_base + reloc_size;
            uint8_t *p = reloc_base;
            while (p < reloc_end) {
                IMAGE_BASE_RELOCATION br;
                memcpy(&br, p, sizeof(br));
                if (br.SizeOfBlock == 0) break;
                uint32_t va = br.VirtualAddress;
                uint32_t block_size = br.SizeOfBlock;
                uint16_t *entries = (uint16_t*)(p + sizeof(br));
                int count = (block_size - sizeof(br)) / sizeof(uint16_t);
                for (int i = 0; i < count; ++i) {
                    uint16_t entry = entries[i];
                    uint16_t type = entry >> 12;
                    uint16_t offset = entry & 0x0FFF;
                    if (type == IMAGE_REL_BASED_DIR64) {
                        uint64_t *patch = (uint64_t*)(image_mem + va + offset);
                        *patch = *patch + delta;
                    }
                }
                p += block_size;
            }
        }
    }

    /* Resolve imports (very small) */
    /* Locate import directory */
    uint8_t *opt_base = nt_ptr + 4 + sizeof(fh);
    uint8_t *dir_ptr = opt_base + sizeof(IMAGE_OPTIONAL_HEADER64);
    IMAGE_DATA_DIRECTORY *import_dir = (IMAGE_DATA_DIRECTORY*)(dir_ptr + IMAGE_DIRECTORY_ENTRY_IMPORT * sizeof(IMAGE_DATA_DIRECTORY));
    uint32_t import_rva = import_dir->VirtualAddress;
    uint32_t import_size = import_dir->Size;
    if (import_rva && import_size) {
        IMAGE_IMPORT_DESCRIPTOR *imp = (IMAGE_IMPORT_DESCRIPTOR*)(image_mem + import_rva);
        while (imp->Name) {
            char libname[256];
            char *libname_src = (char*)(image_mem + imp->Name);
            strncpy(libname, libname_src, sizeof(libname)-1);
            libname[sizeof(libname)-1] = '\0';
            /* For each thunk, resolve by name */
            uint32_t *thunk = (uint32_t*)(image_mem + imp->OriginalFirstThunk);
            uint32_t *first_thunk = (uint32_t*)(image_mem + imp->FirstThunk);
            if (!thunk) thunk = (uint32_t*)(image_mem + imp->FirstThunk);
            for (; *thunk; ++thunk, ++first_thunk) {
                uint32_t hint_name_rva = *thunk;
                char *hint_name = (char*)(image_mem + hint_name_rva + 2); /* skip hint */
                void *sym = resolve_import_symbol(hint_name);
                if (!sym) {
                    /* unresolved import: try to map common names to stubs */
                    /* For now, unresolved imports are fatal */
                    char buf[128];
                    snprintf(buf, sizeof(buf), "pe_load_image: unresolved import %s (lib %s)", hint_name, libname);
                    trace_msg(buf);
                    /* continue but set pointer to NULL */
                    *first_thunk = 0;
                } else {
                    /* write pointer into IAT */
                    uint64_t ptrval = (uint64_t)(uintptr_t)sym;
                    memcpy(first_thunk, &ptrval, sizeof(uint64_t));
                }
            }
            ++imp;
        }
    }

    /* Compute entry point pointer */
    uint64_t entry_rva = opt.AddressOfEntryPoint;
    void *entry_ptr = (void*)((uintptr_t)image_mem + entry_rva);

    if (out_image_base) *out_image_base = (uint64_t)(uintptr_t)image_mem;
    if (out_image_size) *out_image_size = size_of_image;

    free(sections);
    return entry_ptr;
}

/* --------------------------- UEFI call trampoline ------------------------- */

/* Type of UEFI application entry: EFI_STATUS EFIAPI (EFI_HANDLE ImageHandle, EFI_SYSTEM_TABLE *SystemTable) */
typedef EFI_STATUS (*EFI_IMAGE_ENTRY_POINT)(EFI_HANDLE, EFI_SYSTEM_TABLE*);

/* Call the loaded image entry point */
int ue_call_image(void *entry, EFI_HANDLE image_handle, EFI_SYSTEM_TABLE *systab) {
    if (!entry) return -1;
    EFI_IMAGE_ENTRY_POINT ep = (EFI_IMAGE_ENTRY_POINT)entry;
    /* Call the entry point. It may call UEFI BootServices; our stubs are in SystemTable. */
    EFI_STATUS st = ep(image_handle, systab);
    char buf[128];
    snprintf(buf, sizeof(buf), "UEFI image returned status 0x%016llx", (unsigned long long)st);
    trace_msg(buf);
    return 0;
}

/* --------------------------- Loader helpers ------------------------------- */

/* Load file into RAM at guest_addr */
int load_file_to_ram(const char *path, uint64_t guest_addr) {
    int fd = open(path, O_RDONLY);
    if (fd < 0) return -1;
    struct stat st;
    if (fstat(fd, &st) < 0) { close(fd); return -1; }
    size_t sz = (size_t)st.st_size;
    uint8_t *buf = malloc(sz);
    if (!buf) { close(fd); return -1; }
    ssize_t r = read(fd, buf, sz);
    close(fd);
    if (r != (ssize_t)sz) { free(buf); return -1; }
    for (size_t i = 0; i < sz; ++i) mem_write8(guest_addr + i, buf[i]);
    free(buf);
    return 0;
}

/* --------------------------- Initialization ------------------------------- */

void jemu_init(void) {
    if (!ram_mem) {
        ram_mem = malloc(RAM_SIZE);
        if (!ram_mem) { fprintf(stderr, "ram alloc failed\n"); exit(1); }
        memset(ram_mem, 0, RAM_SIZE);
    }
    memset(&cpu, 0, sizeof(cpu));
    cpu.gpr[4] = RAM_SIZE - 0x1000; /* RSP */
    cpu.rip = 0;
    cpu.halted = 0;
    debug_log_pos = 0;
    ue_init_environment();
}

/* --------------------------- Utility printing ----------------------------- */

static void print_hex64(uint64_t v) {
    char buf[32];
    const char hex[] = "0123456789ABCDEF";
    for (int i = 0; i < 16; ++i) {
        buf[15-i] = hex[v & 0xF];
        v >>= 4;
    }
    buf[16] = '\0';
    printf("%s", buf);
}

/* --------------------------- Main program -------------------------------- */

int main(int argc, char **argv) {
    if (argc < 2) {
        fprintf(stderr, "Usage: %s <binary-or-efi> [load_addr] [entry_rip] [max_instr]\n", argv[0]);
        return 2;
    }
    const char *path = argv[1];
    uint64_t load_addr = 0x0000;
    uint64_t entry_rip = 0x0000;
    uint64_t max_instr = 200000;

    if (argc >= 3) load_addr = strtoull(argv[2], NULL, 0);
    if (argc >= 4) entry_rip = strtoull(argv[3], NULL, 0);
    if (argc >= 5) max_instr = strtoull(argv[4], NULL, 0);

    jemu_init();

    if (load_file_to_ram(path, load_addr) != 0) {
        fprintf(stderr, "Failed to load %s into RAM at 0x%llx\n", path, (unsigned long long)load_addr);
        return 3;
    }

    /* If entry_rip is zero, attempt to detect PE/COFF and load it */
    if (entry_rip == 0) {
        /* Check for MZ header at load_addr */
        uint8_t *p = get_memory_ptr(load_addr);
        if (!p) {
            fprintf(stderr, "Invalid load pointer\n");
            return 4;
        }
        IMAGE_DOS_HEADER dos;
        memcpy(&dos, p, sizeof(dos));
        if (dos.e_magic == 0x5A4D) {
            /* Attempt to load PE image */
            uint64_t image_base = 0, image_size = 0;
            void *entry = pe_load_image(load_addr, &image_base, &image_size);
            if (!entry) {
                fprintf(stderr, "PE loader failed\n");
                return 5;
            }
            /* Build a minimal EFI_HANDLE and call entry */
            EFI_HANDLE image_handle = (EFI_HANDLE) (uintptr_t) image_base;
            EFI_SYSTEM_TABLE *systab = &SystemTable;
            /* Provide pointers to BootServices and RuntimeServices already set in ue_init_environment */
            systab->BootServices = &BootServices;
            systab->RuntimeServices = &RuntimeServices;
            systab->ConOut = &SimpleTextOut;
            /* Call the image */
            printf("Calling UEFI image entry at %p (image base %p)\n", entry, (void*)(uintptr_t)image_base);
            ue_call_image(entry, image_handle, systab);
            printf("UEFI image call returned; exiting emulator\n");
            return 0;
        } else {
            /* Not a PE image; set RIP to load_addr and run emulator executor loop (stub) */
            cpu.rip = load_addr;
        }
    } else {
        cpu.rip = entry_rip;
    }

    /* Run the emulator harness (very small loop) */
    uint64_t steps = 0;
    while (!cpu.halted && steps < max_instr) {
        execute_one_stub();
        steps++;
    }

    printf("Emulator finished: steps=%llu\n", (unsigned long long)steps);
    printf("---- debug log ----\n");
    fwrite(debug_log, 1, debug_log_pos, stdout);
    printf("\n---- end log ----\n");
    return 0;
}
