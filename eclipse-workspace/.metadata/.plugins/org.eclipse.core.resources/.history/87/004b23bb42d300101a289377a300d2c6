// Simple string join helper
static QString joinList(const QStringList &list, const QString &sep = ", ") {
    QString out;
    for (int i = 0; i < list.size(); ++i) {
        out += list.at(i);
        if (i + 1 < list.size()) out += sep;
    }
    return out;
}

// Convert bytes to hex string
static QString toHex(const QByteArray &data) {
    QString s;
    for (auto b : data) {
        s += QString("%1").arg(static_cast<unsigned char>(b), 2, 16, QChar('0'));
    }
    return s;
}

