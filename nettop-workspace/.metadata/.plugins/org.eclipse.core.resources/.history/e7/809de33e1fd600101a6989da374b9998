// nettop.cpp
//
// Single-file Qt5 + OpenGL (QOpenGLWidget) application that visualizes
// live TCP/UDP connections. This version embeds a libpcap-based capture
// thread (Option B) so the UI can capture packets directly instead of
// only tailing netdump.log.
//
// Build notes:
// - Requires Qt5 (Widgets, OpenGL) and libpcap.
// - Link with: -lpcap `pkg-config --cflags --libs Qt5Widgets Qt5Gui Qt5Core`
// - Example CMake: link Qt5::Widgets Qt5::OpenGL and add pcap to target_link_libraries.
//
// Security/privileges:
// - Live capture typically requires root or CAP_NET_RAW/CAP_NET_ADMIN.
// - You can run the binary with sudo or grant capabilities to the executable.
//
// This is a prototype: production code should add robust error handling,
// more complete protocol parsing, and careful resource management.

#include <pcap.h> // libpcap for live capture (Option B)
#include <QApplication>
#include <QMainWindow>
#include <QOpenGLWidget>
#include <QOpenGLFunctions>
#include <QThread>
#include <QFile>
#include <QTextStream>
#include <QJsonDocument>
#include <QJsonObject>
#include <QMutex>
#include <QMutexLocker>
#include <QTimer>
#include <QDateTime>
#include <QPainter>
#include <QPaintEvent>
#include <QVBoxLayout>
#include <QHBoxLayout>
#include <QLabel>
#include <QLineEdit>
#include <QPushButton>
#include <QListWidget>
#include <QSplitter>
#include <QRandomGenerator>
#include <QStyleOption>
#include <QWheelEvent>
#include <QMouseEvent>
#include <QElapsedTimer>
#include <QMetaType>
#include <cmath>
#include <map>
#include <unordered_map>
#include <tuple>
