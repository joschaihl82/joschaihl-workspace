cmake_minimum_required(VERSION 3.16)
project(MiniGTK4Browser C)

set(CMAKE_C_STANDARD 11)
set(CMAKE_C_STANDARD_REQUIRED ON)

if(NOT CMAKE_BUILD_TYPE)
  set(CMAKE_BUILD_TYPE Release CACHE STRING "Build type" FORCE)
endif()

# User overrides
set(GTK4_ROOT "" CACHE PATH "Prefix where GTK4 is installed")
set(WEBKIT_ROOT "" CACHE PATH "Prefix where WebKitGTK is installed")
set(EXTRA_INCLUDE_DIRS "" CACHE STRING "Extra include directories (semicolon separated)")
set(EXTRA_LIBS "" CACHE STRING "Extra libraries to link (semicolon separated)")
set(EXTRA_LINK_DIRS "" CACHE STRING "Extra library directories (semicolon separated)")

# Build search path strings (semicolon-separated)
set(_search_inc_paths "")
set(_search_lib_paths "")

if(GTK4_ROOT)
  if(_search_inc_paths STREQUAL "")
    set(_search_inc_paths "${GTK4_ROOT}/include;${GTK4_ROOT}/include/gtk-4.0")
  else()
    set(_search_inc_paths "${_search_inc_paths};${GTK4_ROOT}/include;${GTK4_ROOT}/include/gtk-4.0")
  endif()
  if(_search_lib_paths STREQUAL "")
    set(_search_lib_paths "${GTK4_ROOT}/lib;${GTK4_ROOT}/lib64")
  else()
    set(_search_lib_paths "${_search_lib_paths};${GTK4_ROOT}/lib;${GTK4_ROOT}/lib64")
  endif()
endif()

if(WEBKIT_ROOT)
  if(_search_inc_paths STREQUAL "")
    set(_search_inc_paths "${WEBKIT_ROOT}/include;${WEBKIT_ROOT}/include/webkit2gtk-6.0")
  else()
    set(_search_inc_paths "${_search_inc_paths};${WEBKIT_ROOT}/include;${WEBKIT_ROOT}/include/webkit2gtk-6.0")
  endif()
  if(_search_lib_paths STREQUAL "")
    set(_search_lib_paths "${WEBKIT_ROOT}/lib;${WEBKIT_ROOT}/lib64")
  else()
    set(_search_lib_paths "${_search_lib_paths};${WEBKIT_ROOT}/lib;${WEBKIT_ROOT}/lib64")
  endif()
endif()

# Append common system locations
if(_search_inc_paths STREQUAL "")
  set(_search_inc_paths "/usr/include;/usr/local/include;/usr/include/gtk-4.0;/usr/local/include/gtk-4.0;/usr/include/webkit2gtk-6.0;/usr/local/include/webkit2gtk-6.0")
else()
  set(_search_inc_paths "${_search_inc_paths};/usr/include;/usr/local/include;/usr/include/gtk-4.0;/usr/local/include/gtk-4.0;/usr/include/webkit2gtk-6.0;/usr/local/include/webkit2gtk-6.0")
endif()

if(_search_lib_paths STREQUAL "")
  set(_search_lib_paths "/usr/lib;/usr/lib64;/usr/local/lib;/usr/lib/x86_64-linux-gnu")
else()
  set(_search_lib_paths "${_search_lib_paths};/usr/lib;/usr/lib64;/usr/local/lib;/usr/lib/x86_64-linux-gnu")
endif()

# Convert semicolon-separated search paths into a CMake PATHS argument by expanding variable
# (find_path/find_library accept a semicolon-separated list)
find_path(GTK4_INCLUDE_DIR
  NAMES gtk/gtk.h
  PATHS ${_search_inc_paths}
)
find_path(WEBKIT_INCLUDE_DIR
  NAMES webkit2/webkit2.h
  PATHS ${_search_inc_paths}
)

find_library(GTK4_LIBRARY
  NAMES gtk-4 gtk-4.0
  PATHS ${_search_lib_paths}
)
find_library(WEBKIT_LIBRARY
  NAMES webkit2gtk-6.0 webkit2gtk-4.0 webkit2gtk-4
  PATHS ${_search_lib_paths}
)

# Try to find common dependencies (glib/gobject/gio)
find_library(GLIB_LIBRARY NAMES glib-2.0 PATHS ${_search_lib_paths})
find_library(GOBJECT_LIBRARY NAMES gobject-2.0 PATHS ${_search_lib_paths})
find_library(GIO_LIBRARY NAMES gio-2.0 PATHS ${_search_lib_paths})
find_library(GMODULE_LIBRARY NAMES gmodule-2.0 PATHS ${_search_lib_paths})
find_library(GTHREAD_LIBRARY NAMES gthread-2.0 PATHS ${_search_lib_paths})

# Fallback to default search if not found
if(NOT GTK4_INCLUDE_DIR)
  find_path(GTK4_INCLUDE_DIR NAMES gtk/gtk.h)
endif()
if(NOT WEBKIT_INCLUDE_DIR)
  find_path(WEBKIT_INCLUDE_DIR NAMES webkit2/webkit2.h)
endif()
if(NOT GTK4_LIBRARY)
  find_library(GTK4_LIBRARY NAMES gtk-4 gtk-4.0)
endif()
if(NOT WEBKIT_LIBRARY)
  find_library(WEBKIT_LIBRARY NAMES webkit2gtk-6.0 webkit2gtk-4.0 webkit2gtk-4)
endif()
if(NOT GLIB_LIBRARY)
  find_library(GLIB_LIBRARY NAMES glib-2.0)
endif()
if(NOT GOBJECT_LIBRARY)
  find_library(GOBJECT_LIBRARY NAMES gobject-2.0)
endif()
if(NOT GIO_LIBRARY)
  find_library(GIO_LIBRARY NAMES gio-2.0)
endif()
if(NOT GMODULE_LIBRARY)
  find_library(GMODULE_LIBRARY NAMES gmodule-2.0)
endif()
if(NOT GTHREAD_LIBRARY)
  find_library(GTHREAD_LIBRARY NAMES gthread-2.0)
endif()

# Validate
if(NOT GTK4_INCLUDE_DIR)
  message(FATAL_ERROR "GTK4 headers not found. Use -DGTK4_ROOT=/path or install GTK4 dev files.")
endif()
if(NOT WEBKIT_INCLUDE_DIR)
  message(FATAL_ERROR "WebKitGTK headers not found. Use -DWEBKIT_ROOT=/path or install WebKitGTK dev files.")
endif()
if(NOT GTK4_LIBRARY)
  message(FATAL_ERROR "GTK4 library not found. Use -DGTK4_ROOT=/path or install GTK4 dev libs.")
endif()
if(NOT WEBKIT_LIBRARY)
  message(FATAL_ERROR "WebKitGTK library not found. Use -DWEBKIT_ROOT=/path or install WebKitGTK dev libs.")
endif()

# Print summary
string(REPLACE ";" " " _inc_paths_str "${_search_inc_paths}")
string(REPLACE ";" " " _lib_paths_str "${_search_lib_paths}")
message(STATUS "GTK4 include: ${GTK4_INCLUDE_DIR}")
message(STATUS "GTK4 lib:     ${GTK4_LIBRARY}")
message(STATUS "WebKit include:${WEBKIT_INCLUDE_DIR}")
message(STATUS "WebKit lib:    ${WEBKIT_LIBRARY}")
message(STATUS "Search include paths: ${_inc_paths_str}")
message(STATUS "Search lib paths: ${_lib_paths_str}")

# Sources
set(SRC browser.c)
add_executable(browser ${SRC})

# Include dirs
target_include_directories(browser PRIVATE ${GTK4_INCLUDE_DIR} ${WEBKIT_INCLUDE_DIR})

# Extra include dirs (semicolon-separated string)
if(EXTRA_INCLUDE_DIRS)
  # split by semicolon: CMake foreach will iterate semicolon-separated list
  foreach(_inc ${EXTRA_INCLUDE_DIRS})
    target_include_directories(browser PRIVATE ${_inc})
  endforeach()
endif()

# Extra link dirs
if(EXTRA_LINK_DIRS)
  foreach(_ld ${EXTRA_LINK_DIRS})
    link_directories(${_ld})
  endforeach()
endif()

# Link libs: build semicolon-separated list string, then expand
set(_link_libs "${WEBKIT_LIBRARY};${GTK4_LIBRARY}")
if(GLIB_LIBRARY)
  set(_link_libs "${_link_libs};${GLIB_LIBRARY}")
endif()
if(GOBJECT_LIBRARY)
  set(_link_libs "${_link_libs};${GOBJECT_LIBRARY}")
endif()
if(GIO_LIBRARY)
  set(_link_libs "${_link_libs};${GIO_LIBRARY}")
endif()
if(GMODULE_LIBRARY)
  set(_link_libs "${_link_libs};${GMODULE_LIBRARY}")
endif()
if(GTHREAD_LIBRARY)
  set(_link_libs "${_link_libs};${GTHREAD_LIBRARY}")
endif()

if(EXTRA_LIBS)
  foreach(_l ${EXTRA_LIBS})
    set(_link_libs "${_link_libs};${_l}")
  endforeach()
endif()

# Expand and link
foreach(_lib ${_link_libs})
  if(NOT _lib STREQUAL "")
    target_link_libraries(browser PRIVATE ${_lib})
  endif()
endforeach()

# Compile options
if (CMAKE_C_COMPILER_ID STREQUAL "GNU" OR CMAKE_C_COMPILER_ID MATCHES "Clang")
  target_compile_options(browser PRIVATE -Wall -Wextra -Wpedantic -pthread -D_REENTRANT)
else()
  target_compile_options(browser PRIVATE -D_REENTRANT)
endif()

# Helpful suggestion
if(NOT GLIB_LIBRARY OR NOT GOBJECT_LIBRARY OR NOT GIO_LIBRARY)
  message(STATUS "If you get undefined references, re-run cmake with -DEXTRA_LIBS=\"gobject-2.0;gio-2.0;glib-2.0;gmodule-2.0;gthread-2.0\"")
endif()

install(TARGETS browser RUNTIME DESTINATION bin)
set(CMAKE_EXPORT_COMPILE_COMMANDS ON)
