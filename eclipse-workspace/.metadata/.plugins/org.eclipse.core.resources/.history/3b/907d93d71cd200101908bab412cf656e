// ---- Low-level CPU setup ----
#define MSR_STAR   0xC0000081
#define MSR_LSTAR  0xC0000082
#define MSR_SFMASK 0xC0000084
#define MSR_EFER   0xC0000080

static inline void wrmsr(uint32_t msr, uint64_t val) {
    uint32_t lo = (uint32_t)val, hi = (uint32_t)(val >> 32);
    __asm__ __volatile__("wrmsr" : : "c"(msr), "a"(lo), "d"(hi));
}
static inline uint64_t rdmsr(uint32_t msr) {
    uint32_t lo, hi;
    __asm__ __volatile__("rdmsr" : "=a"(lo), "=d"(hi) : "c"(msr));
    return ((uint64_t)hi << 32) | lo;
}

struct __attribute__((packed)) GDTEntry { uint16_t limit; uint16_t base_lo; uint8_t base_mid; uint8_t access; uint8_t gran; uint8_t base_hi; };
struct __attribute__((packed)) GDTR { uint16_t size; uint64_t base; };
struct __attribute__((packed)) IDTEntry { uint16_t off_lo; uint16_t sel; uint8_t ist; uint8_t type_attr; uint16_t off_mid; uint32_t off_hi; uint32_t zero; };
struct __attribute__((packed)) IDTR { uint16_t size; uint64_t base; };

static struct GDTEntry GDT[6];
static struct GDTR gdtr;
static struct IDTEntry IDT[256];
static struct IDTR idtr;

#define KERN_CS 0x08
#define KERN_DS 0x10
#define USER_CS 0x23
#define USER_DS 0x1b

static inline void lgdt(struct GDTR *g) { __asm__ __volatile__("lgdt %0" : : "m"(*g)); }
static inline void lidt(struct IDTR *i) { __asm__ __volatile__("lidt %0" : : "m"(*i)); }
static inline void load_segments(uint16_t cs, uint16_t ds) {
    __asm__ __volatile__(
        "pushq %0; lea 1f(%%rip), %%rax; pushq %%rax; lretq; 1:\n"
        "mov %1, %%ds; mov %1, %%es; mov %1, %%ss"
        : : "r"(cs), "r"(ds) : "rax");
}

static void gdt_init() {
    memset(GDT, 0, sizeof(GDT));
    GDT[1].access = 0x9A; GDT[1].gran = 0x20; // kernel code
    GDT[2].access = 0x92;                      // kernel data
    GDT[3].access = 0xFA; GDT[3].gran = 0x20; // user code
    GDT[4].access = 0xF2;                      // user data
    gdtr.size = sizeof(GDT)-1; gdtr.base = (uint64_t)&GDT[0];
    lgdt(&gdtr);
    load_segments(KERN_CS, KERN_DS);
}

// simple ISR stub (no interrupt attribute to avoid SSE restriction)
static void isr_default(void *frame) { (void)frame; }

static void idt_set_gate(int vec, void (*fn)(void), uint16_t sel, uint8_t attr) {
    uint64_t off = (uint64_t)fn;
    IDT[vec].off_lo = off & 0xFFFF;
    IDT[vec].sel = sel;
    IDT[vec].ist = 0;
    IDT[vec].type_attr = attr;
    IDT[vec].off_mid = (off >> 16) & 0xFFFF;
    IDT[vec].off_hi = (off >> 32);
    IDT[vec].zero = 0;
}
static void idt_init() {
    for (int i=0;i<256;i++) idt_set_gate(i, (void(*)(void))isr_default, KERN_CS, 0x8E);
    idtr.size = sizeof(IDT)-1; idtr.base = (uint64_t)&IDT[0];
    lidt(&idtr);
}

// ---- Paging: identity map first 1 GiB ----
#define PAGE_SIZE 4096
static uint64_t *PML4,*PDPT,*PD,*PT;
static EFI_BOOT_SERVICES *BS = NULL;

static void paging_init_identity_1g() {
    void *p;
    BS->AllocatePool(0, PAGE_SIZE, &p); PML4 = p;
    BS->AllocatePool(0, PAGE_SIZE, &p); PDPT = p;
    BS->AllocatePool(0, PAGE_SIZE, &p); PD = p;
    BS->AllocatePool(0, PAGE_SIZE, &p); PT = p;
    memset(PML4,0,PAGE_SIZE); memset(PDPT,0,PAGE_SIZE); memset(PD,0,PAGE_SIZE); memset(PT,0,PAGE_SIZE);
    PML4[0] = (uint64_t)PDPT | 0x003;
    PDPT[0] = (uint64_t)PD | 0x003;
    PD[0]   = (uint64_t)PT | 0x003;
    for (int i=0;i<512;i++) PT[i] = ((uint64_t)i*PAGE_SIZE) | 0x003;
    __asm__ __volatile__("mov %0, %%cr3" : : "r"(PML4) : "memory");
}

// ---- Syscall/Sysret ----
extern void syscall_entry(void);
uint64_t syscall_handler_asm(void) __attribute__((used));

static void syscall_init() {
    uint64_t star = ((uint64_t)KERN_CS << 32) | ((uint64_t)USER_CS << 48);
    wrmsr(MSR_STAR, star);
    wrmsr(MSR_LSTAR, (uint64_t)syscall_entry);
    wrmsr(MSR_SFMASK, (1ULL<<9) /*IF*/ | (1ULL<<10) /*DF*/);
    wrmsr(MSR_EFER, rdmsr(MSR_EFER) | 1); // SCE
}

__asm__(
".global syscall_entry\n"
"syscall_entry:\n"
"    swapgs\n"
"    pushq %r15; pushq %r14; pushq %r13; pushq %r12; pushq %r11; pushq %r10; pushq %r9; pushq %r8;\n"
"    pushq %rsi; pushq %rdi; pushq %rbp; pushq %rdx; pushq %rcx; pushq %rbx; pushq %rax;\n"
"    mov %rax, %rdi\n"
"    call syscall_handler_asm\n"
"    popq %rax; popq %rbx; popq %rcx; popq %rdx; popq %rbp; popq %rdi; popq %rsi; popq %r8; popq %r9; popq %r10; popq %r11; popq %r12; popq %r13; popq %r14; popq %r15;\n"
"    swapgs\n"
"    sysretq\n"
);

// ---- Framebuffer text console via GOP ----
static void *fb_base = NULL;
static uint32_t fb_width = 0, fb_height = 0, fb_pitch = 0;
static uint32_t fb_bpp = 32;
static uint32_t cursor_x = 0, cursor_y = 0;
static const uint32_t fg_rgb = 0x00FFFFFF; // white (assume XRGB)
static const uint32_t bg_rgb = 0x00000000; // black

static void fb_clear() {
    if (!fb_base) return;
    uint8_t *p = (uint8_t*)fb_base;
    for (uint32_t y=0; y<fb_height; y++) {
        uint32_t *row = (uint32_t*)(p + y*fb_pitch);
        for (uint32_t x=0; x<fb_width; x++) row[x] = bg_rgb;
    }
    cursor_x = 0; cursor_y = 0;
}

