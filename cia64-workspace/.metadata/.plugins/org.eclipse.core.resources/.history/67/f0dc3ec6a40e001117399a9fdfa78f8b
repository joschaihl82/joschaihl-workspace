// cia64as_linked.c -- CIA64 assembler with linked-list labels and 8-byte load header
// Build: gcc -O2 -std=c11 -o cia64as_linked cia64as_linked.c
// Usage: ./cia64as_linked -o out.bin [-a load_addr] in.s
//
// Header (8 bytes, little-endian):
//   uint32_t load_addr
//   uint32_t payload_size

#define _GNU_SOURCE
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <stdint.h>
#include <ctype.h>
#include <stdarg.h>
#include <errno.h>

#define MAX_LINE 1024
#define MAX_TOKENS 32
#define MAX_OUTPUT (1<<24) // 16MB output

typedef struct LabelNode {
    char *name;
    uint32_t addr;
    struct LabelNode *next;
} LabelNode;

static LabelNode *label_head = NULL;

static uint8_t *outbuf;
static size_t outcap = MAX_OUTPUT;
static size_t outpos = 0;
static uint32_t loc = 0; // location counter (bytes)
static uint32_t header_load_addr = 0; // default load address

static char *trim(char *s) {
    while (*s && isspace((unsigned char)*s)) s++;
    char *e = s + strlen(s);
    while (e > s && isspace((unsigned char)*(e-1))) { *(--e) = 0; }
    return s;
}

static void fatal(const char *fmt, ...) {
    va_list ap; va_start(ap, fmt);
    vfprintf(stderr, fmt, ap);
    va_end(ap);
    exit(1);
}

/* Linked-list label helpers */
static void add_label(const char *name, uint32_t addr) {
    for (LabelNode *n = label_head; n; n = n->next) {
        if (strcmp(n->name, name) == 0) {
            fprintf(stderr, "Label redefined: %s\n", name);
            exit(1);
        }
    }
    LabelNode *node = malloc(sizeof(LabelNode));
    if (!node) fatal("out of memory\n");
    node->name = strdup(name);
    node->addr = addr;
    node->next = label_head;
    label_head = node;
}

static int find_label(const char *name, uint32_t *addr_out) {
    for (LabelNode *n = label_head; n; n = n->next) {
        if (strcmp(n->name, name) == 0) {
            *addr_out = n->addr;
            return 1;
        }
    }
    return 0;
}

static void free_labels(void) {
    LabelNode *n = label_head;
    while (n) {
        LabelNode *next = n->next;
        free(n->name);
        free(n);
        n = next;
    }
    label_head = NULL;
}

/* Register parsing helpers */
static int reg_x(const char *tok) {
    if (tok[0]=='x' || tok[0]=='X') {
        char *end; long v = strtol(tok+1, &end, 0);
        if (*end==0 && v>=0 && v<32) return (int)v;
    }
    return -1;
}
static int reg_f(const char *tok) {
    if (tok[0]=='f' || tok[0]=='F') {
        char *end; long v = strtol(tok+1, &end, 0);
        if (*end==0 && v>=0 && v<32) return (int)v;
    }
    return -1;
}
static int reg_v(const char *tok) {
    if (tok[0]=='v' || tok[0]=='V') {
        char *end; long v = strtol(tok+1, &end, 0);
        if (*end==0 && v>=0 && v<16) return (int)v;
    }
    return -1;
}

static uint32_t parse_imm(const char *s) {
    if (!s) return 0;
    if (s[0]=='0' && (s[1]=='x' || s[1]=='X')) return (uint32_t)strtoul(s+2, NULL, 16);
    if (s[0]=='-') return (uint32_t)strtol(s, NULL, 0);
    return (uint32_t)strtoul(s, NULL, 0);
}

/* Emit helpers */
static void emit_word(uint32_t w) {
    if (outpos + 4 > outcap) fatal("output overflow\n");
    outbuf[outpos+0] = w & 0xFF;
    outbuf[outpos+1] = (w>>8) & 0xFF;
    outbuf[outpos+2] = (w>>16) & 0xFF;
    outbuf[outpos+3] = (w>>24) & 0xFF;
    outpos += 4;
    loc += 4;
}
static void emit_byte(uint8_t b) {
    if (outpos + 1 > outcap) fatal("output overflow\n");
    outbuf[outpos++] = b;
    loc += 1;
}
static void emit_bytes(const void *p, size_t n) {
    if (outpos + n > outcap) fatal("output overflow\n");
    memcpy(outbuf + outpos, p, n);
    outpos += n;
    loc += n;
}

/* Encoding helpers (RISC-V-like) */
static uint32_t encode_r(uint32_t funct7, uint32_t rs2, uint32_t rs1, uint32_t funct3, uint32_t rd, uint32_t opcode) {
    return (funct7<<25) | (rs2<<20) | (rs1<<15) | (funct3<<12) | (rd<<7) | opcode;
}
static uint32_t encode_i(int32_t imm, uint32_t rs1, uint32_t funct3, uint32_t rd, uint32_t opcode) {
    uint32_t imm12 = (uint32_t)imm & 0xFFF;
    return (imm12<<20) | (rs1<<15) | (funct3<<12) | (rd<<7) | opcode;
}
static uint32_t encode_s(int32_t imm, uint32_t rs2, uint32_t rs1, uint32_t funct3, uint32_t opcode) {
    uint32_t imm11_5 = ((uint32_t)imm >> 5) & 0x7F;
    uint32_t imm4_0 = ((uint32_t)imm) & 0x1F;
    return (imm11_5<<25) | (rs2<<20) | (rs1<<15) | (funct3<<12) | (imm4_0<<7) | opcode;
}
static uint32_t encode_b(int32_t imm, uint32_t rs2, uint32_t rs1, uint32_t funct3, uint32_t opcode) {
    uint32_t imm12 = ((uint32_t)imm >> 12) & 0x1;
    uint32_t imm11 = ((uint32_t)imm >> 11) & 0x1;
    uint32_t imm10_5 = ((uint32_t)imm >> 5) & 0x3F;
    uint32_t imm4_1 = ((uint32_t)imm >> 1) & 0xF;
    return (imm12<<31) | (imm11<<7) | (imm10_5<<25) | (imm4_1<<8) | (rs2<<20) | (rs1<<15) | (funct3<<12) | opcode;
}
static uint32_t encode_j(int32_t imm, uint32_t rd, uint32_t opcode) {
    uint32_t imm20 = ((uint32_t)imm >> 20) & 0x1;
    uint32_t imm10_1 = ((uint32_t)imm >> 1) & 0x3FF;
    uint32_t imm11 = ((uint32_t)imm >> 11) & 0x1;
    uint32_t imm19_12 = ((uint32_t)imm >> 12) & 0xFF;
    return (imm20<<31) | (imm19_12<<12) | (imm11<<20) | (imm10_1<<21) | (rd<<7) | opcode;
}

/* Opcodes */
enum {
    OPC_R = 0x33,
    OPC_I = 0x13,
    OPC_LOAD = 0x03,
    OPC_STORE = 0x23,
    OPC_BRANCH = 0x63,
    OPC_JAL = 0x6F,
    OPC_JALR = 0x67,
    OPC_SYSTEM = 0x73,
    OPC_FP = 0x53,
    OPC_VEC = 0x5B
};

/* Assemble one instruction line (trimmed) */
static void assemble_inst(char *line, int lineno) {
    char *tok[MAX_TOKENS]; int nt=0;
    char *p = line;
    while (*p) {
        while (*p && isspace((unsigned char)*p)) p++;
        if (!*p) break;
        if (*p=='#') break;
        char *start = p;
        if (*p=='"') {
            p++;
            while (*p && *p!='"') p++;
            if (*p=='"') p++;
            int len = p - start;
            tok[nt] = malloc(len+1);
            strncpy(tok[nt], start, len); tok[nt][len]=0; nt++;
            continue;
        }
        while (*p && *p!=',' && !isspace((unsigned char)*p)) p++;
        int len = p - start;
        tok[nt] = malloc(len+1);
        strncpy(tok[nt], start, len); tok[nt][len]=0; nt++;
        while (*p==',') p++;
    }
    if (nt==0) return;
    for (int i=0;i<nt;i++) {
        char *t = trim(tok[i]);
        memmove(tok[i], t, strlen(t)+1);
    }
    char *m = tok[0];

    /* R-type integer ops */
    if (strcasecmp(m,"ADD")==0 || strcasecmp(m,"SUB")==0 || strcasecmp(m,"SLL")==0 ||
        strcasecmp(m,"SLT")==0 || strcasecmp(m,"SLTU")==0 || strcasecmp(m,"XOR")==0 ||
        strcasecmp(m,"SRL")==0 || strcasecmp(m,"SRA")==0 || strcasecmp(m,"OR")==0 ||
        strcasecmp(m,"AND")==0) {
        if (nt < 4) fatal("line %d: %s needs 3 operands\n", lineno, m);
        int rd = reg_x(tok[1]); int rs1 = reg_x(tok[2]); int rs2 = reg_x(tok[3]);
        if (rd<0||rs1<0||rs2<0) fatal("line %d: invalid register\n", lineno);
        uint32_t funct3=0, funct7=0;
        if (strcasecmp(m,"ADD")==0) { funct3=0; funct7=0x00; }
        else if (strcasecmp(m,"SUB")==0) { funct3=0; funct7=0x20; }
        else if (strcasecmp(m,"SLL")==0) { funct3=0x1; funct7=0x00; }
        else if (strcasecmp(m,"SLT")==0) { funct3=0x2; funct7=0x00; }
        else if (strcasecmp(m,"SLTU")==0) { funct3=0x3; funct7=0x00; }
        else if (strcasecmp(m,"XOR")==0) { funct3=0x4; funct7=0x00; }
        else if (strcasecmp(m,"SRL")==0) { funct3=0x5; funct7=0x00; }
        else if (strcasecmp(m,"SRA")==0) { funct3=0x5; funct7=0x20; }
        else if (strcasecmp(m,"OR")==0) { funct3=0x6; funct7=0x00; }
        else if (strcasecmp(m,"AND")==0) { funct3=0x7; funct7=0x00; }
        uint32_t w = encode_r(funct7, rs2, rs1, funct3, rd, OPC_R);
        emit_word(w);
        goto cleanup;
    }

    /* I-type ALU */
    if (strcasecmp(m,"ADDI")==0 || strcasecmp(m,"SLLI")==0 || strcasecmp(m,"SRLI")==0 || strcasecmp(m,"SRAI")==0) {
        if (nt < 4) fatal("line %d: %s needs 3 operands\n", lineno, m);
        int rd = reg_x(tok[1]); int rs1 = reg_x(tok[2]);
        if (rd<0||rs1<0) fatal("line %d: invalid register\n", lineno);
        if (strcasecmp(m,"ADDI")==0) {
            int32_t imm = (int32_t)parse_imm(tok[3]);
            uint32_t w = encode_i(imm, rs1, 0x0, rd, OPC_I);
            emit_word(w);
            goto cleanup;
        } else {
            int sh = (int)parse_imm(tok[3]);
            uint32_t funct3 = (strcasecmp(m,"SLLI")==0)?0x1:0x5;
            uint32_t funct7 = (strcasecmp(m,"SRAI")==0)?0x20:0x00;
            uint32_t imm12 = (sh & 0x3F);
            uint32_t w = (funct7<<25) | (imm12<<20) | (rs1<<15) | (funct3<<12) | (rd<<7) | OPC_I;
            emit_word(w);
            goto cleanup;
        }
    }

    /* Loads */
    if (strcasecmp(m,"LD")==0 || strcasecmp(m,"LW")==0 || strcasecmp(m,"LH")==0 || strcasecmp(m,"LB")==0 ||
        strcasecmp(m,"LWU")==0 || strcasecmp(m,"LHU")==0 || strcasecmp(m,"LBU")==0) {
        if (nt < 3) fatal("line %d: %s needs rd, offset(base)\n", lineno, m);
        int rd = reg_x(tok[1]); if (rd<0) fatal("line %d: invalid rd\n", lineno);
        char *s = tok[2];
        char *paren = strchr(s,'(');
        if (!paren) fatal("line %d: bad mem operand\n", lineno);
        *paren = 0;
        char *offstr = s;
        char *regstr = paren+1;
        char *rp = strchr(regstr,')'); if (!rp) fatal("line %d: bad mem operand\n", lineno);
        *rp = 0;
        int rs1 = reg_x(regstr); if (rs1<0) fatal("line %d: bad base reg\n", lineno);
        int32_t imm = (int32_t)parse_imm(offstr);
        uint32_t f3 = 0;
        if (strcasecmp(m,"LB")==0) f3=0x0;
        else if (strcasecmp(m,"LH")==0) f3=0x1;
        else if (strcasecmp(m,"LW")==0) f3=0x2;
        else if (strcasecmp(m,"LD")==0) f3=0x3;
        else if (strcasecmp(m,"LBU")==0) f3=0x4;
        else if (strcasecmp(m,"LHU")==0) f3=0x5;
        else if (strcasecmp(m,"LWU")==0) f3=0x6;
        uint32_t w = encode_i(imm, rs1, f3, rd, OPC_LOAD);
        emit_word(w);
        goto cleanup;
    }

    /* Stores */
    if (strcasecmp(m,"SD")==0 || strcasecmp(m,"SW")==0 || strcasecmp(m,"SH")==0 || strcasecmp(m,"SB")==0) {
        if (nt < 3) fatal("line %d: %s needs rs2, offset(base)\n", lineno, m);
        int rs2 = reg_x(tok[1]); if (rs2<0) fatal("line %d: invalid rs2\n", lineno);
        char *s = tok[2];
        char *paren = strchr(s,'(');
        if (!paren) fatal("line %d: bad mem operand\n", lineno);
        *paren = 0;
        char *offstr = s;
        char *regstr = paren+1;
        char *rp = strchr(regstr,')'); if (!rp) fatal("line %d: bad mem operand\n", lineno);
        *rp = 0;
        int rs1 = reg_x(regstr); if (rs1<0) fatal("line %d: bad base reg\n", lineno);
        int32_t imm = (int32_t)parse_imm(offstr);
        uint32_t f3 = 0;
        if (strcasecmp(m,"SB")==0) f3=0x0;
        else if (strcasecmp(m,"SH")==0) f3=0x1;
        else if (strcasecmp(m,"SW")==0) f3=0x2;
        else if (strcasecmp(m,"SD")==0) f3=0x3;
        uint32_t w = encode_s(imm, rs2, rs1, f3, OPC_STORE);
        emit_word(w);
        goto cleanup;
    }

    /* Branches */
    if (strcasecmp(m,"BEQ")==0 || strcasecmp(m,"BNE")==0 || strcasecmp(m,"BLT")==0 || strcasecmp(m,"BGE")==0 ||
        strcasecmp(m,"BLTU")==0 || strcasecmp(m,"BGEU")==0) {
        if (nt < 4) fatal("line %d: %s needs rs1, rs2, label\n", lineno, m);
        int rs1 = reg_x(tok[1]); int rs2 = reg_x(tok[2]);
        if (rs1<0||rs2<0) fatal("line %d: bad regs\n", lineno);
        char *label = tok[3];
        uint32_t target;
        if (!find_label(label, &target)) fatal("line %d: unknown label %s\n", lineno, label);
        int32_t imm = (int32_t)((int64_t)target - (int64_t)loc);
        uint32_t f3 = 0;
        if (strcasecmp(m,"BEQ")==0) f3=0x0;
        else if (strcasecmp(m,"BNE")==0) f3=0x1;
        else if (strcasecmp(m,"BLT")==0) f3=0x4;
        else if (strcasecmp(m,"BGE")==0) f3=0x5;
        else if (strcasecmp(m,"BLTU")==0) f3=0x6;
        else if (strcasecmp(m,"BGEU")==0) f3=0x7;
        uint32_t w = encode_b(imm, rs2, rs1, f3, OPC_BRANCH);
        emit_word(w);
        goto cleanup;
    }

    /* JAL */
    if (strcasecmp(m,"JAL")==0) {
        if (nt < 3) fatal("line %d: JAL rd, label\n", lineno);
        int rd = reg_x(tok[1]); if (rd<0) fatal("line %d: bad rd\n", lineno);
        char *label = tok[2];
        uint32_t target;
        if (!find_label(label, &target)) fatal("line %d: unknown label %s\n", lineno, label);
        int32_t imm = (int32_t)((int64_t)target - (int64_t)loc);
        uint32_t w = encode_j(imm, rd, OPC_JAL);
        emit_word(w);
        goto cleanup;
    }

    /* JALR */
    if (strcasecmp(m,"JALR")==0) {
        if (nt < 4) fatal("line %d: JALR rd, rs1, imm\n", lineno);
        int rd = reg_x(tok[1]); int rs1 = reg_x(tok[2]); if (rd<0||rs1<0) fatal("line %d: bad regs\n", lineno);
        int32_t imm = (int32_t)parse_imm(tok[3]);
        uint32_t w = encode_i(imm, rs1, 0x0, rd, OPC_JALR);
        emit_word(w);
        goto cleanup;
    }

    /* ECALL */
    if (strcasecmp(m,"ECALL")==0) {
        uint32_t w = 0x00000073;
        emit_word(w);
        goto cleanup;
    }

    /* FP scalar */
    if (strcasecmp(m,"FADD.D")==0 || strcasecmp(m,"FSUB.D")==0 || strcasecmp(m,"FMUL.D")==0 || strcasecmp(m,"FDIV.D")==0 ||
        strcasecmp(m,"FCVT.D.SI")==0 || strcasecmp(m,"FCVT.SI.D")==0) {
        if (strcasecmp(m,"FCVT.D.SI")==0) {
            if (nt < 3) fatal("line %d: FCVT.D.SI rd, rs1\n", lineno);
            int rd = reg_f(tok[1]); int rs1 = reg_x(tok[2]); if (rd<0||rs1<0) fatal("line %d: bad regs\n", lineno);
            uint32_t w = (0x20<<25) | (0<<20) | (rs1<<15) | (0<<12) | (rd<<7) | OPC_FP;
            emit_word(w);
            goto cleanup;
        } else if (strcasecmp(m,"FCVT.SI.D")==0) {
            if (nt < 3) fatal("line %d: FCVT.SI.D rd, rs1\n", lineno);
            int rd = reg_x(tok[1]); int rs1 = reg_f(tok[2]); if (rd<0||rs1<0) fatal("line %d: bad regs\n", lineno);
            uint32_t w = (0x20<<25) | (rs1<<20) | (0<<15) | (1<<12) | (rd<<7) | OPC_FP;
            emit_word(w);
            goto cleanup;
        } else {
            if (nt < 4) fatal("line %d: %s needs rd, rs1, rs2\n", lineno, m);
            int rd = reg_f(tok[1]); int rs1 = reg_f(tok[2]); int rs2 = reg_f(tok[3]);
            if (rd<0||rs1<0||rs2<0) fatal("line %d: bad fregs\n", lineno);
            uint32_t f7=0, f3=0;
            if (strcasecmp(m,"FADD.D")==0) { f7=0x00; f3=0x0; }
            else if (strcasecmp(m,"FSUB.D")==0) { f7=0x00; f3=0x1; }
            else if (strcasecmp(m,"FMUL.D")==0) { f7=0x00; f3=0x2; }
            else if (strcasecmp(m,"FDIV.D")==0) { f7=0x00; f3=0x3; }
            uint32_t w = encode_r(f7, rs2, rs1, f3, rd, OPC_FP);
            emit_word(w);
            goto cleanup;
        }
    }

    /* Vector */
    if (strcasecmp(m,"VADD.64")==0 || strcasecmp(m,"VMUL.64")==0 || strcasecmp(m,"VADD.32")==0) {
        if (nt < 4) fatal("line %d: %s needs vd, vs1, vs2\n", lineno, m);
        int vd = reg_v(tok[1]); int vs1 = reg_v(tok[2]); int vs2 = reg_v(tok[3]);
        if (vd<0||vs1<0||vs2<0) fatal("line %d: bad vregs\n", lineno);
        uint32_t f7=0, f3=0;
        if (strcasecmp(m,"VADD.64")==0) { f7=0x00; f3=0x0; }
        else if (strcasecmp(m,"VMUL.64")==0) { f7=0x00; f3=0x1; }
        else if (strcasecmp(m,"VADD.32")==0) { f7=0x10; f3=0x0; }
        uint32_t w = encode_r(f7, vs2, vs1, f3, vd, OPC_VEC);
        emit_word(w);
        goto cleanup;
    }
    if (strcasecmp(m,"VLD")==0 || strcasecmp(m,"VST")==0) {
        if (nt < 3) fatal("line %d: %s needs vd, offset(base)\n", lineno, m);
        int vd = reg_v(tok[1]); if (vd<0) fatal("line %d: bad vd\n", lineno);
        char *s = tok[2];
        char *paren = strchr(s,'(');
        if (!paren) fatal("line %d: bad mem operand\n", lineno);
        *paren = 0;
        char *offstr = s;
        char *regstr = paren+1;
        char *rp = strchr(regstr,')'); if (!rp) fatal("line %d: bad mem operand\n", lineno);
        *rp = 0;
        int rs1 = reg_x(regstr); if (rs1<0) fatal("line %d: bad base reg\n", lineno);
        int imm12 = (int)parse_imm(offstr) & 0xFFF;
        uint32_t f7 = 0x20;
        uint32_t f3 = (strcasecmp(m,"VLD")==0)?0x0:0x1;
        uint32_t w = (f7<<25) | (imm12<<20) | (rs1<<15) | (f3<<12) | (vd<<7) | OPC_VEC;
        emit_word(w);
        goto cleanup;
    }

    /* Directives */
    if (m[0]=='.') {
        if (strcasecmp(m,".org")==0) {
            if (nt < 2) fatal("line %d: .org needs address\n", lineno);
            uint32_t addr = parse_imm(tok[1]);
            if (addr < loc) fatal("line %d: .org to lower address\n", lineno);
            while (loc < addr) emit_byte(0);
            goto cleanup;
        } else if (strcasecmp(m,".word")==0) {
            if (nt < 2) fatal("line %d: .word needs value\n", lineno);
            uint32_t v = parse_imm(tok[1]);
            emit_word(v);
            goto cleanup;
        } else if (strcasecmp(m,".byte")==0) {
            if (nt < 2) fatal("line %d: .byte needs value\n", lineno);
            uint32_t v = parse_imm(tok[1]);
            emit_byte((uint8_t)v);
            goto cleanup;
        } else if (strcasecmp(m,".ascii")==0) {
            if (nt < 2) fatal("line %d: .ascii needs string\n", lineno);
            char *s = tok[1];
            if (s[0]=='"' && s[strlen(s)-1]=='"') {
                s[strlen(s)-1]=0; s++;
            }
            emit_bytes(s, strlen(s));
            goto cleanup;
        } else {
            goto cleanup;
        }
    }

    fatal("line %d: unknown mnemonic: %s\n", lineno, m);

cleanup:
    for (int i=0;i<nt;i++) free(tok[i]);
}

/* First pass: collect labels and update loc */
static void first_pass(FILE *f) {
    char linebuf[MAX_LINE];
    int lineno = 0;
    loc = 0;
    while (fgets(linebuf, sizeof(linebuf), f)) {
        lineno++;
        char *s = linebuf;
        char *c = strchr(s, '#'); if (c) *c = 0;
        char *t = trim(s);
        if (*t==0) continue;
        char *colon = strchr(t, ':');
        if (colon) {
            *colon = 0;
            char *lbl = trim(t);
            if (strlen(lbl)==0) fatal("line %d: empty label\n", lineno);
            add_label(lbl, loc);
            t = trim(colon+1);
            if (*t==0) continue;
        }
        char first[MAX_LINE];
        int i=0;
        while (t[i] && !isspace((unsigned char)t[i]) && t[i]!=',') { first[i]=t[i]; i++; }
        first[i]=0;
        if (first[0]=='.') {
            if (strcasecmp(first,".org")==0) {
                char *p = t + strlen(first);
                p = trim(p);
                if (*p==0) fatal("line %d: .org needs address\n", lineno);
                uint32_t addr = parse_imm(p);
                if (addr < loc) fatal("line %d: .org to lower address\n", lineno);
                loc = addr;
            } else if (strcasecmp(first,".word")==0) loc += 4;
            else if (strcasecmp(first,".byte")==0) loc += 1;
            else if (strcasecmp(first,".ascii")==0) {
                char *p = strchr(t, ' ');
                if (!p) fatal("line %d: .ascii needs string\n", lineno);
                p = trim(p);
                if (p[0]=='"') {
                    char *q = strchr(p+1, '"');
                    if (!q) fatal("line %d: unterminated string\n", lineno);
                    loc += (q - (p+1));
                } else loc += strlen(p);
            } else { /* ignore */ }
        } else {
            loc += 4;
        }
    }
}

/* Second pass: emit payload (no header yet) */
static void second_pass(FILE *f) {
    char linebuf[MAX_LINE];
    int lineno = 0;
    loc = 0;
    outpos = 0;
    while (fgets(linebuf, sizeof(linebuf), f)) {
        lineno++;
        char *s = linebuf;
        char *c = strchr(s, '#'); if (c) *c = 0;
        char *t = trim(s);
        if (*t==0) continue;
        char *colon = strchr(t, ':');
        if (colon) {
            *colon = 0;
            t = trim(colon+1);
            if (*t==0) continue;
        }
        char copy[MAX_LINE]; strncpy(copy, t, sizeof(copy)); copy[sizeof(copy)-1]=0;
        char *first = strtok(copy, " \t,");
        if (!first) continue;
        if (first[0]=='.') {
            if (strcasecmp(first,".org")==0) {
                char *arg = t + strlen(first);
                arg = trim(arg);
                uint32_t addr = parse_imm(arg);
                while (loc < addr) emit_byte(0);
            } else if (strcasecmp(first,".word")==0) {
                char *arg = t + strlen(first);
                arg = trim(arg);
                uint32_t v = parse_imm(arg);
                emit_word(v);
            } else if (strcasecmp(first,".byte")==0) {
                char *arg = t + strlen(first);
                arg = trim(arg);
                uint32_t v = parse_imm(arg);
                emit_byte((uint8_t)v);
            } else if (strcasecmp(first,".ascii")==0) {
                char *arg = t + strlen(first);
                arg = trim(arg);
                if (arg[0]=='"') {
                    char *q = strchr(arg+1, '"');
                    if (!q) fatal("line %d: unterminated string\n", lineno);
                    *q = 0; arg++;
                    emit_bytes(arg, strlen(arg));
                } else {
                    emit_bytes(arg, strlen(arg));
                }
            } else { /* ignore */ }
        } else {
            assemble_inst(t, lineno);
        }
    }
}

/* Write output file with 8-byte header */
static void write_output(const char *outfile, uint32_t load_addr) {
    FILE *fo = fopen(outfile, "wb");
    if (!fo) fatal("fopen %s: %s\n", outfile, strerror(errno));
    uint32_t payload_size = (uint32_t)outpos;
    uint8_t hdr[8];
    hdr[0] = load_addr & 0xFF; hdr[1] = (load_addr>>8)&0xFF; hdr[2] = (load_addr>>16)&0xFF; hdr[3] = (load_addr>>24)&0xFF;
    hdr[4] = payload_size & 0xFF; hdr[5] = (payload_size>>8)&0xFF; hdr[6] = (payload_size>>16)&0xFF; hdr[7] = (payload_size>>24)&0xFF;
    if (fwrite(hdr,1,8,fo) != 8) fatal("fwrite header failed\n");
    if (payload_size) {
        if (fwrite(outbuf,1,payload_size,fo) != payload_size) fatal("fwrite payload failed\n");
    }
    fclose(fo);
    printf("Assembled %u bytes (load addr 0x%08x) -> %s\n", payload_size, load_addr, outfile);
}

/* Main */
int assemble(int argc, char **argv) {
    if (argc < 3) {
        fprintf(stderr,"Usage: %s -o out.bin [-a load_addr] in.s\n", argv[0]);
        return 1;
    }
    char *infile = NULL; char *outfile = NULL;
    for (int i=1;i<argc;i++) {
        if (strcmp(argv[i],"-o")==0) { if (i+1<argc) { outfile = argv[++i]; } else fatal("missing -o arg\n"); }
        else if (strcmp(argv[i],"-a")==0) { if (i+1<argc) { header_load_addr = (uint32_t)strtoul(argv[++i], NULL, 0); } else fatal("missing -a arg\n"); }
        else infile = argv[i];
    }
    if (!infile || !outfile) { fprintf(stderr,"Usage: %s -o out.bin [-a load_addr] in.s\n", argv[0]); return 1; }

    FILE *f = fopen(infile, "r");
    if (!f) fatal("fopen %s: %s\n", infile, strerror(errno));
    outbuf = malloc(outcap);
    if (!outbuf) fatal("malloc failed\n");

    first_pass(f);
    rewind(f);
    second_pass(f);
    fclose(f);

    write_output(outfile, header_load_addr);

    free(outbuf);
    free_labels();
    return 0;
}
