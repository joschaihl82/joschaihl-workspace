### jemu.c (SSE-free)

```c
// ============================================================================
// jemu.c - x64 emulator (SSE/XMM support removed)
// ============================================================================
//
// This is a self-contained, minimal x86-64 emulator core without any SSE/XMM
// support or SSE-specific micro-ops. It implements a practical subset of
// integer x86-64 instructions, 0F-group non-SSE opcodes (IMUL, Jcc, SETcc),
// basic ModR/M + SIB addressing, memory, stack, simple tracing, soft
// breakpoints, and an SDL framebuffer for visualization.
//
// Notes:
// - SSE/XMM related types, helpers and opcodes are removed and will cause a
//   clear error if encountered.
// - Inline asm paths are disabled for portability; the code uses memcpy/read/write.
// - This is an interpreter, not a full CPU; extend execute_one() to add more
//   opcodes as needed.
//
// Build:
//   gcc -O2 -std=c11 -Wall -Wextra -pthread -o jemu jemu.c `sdl2-config --cflags --libs`
//
// Run:
//   ./jemu [optional-binary-to-load]
//
// ----------------------------------------------------------------------------

#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>
#include <inttypes.h>
#include <string.h>
#include <stdarg.h>
#include <pthread.h>
#include <time.h>
#include <unistd.h>
#include <SDL2/SDL.h>

/* -------------------------
 configuration switches
 ------------------------- */
/* Disable inline asm to make the build portable (no SSE/inline asm required) */
#undef USE_INLINE_ASM_FASTMEM
#undef USE_INLINE_ASM_FETCH
#undef USE_INLINE_ASM_STACK
#define USE_INLINE_ASM_FASTMEM 0
#define USE_INLINE_ASM_FETCH 0
#define USE_INLINE_ASM_STACK 0

/* Framebuffer streaming (keep if you want SDL streaming) */
#define USE_FB_STREAMING 1

/* Strict handling of MOVDQA alignment: 0=warn+copy, 1=trap (exit) */
#define STRICT_MOVDQA_ALIGNMENT 0

/* Micro-ops and trace config */
#define TRACE_RING_SIZE (1 << 15) /* 32K entries */
#define ENABLE_SOFT_BREAKPOINTS 1
#define MAX_SOFT_BP 64

/* -------------------------
 basic sizes and globals
 ------------------------- */
#define RAM_SIZE (64ULL * 1024 * 1024) /* 64 MiB default */

static uint8_t *ram_mem = NULL;
static uint8_t *fb_mem = NULL;

/* trace entry */
typedef struct {
	uint64_t rip;
	uint8_t opcode;
	uint8_t op2;
	uint8_t modrm;
	uint8_t prefixes; /* bit0:66, bit1:F2, bit2:F3, bit3:REX.W */
	uint64_t info_a; /* e.g., dst reg idx or EA */
	uint64_t info_b; /* src reg idx or imm */
} TraceEntry;

/* soft breakpoint */
typedef struct {
	int active;
	uint64_t addr;
} SoftBP;

/* minimal cpu type */
typedef struct {
	uint64_t gpr[16]; /* rax..r15 */
	uint64_t rflags;
	uint64_t rip;

	/* decode state */
	int op_size; /* 16/32/64 */
	int addr_size;/* 32/64 */
	int has_rex;
	int rex_w, rex_r, rex_x, rex_b;

	/* legacy prefixes (tracked per-insn) */
	int pref_66; /* operand-size override */
	int pref_f2; /* repne/legacy SIMD selector */
	int pref_f3; /* rep/legacy SIMD selector */

	int modrm_mod, modrm_reg, modrm_rm;
	uint8_t last_opcode;

	/* trace ring buffer */
	TraceEntry trace[TRACE_RING_SIZE];
	uint32_t trace_head;

	/* soft breakpoints */
	SoftBP bp[MAX_SOFT_BP];
} X64CPU;

static X64CPU cpu;

/* -------------------------
 forward declarations
 ------------------------- */
uint8_t* get_memory_ptr(uint64_t addr);
uint8_t mem_read8(uint64_t addr);
uint16_t mem_read16(uint64_t addr);
uint32_t mem_read32(uint64_t addr);
uint64_t mem_read64(uint64_t addr);
void mem_write8(uint64_t addr, uint8_t v);
void mem_write16(uint64_t addr, uint16_t v);
void mem_write32(uint64_t addr, uint32_t v);
void mem_write64(uint64_t addr, uint64_t v);

uint8_t fetch8(void);
uint16_t fetch16(void);
uint32_t fetch32(void);
uint64_t fetch64(void);

void decode_modrm(void);
uint64_t compute_ea(void);
void cpu_decode_reset(void);
void execute_one_extended(void);
void execute_one(void);

/* micro-ops layer (SSE removed) */
typedef enum {
	UOP_NONE = 0,
	UOP_ALU_BIN, /* dst = alu(dst, src) */
	UOP_ALU_BIN_MEM, /* mem = alu(mem, src) */
	UOP_ALU_IMM, /* dst = alu(dst, imm) */
	UOP_MOV_REG_REG,
	UOP_MOV_REG_MEM_LOAD,
	UOP_MOV_MEM_REG_STORE,
	UOP_PUSH_REG,
	UOP_POP_REG,
	UOP_PUSH_IMM,
	UOP_PUSH_MEM,
	UOP_POP_MEM,
	UOP_JMP_REL8,
	UOP_JMP_REL32,
	UOP_CALL_REL32,
	UOP_RET,
	UOP_LEA,
	UOP_BREAK_TRAP
} UopKind;

typedef enum {
	opAdd, opOr, opAdc, opSbb, opAnd, opSub, opXor, opCmp
} AluOp;

/* micro-op record */
typedef struct {
	UopKind kind;
	AluOp aop;
	int width; /* 8,16,32,64 where relevant */
	int dst_reg; /* gpr index */
	int src_reg; /* gpr index */
	uint64_t imm;
	uint64_t ea;
	uint8_t prefix_bits;
	uint8_t opcode;
	uint8_t op2; /* for 0F group */
} Uop;

/* micro-op executor */
static inline void exec_uop(const Uop *u);

/* trace helpers */
static inline void trace_emit(uint64_t rip, uint8_t opcode, uint8_t op2,
		uint8_t modrm, uint8_t prefixes, uint64_t a, uint64_t b);

/* soft breakpoints */
static inline int bp_check(uint64_t rip);
static inline int bp_add(uint64_t addr);
static inline void bp_clear_all(void);

/* -------------------------
 tracing / helpers
 ------------------------- */
static void trace_printf(const char *fmt, ...) {
	va_list ap;
	va_start(ap, fmt);
	vfprintf(stderr, fmt, ap);
	va_end(ap);
}
static const char* gpr_name(int idx) {
	static const char *names[16] = { "rax", "rcx", "rdx", "rbx", "rsp", "rbp",
			"rsi", "rdi", "r8", "r9", "r10", "r11", "r12", "r13", "r14", "r15" };
	if (idx >= 0 && idx < 16)
		return names[idx];
	return "r?";
}

/* -------------------------
 memory helpers
 ------------------------- */
uint8_t* get_memory_ptr(uint64_t addr) {
	if (!ram_mem)
		return NULL;
	return &ram_mem[addr % RAM_SIZE];
}
uint8_t mem_read8(uint64_t addr) {
	uint8_t *p = get_memory_ptr(addr);
	return p ? p[0] : 0;
}
uint16_t mem_read16(uint64_t addr) {
	uint8_t *p = get_memory_ptr(addr);
	if (!p)
		return 0;
	uint16_t v;
	memcpy(&v, p, 2);
	return v;
}
uint32_t mem_read32(uint64_t addr) {
	uint8_t *p = get_memory_ptr(addr);
	if (!p)
		return 0;
	uint32_t v;
	memcpy(&v, p, 4);
	return v;
}
uint64_t mem_read64(uint64_t addr) {
#if USE_INLINE_ASM_FASTMEM && defined(__x86_64__) && defined(__GNUC__)
    uint8_t *p = get_memory_ptr(addr);
    if (!p) return 0;
    uint64_t val;
    asm volatile ("movq (%1), %0" : "=r"(val) : "r"(p) : "memory");
    return val;
#else
	uint8_t *p = get_memory_ptr(addr);
	if (!p)
		return 0;
	uint64_t v;
	memcpy(&v, p, 8);
	return v;
#endif
}
void mem_write8(uint64_t addr, uint8_t v) {
	uint8_t *p = get_memory_ptr(addr);
	if (!p)
		return;
	p[0] = v;
}
void mem_write16(uint64_t addr, uint16_t v) {
	uint8_t *p = get_memory_ptr(addr);
	if (!p)
		return;
	memcpy(p, &v, 2);
}
void mem_write32(uint64_t addr, uint32_t v) {
	uint8_t *p = get_memory_ptr(addr);
	if (!p)
		return;
	memcpy(p, &v, 4);
}
void mem_write64(uint64_t addr, uint64_t v) {
#if USE_INLINE_ASM_FASTMEM && defined(__x86_64__) && defined(__GNUC__)
    uint8_t *p = get_memory_ptr(addr);
    if (!p) return;
    asm volatile ("movq %1, (%0)" : : "r"(p), "r"(v) : "memory");
#else
	uint8_t *p = get_memory_ptr(addr);
	if (!p)
		return;
	memcpy(p, &v, 8);
#endif
}

/* -------------------------
 fetch helpers
 ------------------------- */
uint8_t fetch8(void) {
#if USE_INLINE_ASM_FETCH && defined(__x86_64__) && defined(__GNUC__)
    uint8_t b = 0;
    uint8_t *p = get_memory_ptr(cpu.rip);
    if (p) { asm volatile ("movb (%1), %0" : "=r"(b) : "r"(p) : "memory"); }
    cpu.rip += 1;
    return b;
#else
	uint8_t v = mem_read8(cpu.rip);
	cpu.rip += 1;
	return v;
#endif
}
uint16_t fetch16(void) {
	uint16_t v = mem_read16(cpu.rip);
	cpu.rip += 2;
	return v;
}
uint32_t fetch32(void) {
#if USE_INLINE_ASM_FETCH && defined(__x86_64__) && defined(__GNUC__)
    uint32_t v = 0;
    uint8_t *p = get_memory_ptr(cpu.rip);
    if (p) { asm volatile ("movl (%1), %0" : "=r"(v) : "r"(p) : "memory"); }
    cpu.rip += 4;
    return v;
#else
	uint32_t v = mem_read32(cpu.rip);
	cpu.rip += 4;
	return v;
#endif
}
uint64_t fetch64(void) {
#if USE_INLINE_ASM_FETCH && defined(__x86_64__) && defined(__GNUC__)
    uint64_t v = 0;
    uint8_t *p = get_memory_ptr(cpu.rip);
    if (p) { asm volatile ("movq (%1), %0" : "=r"(v) : "r"(p) : "memory"); }
    cpu.rip += 8;
    return v;
#else
	uint64_t v = mem_read64(cpu.rip);
	cpu.rip += 8;
	return v;
#endif
}

/* -------------------------
 simplified modrm / ea (extended with SIB)
 ------------------------- */
static uint64_t compute_ea_sib(uint8_t sib) {
	int scale = (sib >> 6) & 3;
	int index = (sib >> 3) & 7;
	int base = sib & 7;

	int rex_index = cpu.rex_x ? 8 : 0;
	int rex_base = cpu.rex_b ? 8 : 0;

	uint64_t base_val = 0, idx_val = 0;
	if (cpu.modrm_mod == 0 && base == 5) {
		base_val = 0; /* disp32 only */
	} else {
		base_val = cpu.gpr[base | rex_base];
	}
	if (index == 4)
		idx_val = 0;
	else
		idx_val = cpu.gpr[index | rex_index] << scale;
	return base_val + idx_val;
}

void decode_modrm(void) {
	uint8_t b = fetch8();
	cpu.modrm_mod = (b >> 6) & 3;
	cpu.modrm_reg = (b >> 3) & 7;
	cpu.modrm_rm = b & 7;
}

uint64_t compute_ea(void) {
	int rm = cpu.modrm_rm | (cpu.rex_b << 3);

	if (cpu.modrm_mod == 0) {
		if ((rm & 7) == 4) {
			uint8_t sib = fetch8();
			uint64_t addr = compute_ea_sib(sib);
			if ((sib & 7) == 5) {
				int32_t disp = (int32_t) fetch32();
				return addr + (uint64_t) (int64_t) disp;
			}
			return addr;
		}
		if ((rm & 7) == 5) {
			int32_t disp = (int32_t) fetch32();
			return cpu.rip + (int64_t) disp;
		}
		return cpu.gpr[rm];
	} else if (cpu.modrm_mod == 1) {
		if ((rm & 7) == 4) {
			uint8_t sib = fetch8();
			uint64_t addr = compute_ea_sib(sib);
			int8_t d8 = (int8_t) fetch8();
			return addr + (int64_t) d8;
		}
		int8_t d8 = (int8_t) fetch8();
		return cpu.gpr[rm] + (int64_t) d8;
	} else {
		if ((rm & 7) == 4) {
			uint8_t sib = fetch8();
			uint64_t addr = compute_ea_sib(sib);
			int32_t d32 = (int32_t) fetch32();
			return addr + (int64_t) d32;
		}
		int32_t d32 = (int32_t) fetch32();
		return cpu.gpr[rm] + (int64_t) d32;
	}
}

void cpu_decode_reset(void) {
	cpu.op_size = 64;
	cpu.addr_size = 64;
	cpu.has_rex = 0;
	cpu.rex_w = cpu.rex_r = cpu.rex_x = cpu.rex_b = 0;
	cpu.pref_66 = cpu.pref_f2 = cpu.pref_f3 = 0;
}

/* -------------------------
 flag helpers
 ------------------------- */
static inline int parity8(uint8_t x) {
	x ^= x >> 4;
	x &= 0xF;
	return (0x6996 >> x) & 1;
}
static inline void set_flag_zf_sf_pfN(uint64_t res, int width) {
	uint64_t mask = (width == 64) ? ~0ULL : ((1ULL << width) - 1);
	uint64_t v = res & mask;
	if (v == 0)
		cpu.rflags |= (1ULL << 6);
	else
		cpu.rflags &= ~(1ULL << 6);
	if (v & (1ULL << (width - 1)))
		cpu.rflags |= (1ULL << 7);
	else
		cpu.rflags &= ~(1ULL << 7);
	if (parity8((uint8_t) (v & 0xFF)))
		cpu.rflags |= (1ULL << 2);
	else
		cpu.rflags &= ~(1ULL << 2);
}
static inline void update_add_flags_uN(uint64_t a, uint64_t b, uint64_t res,
		int width) {
	uint64_t mask = (width == 64) ? ~0ULL : ((1ULL << width) - 1);
	a &= mask;
	b &= mask;
	res &= mask;
	uint64_t carry = (res < a) || (res < b);
	if (carry)
		cpu.rflags |= 1ULL;
	else
		cpu.rflags &= ~1ULL;
	int sa = (a >> (width - 1)) & 1, sb = (b >> (width - 1)) & 1, sr = (res
			>> (width - 1)) & 1;
	if ((sa == sb) && (sr != sa))
		cpu.rflags |= (1ULL << 11);
	else
		cpu.rflags &= ~(1ULL << 11);
}
static inline void update_sub_flags_uN(uint64_t a, uint64_t b, uint64_t res,
		int width) {
	uint64_t mask = (width == 64) ? ~0ULL : ((1ULL << width) - 1);
	a &= mask;
	b &= mask;
	res &= mask;
	uint64_t borrow = (a < b);
	if (borrow)
		cpu.rflags |= 1ULL;
	else
		cpu.rflags &= ~1ULL;
	int sa = (a >> (width - 1)) & 1, sb = (b >> (width - 1)) & 1, sr = (res
			>> (width - 1)) & 1;
	if ((sa != sb) && (sr != sa))
		cpu.rflags |= (1ULL << 11);
	else
		cpu.rflags &= ~(1ULL << 11);
}
static inline void clear_alu_flags() {
	cpu.rflags &= ~((1ULL << 0) | (1ULL << 2) | (1ULL << 4) | (1ULL << 6)
			| (1ULL << 7) | (1ULL << 11));
}
static inline uint64_t add_with_carry_uN(uint64_t a, uint64_t b, uint64_t cf,
		int width) {
	uint64_t mask = (width == 64) ? ~0ULL : ((1ULL << width) - 1);
	uint64_t ua = a & mask, ub = b & mask;
	uint64_t res = ua + ub + (cf & 1);
	uint64_t carry1 = (res < ua);
	uint64_t carry2 = ((cf & 1) && res == ua);
	if (carry1 || carry2)
		cpu.rflags |= 1ULL;
	else
		cpu.rflags &= ~1ULL;
	int sa = (ua >> (width - 1)) & 1, sb = (ub >> (width - 1)) & 1, sr = (res
			>> (width - 1)) & 1;
	if ((sa == sb) && (sr != sa))
		cpu.rflags |= (1ULL << 11);
	else
		cpu.rflags &= ~(1ULL << 11);
	set_flag_zf_sf_pfN(res, width);
	return res & mask;
}
static inline uint64_t sub_with_borrow_uN(uint64_t a, uint64_t b, uint64_t cf,
		int width) {
	uint64_t mask = (width == 64) ? ~0ULL : ((1ULL << width) - 1);
	uint64_t ua = a & mask, ub = b & mask;
	uint64_t borrow_in = (cf & 1);
	uint64_t res = ua - ub - borrow_in;
	uint64_t borrow1 = (ua < ub);
	uint64_t borrow2 = (borrow_in && ua == ub);
	if (borrow1 || borrow2)
		cpu.rflags |= 1ULL;
	else
		cpu.rflags &= ~1ULL;
	int sa = (ua >> (width - 1)) & 1, sb = (ub >> (width - 1)) & 1, sr = (res
			>> (width - 1)) & 1;
	if ((sa != sb) && (sr != sa))
		cpu.rflags |= (1ULL << 11);
	else
		cpu.rflags &= ~(1ULL << 11);
	set_flag_zf_sf_pfN(res, width);
	return res & mask;
}

/* -------------------------
 conditional check (3.5 rule)
 ------------------------- */
static inline int funGet(int numBit) {
	return (cpu.rflags >> numBit) & 1;
}
static inline int funCnd(int numCode) {
	switch (numCode & 0xF) {
	case 0x0:
		return funGet(11);
	case 0x1:
		return !funGet(11);
	case 0x2:
		return funGet(0);
	case 0x3:
		return !funGet(0);
	case 0x4:
		return funGet(6);
	case 0x5:
		return !funGet(6);
	case 0x6:
		return funGet(0) || funGet(6);
	case 0x7:
		return !(funGet(0) || funGet(6));
	case 0x8:
		return funGet(7);
	case 0x9:
		return !funGet(7);
	case 0xA:
		return funGet(2);
	case 0xB:
		return !funGet(2);
	case 0xC:
		return funGet(7) != funGet(11);
	case 0xD:
		return funGet(7) == funGet(11);
	case 0xE:
		return (funGet(7) != funGet(11)) || funGet(6);
	case 0xF:
		return !((funGet(7) != funGet(11)) || funGet(6));
	}
	return 0;
}

/* -------------------------
 stack helpers
 ------------------------- */
static inline void push_u64(uint64_t v) {
#if USE_INLINE_ASM_STACK && defined(__x86_64__) && defined(__GNUC__)
    uint64_t sp = cpu.gpr[4] - 8;
    cpu.gpr[4] = sp;
    uint8_t *p = get_memory_ptr(sp);
    if (p) asm volatile ("movq %1, (%0)" : : "r"(p), "r"(v) : "memory");
#else
	cpu.gpr[4] -= 8;
	mem_write64(cpu.gpr[4], v);
#endif
}
static inline uint64_t pop_u64(void) {
#if USE_INLINE_ASM_STACK && defined(__x86_64__) && defined(__GNUC__)
    uint64_t sp = cpu.gpr[4];
    uint8_t *p = get_memory_ptr(sp);
    uint64_t v = 0;
    if (p) asm volatile ("movq (%1), %0" : "=r"(v) : "r"(p) : "memory");
    cpu.gpr[4] = sp + 8;
    return v;
#else
	uint64_t v = mem_read64(cpu.gpr[4]);
	cpu.gpr[4] += 8;
	return v;
#endif
}

/* -------------------------
 ALU execution helper (micro-ops consume these)
 ------------------------- */
static uint64_t funAluExecWidth(AluOp oper, uint64_t lhs, uint64_t rhs,
		int width) {
	uint64_t res = 0;
	clear_alu_flags();
	switch (oper) {
	case opAdd:
		res = lhs + rhs;
		update_add_flags_uN(lhs, rhs, res, width);
		set_flag_zf_sf_pfN(res, width);
		break;
	case opOr:
		res = lhs | rhs;
		set_flag_zf_sf_pfN(res, width);
		cpu.rflags &= ~((1ULL << 0) | (1ULL << 11));
		break;
	case opAnd:
		res = lhs & rhs;
		set_flag_zf_sf_pfN(res, width);
		cpu.rflags &= ~((1ULL << 0) | (1ULL << 11));
		break;
	case opXor:
		res = lhs ^ rhs;
		set_flag_zf_sf_pfN(res, width);
		cpu.rflags &= ~((1ULL << 0) | (1ULL << 11));
		break;
	case opSub:
	case opCmp:
		res = lhs - rhs;
		update_sub_flags_uN(lhs, rhs, res, width);
		set_flag_zf_sf_pfN(res, width);
		break;
	case opAdc: {
		uint64_t cf = cpu.rflags & 1ULL;
		res = add_with_carry_uN(lhs, rhs, cf, width);
		break;
	}
	case opSbb: {
		uint64_t cf = cpu.rflags & 1ULL;
		res = sub_with_borrow_uN(lhs, rhs, cf, width);
		break;
	}
	default:
		trace_printf("unimplemented alu op: %d\n", oper);
		exit(1);
	}
	return res;
}

/* -------------------------
 trace helpers
 ------------------------- */
static inline void trace_emit(uint64_t rip, uint8_t opcode, uint8_t op2,
		uint8_t modrm, uint8_t prefixes, uint64_t a, uint64_t b) {
	uint32_t i = cpu.trace_head++ & (TRACE_RING_SIZE - 1);
	cpu.trace[i].rip = rip;
	cpu.trace[i].opcode = opcode;
	cpu.trace[i].op2 = op2;
	cpu.trace[i].modrm = modrm;
	cpu.trace[i].prefixes = prefixes;
	cpu.trace[i].info_a = a;
	cpu.trace[i].info_b = b;
}

/* -------------------------
 soft breakpoints
 ------------------------- */
static inline int bp_check(uint64_t rip) {
#if ENABLE_SOFT_BREAKPOINTS
	for (int i = 0; i < MAX_SOFT_BP; i++) {
		if (cpu.bp[i].active && cpu.bp[i].addr == rip)
			return 1;
	}
#endif
	return 0;
}
static inline int bp_add(uint64_t addr) {
#if ENABLE_SOFT_BREAKPOINTS
	for (int i = 0; i < MAX_SOFT_BP; i++) {
		if (!cpu.bp[i].active) {
			cpu.bp[i].active = 1;
			cpu.bp[i].addr = addr;
			return 0;
		}
	}
	return -1;
#else
    (void)addr; return -1;
#endif
}
static inline void bp_clear_all(void) {
#if ENABLE_SOFT_BREAKPOINTS
	for (int i = 0; i < MAX_SOFT_BP; i++)
		cpu.bp[i].active = 0;
#endif
}

/* -------------------------
 micro-op executor
 ------------------------- */
static inline void exec_uop(const Uop *u) {
	switch (u->kind) {
	case UOP_ALU_BIN: {
		uint64_t *dstp = &cpu.gpr[u->dst_reg];
		uint64_t src = cpu.gpr[u->src_reg];
		uint64_t res = funAluExecWidth(u->aop, *dstp, src, u->width);
		if (u->aop != opCmp)
			*dstp = res;
		break;
	}
	case UOP_ALU_BIN_MEM: {
		uint64_t val = mem_read64(u->ea);
		uint64_t src = cpu.gpr[u->src_reg];
		uint64_t res = funAluExecWidth(u->aop, val, src, u->width);
		if (u->aop != opCmp)
			mem_write64(u->ea, res);
		break;
	}
	case UOP_ALU_IMM: {
		uint64_t *dstp = &cpu.gpr[u->dst_reg];
		uint64_t res = funAluExecWidth(u->aop, *dstp, u->imm, u->width);
		if (u->aop != opCmp)
			*dstp = res;
		break;
	}
	case UOP_MOV_REG_REG: {
		cpu.gpr[u->dst_reg] = cpu.gpr[u->src_reg];
		break;
	}
	case UOP_MOV_REG_MEM_LOAD: {
		cpu.gpr[u->dst_reg] = mem_read64(u->ea);
		break;
	}
	case UOP_MOV_MEM_REG_STORE: {
		mem_write64(u->ea, cpu.gpr[u->src_reg]);
		break;
	}
	case UOP_PUSH_REG: {
		push_u64(cpu.gpr[u->src_reg]);
		break;
	}
	case UOP_POP_REG: {
		cpu.gpr[u->dst_reg] = pop_u64();
		break;
	}
	case UOP_PUSH_IMM: {
		push_u64(u->imm);
		break;
	}
	case UOP_PUSH_MEM: {
		push_u64(mem_read64(u->ea));
		break;
	}
	case UOP_POP_MEM: {
		mem_write64(u->ea, pop_u64());
		break;
	}
	case UOP_JMP_REL8: {
		cpu.rip += (int64_t) (int8_t) u->imm;
		break;
	}
	case UOP_JMP_REL32: {
		cpu.rip += (int64_t) (int32_t) u->imm;
		break;
	}
	case UOP_CALL_REL32: {
		push_u64(cpu.rip);
		cpu.rip += (int64_t) (int32_t) u->imm;
		break;
	}
	case UOP_RET: {
		cpu.rip = pop_u64();
		break;
	}
	case UOP_LEA: {
		cpu.gpr[u->dst_reg] = u->ea;
		break;
	}
	case UOP_BREAK_TRAP: {
		trace_printf("soft breakpoint trap at rip=0x%016" PRIx64 "\n", cpu.rip);
		exit(0);
	}
	default:
		trace_printf("unimplemented uop kind: %d\n", u->kind);
		exit(1);
	}
}

/* -------------------------
 0F group handler (SSE removed)
 ------------------------- */
void handle_0F_group(uint8_t op2) {
	uint8_t modrm_peek = mem_read8(cpu.rip);
	uint8_t prefixes = (cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
			| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0);
	switch (op2) {
	/* SSE/XMM opcodes are unsupported in this build */
	case 0x6F:
	case 0x7F:
	case 0x28:
	case 0x29:
	case 0x10:
	case 0x11:
	case 0x54:
	case 0x56:
	case 0x57:
	case 0xC6:
		trace_printf(
				"Unsupported SSE/XMM opcode: 0F %02X at rip=0x%016" PRIx64 "\n",
				op2, cpu.rip - 2);
		exit(1);
		break;

		/* IMUL two-operand without immediate: 0F AF */
	case 0xAF: {
		decode_modrm();
		int dst = cpu.modrm_reg | (cpu.rex_r << 3);
		int width = cpu.rex_w ? 64 : 32;
		uint64_t rhs;
		if (cpu.modrm_mod == 3) {
			rhs = cpu.gpr[(cpu.modrm_rm | (cpu.rex_b << 3))];
		} else {
			uint64_t ea = compute_ea();
			rhs = cpu.rex_w ?
					mem_read64(ea) :
					(uint64_t) (int64_t) (int32_t) mem_read32(ea);
		}
		uint64_t lhs = cpu.gpr[dst];
		__int128 prod =
				(width == 64) ?
						(__int128) (int64_t) lhs * (int64_t) rhs :
						(__int128) (int32_t) lhs * (int32_t) rhs;
		uint64_t mask = (width == 64) ? ~0ULL : 0xFFFFFFFFULL;
		uint64_t res = (uint64_t) prod & mask;
		__int128 signext =
				(width == 64) ?
						(__int128) (int64_t) res : (__int128) (int32_t) res;
		int overflow = (prod != signext);
		if (overflow)
			cpu.rflags |= ((1ULL << 0) | (1ULL << 11));
		else
			cpu.rflags &= ~((1ULL << 0) | (1ULL << 11));
		cpu.gpr[dst] = res;
		break;
	}

		/* MOVZX / MOVSX (integer forms) */
	case 0xB6: { /* MOVZX r32/64, r/m8 */
		decode_modrm();
		int dst = cpu.modrm_reg | (cpu.rex_r << 3);
		if (cpu.modrm_mod == 3) {
			int src = cpu.modrm_rm | (cpu.rex_b << 3);
			uint64_t val = cpu.gpr[src] & 0xFF;
			cpu.gpr[dst] = cpu.rex_w ? val : (uint64_t) (uint32_t) val;
		} else {
			uint64_t ea = compute_ea();
			uint8_t v = mem_read8(ea);
			uint64_t val = (uint64_t) v;
			cpu.gpr[dst] = cpu.rex_w ? val : (uint64_t) (uint32_t) val;
		}
		trace_emit(cpu.rip - 3, 0x0F, op2,
				(cpu.modrm_mod << 6) | (cpu.modrm_reg << 3) | cpu.modrm_rm,
				prefixes, dst, 0);
		break;
	}
	case 0xB7: { /* MOVZX r32/64, r/m16 */
		decode_modrm();
		int dst = cpu.modrm_reg | (cpu.rex_r << 3);
		if (cpu.modrm_mod == 3) {
			int src = cpu.modrm_rm | (cpu.rex_b << 3);
			uint64_t val = cpu.gpr[src] & 0xFFFF;
			cpu.gpr[dst] = cpu.rex_w ? val : (uint64_t) (uint32_t) val;
		} else {
			uint64_t ea = compute_ea();
			uint16_t v = mem_read16(ea);
			uint64_t val = (uint64_t) v;
			cpu.gpr[dst] = cpu.rex_w ? val : (uint64_t) (uint32_t) val;
		}
		trace_emit(cpu.rip - 3, 0x0F, op2,
				(cpu.modrm_mod << 6) | (cpu.modrm_reg << 3) | cpu.modrm_rm,
				prefixes, dst, 0);
		break;
	}
	case 0xBE: { /* MOVSX r32/64, r/m8 */
		decode_modrm();
		int dst = cpu.modrm_reg | (cpu.rex_r << 3);
		if (cpu.modrm_mod == 3) {
			int src = cpu.modrm_rm | (cpu.rex_b << 3);
			int8_t v = (int8_t) (cpu.gpr[src] & 0xFF);
			cpu.gpr[dst] =
					cpu.rex_w ?
							(uint64_t) (int64_t) v :
							(uint64_t) (uint32_t) (int32_t) v;
		} else {
			uint64_t ea = compute_ea();
			int8_t v = (int8_t) mem_read8(ea);
			cpu.gpr[dst] =
					cpu.rex_w ?
							(uint64_t) (int64_t) v :
							(uint64_t) (uint32_t) (int32_t) v;
		}
		trace_emit(cpu.rip - 3, 0x0F, op2,
				(cpu.modrm_mod << 6) | (cpu.modrm_reg << 3) | cpu.modrm_rm,
				prefixes, dst, 0);
		break;
	}
	case 0xBF: { /* MOVSX r32/64, r/m16 */
		decode_modrm();
		int dst = cpu.modrm_reg | (cpu.rex_r << 3);
		if (cpu.modrm_mod == 3) {
			int src = cpu.modrm_rm | (cpu.rex_b << 3);
			int16_t v = (int16_t) (cpu.gpr[src] & 0xFFFF);
			cpu.gpr[dst] =
					cpu.rex_w ?
							(uint64_t) (int64_t) v :
							(uint64_t) (uint32_t) (int32_t) v;
		} else {
			uint64_t ea = compute_ea();
			int16_t v = (int16_t) mem_read16(ea);
			cpu.gpr[dst] =
					cpu.rex_w ?
							(uint64_t) (int64_t) v :
							(uint64_t) (uint32_t) (int32_t) v;
		}
		trace_emit(cpu.rip - 3, 0x0F, op2,
				(cpu.modrm_mod << 6) | (cpu.modrm_reg << 3) | cpu.modrm_rm,
				prefixes, dst, 0);
		break;
	}

		/* Jcc (rel32) and SETcc */
	case 0x80 ... 0x8F: {
		int32_t disp = (int32_t) fetch32();
		trace_emit(cpu.rip - 6, 0x0F, op2, modrm_peek, prefixes,
				(uint64_t) disp, cpu.rflags);
		if (funCnd(op2))
			cpu.rip += (int64_t) disp;
		break;
	}
	case 0x90 ... 0x9F: {
		decode_modrm();
		uint8_t set_val = funCnd(op2) ? 1 : 0;
		trace_emit(cpu.rip - 3, 0x0F, op2,
				(cpu.modrm_mod << 6) | (cpu.modrm_reg << 3) | cpu.modrm_rm,
				prefixes, set_val, 0);
		if (cpu.modrm_mod == 3) {
			uint64_t *regp = &cpu.gpr[(cpu.modrm_rm | (cpu.rex_b << 3))];
			*regp = (*regp & ~0xFFULL) | set_val;
		} else {
			mem_write8(compute_ea(), set_val);
		}
		break;
	}

	default:
		trace_printf(
				"Unimplemented 0F opcode: 0F %02X at rip=0x%016" PRIx64 "\n",
				op2, cpu.rip - 2);
		exit(1);
	}
}

/* -------------------------
 extended execute (fallback path)
 ------------------------- */
void execute_one_extended(void) {
	cpu_decode_reset();
	int decoding = 1;
	uint8_t op = 0;
	while (decoding) {
		uint8_t b = fetch8();
		switch (b) {
		case 0x66:
			cpu.op_size = 16;
			cpu.pref_66 = 1;
			continue;
		case 0x67:
			cpu.addr_size = 32;
			continue;
		case 0xF2:
			cpu.pref_f2 = 1;
			continue;
		case 0xF3:
			cpu.pref_f3 = 1;
			continue;
		default:
			if ((b & 0xF0) == 0x40) {
				cpu.has_rex = 1;
				cpu.rex_w = (b >> 3) & 1;
				cpu.rex_r = (b >> 2) & 1;
				cpu.rex_x = (b >> 1) & 1;
				cpu.rex_b = b & 1;
				if (cpu.rex_w)
					cpu.op_size = 64;
				continue;
			}
			op = b;
			decoding = 0;
			break;
		}
	}

	switch (op) {
	case 0x0F:
		handle_0F_group(fetch8());
		break;
	default:
		trace_printf(
				"Unimplemented extended (fallback): 0x%02X at rip=0x%016" PRIx64 "\n",
				op, cpu.rip - 1);
		exit(1);
	}
}

/* -------------------------
 main opcode executor (x64)
 ------------------------- */

void execute_one(void) {
	cpu_decode_reset();
	int decoding = 1;
	uint8_t op = 0;

	/* decode legacy prefixes and REX */
	while (decoding) {
		uint8_t b = fetch8();
		switch (b) {
		case 0x66:
			cpu.op_size = 16;
			cpu.pref_66 = 1;
			continue;
		case 0x67:
			cpu.addr_size = 32;
			continue;
		case 0xF2:
			cpu.pref_f2 = 1;
			continue;
		case 0xF3:
			cpu.pref_f3 = 1;
			continue;
		default:
			if ((b & 0xF0) == 0x40) {
				cpu.has_rex = 1;
				cpu.rex_w = (b >> 3) & 1;
				cpu.rex_r = (b >> 2) & 1;
				cpu.rex_x = (b >> 1) & 1;
				cpu.rex_b = b & 1;
				if (cpu.rex_w)
					cpu.op_size = 64;
				continue;
			}
			op = b;
			decoding = 0;
			break;
		}
	}

	switch (op) {
	/* NOP */
	case 0x90:
		trace_emit(cpu.rip - 1, op, 0, 0,
				(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
						| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), 0, 0);
		break;

		/* RET */
	case 0xC3:
		trace_emit(cpu.rip - 1, op, 0, 0,
				(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
						| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), 0, 0);
		cpu.rip = pop_u64();
		return;

		/* PUSH r64: 0x50 + reg */
	case 0x50 ... 0x57: {
		int reg = (op & 7) | (cpu.rex_b ? 8 : 0);
		trace_emit(cpu.rip - 1, op, 0, 0,
				(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
						| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), reg, 0);
		push_u64(cpu.gpr[reg]);
		break;
	}

		/* POP r64: 0x58 + reg */
	case 0x58 ... 0x5F: {
		int reg = (op & 7) | (cpu.rex_b ? 8 : 0);
		trace_emit(cpu.rip - 1, op, 0, 0,
				(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
						| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), reg, 0);
		cpu.gpr[reg] = pop_u64();
		break;
	}

		/* MOV r64, imm64 : 0xB8 + reg (REX.W selects 64-bit immediate) */
	case 0xB8 ... 0xBF: {
		int reg = (op & 7) | (cpu.rex_b ? 8 : 0);
		uint64_t imm = cpu.rex_w ? fetch64() : (uint64_t) fetch32();
		trace_emit(cpu.rip - (cpu.rex_w ? 9 : 5), op, 0, 0,
				(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
						| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), reg,
				imm);
		if (cpu.rex_w)
			cpu.gpr[reg] = imm;
		else
			cpu.gpr[reg] = (uint64_t) (uint32_t) imm; /* zero-extend 32->64 */
		break;
	}

		/* MOV r/m64, r64 : 0x89 /r */
	case 0x89: {
		uint8_t modrm_peek = mem_read8(cpu.rip);
		decode_modrm();
		int reg = cpu.modrm_reg | (cpu.rex_r << 3);
		if (cpu.modrm_mod == 3) {
			int rm = cpu.modrm_rm | (cpu.rex_b << 3);
			trace_emit(cpu.rip - 2, op, 0,
					(cpu.modrm_mod << 6) | (cpu.modrm_reg << 3) | cpu.modrm_rm,
					(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
							| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), reg,
					rm);
			cpu.gpr[rm] = cpu.gpr[reg];
		} else {
			uint64_t ea = compute_ea();
			trace_emit(cpu.rip - 2, op, 0, modrm_peek,
					(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
							| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), reg,
					ea);
			mem_write64(ea, cpu.gpr[reg]);
		}
		break;
	}

		/* MOV r64, r/m64 : 0x8B /r */
	case 0x8B: {
		uint8_t modrm_peek = mem_read8(cpu.rip);
		decode_modrm();
		int reg = cpu.modrm_reg | (cpu.rex_r << 3);
		if (cpu.modrm_mod == 3) {
			int rm = cpu.modrm_rm | (cpu.rex_b << 3);
			trace_emit(cpu.rip - 2, op, 0,
					(cpu.modrm_mod << 6) | (cpu.modrm_reg << 3) | cpu.modrm_rm,
					(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
							| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), reg,
					rm);
			cpu.gpr[reg] = cpu.gpr[rm];
		} else {
			uint64_t ea = compute_ea();
			trace_emit(cpu.rip - 2, op, 0, modrm_peek,
					(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
							| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), reg,
					ea);
			cpu.gpr[reg] = mem_read64(ea);
		}
		break;
	}

		/* MOV r/m64, imm32 : C7 /0 (we handle as 64-bit store if REX.W) */
	case 0xC7: {
		uint8_t modrm_peek = mem_read8(cpu.rip);
		decode_modrm();
		int opnum = cpu.modrm_reg;
		if (opnum != 0) {
			trace_printf("Unhandled C7 /%d\n", opnum);
			exit(1);
		}
		uint32_t imm32 = fetch32();
		if (cpu.modrm_mod == 3) {
			int rm = cpu.modrm_rm | (cpu.rex_b << 3);
			trace_emit(cpu.rip - 6, op, 0,
					(cpu.modrm_mod << 6) | (cpu.modrm_reg << 3) | cpu.modrm_rm,
					(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
							| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), rm,
					imm32);
			if (cpu.rex_w)
				cpu.gpr[rm] = (uint64_t) (int32_t) imm32;
			else
				cpu.gpr[rm] = (uint64_t) imm32;
		} else {
			uint64_t ea = compute_ea();
			trace_emit(cpu.rip - 6, op, 0, modrm_peek,
					(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
							| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), ea,
					imm32);
			if (cpu.rex_w)
				mem_write64(ea, (uint64_t) (int32_t) imm32);
			else
				mem_write32(ea, imm32);
		}
		break;
	}

		/* ADD r/m64, r64 : 0x01 /r */
	case 0x01: {
		uint8_t modrm_peek = mem_read8(cpu.rip);
		decode_modrm();
		int reg = cpu.modrm_reg | (cpu.rex_r << 3);
		if (cpu.modrm_mod == 3) {
			int rm = cpu.modrm_rm | (cpu.rex_b << 3);
			uint64_t res = funAluExecWidth(opAdd, cpu.gpr[rm], cpu.gpr[reg],
					cpu.rex_w ? 64 : 32);
			cpu.gpr[rm] = res;
			trace_emit(cpu.rip - 2, op, 0,
					(cpu.modrm_mod << 6) | (cpu.modrm_reg << 3) | cpu.modrm_rm,
					(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
							| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), rm,
					reg);
		} else {
			uint64_t ea = compute_ea();
			uint64_t val = mem_read64(ea);
			uint64_t res = funAluExecWidth(opAdd, val, cpu.gpr[reg],
					cpu.rex_w ? 64 : 32);
			mem_write64(ea, res);
			trace_emit(cpu.rip - 2, op, 0, modrm_peek,
					(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
							| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), ea,
					reg);
		}
		break;
	}

		/* ADD r64, r/m64 : 0x03 /r */
	case 0x03: {
		uint8_t modrm_peek = mem_read8(cpu.rip);
		decode_modrm();
		int reg = cpu.modrm_reg | (cpu.rex_r << 3);
		if (cpu.modrm_mod == 3) {
			int rm = cpu.modrm_rm | (cpu.rex_b << 3);
			uint64_t res = funAluExecWidth(opAdd, cpu.gpr[reg], cpu.gpr[rm],
					cpu.rex_w ? 64 : 32);
			cpu.gpr[reg] = res;
			trace_emit(cpu.rip - 2, op, 0,
					(cpu.modrm_mod << 6) | (cpu.modrm_reg << 3) | cpu.modrm_rm,
					(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
							| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), reg,
					rm);
		} else {
			uint64_t ea = compute_ea();
			uint64_t val = mem_read64(ea);
			uint64_t res = funAluExecWidth(opAdd, cpu.gpr[reg], val,
					cpu.rex_w ? 64 : 32);
			cpu.gpr[reg] = res;
			trace_emit(cpu.rip - 2, op, 0, modrm_peek,
					(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
							| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), reg,
					ea);
		}
		break;
	}

		/* SUB r/m64, r64 : 0x29 /r */
	case 0x29: {
		uint8_t modrm_peek = mem_read8(cpu.rip);
		decode_modrm();
		int reg = cpu.modrm_reg | (cpu.rex_r << 3);
		if (cpu.modrm_mod == 3) {
			int rm = cpu.modrm_rm | (cpu.rex_b << 3);
			uint64_t res = funAluExecWidth(opSub, cpu.gpr[rm], cpu.gpr[reg],
					cpu.rex_w ? 64 : 32);
			cpu.gpr[rm] = res;
			trace_emit(cpu.rip - 2, op, 0,
					(cpu.modrm_mod << 6) | (cpu.modrm_reg << 3) | cpu.modrm_rm,
					(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
							| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), rm,
					reg);
		} else {
			uint64_t ea = compute_ea();
			uint64_t val = mem_read64(ea);
			uint64_t res = funAluExecWidth(opSub, val, cpu.gpr[reg],
					cpu.rex_w ? 64 : 32);
			mem_write64(ea, res);
			trace_emit(cpu.rip - 2, op, 0, modrm_peek,
					(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
							| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), ea,
					reg);
		}
		break;
	}

		/* SUB r64, r/m64 : 0x2B /r */
	case 0x2B: {
		uint8_t modrm_peek = mem_read8(cpu.rip);
		decode_modrm();
		int reg = cpu.modrm_reg | (cpu.rex_r << 3);
		if (cpu.modrm_mod == 3) {
			int rm = cpu.modrm_rm | (cpu.rex_b << 3);
			uint64_t res = funAluExecWidth(opSub, cpu.gpr[reg], cpu.gpr[rm],
					cpu.rex_w ? 64 : 32);
			cpu.gpr[reg] = res;
			trace_emit(cpu.rip - 2, op, 0,
					(cpu.modrm_mod << 6) | (cpu.modrm_reg << 3) | cpu.modrm_rm,
					(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
							| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), reg,
					rm);
		} else {
			uint64_t ea = compute_ea();
			uint64_t val = mem_read64(ea);
			uint64_t res = funAluExecWidth(opSub, cpu.gpr[reg], val,
					cpu.rex_w ? 64 : 32);
			cpu.gpr[reg] = res;
			trace_emit(cpu.rip - 2, op, 0, modrm_peek,
					(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
							| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), reg,
					ea);
		}
		break;
	}

		/* XOR r/m64, r64 : 0x31 /r */
	case 0x31: {
		uint8_t modrm_peek = mem_read8(cpu.rip);
		decode_modrm();
		int reg = cpu.modrm_reg | (cpu.rex_r << 3);
		if (cpu.modrm_mod == 3) {
			int rm = cpu.modrm_rm | (cpu.rex_b << 3);
			uint64_t res = funAluExecWidth(opXor, cpu.gpr[rm], cpu.gpr[reg],
					cpu.rex_w ? 64 : 32);
			cpu.gpr[rm] = res;
			trace_emit(cpu.rip - 2, op, 0,
					(cpu.modrm_mod << 6) | (cpu.modrm_reg << 3) | cpu.modrm_rm,
					(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
							| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), rm,
					reg);
		} else {
			uint64_t ea = compute_ea();
			uint64_t val = mem_read64(ea);
			uint64_t res = funAluExecWidth(opXor, val, cpu.gpr[reg],
					cpu.rex_w ? 64 : 32);
			mem_write64(ea, res);
			trace_emit(cpu.rip - 2, op, 0, modrm_peek,
					(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
							| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), ea,
					reg);
		}
		break;
	}

		/* XOR r64, r/m64 : 0x33 /r */
	case 0x33: {
		uint8_t modrm_peek = mem_read8(cpu.rip);
		decode_modrm();
		int reg = cpu.modrm_reg | (cpu.rex_r << 3);
		if (cpu.modrm_mod == 3) {
			int rm = cpu.modrm_rm | (cpu.rex_b << 3);
			uint64_t res = funAluExecWidth(opXor, cpu.gpr[reg], cpu.gpr[rm],
					cpu.rex_w ? 64 : 32);
			cpu.gpr[reg] = res;
			trace_emit(cpu.rip - 2, op, 0,
					(cpu.modrm_mod << 6) | (cpu.modrm_reg << 3) | cpu.modrm_rm,
					(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
							| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), reg,
					rm);
		} else {
			uint64_t ea = compute_ea();
			uint64_t val = mem_read64(ea);
			uint64_t res = funAluExecWidth(opXor, cpu.gpr[reg], val,
					cpu.rex_w ? 64 : 32);
			cpu.gpr[reg] = res;
			trace_emit(cpu.rip - 2, op, 0, modrm_peek,
					(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
							| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), reg,
					ea);
		}
		break;
	}

		/* CMP r/m64, r64 : 0x39 /r */
	case 0x39: {
		uint8_t modrm_peek = mem_read8(cpu.rip);
		decode_modrm();
		int reg = cpu.modrm_reg | (cpu.rex_r << 3);
		if (cpu.modrm_mod == 3) {
			int rm = cpu.modrm_rm | (cpu.rex_b << 3);
			funAluExecWidth(opCmp, cpu.gpr[rm], cpu.gpr[reg],
					cpu.rex_w ? 64 : 32);
			trace_emit(cpu.rip - 2, op, 0,
					(cpu.modrm_mod << 6) | (cpu.modrm_reg << 3) | cpu.modrm_rm,
					(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
							| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), rm,
					reg);
		} else {
			uint64_t ea = compute_ea();
			uint64_t val = mem_read64(ea);
			funAluExecWidth(opCmp, val, cpu.gpr[reg], cpu.rex_w ? 64 : 32);
			trace_emit(cpu.rip - 2, op, 0, modrm_peek,
					(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
							| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), ea,
					reg);
		}
		break;
	}

		/* CMP r64, r/m64 : 0x3B /r */
	case 0x3B: {
		uint8_t modrm_peek = mem_read8(cpu.rip);
		decode_modrm();
		int reg = cpu.modrm_reg | (cpu.rex_r << 3);
		if (cpu.modrm_mod == 3) {
			int rm = cpu.modrm_rm | (cpu.rex_b << 3);
			funAluExecWidth(opCmp, cpu.gpr[reg], cpu.gpr[rm],
					cpu.rex_w ? 64 : 32);
			trace_emit(cpu.rip - 2, op, 0,
					(cpu.modrm_mod << 6) | (cpu.modrm_reg << 3) | cpu.modrm_rm,
					(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
							| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), reg,
					rm);
		} else {
			uint64_t ea = compute_ea();
			uint64_t val = mem_read64(ea);
			funAluExecWidth(opCmp, cpu.gpr[reg], val, cpu.rex_w ? 64 : 32);
			trace_emit(cpu.rip - 2, op, 0, modrm_peek,
					(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
							| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), reg,
					ea);
		}
		break;
	}

		/* LEA r64, m : 0x8D /r */
	case 0x8D: {
		uint8_t modrm_peek = mem_read8(cpu.rip);
		decode_modrm();
		int dst = cpu.modrm_reg | (cpu.rex_r << 3);
		uint64_t ea = compute_ea();
		cpu.gpr[dst] = ea;
		trace_emit(cpu.rip - 3, op, 0, modrm_peek,
				(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
						| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), dst, ea);
		break;
	}

		/* Group FF: INC/DEC/call/jmp/push etc. We'll implement INC (/0) and DEC (/1) */
	case 0xFF: {
		uint8_t modrm_peek = mem_read8(cpu.rip);
		decode_modrm();
		int sub = cpu.modrm_reg; /* /0 INC, /1 DEC, others ignored here */
		if (sub == 0) { /* INC r/m */
			if (cpu.modrm_mod == 3) {
				int rm = cpu.modrm_rm | (cpu.rex_b << 3);
				uint64_t res = funAluExecWidth(opAdd, cpu.gpr[rm], 1,
						cpu.rex_w ? 64 : 32);
				cpu.gpr[rm] = res;
			} else {
				uint64_t ea = compute_ea();
				uint64_t val = mem_read64(ea);
				uint64_t res = funAluExecWidth(opAdd, val, 1,
						cpu.rex_w ? 64 : 32);
				mem_write64(ea, res);
			}
		} else if (sub == 1) { /* DEC r/m */
			if (cpu.modrm_mod == 3) {
				int rm = cpu.modrm_rm | (cpu.rex_b << 3);
				uint64_t res = funAluExecWidth(opSub, cpu.gpr[rm], 1,
						cpu.rex_w ? 64 : 32);
				cpu.gpr[rm] = res;
			} else {
				uint64_t ea = compute_ea();
				uint64_t val = mem_read64(ea);
				uint64_t res = funAluExecWidth(opSub, val, 1,
						cpu.rex_w ? 64 : 32);
				mem_write64(ea, res);
			}
		} else {
			trace_printf("Unhandled FF /%d at rip=0x%016" PRIx64 "\n", sub,
					cpu.rip - 2);
			exit(1);
		}
		trace_emit(cpu.rip - 2, op, 0, modrm_peek,
				(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
						| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), sub, 0);
		break;
	}

		/* TEST imm: F6/F7 group. We'll implement F6 /0 (test r/m8, imm8) and F7 /0 (test r/m, imm32) */
	case 0xF6:
	case 0xF7: {
		int is64 = (op == 0xF7);
		uint8_t modrm_peek = mem_read8(cpu.rip);
		decode_modrm();
		int sub = cpu.modrm_reg;
		if (sub == 0) { /* TEST r/m, imm */
			if (is64) {
				uint32_t imm32 = fetch32();
				if (cpu.modrm_mod == 3) {
					int rm = cpu.modrm_rm | (cpu.rex_b << 3);
					funAluExecWidth(opAnd, cpu.gpr[rm], (uint64_t) imm32,
							cpu.rex_w ? 64 : 32);
				} else {
					uint64_t ea = compute_ea();
					uint64_t val = mem_read64(ea);
					funAluExecWidth(opAnd, val, (uint64_t) imm32,
							cpu.rex_w ? 64 : 32);
				}
			} else {
				uint8_t imm8 = fetch8();
				if (cpu.modrm_mod == 3) {
					int rm = cpu.modrm_rm | (cpu.rex_b << 3);
					funAluExecWidth(opAnd, cpu.gpr[rm], (uint64_t) imm8, 8);
				} else {
					uint64_t ea = compute_ea();
					uint8_t val = mem_read8(ea);
					funAluExecWidth(opAnd, val, (uint64_t) imm8, 8);
				}
			}
		} else {
			trace_printf("Unhandled F6/F7 /%d at rip=0x%016" PRIx64 "\n", sub,
					cpu.rip - 2);
			exit(1);
		}
		trace_emit(cpu.rip - (is64 ? 6 : 3), op, 0, modrm_peek,
				(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
						| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), sub, 0);
		break;
	}

		/* Shift group: D0/D1 (by 1), D2/D3 (by CL), C1 (imm8) - implement SHL/SHR/SAR (reg code 4/5/7) */
	case 0xD0:
	case 0xD1:
	case 0xD2:
	case 0xD3:
	case 0xC1: {
		int by_cl = (op == 0xD2 || op == 0xD3);
		int by_imm = (op == 0xC1);
		int by_one = (op == 0xD0 || op == 0xD1);
		uint8_t modrm_peek = mem_read8(cpu.rip);
		decode_modrm();
		int code = cpu.modrm_reg; /* operation selector */
		int width = (cpu.rex_w ? 64 : 32);
		uint64_t count = 0;
		if (by_one)
			count = 1;
		else if (by_cl)
			count = cpu.gpr[1] & 0xFF; /* CL is low 8 bits of RCX */
		else if (by_imm)
			count = fetch8();
		/* only implement SHL (4), SHR (5), SAR (7) */
		if (cpu.modrm_mod == 3) {
			int rm = cpu.modrm_rm | (cpu.rex_b << 3);
			uint64_t val = cpu.gpr[rm];
			if (code == 4) { /* SHL */
				uint64_t res = val << (count & 63);
				cpu.gpr[rm] = res;
				set_flag_zf_sf_pfN(res, width);
			} else if (code == 5) { /* SHR (logical) */
				uint64_t res = (val >> (count & 63));
				cpu.gpr[rm] = res;
				set_flag_zf_sf_pfN(res, width);
			} else if (code == 7) { /* SAR (arith) */
				if (width == 64) {
					int64_t s = (int64_t) val;
					int64_t r = s >> (count & 63);
					cpu.gpr[rm] = (uint64_t) r;
					set_flag_zf_sf_pfN((uint64_t) r, width);
				} else {
					int32_t s = (int32_t) val;
					int32_t r = s >> (count & 31);
					cpu.gpr[rm] = (uint64_t) (uint32_t) r;
					set_flag_zf_sf_pfN((uint64_t) r, width);
				}
			} else {
				trace_printf("Unhandled shift code %d\n", code);
				exit(1);
			}
		} else {
			uint64_t ea = compute_ea();
			uint64_t val = mem_read64(ea);
			if (code == 4)
				val = val << (count & 63);
			else if (code == 5)
				val = val >> (count & 63);
			else if (code == 7) {
				if (width == 64)
					val = (uint64_t) ((int64_t) val >> (count & 63));
				else
					val = (uint64_t) (uint32_t) ((int32_t) val >> (count & 31));
			} else {
				trace_printf("Unhandled shift code %d\n", code);
				exit(1);
			}
			mem_write64(ea, val);
		}
		trace_emit(cpu.rip - (by_imm ? 3 : 2), op, 0, modrm_peek,
				(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
						| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), code,
				count);
		break;
	}

		/* IMUL r64, r/m64, imm8 : 0x6B /r (sign-extended imm8) */
	case 0x6B: {
		uint8_t modrm_peek = mem_read8(cpu.rip);
		decode_modrm();
		int dst = cpu.modrm_reg | (cpu.rex_r << 3);
		uint8_t imm8 = fetch8();
		int64_t imm = (int8_t) imm8;
		uint64_t rhs;
		if (cpu.modrm_mod == 3) {
			rhs = cpu.gpr[cpu.modrm_rm | (cpu.rex_b << 3)];
		} else {
			uint64_t ea = compute_ea();
			rhs = cpu.rex_w ?
					mem_read64(ea) :
					(uint64_t) (int64_t) (int32_t) mem_read32(ea);
		}
		if (cpu.rex_w) {
			__int128 prod = (__int128) (int64_t) cpu.gpr[dst] * (__int128) imm;
			cpu.gpr[dst] = (uint64_t) prod;
		} else {
			__int128 prod = (__int128) (int32_t) cpu.gpr[dst]
					* (__int128) (int32_t) imm;
			cpu.gpr[dst] = (uint64_t) (int32_t) prod;
		}
		trace_emit(cpu.rip - 3, op, 0, modrm_peek,
				(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
						| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), dst,
				imm);
		break;
	}

		/* IMUL r64, r/m64, imm32 : 0x69 /r */
	case 0x69: {
		uint8_t modrm_peek = mem_read8(cpu.rip);
		decode_modrm();
		int dst = cpu.modrm_reg | (cpu.rex_r << 3);
		int32_t imm32 = fetch32();
		uint64_t rhs;
		if (cpu.modrm_mod == 3) {
			rhs = cpu.gpr[cpu.modrm_rm | (cpu.rex_b << 3)];
		} else {
			uint64_t ea = compute_ea();
			rhs = cpu.rex_w ?
					mem_read64(ea) :
					(uint64_t) (int64_t) (int32_t) mem_read32(ea);
		}

		if (cpu.rex_w) {
			__int128 prod = (__int128) (int64_t) cpu.gpr[dst]
					* (__int128) (int64_t) imm32;
			cpu.gpr[dst] = (uint64_t) prod;
		} else {
			__int128 prod = (__int128) (int32_t) cpu.gpr[dst]
					* (__int128) (int32_t) imm32;
			cpu.gpr[dst] = (uint64_t) (int32_t) prod;
		}
		trace_emit(cpu.rip - 6, op, 0, modrm_peek,
				(cpu.pref_66 ? 1 : 0) | (cpu.pref_f2 ? 2 : 0)
						| (cpu.pref_f3 ? 4 : 0) | (cpu.rex_w ? 8 : 0), dst,
				imm32);
		break;
	}

	default:
		trace_printf("Unimplemented opcode: 0x%02X at rip=0x%016" PRIx64 "\n",
				op, cpu.rip - 1);
		exit(1);
	}
}

/* -------------------------
 framebuffer / sdl (continued)
 ------------------------- */

typedef struct {
	SDL_Window *window;
	SDL_Renderer *renderer;
	SDL_Texture *texture;
	int width, height;
	int pitch;
} FBDisplay;
static FBDisplay fbdisp;

int fb_init_display(int width, int height) {
#if USE_FB_STREAMING
	if (SDL_Init(SDL_INIT_VIDEO | SDL_INIT_TIMER) != 0) {
		trace_printf("SDL_Init failed: %s\n", SDL_GetError());
		return -1;
	}
	fbdisp.width = width;
	fbdisp.height = height;
	fbdisp.window = SDL_CreateWindow("x64emu", SDL_WINDOWPOS_CENTERED,
			SDL_WINDOWPOS_CENTERED, width, height, SDL_WINDOW_SHOWN);
	if (!fbdisp.window) {
		trace_printf("SDL_CreateWindow failed: %s\n", SDL_GetError());
		SDL_Quit();
		return -1;
	}
	fbdisp.renderer = SDL_CreateRenderer(fbdisp.window, -1,
			SDL_RENDERER_ACCELERATED | SDL_RENDERER_PRESENTVSYNC);
	if (!fbdisp.renderer) {
		trace_printf("SDL_CreateRenderer failed: %s\n", SDL_GetError());
		SDL_DestroyWindow(fbdisp.window);
		SDL_Quit();
		return -1;
	}
	fbdisp.texture = SDL_CreateTexture(fbdisp.renderer,
			SDL_PIXELFORMAT_ARGB8888, SDL_TEXTUREACCESS_STREAMING, width,
			height);
	if (!fbdisp.texture) {
		trace_printf("SDL_CreateTexture failed: %s\n", SDL_GetError());
		SDL_DestroyRenderer(fbdisp.renderer);
		SDL_DestroyWindow(fbdisp.window);
		SDL_Quit();
		return -1;
	}
	fbdisp.pitch = width * 4;
	return 0;
#else
        (void)width; (void)height;
        return 0;
    #endif
}

void fb_shutdown_display(void) {
#if USE_FB_STREAMING
	if (fbdisp.texture)
		SDL_DestroyTexture(fbdisp.texture);
	if (fbdisp.renderer)
		SDL_DestroyRenderer(fbdisp.renderer);
	if (fbdisp.window)
		SDL_DestroyWindow(fbdisp.window);
	SDL_Quit();
#endif
}

/* Simple helper to blit fb_mem (ARGB32) to the SDL texture */
void fb_update_display(void) {
#if USE_FB_STREAMING
	if (!fbdisp.texture || !fb_mem)
		return;
	void *pixels = NULL;
	int pitch = 0;
	if (SDL_LockTexture(fbdisp.texture, NULL, &pixels, &pitch) == 0) {
		int copy_pitch = (pitch < fbdisp.pitch) ? pitch : fbdisp.pitch;
		for (int y = 0; y < fbdisp.height; ++y) {
			memcpy((uint8_t*) pixels + y * pitch, fb_mem + y * fbdisp.pitch,
					copy_pitch);
		}
		SDL_UnlockTexture(fbdisp.texture);
		SDL_RenderClear(fbdisp.renderer);
		SDL_RenderCopy(fbdisp.renderer, fbdisp.texture, NULL, NULL);
		SDL_RenderPresent(fbdisp.renderer);
	}
#endif
}

/* -------------------------
 minimal program loader / main
 ------------------------- */

void cpu_reset(void) {
	memset(&cpu, 0, sizeof(cpu));
	cpu.gpr[4] = RAM_SIZE - 8; /* set RSP near top of RAM */
	cpu.rip = 0;
	cpu_decode_reset();
	bp_clear_all();
}

/* Very small helper to load a binary blob into RAM at address 0 */
int load_binary_to_ram(const char *path) {
	FILE *f = fopen(path, "rb");
	if (!f)
		return -1;
	fseek(f, 0, SEEK_END);
	long sz = ftell(f);
	fseek(f, 0, SEEK_SET);
	if (sz <= 0) {
		fclose(f);
		return -1;
	}
	if ((uint64_t) sz > RAM_SIZE) {
		fclose(f);
		return -1;
	}
	if (!ram_mem)
		return -1;
	if (fread(ram_mem, 1, (size_t) sz, f) != (size_t) sz) {
		fclose(f);
		return -1;
	}
	fclose(f);
	return 0;
}

int main(int argc, char **argv) {
	const int fb_w = 640, fb_h = 480;
	ram_mem = (uint8_t*) malloc(RAM_SIZE);
	if (!ram_mem) {
		fprintf(stderr, "Failed to allocate RAM\n");
		return 1;
	}
	memset(ram_mem, 0, RAM_SIZE);

	/* optional framebuffer memory: simple ARGB32 buffer at a fixed address */
	const uint64_t fb_addr = 0x1000000; /* 16 MiB offset */
	const size_t fb_size = fb_w * fb_h * 4;
	if (fb_addr + fb_size < RAM_SIZE) {
		fb_mem = &ram_mem[fb_addr];
		memset(fb_mem, 0, fb_size);
	} else {
		fb_mem = NULL;
	}

	if (fb_init_display(fb_w, fb_h) != 0) {
		trace_printf("Failed to init display, continuing headless\n");
	}

	cpu_reset();

	/* optional: load a binary if provided */
	if (argc >= 2) {
		if (load_binary_to_ram(argv[1]) != 0) {
			trace_printf("Failed to load binary: %s\n", argv[1]);
		} else {
			trace_printf("Loaded binary: %s\n", argv[1]);
		}
	}

	/* main emulation loop (very simple) */
	int running = 1;
	uint64_t cycles = 0;
	while (running) {
		execute_one();

		/* update display occasionally */
		if (fb_mem && (cycles & 0x3FF) == 0)
			fb_update_display();

		/* handle SDL events so window stays responsive */
#if USE_FB_STREAMING
		SDL_Event ev;
		while (SDL_PollEvent(&ev)) {
			if (ev.type == SDL_QUIT) {
				running = 0;
				break;
			}
		}
#endif
		cycles++;
	}

	fb_shutdown_display();
	free(ram_mem);
	return 0;
}
