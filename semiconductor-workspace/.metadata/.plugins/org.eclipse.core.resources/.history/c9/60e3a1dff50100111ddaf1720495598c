/*
 * main.c
 *
 * GLUT/OpenGL port of the Xlib CAD demo.
 *
 * Compile (Linux):
 *   gcc main.c -o cad -lGL -lGLU -lglut -lm
 *
 * Run:
 *   ./cad
 *
 * Controls:
 *   + or =    : zoom in (centered at window center)
 *   -         : zoom out
 *   Mouse wheel up/down (buttons 3/4) : zoom in/out at mouse
 *   Left click: add point at mouse world position
 *   Esc       : quit
 *
 * Notes:
 *  - World units are millimeters (mm).
 *  - px_per_mm defaults to 96 DPI -> 96/25.4 px/mm (~3.7795).
 *  - Cursor is hidden and a crosshair is drawn at the mouse position.
 *  - Rulers (top/left) and status bar (bottom 20px) are implemented.
 */

#include <GL/gl.h>
#include <GL/glu.h>
#include <GL/glut.h>

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <math.h>

/* Configuration */
#define RULER_THICKNESS 28   /* px: top ruler height and left ruler width */
#define STATUS_HEIGHT 20     /* px: bottom status area */
#define MAX_POINTS 8192

/* Global state */
static int win_w = 1200, win_h = 800;
static double px_per_mm = 96.0 / 25.4; /* default px per mm (approx 96 DPI) */

static double zoom_factor = 1.0; /* 1.0 = 100% */
static double pan_x = 0.0; /* world coords offset (mm) */
static double pan_y = 0.0;

static int mouse_x = 0, mouse_y = 0; /* last mouse position (window coords) */

static double points_x[MAX_POINTS];
static double points_y[MAX_POINTS];
static int points_count = 0;

/* Utility: choose adaptive mm step for grid/ruler (1,2,5,10,20,50,100,...) */
static double choose_mm_step(double pxmm) {
    const double target_px = 12.0;
    if (pxmm <= 0.0) return 1.0;
    double seq[] = {1.0,2.0,5.0,10.0,20.0,50.0,100.0,200.0,500.0,1000.0};
    for (size_t i=0;i<sizeof(seq)/sizeof(seq[0]);++i) {
        if (seq[i] * pxmm >= target_px) return seq[i];
    }
    double mm = 1000.0;
    while (mm * pxmm < target_px) mm *= 2.0;
    return mm;
}

/* Convert world (mm) -> screen (pixels). Screen origin (0,0) is top-left.
   Content area excludes left/top rulers and bottom status area. */
static void world_to_screen(double wx, double wy, int *sx, int *sy) {
    int content_w = win_w - RULER_THICKNESS;
    int content_h = win_h - RULER_THICKNESS - STATUS_HEIGHT;
    double origin_x = RULER_THICKNESS + content_w / 2.0;
    double origin_y = RULER_THICKNESS + content_h / 2.0;
    double zx = (wx - pan_x) * zoom_factor;
    double zy = (wy - pan_y) * zoom_factor;
    if (sx) *sx = (int)round(origin_x + zx);
    if (sy) *sy = (int)round(origin_y + zy);
}

/* Convert screen -> world (mm) */
static void screen_to_world(int sx, int sy, double *wx, double *wy) {
    int content_w = win_w - RULER_THICKNESS;
    int content_h = win_h - RULER_THICKNESS - STATUS_HEIGHT;
    double origin_x = RULER_THICKNESS + content_w / 2.0;
    double origin_y = RULER_THICKNESS + content_h / 2.0;
    if (wx) *wx = (double)(sx - origin_x) / zoom_factor + pan_x;
    if (wy) *wy = (double)(sy - origin_y) / zoom_factor + pan_y;
}

/* Adjust zoom keeping screen point stable in world coords */
static void adjust_zoom_at(double new_zoom, int screen_x, int screen_y) {
    if (new_zoom <= 0.0) return;
    double wx_before, wy_before;
    screen_to_world(screen_x, screen_y, &wx_before, &wy_before);
    zoom_factor = new_zoom;
    pan_x = wx_before - (double)screen_x / zoom_factor;
    pan_y = wy_before - (double)screen_y / zoom_factor;
}

/* Zoom helpers */
static void zoom_in_at(int sx, int sy) {
    double factor = 1.15;
    double new_zoom = zoom_factor * factor;
    if (new_zoom > 100.0) new_zoom = 100.0;
    adjust_zoom_at(new_zoom, sx, sy);
}
static void zoom_out_at(int sx, int sy) {
    double factor = 1.15;
    double new_zoom = zoom_factor / factor;
    if (new_zoom < 0.01) new_zoom = 0.01;
    adjust_zoom_at(new_zoom, sx, sy);
}

/* Draw text using GLUT bitmap font at pixel coordinates (x,y) with baseline y */
static void draw_text_bitmap(int x, int y, const char *s) {
    glRasterPos2i(x, y);
    for (const char *p = s; *p; ++p) glutBitmapCharacter(GLUT_BITMAP_HELVETICA_12, *p);
}

/* Draw crosshair at mouse position */
static void draw_crosshair(int mx, int my) {
    glColor3f(0.0f, 0.0f, 0.0f);
    glLineWidth(1.0f);
    glBegin(GL_LINES);
      glVertex2i(mx - 10, my);
      glVertex2i(mx + 10, my);
      glVertex2i(mx, my - 10);
      glVertex2i(mx, my + 10);
    glEnd();
}

/* Draw rulers (top and left). They must align exactly with grid ticks. */
static void draw_rulers_and_ticks() {
    /* We'll draw rulers in pixel coordinates (orthographic) */
    /* Compute px per mm on screen (including zoom) */
    double pxmm = px_per_mm * zoom_factor;
    if (pxmm <= 0.0) pxmm = (96.0/25.4) * zoom_factor;

    int content_w = win_w - RULER_THICKNESS;
    int content_h = win_h - RULER_THICKNESS - STATUS_HEIGHT;
    int origin_sx = RULER_THICKNESS + content_w / 2;
    int origin_sy = RULER_THICKNESS + content_h / 2;

    /* Draw ruler backgrounds */
    glColor3ub(240,240,240);
    glBegin(GL_QUADS);
      glVertex2i(0,0); glVertex2i(win_w,0); glVertex2i(win_w,RULER_THICKNESS); glVertex2i(0,RULER_THICKNESS); /* top */
      glVertex2i(0,0); glVertex2i(RULER_THICKNESS,0); glVertex2i(RULER_THICKNESS,win_h); glVertex2i(0,win_h); /* left */
    glEnd();

    /* Separator lines */
    glColor3ub(160,160,160);
    glBegin(GL_LINES);
      glVertex2i(0, RULER_THICKNESS-1); glVertex2i(win_w, RULER_THICKNESS-1);
      glVertex2i(RULER_THICKNESS-1, 0); glVertex2i(RULER_THICKNESS-1, win_h);
    glEnd();

    /* Choose step in mm */
    double step_mm = choose_mm_step(pxmm);
    double major_mm = (step_mm > 10.0) ? step_mm : 10.0;

    /* Visible extents in mm from origin (content area) */
    int max_left_px = origin_sx - RULER_THICKNESS;
    int max_right_px = (RULER_THICKNESS + content_w) - origin_sx;
    int max_up_px = origin_sy - RULER_THICKNESS;
    int max_down_px = (RULER_THICKNESS + content_h) - origin_sy;

    int max_left_mm = (int)ceil((double)max_left_px / pxmm);
    int max_right_mm = (int)ceil((double)max_right_px / pxmm);
    int max_up_mm = (int)ceil((double)max_up_px / pxmm);
    int max_down_mm = (int)ceil((double)max_down_px / pxmm);

    /* Draw ticks on top ruler (horizontal) */
    glColor3ub(0,0,0);
    int kmin = (int)floor(-max_left_mm / step_mm) - 1;
    int kmax = (int)ceil(max_right_mm / step_mm) + 1;
    for (int k = kmin; k <= kmax; ++k) {
        double mmpos = k * step_mm;
        double sx = origin_sx + mmpos * pxmm;
        if (sx < RULER_THICKNESS - 2 || sx > RULER_THICKNESS + content_w + 2) continue;
        if (fmod(fabs(mmpos), major_mm) < 1e-6) {
            /* major tick */
            glBegin(GL_LINES);
              glVertex2i((int)round(sx), RULER_THICKNESS-1);
              glVertex2i((int)round(sx), RULER_THICKNESS-1 - 12);
            glEnd();
            /* label in cm */
            int cm = (int)round(fabs(mmpos) / 10.0);
            char buf[32];
            if (fabs(mmpos) < 0.5) snprintf(buf, sizeof(buf), "0");
            else snprintf(buf, sizeof(buf), "%dcm", cm);
            /* draw text centered approx */
            int tx = (int)round(sx) - 12;
            int ty = RULER_THICKNESS - 14;
            glColor3ub(0,0,0);
            glRasterPos2i(tx, ty);
            for (char *p = buf; *p; ++p) glutBitmapCharacter(GLUT_BITMAP_HELVETICA_12, *p);
        } else {
            /* minor tick */
            glBegin(GL_LINES);
              glVertex2i((int)round(sx), RULER_THICKNESS-1);
              glVertex2i((int)round(sx), RULER_THICKNESS-1 - 6);
            glEnd();
        }
    }

    /* Draw ticks on left ruler (vertical) */
    kmin = (int)floor(-max_up_mm / step_mm) - 1;
    kmax = (int)ceil(max_down_mm / step_mm) + 1;
    for (int k = kmin; k <= kmax; ++k) {
        double mmpos = k * step_mm;
        double sy = origin_sy + mmpos * pxmm;
        if (sy < RULER_THICKNESS - 2 || sy > RULER_THICKNESS + content_h + 2) continue;
        if (fmod(fabs(mmpos), major_mm) < 1e-6) {
            glBegin(GL_LINES);
              glVertex2i(RULER_THICKNESS-1, (int)round(sy));
              glVertex2i(RULER_THICKNESS-1 - 12, (int)round(sy));
            glEnd();
            int cm = (int)round(fabs(mmpos) / 10.0);
            char buf[32];
            if (fabs(mmpos) < 0.5) snprintf(buf, sizeof(buf), "0");
            else snprintf(buf, sizeof(buf), "%dcm", cm);
            int tx = 4;
            int ty = (int)round(sy) + 4;
            glColor3ub(0,0,0);
            glRasterPos2i(tx, ty);
            for (char *p = buf; *p; ++p) glutBitmapCharacter(GLUT_BITMAP_HELVETICA_12, *p);
        } else {
            glBegin(GL_LINES);
              glVertex2i(RULER_THICKNESS-1, (int)round(sy));
              glVertex2i(RULER_THICKNESS-1 - 6, (int)round(sy));
            glEnd();
        }
    }

    /* Corner label */
    glColor3ub(0,0,0);
    glRasterPos2i(6, RULER_THICKNESS - 6);
    const char *lbl = "mm / cm";
    for (const char *p = lbl; *p; ++p) glutBitmapCharacter(GLUT_BITMAP_HELVETICA_12, *p);
}

/* Display callback */
static void display_cb(void) {
    glClearColor(1.0f,1.0f,1.0f,1.0f);
    glClear(GL_COLOR_BUFFER_BIT);

    /* Set up orthographic projection with pixel coordinates (0..win_w, 0..win_h)
       and origin at top-left (we flip Y) */
    glMatrixMode(GL_PROJECTION);
    glLoadIdentity();
    gluOrtho2D(0.0, win_w, win_h, 0.0); /* top-left origin */
    glMatrixMode(GL_MODELVIEW);
    glLoadIdentity();

    /* Draw scene: grid (background), points, rulers (foreground), status bar, crosshair */
    /* Grid and points are drawn in pixel coordinates using world->screen mapping */

    /* Draw grid and points (background) */
    /* We'll draw grid lines first (in draw_scene style) */
    double pxmm = px_per_mm * zoom_factor;
    if (pxmm <= 0.0) pxmm = (96.0/25.4) * zoom_factor;
    double step_mm = choose_mm_step(pxmm);
    double major_mm = (step_mm > 10.0) ? step_mm : 10.0;

    /* visible world bounds (content area) */
    double wx0, wy0, wx1, wy1;
    screen_to_world(0, 0, &wx0, &wy0);
    screen_to_world(win_w, win_h, &wx1, &wy1);

    double start_x_mm = floor(wx0 / step_mm) * step_mm;
    double end_x_mm   = ceil(wx1 / step_mm) * step_mm;
    double start_y_mm = floor(wy0 / step_mm) * step_mm;
    double end_y_mm   = ceil(wy1 / step_mm) * step_mm;

    /* Draw vertical grid lines */
    glColor3ub(224,224,224);
    glLineWidth(1.0f);
    for (double xm = start_x_mm; xm <= end_x_mm + 0.5*step_mm; xm += step_mm) {
        int sx0, sy0, sx1, sy1;
        world_to_screen(xm, wy0, &sx0, &sy0);
        world_to_screen(xm, wy1, &sx1, &sy1);
        if (fmod(fabs(xm), major_mm) < 1e-6) {
            glColor3ub(192,192,192);
            glBegin(GL_LINES); glVertex2i(sx0, sy0); glVertex2i(sx1, sy1); glEnd();
            glColor3ub(224,224,224);
        } else {
            glBegin(GL_LINES); glVertex2i(sx0, sy0); glVertex2i(sx1, sy1); glEnd();
        }
    }
    /* Draw horizontal grid lines */
    for (double ym = start_y_mm; ym <= end_y_mm + 0.5*step_mm; ym += step_mm) {
        int sx0, sy0, sx1, sy1;
        world_to_screen(wx0, ym, &sx0, &sy0);
        world_to_screen(wx1, ym, &sx1, &sy1);
        if (fmod(fabs(ym), major_mm) < 1e-6) {
            glColor3ub(192,192,192);
            glBegin(GL_LINES); glVertex2i(sx0, sy0); glVertex2i(sx1, sy1); glEnd();
            glColor3ub(224,224,224);
        } else {
            glBegin(GL_LINES); glVertex2i(sx0, sy0); glVertex2i(sx1, sy1); glEnd();
        }
    }

    /* Draw points (above grid but below rulers) */
    glColor3ub(0,0,0);
    for (int i=0;i<points_count;++i) {
        int sx, sy;
        world_to_screen(points_x[i], points_y[i], &sx, &sy);
        int r = (int)fmax(2.0, 3.0 * zoom_factor);
        /* filled circle approximation */
        glBegin(GL_TRIANGLE_FAN);
        glVertex2i(sx, sy);
        for (int a=0;a<=20;++a) {
            double ang = a * (2.0*M_PI/20.0);
            glVertex2f(sx + cos(ang)*r, sy + sin(ang)*r);
        }
        glEnd();
    }

    /* Draw rulers on top */
    draw_rulers_and_ticks();

    /* Draw bottom status bar */
    int status_y = win_h - STATUS_HEIGHT;
    glColor3ub(248,248,248);
    glBegin(GL_QUADS);
      glVertex2i(0, status_y); glVertex2i(win_w, status_y); glVertex2i(win_w, win_h); glVertex2i(0, win_h);
    glEnd();
    glColor3ub(192,192,192);
    glBegin(GL_LINES);
      glVertex2i(0, status_y); glVertex2i(win_w, status_y);
    glEnd();
    /* Status text */
    char status[128];
    snprintf(status, sizeof(status), "Zoom: %.1f%%   Points: %d", zoom_factor*100.0, points_count);
    glColor3ub(0,0,0);
    glRasterPos2i(8, status_y + STATUS_HEIGHT - 6);
    for (const char *p = status; *p; ++p) glutBitmapCharacter(GLUT_BITMAP_HELVETICA_12, *p);

    /* Draw crosshair at mouse position (cursor hidden) */
    draw_crosshair(mouse_x, mouse_y);

    glutSwapBuffers();
}

/* Reshape callback */
static void reshape_cb(int w, int h) {
    win_w = w; win_h = h;
    glViewport(0,0,w,h);
    glutPostRedisplay();
}

/* Mouse callback (button press) */
static void mouse_cb(int button, int state, int x, int y) {
    mouse_x = x; mouse_y = y;
    if (state != GLUT_DOWN) return;
    if (button == GLUT_LEFT_BUTTON) {
        /* add point at world coordinate */
        double wx, wy;
        screen_to_world(x, y, &wx, &wy);
        if (points_count < MAX_POINTS) {
            points_x[points_count] = wx;
            points_y[points_count] = wy;
            points_count++;
        }
        glutPostRedisplay();
    } else if (button == 3) {
        /* wheel up */
        zoom_in_at(x, y);
        glutPostRedisplay();
    } else if (button == 4) {
        /* wheel down */
        zoom_out_at(x, y);
        glutPostRedisplay();
    }
}

/* Motion callback (mouse move with button) */
static void motion_cb(int x, int y) {
    mouse_x = x; mouse_y = y;
    glutPostRedisplay();
}

/* Passive motion (mouse move without button) */
static void passive_motion_cb(int x, int y) {
    mouse_x = x; mouse_y = y;
    glutPostRedisplay();
}

/* Keyboard callback */
static void keyboard_cb(unsigned char key, int x, int y) {
    (void)x; (void)y;
    if (key == 27) { /* ESC */
        exit(0);
    } else if (key == '+' || key == '=' ) {
        /* zoom centered at content center */
        int cx = RULER_THICKNESS + (win_w - RULER_THICKNESS)/2;
        int cy = RULER_THICKNESS + (win_h - RULER_THICKNESS - STATUS_HEIGHT)/2;
        zoom_in_at(cx, cy);
        glutPostRedisplay();
    } else if (key == '-') {
        int cx = RULER_THICKNESS + (win_w - RULER_THICKNESS)/2;
        int cy = RULER_THICKNESS + (win_h - RULER_THICKNESS - STATUS_HEIGHT)/2;
        zoom_out_at(cx, cy);
        glutPostRedisplay();
    }
}

/* Special keys (numpad etc.) */
static void special_cb(int key, int x, int y) {
    (void)x; (void)y;
    if (key == GLUT_KEY_F1) { /* reserved */
    }
}

/* Hide system cursor and use our crosshair */
static void hide_system_cursor() {
    /* GLUT provides glutSetCursor; GLUT_CURSOR_NONE hides it */
    glutSetCursor(GLUT_CURSOR_NONE);
}

/* Initialize OpenGL state */
static void init_gl() {
    glDisable(GL_DEPTH_TEST);
    glEnable(GL_BLEND);
    glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);
}

/* Entry point */
int main(int argc, char **argv) {
    glutInit(&argc, argv);
    glutInitDisplayMode(GLUT_DOUBLE | GLUT_RGBA);
    glutInitWindowSize(win_w, win_h);
    glutCreateWindow("GLUT CAD - Rulers, Grid, Zoom, Crosshair");

    init_gl();

    /* Hide system cursor and draw our own crosshair */
    hide_system_cursor();

    /* Register callbacks */
    glutDisplayFunc(display_cb);
    glutReshapeFunc(reshape_cb);
    glutMouseFunc(mouse_cb);
    glutMotionFunc(motion_cb);
    glutPassiveMotionFunc(passive_motion_cb);
    glutKeyboardFunc(keyboard_cb);
    glutSpecialFunc(special_cb);

    /* Initial clear and loop */
    glutMainLoop();
    return 0;
}
