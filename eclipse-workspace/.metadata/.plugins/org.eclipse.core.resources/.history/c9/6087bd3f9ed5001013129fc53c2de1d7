enum {
    max_buf_size = 1024,
    null_section = 0,
    text_section = 1,
    shstrtab_section = 2,
    symtab_section = 3,
    strtab_section = 4
};

typedef struct {
    unsigned char ident[16];
    uint16_t type;
    uint16_t machine;
    uint32_t version;
    uint64_t entry;
    uint64_t phoff;
    uint64_t shoff;
    uint32_t flags;
    uint16_t hsize;
    uint16_t phsize;
    uint16_t phnum;
    uint16_t shsize;
    uint16_t shnum;
    uint16_t strndx;
} elfhdr_t;

typedef struct {
    uint32_t name;
    uint32_t type;
    uint64_t flags;
    uint64_t addr;
    uint64_t offset;
    uint64_t size;
    uint32_t link;
    uint32_t info;
    uint64_t align;
    uint64_t esize;
} shdr_t;

typedef struct {
    uint32_t name;
    uint8_t info;
    uint8_t other;
    uint16_t index;
    uint64_t value;
    uint64_t size;
} sym_t;

typedef struct {
    shdr_t hdr;
    size_t len;
    unsigned char *data;
} section_t;

typedef struct {
    elfhdr_t hdr;
    section_t sec[5];
} elf64_t;

typedef struct {
    size_t len;
    char *buf;
} strtab_t;

// ====================================================================
// --- LEXER STRUCTURES (Lexing Logic: next_token) ---
// ====================================================================

typedef enum {
    tkn_eof,
    tkn_num,
    tkn_ident,
    tkn_instr,
    tkn_reg,
    tkn_xmm_reg,
    tkn_sym,
} tokentype_t;

typedef enum {
    sym_colon,
    sym_comma,
    sym_comment,
    sym_unknown,
    sym_lparen, // ( for AT&T memory
    sym_rparen, // ) for AT&T memory
} symtype_t;

typedef struct {
    tokentype_t type;
    void *data;
} token_t;

typedef struct {
    char *buf;
    size_t i;
} lexer_t;

// ====================================================================
// --- PARSER STRUCTURES (Parsing Logic: next_instr) ---
// ====================================================================

typedef enum {
    instr_nop,
    instr_mov, instr_add, instr_sub, instr_and, instr_or,
    instr_push, instr_pop, instr_inc, instr_dec,
    instr_ret,
    instr_syscall,
    instr_call,
    instr_jmp,
    instr_label,
    instr_global_label,
    // sse instructions
    instr_movaps, instr_movups, instr_addps, instr_subps, instr_mulps,
    parser_eof,
} instrtype_t;

typedef struct {
    instrtype_t type;
    void *data;
} instr_t;

typedef enum {
    op_reg,
    op_xmm_reg,
    op_label,
    op_int,
    op_mem,
    op_unknown,
    op_none
} optype_t;

typedef struct {
    optype_t type;
    void *data;
} op_t;

// for binary operations, op1 will be the internal destination, op2 will be the internal source
typedef struct {
    op_t *op1;
    op_t *op2;
} binary_op_t;

typedef struct _symentry {
    char *name;
    size_t offset;
    struct _symentry *next;
} symentry_t;

typedef struct {
    symentry_t *syms;
    size_t offset;
} asm_t;

// operand type matching for the instruction table
typedef enum {
    insn_op_match_r64,          // general purpose register (rax, rbx, ...)
    insn_op_match_xmm,          // xmm register
    insn_op_match_imm32,        // 32-bit immediate
    insn_op_match_label,        // label for jmp/call
    insn_op_match_r_m,          // register or memory operand (r/m field in modrm)
    insn_op_match_r_m_gpr,      // gpr register or memory (for gpr instructions)
    insn_op_match_none,         // no operand
} insn_op_match_t;

// instruction format flags/encoding steps
enum {
    enc_none,
    enc_imm32,          // 4 byte immediate data
    enc_rel32,          // 4 byte relative displacement (jmp/call)
    enc_w_prefix,       // rex.w bit
    enc_r_prefix,       // rex.r bit (from op2 reg field/source)
    enc_b_prefix,       // rex.b bit (from op1 r/m field/destination)
    enc_66_prefix,
    enc_f2_prefix,
    enc_f3_prefix,
    enc_opcode,         // base opcode bytes
    enc_modrm_reg_rr,   // modrm r/m field is op1(dst), reg field is op2(src)
    enc_modrm_ext,      // modrm r/m field is op1(dst), reg field is modrm_ext (i-r, unary)
    enc_pop_push_reg,   // 50+r / 58+r
};

// instruction table structure
typedef struct {
    instrtype_t type;
    const char *name;
    uint8_t opcodes[3];
    size_t opcode_len;
    uint8_t modrm_ext;           // modrm reg/op field if not a register
    insn_op_match_t op1_match;   // expected type of op1 (internal destination)
    insn_op_match_t op2_match;   // expected type of op2 (internal source)
    uint8_t encoding_steps[8];   // ordered list of enc_ flags
} insn_t;


