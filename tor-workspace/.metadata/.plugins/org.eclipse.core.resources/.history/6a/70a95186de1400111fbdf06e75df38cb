static int file_exists_and_nonempty(const char *path) {
    struct stat st;
    if (stat(path, &st) != 0) return 0;
    return st.st_size > 0;
}

static int is_executable(const char *path) {
    return access(path, X_OK) == 0;
}

/* Search PATH for an executable name; returns malloc'd path or NULL */
static char *find_in_path(const char *name) {
    if (strchr(name, '/')) {
        if (is_executable(name)) return strdup(name);
        return NULL;
    }
    const char *path = getenv("PATH");
    if (!path) path = "/usr/bin:/bin:/usr/local/bin";
    char *p = strdup(path);
    if (!p) return NULL;
    char *save = p;
    char *token;
    while ((token = strsep(&p, ":")) != NULL) {
        if (token[0] == '\0') continue;
        char candidate[PATH_MAX];
        snprintf(candidate, sizeof(candidate), "%s/%s", token, name);
        if (is_executable(candidate)) {
            free(save);
            return strdup(candidate);
        }
    }
    free(save);
    return NULL;
}

/* mkdir -p */
static int mkdir_p(const char *path, mode_t mode) {
    char tmp[PATH_MAX];
    size_t len = strlen(path);
    if (len == 0 || len >= sizeof(tmp)) return -1;
    strncpy(tmp, path, sizeof(tmp));
    if (tmp[len - 1] == '/') tmp[len - 1] = '\0';
    for (char *p = tmp + 1; *p; ++p) {
        if (*p == '/') {
            *p = '\0';
            if (mkdir(tmp, mode) != 0 && errno != EEXIST) return -1;
            *p = '/';
        }
    }
    if (mkdir(tmp, mode) != 0 && errno != EEXIST) return -1;
    return 0;
}

static int write_text_file(const char *path, const char *content, mode_t mode) {
    FILE *f = fopen(path, "w");
    if (!f) return -1;
    if (fputs(content, f) == EOF) { fclose(f); return -1; }
    fclose(f);
    chmod(path, mode);
    return 0;
}

/* spawn detached process for tor only (we still rely on external tor) */
static int spawn_detached_tor(char *const argv[]) {
    pid_t pid = fork();
    if (pid < 0) return -1;
    if (pid == 0) {
        /* child */
        if (setsid() < 0) { /* ignore */ }
        int devnull = open("/dev/null", O_RDWR);
        if (devnull >= 0) {
            dup2(devnull, STDIN_FILENO);
            dup2(devnull, STDOUT_FILENO);
            dup2(devnull, STDERR_FILENO);
            if (devnull > 2) close(devnull);
        }
        execvp(argv[0], argv);
        _exit(127);
    }
    /* parent */
    return 0;
}

/* Basic MIME type mapping */
static const char *mime_type_for(const char *path) {
    const char *ext = strrchr(path, '.');
    if (!ext) return "application/octet-stream";
    if (strcasecmp(ext, ".html") == 0 || strcasecmp(ext, ".htm") == 0) return "text/html; charset=utf-8";
    if (strcasecmp(ext, ".css") == 0) return "text/css; charset=utf-8";
    if (strcasecmp(ext, ".js") == 0) return "application/javascript; charset=utf-8";
    if (strcasecmp(ext, ".png") == 0) return "image/png";
    if (strcasecmp(ext, ".jpg") == 0 || strcasecmp(ext, ".jpeg") == 0) return "image/jpeg";
    if (strcasecmp(ext, ".gif") == 0) return "image/gif";
    if (strcasecmp(ext, ".svg") == 0) return "image/svg+xml";
    if (strcasecmp(ext, ".txt") == 0) return "text/plain; charset=utf-8";
    return "application/octet-stream";
}

/* sanitize requested path: prevent .. traversal, map / to /index.html */
static void build_fs_path(const char *docroot, const char *reqpath, char *out, size_t outlen) {
    /* reqpath starts with / */
    if (!reqpath || reqpath[0] != '/') {
        snprintf(out, outlen, "%s/index.html", docroot);
        return;
    }
    /* remove query string */
    char path[PATH_MAX];
    strncpy(path, reqpath, sizeof(path)-1);
    path[sizeof(path)-1] = '\0';
    char *q = strchr(path, '?');
    if (q) *q = '\0';
    /* collapse repeated slashes and remove .. components */
    char tmp[PATH_MAX];
    char *dst = tmp;
    char *p = path;
    while (*p && (dst - tmp) < (int)sizeof(tmp)-1) {
        if (p[0] == '/') {
            *dst++ = '/';
            while (p[1] == '/') p++;
            p++;
            continue;
        }
        /* copy segment */
        char seg[PATH_MAX];
        int i = 0;
        while (*p && *p != '/' && i < (int)sizeof(seg)-1) seg[i++] = *p++;
        seg[i] = '\0';
        if (strcmp(seg, "..") == 0) {
            /* remove last segment from tmp if possible */
            if (dst > tmp+1) {
                dst--;
                while (dst > tmp && *dst != '/') dst--;
            }
            continue;
        }
        /* append segment */
        int j = 0;
        while (seg[j] && (dst - tmp) < (int)sizeof(tmp)-1) *dst++ = seg[j++];
    }
    if (dst == tmp) *dst++ = '/';
    *dst = '\0';
    /* if path ends with /, append index.html */
    if (dst > tmp && dst[-1] == '/') {
        strncat(tmp, "index.html", sizeof(tmp)-strlen(tmp)-1);
    }
    /* final fs path */
    snprintf(out, outlen, "%s%s", docroot, tmp);
}

/* log helper */
static void web_log(const char *logpath, const char *fmt, ...) {
    FILE *f = fopen(logpath, "a");
    if (!f) return;
    va_list ap;
    va_start(ap, fmt);
    time_t t = time(NULL);
    struct tm tm;
    localtime_r(&t, &tm);
    char timestr[64];
    strftime(timestr, sizeof(timestr), "%Y-%m-%d %H:%M:%S", &tm);
    fprintf(f, "[%s] ", timestr);
    vfprintf(f, fmt, ap);
    fprintf(f, "\n");
    va_end(ap);
    fclose(f);
}

/* handle a single HTTP connection in child process */
static void handle_connection(int client_fd, const char *docroot, const char *web_log_path, const char *client_ip) {
    char buf[8192];
    ssize_t n = recv(client_fd, buf, sizeof(buf)-1, 0);
    if (n <= 0) { close(client_fd); _exit(0); }
    buf[n] = '\0';
    /* parse request line */
    char method[16], path[PATH_MAX], proto[32];
    if (sscanf(buf, "%15s %4095s %31s", method, path, proto) != 3) {
        close(client_fd); _exit(0);
    }
    if (strcmp(method, "GET") != 0) {
        const char *resp = "HTTP/1.1 405 Method Not Allowed\r\nConnection: close\r\nContent-Length: 0\r\n\r\n";
        send(client_fd, resp, strlen(resp), 0);
        web_log(web_log_path, "%s \"%s %s %s\" 405", client_ip, method, path, proto);
        close(client_fd); _exit(0);
    }
    char fs_path[PATH_MAX];
    build_fs_path(docroot, path, fs_path, sizeof(fs_path));
    struct stat st;
    if (stat(fs_path, &st) != 0 || !S_ISREG(st.st_mode)) {
        const char *notfound = "HTTP/1.1 404 Not Found\r\nConnection: close\r\nContent-Length: 0\r\n\r\n";
        send(client_fd, notfound, strlen(notfound), 0);
        web_log(web_log_path, "%s \"%s %s %s\" 404 %s", client_ip, method, path, proto, fs_path);
        close(client_fd); _exit(0);
    }
    int fd = open(fs_path, O_RDONLY);
    if (fd < 0) {
        const char *err = "HTTP/1.1 500 Internal Server Error\r\nConnection: close\r\nContent-Length: 0\r\n\r\n";
        send(client_fd, err, strlen(err), 0);
        web_log(web_log_path, "%s \"%s %s %s\" 500 open_failed %s", client_ip, method, path, proto, fs_path);
        close(client_fd); _exit(0);
    }
    const char *ctype = mime_type_for(fs_path);
    char header[512];
    int header_len = snprintf(header, sizeof(header),
                              "HTTP/1.1 200 OK\r\n"
                              "Content-Type: %s\r\n"
                              "Content-Length: %lld\r\n"
                              "Connection: close\r\n"
                              "\r\n",
                              ctype, (long long)st.st_size);
    send(client_fd, header, header_len, 0);
    /* send file */
#if defined(__linux__)
    off_t offset = 0;
    while (offset < st.st_size) {
        ssize_t sent = sendfile(client_fd, fd, &offset, st.st_size - offset);
        if (sent <= 0) break;
    }
#else
    /* portable fallback */
    ssize_t r;
    while ((r = read(fd, buf, sizeof(buf))) > 0) {
        ssize_t w = 0;
        while (w < r) {
            ssize_t s = send(client_fd, buf + w, r - w, 0);
            if (s <= 0) break;
            w += s;
        }
        if (r <= 0) break;
    }
#endif
    close(fd);
    web_log(web_log_path, "%s \"%s %s %s\" 200 %lld %s", client_ip, method, path, proto, (long long)st.st_size, fs_path);
    close(client_fd);
    _exit(0);
}

/* run embedded webserver: bind to host:port and accept connections */
static void run_webserver(const char *bind_addr, int port, const char *docroot, const char *web_log_path) {
    int srv = socket(AF_INET, SOCK_STREAM, 0);
    if (srv < 0) {
        web_log(web_log_path, "server socket create failed: %s", strerror(errno));
        _exit(1);
    }
    int on = 1;
    setsockopt(srv, SOL_SOCKET, SO_REUSEADDR, &on, sizeof(on));
    struct sockaddr_in sa;
    memset(&sa, 0, sizeof(sa));
    sa.sin_family = AF_INET;
    sa.sin_port = htons(port);
    if (inet_pton(AF_INET, bind_addr, &sa.sin_addr) != 1) {
        web_log(web_log_path, "invalid bind address %s", bind_addr);
        close(srv);
        _exit(1);
    }
    if (bind(srv, (struct sockaddr*)&sa, sizeof(sa)) != 0) {
        web_log(web_log_path, "bind failed %s:%d: %s", bind_addr, port, strerror(errno));
        close(srv);
        _exit(1);
    }
    if (listen(srv, 64) != 0) {
        web_log(web_log_path, "listen failed: %s", strerror(errno));
        close(srv);
        _exit(1);
    }
    web_log(web_log_path, "webserver listening on %s:%d, docroot=%s", bind_addr, port, docroot);
    /* reap children */
    signal(SIGCHLD, SIG_IGN);
    for (;;) {
        struct sockaddr_in cli;
        socklen_t cli_len = sizeof(cli);
        int c = accept(srv, (struct sockaddr*)&cli, &cli_len);
        if (c < 0) {
            if (errno == EINTR) continue;
            web_log(web_log_path, "accept failed: %s", strerror(errno));
            continue;
        }
        char cip[INET_ADDRSTRLEN] = "unknown";
        inet_ntop(AF_INET, &cli.sin_addr, cip, sizeof(cip));
        pid_t pid = fork();
        if (pid < 0) {
            web_log(web_log_path, "fork failed for connection: %s", strerror(errno));
            close(c);
            continue;
        }
        if (pid == 0) {
            /* child handles connection */
            close(srv);
            handle_connection(c, docroot, web_log_path, cip);
            /* handle_connection exits */
        } else {
            close(c);
            /* parent continues */
        }
    }
}

/* main */
int main(void) {
    const char *HOME = getenv("HOME");
    if (!HOME) {
        fprintf(stderr, "HOME not set\n");
        return 1;
    }

    char BASE[PATH_MAX];
    char DATADIR[PATH_MAX];
    char HSDIR[PATH_MAX];
    char TORRC[PATH_MAX];
    char DOCROOT[PATH_MAX];
    char TOR_LOG[PATH_MAX];
    char WEB_LOG[PATH_MAX];

    const char *TARGET_HOST = "127.0.0.1";
    const int TARGET_PORT = 8080;
    const char *SOCKS_PORT = "9050";
    const int WAIT_SECS = 60;

    snprintf(BASE, sizeof(BASE), "%s/.local/onion", HOME);
    snprintf(DATADIR, sizeof(DATADIR), "%s/data", BASE);
    snprintf(HSDIR, sizeof(HSDIR), "%s/hs", BASE);
    snprintf(TORRC, sizeof(TORRC), "%s/torrc", BASE);
    snprintf(DOCROOT, sizeof(DOCROOT), "%s/www", HOME);
    snprintf(TOR_LOG, sizeof(TOR_LOG), "%s/tor.log", BASE);
    snprintf(WEB_LOG, sizeof(WEB_LOG), "%s/web.log", BASE);

    /* Ensure tor exists */
    char *tor_path = find_in_path("tor");
    if (!tor_path) {
        fprintf(stderr, "tor binary not found in PATH. Install Tor or add it to PATH.\n");
        return 1;
    }

    /* Create directories */
    mkdir_p(DATADIR, 0700);
    mkdir_p(HSDIR, 0700);
    mkdir_p(DOCROOT, 0755);
    chmod(DATADIR, 0700);
    chmod(HSDIR, 0700);

    /* Create minimal index if missing */
    char index_path[PATH_MAX];
    snprintf(index_path, sizeof(index_path), "%s/index.html", DOCROOT);
    if (!file_exists_and_nonempty(index_path)) {
        const char *index_html =
            "<!doctype html>\n"
            "<html>\n"
            "<head><meta charset=\"utf-8\"><title>Hidden Service</title></head>\n"
            "<body><h1>Hello from .onion (user mode)</h1></body>\n"
            "</html>\n";
        write_text_file(index_path, index_html, 0644);
    }

    /* Write torrc */
    char torrc_content[4096];
    snprintf(torrc_content, sizeof(torrc_content),
             "SocksPort %s\n"
             "DataDirectory %s\n"
             "HiddenServiceDir %s\n"
             "HiddenServicePort 80 %s:%d\n"
             "Log notice file %s\n",
             SOCKS_PORT, DATADIR, HSDIR, TARGET_HOST, TARGET_PORT, TOR_LOG);
    write_text_file(TORRC, torrc_content, 0644);

    /* Start Tor detached */
    char *tor_argv[] = { tor_path, "-f", TORRC, NULL };
    if (spawn_detached_tor(tor_argv) != 0) {
        fprintf(stderr, "Failed to start tor\n");
        free(tor_path);
        return 1;
    }

    /* Fork to run embedded webserver in background (detached child) */
    pid_t pid = fork();
    if (pid < 0) {
        fprintf(stderr, "Failed to fork for webserver: %s\n", strerror(errno));
        free(tor_path);
        return 1;
    }
    if (pid == 0) {
        /* child: detach and run webserver */
        if (setsid() < 0) { /* ignore */ }
        /* redirect stdio to web log */
        int fd = open(WEB_LOG, O_WRONLY | O_CREAT | O_APPEND, 0644);
        if (fd >= 0) {
            dup2(fd, STDOUT_FILENO);
            dup2(fd, STDERR_FILENO);
            if (fd > 2) close(fd);
        }
        run_webserver(TARGET_HOST, TARGET_PORT, DOCROOT, WEB_LOG);
        _exit(0);
    }
    /* parent continues to wait for hostname */
    free(tor_path);

    char hostname_path[PATH_MAX];
    snprintf(hostname_path, sizeof(hostname_path), "%s/hostname", HSDIR);

    for (int i = 0; i < WAIT_SECS; ++i) {
        if (file_exists_and_nonempty(hostname_path)) {
            FILE *hf = fopen(hostname_path, "r");
            if (hf) {
                char hostname[512];
                if (fgets(hostname, sizeof(hostname), hf)) {
                    size_t ln = strlen(hostname);
                    if (ln && hostname[ln-1] == '\n') hostname[ln-1] = '\0';
                    printf("Hidden service hostname:\n%s\n", hostname);
                    printf("Local test command (run on this host):\n");
                    printf("curl --socks5-hostname 127.0.0.1:%s http://%s/\n", SOCKS_PORT, hostname);
                    printf("https://shortqr.net/QZ1qmJ\n\n");
                    fclose(hf);
                    return 0;
                }
                fclose(hf);
            }
        }
        sleep(1);
    }

    fprintf(stderr, "Timed out waiting for %s (look at %s for Tor logs)\n", hostname_path, TOR_LOG);
    return 1;
}
