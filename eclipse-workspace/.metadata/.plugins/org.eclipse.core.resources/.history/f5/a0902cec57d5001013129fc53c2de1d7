ast_node* new_node(int type) {
    ast_node* n = (ast_node*)calloc(1, sizeof(ast_node));
    if (!n) error("memory allocation failed for ast node");
    n->type = type;
    return n;
}

ast_node* expression();
ast_node* statement();

// helper functions (integrated symbol table logic)
variable* lookup_local() {
    for(int i = 0; i < local_count; i++) { if(strcmp(token, locals[i].name) == 0) return &locals[i]; }
    return null;
}
void add_local(int offset, int type) {
    if (local_count >= 1024) error("too many variables");
    for(int i = 0; i < local_count; i++) { if(strcmp(token, locals[i].name) == 0) error("multiple declarations: %s", token); }
    strcpy(locals[local_count].name, token); locals[local_count].offset = offset; locals[local_count].type = type; local_count++;
}
int is_expr_beginning() {
    static const int lexemes[] = { '-', '!', '(', lex_number, lex_char, lex_string, lex_ident, '*' };
    for(int i = 0; i < sizeof(lexemes) / sizeof(int); i++) if(lexeme == lexemes[i]) return 1; return 0;
}
int is_type_keyword() { if (lexeme >= lex_type_int && lexeme <= lex_type_void) return 1; return 0; }
int is_stmt_beginning() {
    static const int lexemes[] = { lex_asm, lex_if, lex_while, lex_break, lex_continue, lex_return, ';', '{' };
    for(int i = 0; i < sizeof(lexemes) / sizeof(int); i++) if(lexeme == lexemes[i]) return 1;
    if (is_type_keyword()) return 1; return is_expr_beginning();
}

// parsing expression levels (recursive descent)

ast_node* expr_level_zero() {
    ast_node* n;
    if(lexeme == '!') {
        expect('!'); n = new_node(node_op_unary); n->unary.op = '!'; n->unary.operand = expr_level_zero(); return n;
    }
    if (lexeme == '*') { 
        expect('*'); n = new_node(node_op_unary); n->unary.op = '*'; n->unary.operand = expr_level_zero(); return n;
    }
    if(lexeme == '-') {
        expect('-');
        if (!neg_number) { n = new_node(node_op_unary); n->unary.op = '-'; n->unary.operand = expr_level_zero(); return n; }
        // negative number handled below
    }
    if(lexeme == lex_number) {
        n = new_node(node_const); n->val = neg_number ? -number : number; expect(lex_number); return n;
    } else if(lexeme == lex_char) {
        long long char_val; 
        if (strlen(token) == 3) char_val = token[1]; else if (token[1] == '\\' && token[2] == 'n') char_val = '\n'; else error("complex character literal not supported");
        n = new_node(node_const); n->val = char_val; expect(lex_char); return n;
    } else if(lexeme == '(') {
        expect('('); n = expression(); expect(')'); return n;
    } else if(lexeme == lex_ident) {
        char name[64]; strcpy(name, token); expect(lex_ident);
        if(lexeme == '(') { error("function calls not fully implemented in ast"); } // should become node_call
        else if(lexeme == '=') { // assignment
            expect('=');
            n = new_node(node_assign);
            n->binary.left = new_node(node_var); strcpy(n->binary.left->var.name, name); // LHS is var node
            n->binary.right = expression(); // RHS is expression
            return n;
        } else { // variable load
            n = new_node(node_var); strcpy(n->var.name, name); return n;
        }
    } else if(lexeme == lex_string) { error("string literals not fully implemented in ast"); }
    error("bad expression start"); return null;
}

ast_node* expr_level_bin(ast_node* (*next_level)(), const char* ops) {
    ast_node* left = next_level();
    while(strchr(ops, lexeme) || lexeme == lex_le || lexeme == lex_ge || lexeme == lex_eq || lexeme == lex_ne || lexeme == lex_log_and || lexeme == lex_log_or) {
        int op = lexeme;
        if (!strchr(ops, op)) { /* handle lexemes like ==, && etc. */ } // already an int/enum token
        read_lexeme();
        ast_node* right = next_level();
        ast_node* n = new_node(node_op_binary);
        n->binary.op = op;
        n->binary.left = left;
        n->binary.right = right;
        left = n;
    }
    return left;
}

// parsing hierarchy (simplified)
ast_node* expr_level_one() { return expr_level_bin(expr_level_zero, "*/%"); }
ast_node* expr_level_two() { return expr_level_bin(expr_level_one, "+-"); }
ast_node* expr_level_three() { return expr_level_bin(expr_level_two, "<>"); }
ast_node* expr_level_four() { return expr_level_bin(expr_level_three, ""); } // ==, != are checked inside expr_level_bin
ast_node* expr_level_five() { return expr_level_bin(expr_level_four, "&"); }
ast_node* expr_level_six() { return expr_level_bin(expr_level_five, "|"); }
ast_node* expr_level_seven() { return expr_level_bin(expr_level_six, ""); } // && is checked inside expr_level_bin

ast_node* expression() { 
    ast_node* n = expr_level_bin(expr_level_seven, ""); // || is checked inside expr_level_bin (lowest precedence)
    return n;
}


// parsing statements
ast_node* statement_list() {
    ast_node* block = new_node(node_block);
    block->block.stmts = (ast_node**)malloc(100 * sizeof(ast_node*)); // allocate space for up to 100 stmts
    block->block.stmt_count = 0;
    
    while(is_stmt_beginning()) {
        block->block.stmts[block->block.stmt_count++] = statement();
        // reallocate if needed, simplified for this example
    }
    return block;
}

ast_node* statement() {
    ast_node* n;
    if (lexeme == '{') {
        expect('{');
        n = statement_list();
        expect('}');
        return n;
    }
    if (is_type_keyword()) { // declaration: int x = 5;
        n = new_node(node_declaration);
        n->var.data_type = lexeme;
        read_lexeme(); // consume type
        if (lexeme == '*') { read_lexeme(); }
        expect(lex_ident);
        strcpy(n->var.name, token);
        n->var.offset = local_count * 8 + 8; // dummy offset logic
        add_local(n->var.offset, n->var.data_type);

        if (lexeme == '=') { expect('='); n->var.init = expression(); }
        expect(';');
        return n;
    }
    if(lexeme == lex_if) {
        expect(lex_if); expect('('); n = new_node(node_if); n->if_stmt.cond = expression(); expect(')');
        n->if_stmt.body_true = statement();
        if(lexeme == lex_else) { expect(lex_else); n->if_stmt.body_false = statement(); }
        return n;
    }
    if(lexeme == lex_while) {
        expect(lex_while); expect('('); n = new_node(node_while); n->while_stmt.cond = expression(); expect(')');
        n->while_stmt.body = statement();
        return n;
    }
    if(lexeme == lex_return) {
        expect(lex_return); n = new_node(node_return); if(is_expr_beginning()) n->ret_stmt.expr = expression(); else n->ret_stmt.expr = null;
        expect(';');
        return n;
    }
    if(lexeme == lex_break) { expect(lex_break); n = new_node(node_break); expect(';'); return n; }
    if(lexeme == lex_continue) { expect(lex_continue); n = new_node(node_continue); expect(';'); return n; }
    
    if(is_expr_beginning()) { // expression statement (e.g., assignment, function call)
        n = expression(); expect(';'); return n;
    }
    expect(';'); return new_node(node_empty); // empty statement
}

