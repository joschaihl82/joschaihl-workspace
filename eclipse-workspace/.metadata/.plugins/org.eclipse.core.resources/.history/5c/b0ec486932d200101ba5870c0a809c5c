/* bootx64.c
 * Post-ExitBootServices NVMe hexdump (standalone ring-0 stub)
 *
 * This is a single-file UEFI application which:
 * 1) Before ExitBootServices:
 *    - Locates an NVMe controller via the PCI IO protocol
 *    - Reads BAR0 (MMIO base) and saves it
 *    - Grabs the Graphics Output Protocol framebuffer info for text output
 *    - Allocates page-aligned buffers for NVMe submission/completion queues
 *    - Allocates a data buffer to receive an LBA (512 bytes)
 *    - Collects the memory map and exits boot services
 * 2) After ExitBootServices (we are still running in ring 0):
 *    - Uses the previously-read BAR0 physical address to access NVMe registers
 *    - Programs controller Admin SQ/CQ registers to point at our allocated pages
 *    - Sends NVMe Admin Identify + IO Read (LBA 0) via PRP1 pointing to our data buffer
 *    - Polls the completion queue for completion
 *    - Renders a simple hexdump of the returned 512 bytes to the framebuffer
 *
 * CAVEATS & WARNINGS
 * - This code assumes the firmware keeps identity mappings for allocated pages
 *   and that the BAR physical address can be directly dereferenced after
 *   ExitBootServices. This works on many OVMF/UEFI implementations but is
 *   NOT guaranteed by the specification.
 * - This program performs raw reads from storage. Use carefully.
 * - This code is for educational / testing purposes and is not hardened.
 *
 * Build notes (example using GNU-EFI and mingw-w64 cross compiler):
 *   see the canvas "bootx64.c - UEFI hexdump (GNU-EFI)" for build hints.
 */

#include <efi.h>
#include <efilib.h>

// NVMe register offsets (from the specification)
#define NVME_REG_CAP 0x0000
#define NVME_REG_VS  0x0008
#define NVME_REG_CC  0x0014
#define NVME_REG_CSTS 0x001c
#define NVME_REG_AQA 0x0024
#define NVME_REG_ASQ 0x0028
#define NVME_REG_ACQ 0x0030

// Doorbells base: 4K-aligned after regs (controller specific). We'll use offset 0x1000
#define NVME_DOORBELL_OFFSET 0x1000

// Admin opcodes
#define NVME_ADMIN_IDENTIFY 0x06
#define NVME_CMD_READ 0x02

// Sizes we'll use
#define PAGE_SIZE 4096
#define ADMIN_Q_ENTRIES 16
#define IO_Q_ENTRIES  16
#define DATA_BUFFER_SIZE 4096 // read one 512-byte LBA into 4K

// Simple framebuffer text helper (we capture GOP before EBS)
typedef struct {
    EFI_PHYSICAL_ADDRESS FrameBufferBase;
    UINT32 FrameBufferWidth;
    UINT32 FrameBufferHeight;
    UINT32 PixelsPerScanLine;
    EFI_GRAPHICS_PIXEL_FORMAT PixelFormat;
} FB_INFO;

// Saved state gathered before ExitBootServices
typedef struct {
    EFI_PHYSICAL_ADDRESS NvmeBar; // physical mmio base (BAR0)
    FB_INFO fb;
    EFI_PHYSICAL_ADDRESS AdminSqPhys; // physical addresses of our queues & buffers
    EFI_PHYSICAL_ADDRESS AdminCqPhys;
    EFI_PHYSICAL_ADDRESS DataBufPhys;
    VOID *AdminSqVirt;
    VOID *AdminCqVirt;
    VOID *DataBufVirt;
    UINTN MemMapSize;
    EFI_MEMORY_DESCRIPTOR *MemMap;
    UINTN MapKey;
    UINTN DescriptorSize;
    UINT32 DescriptorVersion;
} SAVED_STATE;

STATIC SAVED_STATE S;

// Simple memory copy helpers (we cannot rely on libc after EBS)
STATIC VOID *my_memcpy(VOID *dst, const VOID *src, UINTN len){
    UINT8 *d = dst; const UINT8 *s = src;
    while (len--) *d++ = *s++;
    return dst;
}
STATIC VOID *my_memset(VOID *dst, INT32 val, UINTN len){
    UINT8 *d = dst; while (len--) *d++ = (UINT8)val; return dst;
}

// Framebuffer pixel write (we'll render monochrome text glyphs simple)
// To keep this example short we render text as 8x16 bitmap font built-in for hex characters

// Tiny 8x16 font for ASCII 32..127 would be big; instead we'll render hex hexdump
// using a very small 6x8 font for chars 0-9 A-F :
static const UINT8 hex6x8[][6] = {
    // '0'..'9'
    {0x3E,0x51,0x49,0x45,0x3E,0x00}, //0
    {0x00,0x42,0x7F,0x40,0x00,0x00}, //1
    {0x62,0x51,0x49,0x49,0x46,0x00}, //2
    {0x22,0x41,0x49,0x49,0x36,0x00}, //3
    {0x18,0x14,0x12,0x7F,0x10,0x00}, //4
    {0x27,0x45,0x45,0x45,0x39,0x00}, //5
    {0x3C,0x4A,0x49,0x49,0x30,0x00}, //6
    {0x01,0x71,0x09,0x05,0x03,0x00}, //7
    {0x36,0x49,0x49,0x49,0x36,0x00}, //8
    {0x06,0x49,0x49,0x29,0x1E,0x00}, //9
};
static const UINT8 hexAtoF[][6] = {
    {0x7E,0x09,0x09,0x09,0x7E,0x00}, //A
    {0x7F,0x49,0x49,0x49,0x36,0x00}, //B
    {0x3E,0x41,0x41,0x41,0x22,0x00}, //C
    {0x7F,0x41,0x41,0x22,0x1C,0x00}, //D
    {0x7F,0x49,0x49,0x49,0x41,0x00}, //E
    {0x7F,0x09,0x09,0x09,0x01,0x00}  //F
};

// Draw a pixel in 32bpp (we won't set colors beyond black/white)
STATIC VOID fb_put_pixel(UINTN x, UINTN y, UINT8 intensity){
    FB_INFO *fb = &S.fb;
    if (x >= fb->FrameBufferWidth || y >= fb->FrameBufferHeight) return;
    UINT8 *pix = (UINT8*)(UINTN)fb->FrameBufferBase + (y * fb->PixelsPerScanLine + x) * 4;
    // simple: white for intensity>0, black otherwise
    if (intensity) {
        pix[0] = 0xFF; pix[1] = 0xFF; pix[2] = 0xFF; pix[3] = 0x00;
    } else {
        pix[0] = pix[1] = pix[2] = 0x00; pix[3] = 0x00;
    }
}

STATIC VOID fb_draw_char_hex(UINTN sx, UINTN sy, CHAR8 c){
    const UINT8 *glyph;
    if (c >= '0' && c <= '9') glyph = hex6x8[c - '0'];
    else if (c >= 'A' && c <= 'F') glyph = hexAtoF[c - 'A'];
    else return;
    for (UINTN row=0; row<8; ++row){
        UINT8 b = glyph[row%6]; // glyph height assumed 6 but we iterate 8; ok
        for (UINTN col=0; col<6; ++col){
            fb_put_pixel(sx + col, sy + row, (b & (1 << (7 - col))) ? 1 : 0);
        }
    }
}

STATIC VOID fb_draw_string_hex(UINTN sx, UINTN sy, const CHAR8 *s){
    while (*s){
        fb_draw_char_hex(sx, sy, *s);
        sx += 7; // 6 pixels + 1 spacing
        ++s;
    }
}

