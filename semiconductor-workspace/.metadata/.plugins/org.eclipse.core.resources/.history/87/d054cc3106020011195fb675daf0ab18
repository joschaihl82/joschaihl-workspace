/* render.c
 * OpenGL, shader, grid rendering, coordinate transforms, zoom animation
 * Exposes a tiny API used by UI.
 */

#include "app.h"
#include <GL/glew.h>
#include <GL/gl.h>
#include <GL/glu.h>
#include <GL/glut.h>

#include <stdio.h>
#include <stdlib.h>
#include <math.h>
#include <time.h>

#define TOOLBAR_HEIGHT 48

/* Internal state (static to this module) */
static int win_w = 1200, win_h = 800;
static double px_per_mm = 96.0 / 25.4;
static double zoom_factor = 1.0;
static double pan_x = 0.0, pan_y = 0.0;

/* Zoom animation */
static int zoom_animating = 0;
static double zoom_start = 1.0, zoom_target = 1.0;
static double anim_start_time = 0.0, anim_duration = 0.20;
static double anim_world_cx = 0.0, anim_world_cy = 0.0;

/* Shader program + VAO */
static GLuint grid_prog = 0;
static GLuint fs_vao = 0;

/* Uniform locations */
static GLint uni_viewport_origin = -1;
static GLint uni_viewport_size = -1;
static GLint uni_pan = -1;
static GLint uni_zoom = -1;
static GLint uni_step_mm = -1;
static GLint uni_major_units = -1;
static GLint uni_grid_visible = -1;
static GLint uni_px_per_mm = -1;
static GLint uni_color_bg = -1;
static GLint uni_color_minor = -1;
static GLint uni_color_major = -1;

/* Helpers */
static double now_seconds(void) {
    struct timespec ts; clock_gettime(CLOCK_MONOTONIC, &ts);
    return ts.tv_sec + ts.tv_nsec * 1e-9;
}
static double ease_out_quad(double t) {
    if (t<=0) return 0; if (t>=1) return 1; return 1.0 - (1.0 - t)*(1.0 - t);
}
static void ensure_zoom_safe(void) { if (zoom_factor < 1e-12) zoom_factor = 1e-12; }

/* Minimal robust shader helpers */
static GLuint compile_shader_safe(GLenum type, const char *src) {
    if (!src) return 0;
    GLuint s = glCreateShader(type);
    if (!s) return 0;
    glShaderSource(s, 1, &src, NULL);
    glCompileShader(s);
    GLint ok = 0; glGetShaderiv(s, GL_COMPILE_STATUS, &ok);
    if (!ok) {
        GLint len=0; glGetShaderiv(s, GL_INFO_LOG_LENGTH, &len);
        if (len>1) { char *log = malloc(len); glGetShaderInfoLog(s,len,NULL,log); fprintf(stderr,"Shader compile error:\n%s\n",log); free(log); }
        glDeleteShader(s); return 0;
    }
    return s;
}
static GLuint link_program_safe(GLuint vs, GLuint fs) {
    if (!vs || !fs) return 0;
    GLuint p = glCreateProgram();
    if (!p) return 0;
    glAttachShader(p, vs); glAttachShader(p, fs);
    glLinkProgram(p);
    GLint ok=0; glGetProgramiv(p, GL_LINK_STATUS, &ok);
    if (!ok) {
        GLint len=0; glGetProgramiv(p, GL_INFO_LOG_LENGTH, &len);
        if (len>1) { char *log = malloc(len); glGetProgramInfoLog(p,len,NULL,log); fprintf(stderr,"Program link error:\n%s\n",log); free(log); }
        glDeleteProgram(p); return 0;
    }
    return p;
}

/* GLSL 150 shaders (vertex uses gl_VertexID) */
static const char *vs_src =
"#version 150\n"
"void main() { vec2 pos[3] = vec2[3](vec2(-1.0,-1.0), vec2(3.0,-1.0), vec2(-1.0,3.0)); gl_Position = vec4(pos[gl_VertexID],0.0,1.0); }\n";
static const char *fs_src =
"#version 150\n"
"uniform vec2 u_viewport_origin; uniform vec2 u_viewport_size; uniform vec2 u_pan; uniform float u_zoom; uniform float u_px_per_mm; uniform float u_step_mm; uniform float u_major_units; uniform int u_grid_visible; uniform vec3 u_color_bg; uniform vec3 u_color_minor; uniform vec3 u_color_major; out vec4 outColor; float aa(float d,float w){return smoothstep(w,0.0,d);} void main(){ if(u_grid_visible==0){ outColor=vec4(u_color_bg,1.0); return;} vec2 sc=gl_FragCoord.xy; vec2 local=sc-u_viewport_origin; vec2 center=u_viewport_size*0.5; vec2 world=(local-center)/u_zoom+u_pan; float fx=mod(world.x,u_step_mm)/u_step_mm; float fy=mod(world.y,u_step_mm)/u_step_mm; float dx=min(abs(fx),1.0-abs(fx))*u_step_mm*u_zoom; float dy=min(abs(fy),1.0-abs(fy))*u_step_mm*u_zoom; float units_x=world.x/u_step_mm; float units_y=world.y/u_step_mm; float rx=mod(abs(units_x),u_major_units); float ry=mod(abs(units_y),u_major_units); int is_major_x=(rx<1e-3||abs(rx-u_major_units)<1e-3)?1:0; int is_major_y=(ry<1e-3||abs(ry-u_major_units)<1e-3)?1:0; float a_x=aa(dx,1.0); float a_y=aa(dy,1.0); vec3 col=u_color_bg; if(a_x>0.0){ if(is_major_x==1) col=mix(col,u_color_major,a_x); else col=mix(col,u_color_minor,a_x);} if(a_y>0.0){ if(is_major_y==1) col=mix(col,u_color_major,a_y); else col=mix(col,u_color_minor,a_y);} outColor=vec4(col,1.0); }\n";

/* Initialize shader + VAO */
static int init_shader_and_vao(void) {
    GLuint vs = compile_shader_safe(GL_VERTEX_SHADER, vs_src);
    GLuint fs = compile_shader_safe(GL_FRAGMENT_SHADER, fs_src);
    if (!vs || !fs) { if (vs) glDeleteShader(vs); if (fs) glDeleteShader(fs); return 0; }
    grid_prog = link_program_safe(vs, fs);
    glDeleteShader(vs); glDeleteShader(fs);
    if (!grid_prog) return 0;

    uni_viewport_origin = glGetUniformLocation(grid_prog, "u_viewport_origin");
    uni_viewport_size = glGetUniformLocation(grid_prog, "u_viewport_size");
    uni_pan = glGetUniformLocation(grid_prog, "u_pan");
    uni_zoom = glGetUniformLocation(grid_prog, "u_zoom");
    uni_px_per_mm = glGetUniformLocation(grid_prog, "u_px_per_mm");
    uni_step_mm = glGetUniformLocation(grid_prog, "u_step_mm");
    uni_major_units = glGetUniformLocation(grid_prog, "u_major_units");
    uni_grid_visible = glGetUniformLocation(grid_prog, "u_grid_visible");
    uni_color_bg = glGetUniformLocation(grid_prog, "u_color_bg");
    uni_color_minor = glGetUniformLocation(grid_prog, "u_color_minor");
    uni_color_major = glGetUniformLocation(grid_prog, "u_color_major");

    /* VAO for fullscreen triangle */
    glGenVertexArrays(1, &fs_vao);
    glBindVertexArray(fs_vao);
    glBindVertexArray(0);

    fprintf(stderr, "render: shader program %u ready; uniforms: vp_origin=%d vp_size=%d pan=%d zoom=%d step=%d grid=%d\n",
            (unsigned)grid_prog, uni_viewport_origin, uni_viewport_size, uni_pan, uni_zoom, uni_step_mm, uni_grid_visible);
    return 1;
}

/* Public API implementations */

int render_init(int w, int h) {
    win_w = w; win_h = h;
    glewExperimental = GL_TRUE;
    GLenum err = glewInit();
    if (err != GLEW_OK) {
        fprintf(stderr, "render: glewInit failed: %s\n", glewGetErrorString(err));
        /* continue with CPU fallback */
    } else {
        const GLubyte *glsl = glGetString(GL_SHADING_LANGUAGE_VERSION);
        fprintf(stderr, "render: GLSL version: %s\n", glsl ? (const char*)glsl : "NULL");
    }
    glDisable(GL_DEPTH_TEST);
    glEnable(GL_BLEND);
    glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);

    if (!init_shader_and_vao()) {
        fprintf(stderr, "render: GPU shader not available; CPU fallback will be used.\n");
        grid_prog = 0;
    }
    return 1;
}

void render_shutdown(void) {
    if (grid_prog) { glDeleteProgram(grid_prog); grid_prog = 0; }
    if (fs_vao) { glDeleteVertexArrays(1, &fs_vao); fs_vao = 0; }
}

/* Resize */
void render_resize(int w, int h) {
    win_w = w; win_h = h;
    glViewport(0,0,w,h);
}

/* Simple world/screen helpers used internally by render (kept private) */
static void world_to_screen(double wx, double wy, int *sx, int *sy) {
    int x0 = 56; int y0 = TOOLBAR_HEIGHT + 56; /* match UI ruler thickness */
    int cw = win_w - 56; int ch = win_h - (TOOLBAR_HEIGHT + 56) - STATUS_HEIGHT;
    double ox = x0 + cw/2.0, oy = y0 + ch/2.0;
    double zx = (wx - pan_x) * zoom_factor, zy = (wy - pan_y) * zoom_factor;
    if (sx) *sx = (int)round(ox + zx);
    if (sy) *sy = (int)round(oy + zy);
}

/* Draw (called from UI) */
void render_draw(void) {
    /* draw grid via shader if available */
    const double MIN_PX_PER_UNIT = 40.0;
    /* compute step_mm (simple heuristic) */
    double px_per_unit = px_per_mm * zoom_factor * 1.0;
    double step_units = 10.0;
    double step_mm = step_units * 1.0;
    double major_units = 10.0;

    int cx = 56;
    int cy = TOOLBAR_HEIGHT + 56;
    int cw = win_w - 56;
    int ch = win_h - (TOOLBAR_HEIGHT + 56) - STATUS_HEIGHT;

    if (grid_prog && grid_prog != 0 && grid_visible) {
        glUseProgram(grid_prog);
        if (uni_viewport_origin >= 0) glUniform2f(uni_viewport_origin, (GLfloat)cx, (GLfloat)cy);
        if (uni_viewport_size >= 0) glUniform2f(uni_viewport_size, (GLfloat)cw, (GLfloat)ch);
        if (uni_pan >= 0) glUniform2f(uni_pan, (GLfloat)pan_x, (GLfloat)pan_y);
        if (uni_zoom >= 0) glUniform1f(uni_zoom, (GLfloat)zoom_factor);
        if (uni_px_per_mm >= 0) glUniform1f(uni_px_per_mm, (GLfloat)px_per_mm);
        if (uni_step_mm >= 0) glUniform1f(uni_step_mm, (GLfloat)step_mm);
        if (uni_major_units >= 0) glUniform1f(uni_major_units, (GLfloat)major_units);
        if (uni_grid_visible >= 0) glUniform1i(uni_grid_visible, grid_visible ? 1 : 0);
        if (uni_color_bg >= 0) glUniform3f(uni_color_bg, 1.0f, 1.0f, 1.0f);
        if (uni_color_minor >= 0) glUniform3f(uni_color_minor, 0.88f, 0.88f, 0.88f);
        if (uni_color_major >= 0) glUniform3f(uni_color_major, 0.75f, 0.75f, 0.75f);

        glEnable(GL_SCISSOR_TEST);
        glScissor(cx, win_h - (cy + ch), cw, ch);

        glBindVertexArray(fs_vao);
        glDrawArrays(GL_TRIANGLES, 0, 3);
        glBindVertexArray(0);

        glDisable(GL_SCISSOR_TEST);
        glUseProgram(0);
    } else {
        /* CPU fallback: draw vertical lines */
        glLineWidth(1.0f);
        glColor3ub(224,224,224);
        for (int k=-200;k<=200;++k) {
            double wx = k * step_mm;
            int sx0, sy0, sx1, sy1;
            world_to_screen(wx, -1e6, &sx0, &sy0);
            world_to_screen(wx, 1e6, &sx1, &sy1);
            glBegin(GL_LINES); glVertex2i(sx0, sy0); glVertex2i(sx1, sy1); glEnd();
        }
    }
}

/* Zoom centered API used by UI */
void render_zoom_to_centered(double new_zoom, int animate) {
    if (!(new_zoom > 0.0)) return;
    if (new_zoom < 1e-9) new_zoom = 1e-9;
    if (new_zoom > 1e12) new_zoom = 1e12;

    /* compute world coordinate at content center BEFORE changing zoom */
    int ccx = 56 + (win_w - 56)/2;
    int ccy = (TOOLBAR_HEIGHT + 56) + (win_h - (TOOLBAR_HEIGHT + 56) - STATUS_HEIGHT)/2;
    double world_cx_before = (double)(ccx - (56 + (win_w - 56)/2)) / zoom_factor + pan_x;
    double world_cy_before = (double)(ccy - ((TOOLBAR_HEIGHT + 56) + (win_h - (TOOLBAR_HEIGHT + 56) - STATUS_HEIGHT)/2)) / zoom_factor + pan_y;

    if (animate) {
        zoom_animating = 1;
        zoom_start = zoom_factor;
        zoom_target = new_zoom;
        anim_start_time = now_seconds();
        anim_world_cx = world_cx_before;
        anim_world_cy = world_cy_before;
        glutTimerFunc(16, (void(*)(int))timer_handler, 0);
    } else {
        zoom_factor = new_zoom;
        ensure_zoom_safe();
        pan_x = world_cx_before - (double)ccx / zoom_factor;
        pan_y = world_cy_before - (double)ccy / zoom_factor;
    }
}
void render_zoom_in_centered(void) { render_zoom_to_centered(zoom_factor * 1.15, 1); }
void render_zoom_out_centered(void) { render_zoom_to_centered(zoom_factor / 1.15, 1); }

/* Zoom animation timer (internal) */
static void timer_handler(int unused) {
    (void)unused;
    if (!zoom_animating) return;
    double tnow = now_seconds();
    double t = (tnow - anim_start_time) / anim_duration;
    if (t >= 1.0) {
        zoom_factor = zoom_target;
        zoom_animating = 0;
        ensure_zoom_safe();
        glutPostRedisplay();
        return;
    }
    double e = ease_out_quad(t);
    zoom_factor = zoom_start + (zoom_target - zoom_start) * e;
    ensure_zoom_safe();
    glutPostRedisplay();
}
