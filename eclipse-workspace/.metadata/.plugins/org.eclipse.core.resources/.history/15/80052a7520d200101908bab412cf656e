/* linker.ld - PE/COFF layout for x86_64 UEFI binary with PHDRS */
OUTPUT_FORMAT("pei-x86-64")
ENTRY(efi_main)

/* Define program headers expected by some toolchains/objects */
PHDRS
{
  text PT_LOAD FLAGS(5);   /* RX */
  data PT_LOAD FLAGS(6);   /* RW */
  bss  PT_LOAD FLAGS(6);   /* RW */
}

SECTIONS
{
  /* align start to 4K */
  . = ALIGN(0x1000);

  /* code and read-only data -> text PHDR */
  .text : AT(ADDR(.text)) :text
  {
    KEEP(*(.text*))
    KEEP(*(.rodata*))
    KEEP(*(.rdata*))
    KEEP(*(.pdata*))
    KEEP(*(.xdata*))
    KEEP(*(.eh_frame*))
  }

  /* rdata alias (placed in text PHDR as read-only) */
  .rdata : { KEEP(*(.rdata*)) } :text

  /* initialized data -> data PHDR */
  .data : AT(ADDR(.data)) :data
  {
    KEEP(*(.data*))
    KEEP(*(.sdata*))
    KEEP(*(.ctors))
    KEEP(*(.dtors))
  }

  /* relocations and writable metadata -> data PHDR */
  .reloc : AT(ADDR(.reloc)) :data
  {
    KEEP(*(.reloc*))
  }

  /* uninitialized data -> bss PHDR */
  .bss : AT(ADDR(.bss)) :bss
  {
    __bss_start = .;
    KEEP(*(.bss*))
    KEEP(*(.sbss*))
    *(COMMON)
    __bss_end = .;
  }

  /* Provide placeholder symbols for optional binary blobs (objcopy -b binary) */
  PROVIDE(_binary_init_sh_start = 0);
  PROVIDE(_binary_init_sh_end   = 0);
  PROVIDE(_binary_init_sh_size  = 0);

  /* align end */
  . = ALIGN(0x1000);
}
