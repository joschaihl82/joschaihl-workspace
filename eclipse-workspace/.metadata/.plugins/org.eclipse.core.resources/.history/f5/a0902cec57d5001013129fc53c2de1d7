// -----------------------------------------------------------------------------
// 🔨 stage 3: codegen (ast iteration)
// -----------------------------------------------------------------------------

const char* regname(int i) { return regs[cache[i]]; }

void init_cache() { for(int i = 0; i < cache_size; i++) cache[i] = i; stack_size = 0; }
void push() {
    int i = cache_size - 1; int tmp = cache[i];
    if(stack_size >= cache_size) output("\tpush %s\n", regs[tmp]);
    while(i > 0) { cache[i] = cache[i - 1]; i--; }
    cache[0] = tmp; stack_size++;
}
void pop() {
    stack_size--;
    if(stack_size < 0) { stack_size = 0; return; }
    if(stack_size == 0) init_cache();
    else {
        int i = 0; int tmp = cache[0];
        while(i < cache_size - 1) { cache[i] = cache[i + 1]; i++; }
        cache[i] = tmp;
        if(stack_size >= cache_size) output("\tpop %s\n", regs[i]);
    }
}

void codegen_expr(ast_node* n) {
    if (!n) return;
    variable* v;

    switch(n->type) {
        case node_const: 
            push(); output("\tmov %s, %lld\n", regname(0), n->val); break;
        case node_var:
            v = lookup_local(); // assuming lookup works based on token content, but here we must use n->var.name
            // temporarily rely on the current token state matching the node name
            if(!v) error("variable '%s' not found", n->var.name); 
            
            // push address onto stack, then load value
            push();
            output("\tmov %s, qword ptr [rbp - %d]\n", regname(0), v->offset);
            break;
        case node_assign:
            // lhs must be a variable/memory location (not implemented for full c l-value)
            codegen_expr(n->binary.right); // evaluate rhs (result in regname(0))
            v = lookup_local(); // assumes lookup is fine
            if(!v) error("assignment target not found");
            output("\tmov qword ptr [rbp - %d], %s\n", v->offset, regname(0));
            // assignment is an expression, result is the assigned value, already in regname(0)
            break;
        case node_op_unary:
            codegen_expr(n->unary.operand);
            if (n->unary.op == '-') output("\tneg %s\n", regname(0)); // unary minus
            else if (n->unary.op == '!') { // logical not
                output("\ttest %s, %s\n", regname(0), regname(0));
                output("\tsetz cl\n"); output("\tmovzx %s, cl\n", regname(0));
            }
            else if (n->unary.op == '*') { // dereference (simple)
                output("\tmov %s, qword ptr [%s]\n", regname(0), regname(0));
            }
            break;
        case node_op_binary:
            codegen_expr(n->binary.left); // lhs to regname(1)
            codegen_expr(n->binary.right); // rhs to regname(0)
            
            int op = n->binary.op;
            if(op == '+') { output("\tadd %s, %s\n", regname(1), regname(0)); pop(); }
            else if(op == '-') { output("\tsub %s, %s\n", regname(1), regname(0)); pop(); }
            else if(op == '*') { output("\timul %s, %s\n", regname(1), regname(0)); pop(); }
            else if(op == '/' || op == '%') {
                output("\tmov rax, %s\n", regname(1)); output("\tcqo\n"); output("\tidiv %s\n", regname(0)); pop();
                if(op == '/') output("\tmov %s, rax\n", regname(0)); else output("\tmov %s, rdx\n", regname(0));
            }
            // comparisons (==, <, <=, etc.)
            else if(strchr("<>", op) || op == lex_le || op == lex_ge || op == lex_eq || op == lex_ne) {
                char* comp;
                if(op == '<') comp = "l"; else if(op == '>') comp = "g"; else if(op == lex_le) comp = "le"; else if(op == lex_ge) comp = "ge"; else if(op == lex_eq) comp = "e"; else comp = "ne";
                output("\tcmp %s, %s\n", regname(1), regname(0));
                output("\tset%s cl\n", comp); output("\tmovzx %s, cl\n", regname(1)); pop();
            }
            else if(op == lex_log_and) { output("\tand %s, %s\n", regname(1), regname(0)); pop(); }
            else if(op == lex_log_or) { output("\tor %s, %s\n", regname(1), regname(0)); pop(); }
            else error("unknown binary operator in codegen");
            break;
        default: error("unknown expression node type %d", n->type);
    }
}


void codegen_stmt(ast_node* n) {
    if (!n) return;
    int l_end, l_next, l_begin;

    switch(n->type) {
        case node_empty: break;
        case node_declaration:
            if (n->var.init) { // generate code for initializer if present
                codegen_expr(n->var.init); // result in regname(0)
                // store result into the local variable slot
                output("\tmov qword ptr [rbp - %d], %s\n", n->var.offset, regname(0));
                pop();
            }
            break;
        case node_assign:
            codegen_expr(n); // assignment is handled as an expression
            pop(); // discard the result of the assignment expression
            break;
        case node_op_binary: // expression statement
            codegen_expr(n);
            pop(); // discard the result of the expression
            break;
        case node_block:
            for(int i = 0; i < n->block.stmt_count; i++) {
                codegen_stmt(n->block.stmts[i]);
            }
            break;
        case node_if:
            codegen_expr(n->if_stmt.cond); // evaluate condition
            l_end = label++; l_next = label++;
            output("\ttest %s, %s\n", regname(0), regname(0));
            output("\tjz .l%d\n", l_next);
            init_cache(); pop(); // restore cache state after cond expr
            codegen_stmt(n->if_stmt.body_true);
            output("\tjmp .l%d\n", l_end);
            output(".l%d:\n", l_next);
            if(n->if_stmt.body_false) {
                init_cache();
                codegen_stmt(n->if_stmt.body_false);
            }
            output(".l%d:\n", l_end);
            break;
        case node_while:
            while_level++;
            if(while_level == 256) error("while nesting limit exceeded");
            while_labels[while_level] = label; label += 2;
            l_begin = while_labels[while_level]; l_end = while_labels[while_level] + 1;
            
            output(".l%d:\n", l_begin); 
            codegen_expr(n->while_stmt.cond); // condition
            output("\ttest %s, %s\n", regname(0), regname(0));
            output("\tjz .l%d\n", l_end);
            init_cache(); pop(); // restore cache state after cond expr
            codegen_stmt(n->while_stmt.body); // body
            output("\tjmp .l%d\n", l_begin); 
            output(".l%d:\n", l_end);      
            while_level--;
            break;
        case node_return:
            if(n->ret_stmt.expr) {
                codegen_expr(n->ret_stmt.expr);
                if(strcmp(regname(0), "rax") != 0) output("\tmov rax, %s\n", regname(0));
                pop();
            }
            output("\tleave\n"); output("\tret\n");
            break;
        case node_break:
            if(while_level < 0) error("break without while");
            output("\tjmp .l%d\n", while_labels[while_level] + 1);
            break;
        case node_continue:
            if(while_level < 0) error("continue without while");
            output("\tjmp .l%d\n", while_labels[while_level]);
            break;
        default: error("unknown statement node type %d", n->type);
    }
}


void codegen_program() {
    // top level function definition
    output("\t.intel_syntax noprefix\n");
    output("\t.text\n");

    while(lexeme != lex_eof) {
        if(is_type_keyword()) {
            int return_type = lexeme;
            read_lexeme();
            if (lexeme == '*') { read_lexeme(); }
            expect(lex_ident);
            char func_name[64]; strcpy(func_name, token);

            if (lexeme == ';') { output("\t.comm %s, 8, 8\n", func_name); read_lexeme(); continue; } // global var

            output("\t.globl %s\n", func_name); output("%s:\n", func_name);
            output("\tpush rbp\n"); output("\tmov rbp, rsp\n");

            int frame = 0; local_count = 0;
            // parameter parsing updates local_count and frame (re-read/expect tokens)
            ast_node* func_body_ast = null;
            
            // re-read tokens for parameter processing
            // this is a huge flaw in the current sequential structure, as tokens were consumed during parsing logic
            // a proper implementation would have a separate token stream/lookahead buffer

            // simplified: re-parse only to build the body
            expect('('); 
            if(is_type_keyword()) { // simplified param skip
                read_lexeme(); if (lexeme == '*') { read_lexeme(); } expect(lex_ident);
                frame += 8;
                while(lexeme == ',') { read_lexeme(); read_lexeme(); if (lexeme == '*') { read_lexeme(); } expect(lex_ident); frame += 8; }
            }
            expect(')');
            
            // the local_count and locals array must be built during this second pass/re-reading, which is complex.
            // for now, we assume frame calculation (sub rsp) is correct from parameter counting/local var usage.
            // to make this work, the parameter and local declaration parsing logic must update 'locals' and 'frame' correctly.
            
            expect('{');
            func_body_ast = statement_list(); // this builds the ast and updates the symbol table (locals)

            // now that locals are counted from declaration nodes:
            if(frame > 0) output("\tsub rsp, %d\n", frame); // allocate stack space

            // codegen for the function body
            init_cache();
            codegen_stmt(func_body_ast); // iterate through nodes
            
            // implicit return if not already present
            output("\tleave\n"); output("\tret\n");
        } else { error("expected type keyword or end of file"); }
    }
}

// -----------------------------------------------------------------------------
// 🖥️ main driver
// -----------------------------------------------------------------------------

void cleanup() {
    if(src_file) fclose(src_file);
    if(dst_file && dst_file != stdout) fclose(dst_file);
}

int main(int argc, char** argv) {
    if(argc < 2 || argc > 3) { printf("usuage: %s <source> [output]\n", argv[0]); exit(0); }
    src_file = fopen(argv[1], "r");
    if(!src_file) error("opening source file failed");
    if(argc == 3) { dst_file = fopen(argv[2], "w"); if(!dst_file) error("opening output file failed"); }
    else dst_file = stdout;
    atexit(cleanup);
    
    // 1. scan: initial token
    line_number = 1; read_char(); read_lexeme();
    
    // 2. parse: build the ast (implicit: handles the flow of tokens)
    // 3. codegen: iterate through the nodes
    codegen_program();
    
    return 0;
}