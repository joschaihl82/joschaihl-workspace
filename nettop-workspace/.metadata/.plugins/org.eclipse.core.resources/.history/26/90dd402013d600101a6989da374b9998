static const int DNS_CACHE_TTL = 60; // seconds

// ---------- Utility helpers ----------
static QString ipToString(uint32_t ip_net) {
    struct in_addr a;
    a.s_addr = ip_net;
    char buf[INET_ADDRSTRLEN];
    inet_ntop(AF_INET, &a, buf, sizeof(buf));
    return QString::fromUtf8(buf);
}

static QString nowTimestamp() {
    return QDateTime::currentDateTime().toString("yyyy-MM-dd HH:mm:ss");
}

// ---------- Simple reverse DNS cache ----------
struct DnsCacheEntry {
    uint32_t ip;
    QString name;
    qint64 ts;
    bool used;
    DnsCacheEntry(): ip(0), name("-"), ts(0), used(false) {}
};

class DnsCache {
public:
    DnsCache(int size = 1024): size_(size) {
        entries_.resize(size_);
    }
    QString resolve(uint32_t ip_net) {
        if (ip_net == 0) return "-";
        int idx = hash(ip_net);
        qint64 now = QDateTime::currentSecsSinceEpoch();
        for (int i = 0; i < size_; ++i) {
            int j = (idx + i) & (size_ - 1);
            if (entries_[j].used && entries_[j].ip == ip_net) {
                if (now - entries_[j].ts <= DNS_CACHE_TTL) return entries_[j].name;
                break;
            }
            if (!entries_[j].used) { idx = j; break; }
        }
        // perform reverse lookup
        struct sockaddr_in sa;
        sa.sin_family = AF_INET;
        sa.sin_addr.s_addr = ip_net;
        char hostbuf[NI_MAXHOST];
        int rc = getnameinfo((struct sockaddr *)&sa, sizeof(sa), hostbuf, sizeof(hostbuf), NULL, 0, NI_NAMEREQD);
        QString name;
        if (rc == 0) name = QString::fromUtf8(hostbuf);
        else name = ipToString(ip_net);
        // store
        for (int i = 0; i < size_; ++i) {
            int j = (idx + i) & (size_ - 1);
            if (!entries_[j].used || entries_[j].ip == ip_net || (now - entries_[j].ts) > DNS_CACHE_TTL) {
                entries_[j].used = true;
                entries_[j].ip = ip_net;
                entries_[j].name = name;
                entries_[j].ts = now;
                return name;
            }
        }
        // fallback overwrite
        entries_[idx].used = true;
        entries_[idx].ip = ip_net;
        entries_[idx].name = name;
        entries_[idx].ts = now;
        return name;
    }
private:
    int hash(uint32_t ip) {
        return (int)((ip * 2654435761u) & (size_ - 1));
    }
    int size_;
    std::vector<DnsCacheEntry> entries_;
};

// ---------- Process lookup (best-effort) ----------
static bool readFileLine(const QString &path, QString &out) {
    FILE *f = fopen(path.toUtf8().constData(), "r");
    if (!f) return false;
    char buf[512];
    if (!fgets(buf, sizeof(buf), f)) { fclose(f); return false; }
    fclose(f);
    size_t len = strlen(buf);
    if (len && buf[len-1] == '\n') buf[len-1] = '\0';
    out = QString::fromUtf8(buf);
    return true;
}

// Find inode for local port in /proc/net/{tcp,udp}
static bool findInodeForPort(const char *proto, int port, QString &inodeOut) {
    char path[64];
    snprintf(path, sizeof(path), "/proc/net/%s", proto);
    FILE *f = fopen(path, "r");
    if (!f) return false;
    char line[1024];
    // skip header
    if (!fgets(line, sizeof(line), f)) { fclose(f); return false; }
    while (fgets(line, sizeof(line), f)) {
        unsigned long inode = 0;
        char local_addr[64];
        int items = sscanf(line, "%*d: %63s %*s %*s %*s %*s %*s %*s %*s %lu", local_addr, &inode);
        if (items >= 2) {
            char *colon = strchr(local_addr, ':');
            if (!colon) continue;
            unsigned int p;
            if (sscanf(colon + 1, "%x", &p) != 1) continue;
            if ((int)p == port) {
                inodeOut = QString::number(inode);
                fclose(f);
                return true;
            }
        }
    }
    fclose(f);
    return false;
}

// Given inode string, scan /proc/<pid>/fd for socket:[inode]
static bool findProcessByInode(const QString &inode, QString &procNameOut) {
    DIR *pdir = opendir("/proc");
    if (!pdir) return false;
    struct dirent *dent;
    while ((dent = readdir(pdir)) != NULL) {
        char *endptr;
        long pid = strtol(dent->d_name, &endptr, 10);
        if (*endptr != '\0') continue;
        char fdpath[PATH_MAX];
        snprintf(fdpath, sizeof(fdpath), "/proc/%ld/fd", pid);
        DIR *fddir = opendir(fdpath);
        if (!fddir) continue;
        struct dirent *fdent;
        while ((fdent = readdir(fddir)) != NULL) {
            if (strcmp(fdent->d_name, ".") == 0 || strcmp(fdent->d_name, "..") == 0) continue;
            char linkpath[PATH_MAX];
            char target[PATH_MAX];
            snprintf(linkpath, sizeof(linkpath), "%s/%s", fdpath, fdent->d_name);
            ssize_t r = readlink(linkpath, target, sizeof(target)-1);
            if (r <= 0) continue;
            target[r] = '\0';
            char want[64];
            snprintf(want, sizeof(want), "socket:[%s]", inode.toUtf8().constData());
            if (strcmp(target, want) == 0) {
                // read /proc/<pid>/comm
                char commpath[PATH_MAX];
                snprintf(commpath, sizeof(commpath), "/proc/%ld/comm", pid);
                QString comm;
                if (readFileLine(QString::fromUtf8(commpath), comm)) {
                    procNameOut = comm;
                    closedir(fddir);
                    closedir(pdir);
                    return true;
                } else {
                    // fallback to cmdline
                    char cmdpath[PATH_MAX];
                    snprintf(cmdpath, sizeof(cmdpath), "/proc/%ld/cmdline", pid);
                    FILE *cf = fopen(cmdpath, "r");
                    if (cf) {
                        char buf[512];
                        if (fgets(buf, sizeof(buf), cf)) {
                            // cmdline is NUL-separated
                            for (size_t i = 0; i < sizeof(buf); ++i) if (buf[i] == '\0') buf[i] = ' ';
                            procNameOut = QString::fromUtf8(buf);
                            fclose(cf);
                            closedir(fddir);
                            closedir(pdir);
                            return true;
                        }
                        fclose(cf);
                    }
                    closedir(fddir);
                    closedir(pdir);
                    return false;
                }
            }
        }
        closedir(fddir);
    }
    closedir(pdir);
    return false;
}

// High-level: map proto+port to process name or "-"
static QString getProcessNameForLocalPort(const char *proto, int port) {
    QString inode;
    if (findInodeForPort(proto, port, inode)) {
        QString pname;
        if (findProcessByInode(inode, pname)) {
            return pname;
        }
    }
    return QString("-");
}

// ---------- Connection key and stats ----------
struct ConnKey {
    QString app; // process name (best-effort)
    QString src; // "ip:port"
    QString dst; // "ip:port"
    bool operator<(const ConnKey &o) const {
        if (app != o.app) return app < o.app;
        if (src != o.src) return src < o.src;
        return dst < o.dst;
    }
};

struct ConnStats {
    qint64 bytes_in = 0;   // bytes received by local endpoint (from remote -> local)
    qint64 bytes_out = 0;  // bytes sent by local endpoint (local -> remote)
    qint64 last_bytes_in = 0;  // for MB/s calc
    qint64 last_bytes_out = 0;
    double mb_in = 0.0;
    double mb_out = 0.0;
    double mbps_in = 0.0;
    double mbps_out = 0.0;
    QString last_request; // human readable last interpreted request (HTTP line, DNS query, SNI, DHCP)
    qint64 last_seen = 0; // epoch seconds
};

// ---------- Packet capture thread ----------
class PcapWorker : public QThread {
    Q_OBJECT
public:
    PcapWorker(const QString &iface, const QString &filterExpr)
        : iface_(iface), filterExpr_(filterExpr), stopFlag_(false) {}

    void stop() {
        stopFlag_.store(true);
        if (handle_) pcap_breakloop(handle_);
    }

    void run() override {
        char errbuf[PCAP_ERRBUF_SIZE];
        handle_ = pcap_open_live(iface_.toUtf8().constData(), 65535, 1, 1000, errbuf);
        if (!handle_) {
            emit error(QString("pcap_open_live failed: %1").arg(errbuf));
            return;
        }
        if (!filterExpr_.isEmpty()) {
            struct bpf_program fp;
            if (pcap_compile(handle_, &fp, filterExpr_.toUtf8().constData(), 1, PCAP_NETMASK_UNKNOWN) == -1 ||
                pcap_setfilter(handle_, &fp) == -1) {
                emit error(QString("filter error: %1").arg(pcap_geterr(handle_)));
                pcap_freecode(&fp);
                pcap_close(handle_);
                handle_ = nullptr;
                return;
            }
            pcap_freecode(&fp);
        }
        // start loop
        pcap_loop(handle_, -1, &PcapWorker::pcapCallback, reinterpret_cast<u_char*>(this));
        if (handle_) {
            pcap_close(handle_);
            handle_ = nullptr;
        }
    }

signals:
    void packetParsed(const ConnKey &key, qint64 bytes_in, qint64 bytes_out, const QString &lastRequest, qint64 ts);

    void error(const QString &msg);

private:
    QString iface_;
    QString filterExpr_;
    std::atomic<bool> stopFlag_;
    pcap_t *handle_ = nullptr;

    static void pcapCallback(u_char *user, const struct pcap_pkthdr *h, const u_char *bytes) {
        PcapWorker *self = reinterpret_cast<PcapWorker*>(user);
        if (!self) return;
        self->processPacket(h, bytes);
    }

    // Basic parsers: HTTP request, DNS query, TLS SNI, DHCP
    static bool isHttpMethod(const char *p, size_t len) {
        static const char *methods[] = {"GET", "POST", "PUT", "DELETE", "HEAD", "OPTIONS", "PATCH", "CONNECT", "TRACE"};
        for (const char *m : methods) {
            size_t ml = strlen(m);
            if (len >= ml + 1 && memcmp(p, m, ml) == 0 && p[ml] == ' ') return true;
        }
        return false;
    }

    static QString parseHttpRequest(const u_char *payload, size_t plen) {
        const char *p = reinterpret_cast<const char*>(payload);
        const char *end = p + plen;
        const char *hdr_end = strstr(p, "\r\n\r\n");
        if (!hdr_end) return QString();
        const char *line_end = (const char*)memchr(p, '\n', hdr_end - p);
        if (!line_end) return QString();
        size_t first_len = line_end - p;
        if (first_len > 0 && p[first_len-1] == '\r') first_len--;
        if (!isHttpMethod(p, first_len)) return QString();
        QString reqline = QString::fromUtf8(p, (int)first_len);
        // find Host header
        const char *cur = line_end + 1;
        QString host;
        while (cur < hdr_end) {
            const char *next = (const char*)memchr(cur, '\n', hdr_end - cur);
            if (!next) break;
            size_t l = next - cur;
            if (l > 0 && cur[l-1] == '\r') l--;
            if (l >= 5 && strncasecmp(cur, "Host:", 5) == 0) {
                const char *val = cur + 5;
                while (val < next && (*val == ' ' || *val == '\t')) ++val;
                int copylen = (int)(next - val);
                if (copylen > 0) host = QString::fromUtf8(val, copylen);
                break;
            }
            cur = next + 1;
        }
        if (!host.isEmpty()) reqline += " Host: " + host;
        return reqline;
    }

    static QString parseDnsQuery(const u_char *payload, size_t plen) {
        if (plen < 12) return QString();
        uint16_t qdcount = ntohs(*(uint16_t*)(payload + 4));
        if (qdcount == 0) return QString();
        size_t off = 12;
        QString qname;
        while (off < plen) {
            uint8_t len = payload[off++];
            if (len == 0) break;
            if (len & 0xC0) { // compression pointer
                if (off >= plen) break;
                off++;
                break;
            }
            if (off + len > plen) break;
            qname += QString::fromUtf8((const char*)(payload + off), len);
            qname += ".";
            off += len;
        }
        if (!qname.isEmpty() && qname.endsWith(".")) qname.chop(1);
        return qname;
    }

    static QString parseTlsSni(const u_char *payload, size_t plen) {
        if (plen < 5) return QString();
        const u_char *p = payload;
        uint8_t rec_type = p[0];
        if (rec_type != 22) return QString();
        uint16_t rec_len = (p[3] << 8) | p[4];
        if (5 + rec_len > plen) return QString();
        p += 5;
        size_t remain = rec_len;
        if (remain < 4) return QString();
        uint8_t hs_type = p[0];
        if (hs_type != 1) return QString();
        uint32_t hs_len = ((uint32_t)p[1] << 16) | ((uint32_t)p[2] << 8) | p[3];
        if (hs_len + 4 > remain) return QString();
        p += 4;
        size_t hs_rem = hs_len;
        if (hs_rem < 2 + 32 + 1) return QString();
        p += 2 + 32;
        hs_rem -= 34;
        if (hs_rem < 1) return QString();
        uint8_t sid_len = p[0];
        p += 1; hs_rem -= 1;
        if (hs_rem < sid_len) return QString();
        p += sid_len; hs_rem -= sid_len;
        if (hs_rem < 2) return QString();
        uint16_t cs_len = (p[0] << 8) | p[1];
        p += 2; hs_rem -= 2;
        if (hs_rem < cs_len) return QString();
        p += cs_len; hs_rem -= cs_len;
        if (hs_rem < 1) return QString();
        uint8_t comp_len = p[0];
        p += 1; hs_rem -= 1;
        if (hs_rem < comp_len) return QString();
        p += comp_len; hs_rem -= comp_len;
        if (hs_rem < 2) return QString();
        uint16_t ext_total = (p[0] << 8) | p[1];
        p += 2; hs_rem -= 2;
        if (hs_rem < ext_total) return QString();
        const u_char *ext_end = p + ext_total;
        while (p + 4 <= ext_end) {
            uint16_t ext_type = (p[0] << 8) | p[1];
            uint16_t ext_len = (p[2] << 8) | p[3];
            p += 4;
            if (p + ext_len > ext_end) break;
            if (ext_type == 0x0000) {
                if (ext_len < 2) break;
                uint16_t list_len = (p[0] << 8) | p[1];
                const u_char *q = p + 2;
                const u_char *qend = p + ext_len;
                while (q + 3 <= qend) {
                    uint8_t name_type = q[0];
                    uint16_t name_len = (q[1] << 8) | q[2];
                    q += 3;
                    if (q + name_len > qend) break;
                    if (name_type == 0) {
                        return QString::fromUtf8((const char*)q, name_len);
                    }
                    q += name_len;
                }
                break;
            }
            p += ext_len;
        }
        return QString();
    }

    static QString parseDhcp(const u_char *payload, size_t plen) {
        if (plen < 240) return QString();
        const u_char *p = payload;
        uint8_t op = p[0];
        uint32_t xid = ntohl(*(uint32_t*)(p + 4));
        uint32_t yiaddr = *(uint32_t*)(p + 16);
        if (!(payload[236] == 0x63 && payload[237] == 0x82 && payload[238] == 0x53 && payload[239] == 0x63)) {
            return QString();
        }
        const u_char *options = payload + 240;
        size_t optlen = plen - 240;
        int msg_type = -1;
        QString hostname;
        uint32_t req_ip = 0;
        size_t off = 0;
        while (off < optlen) {
            uint8_t code = options[off++];
            if (code == 0xff) break;
            if (code == 0x00) continue;
            if (off >= optlen) break;
            uint8_t len = options[off++];
            if (off + len > optlen) break;
            if (code == 53 && len == 1) msg_type = options[off];
            else if (code == 12) hostname = QString::fromUtf8((const char*)(options + off), len);
            else if (code == 50 && len == 4) memcpy(&req_ip, options + off, 4);
            off += len;
        }
        QString mt;
        switch (msg_type) {
            case 1: mt = "DISCOVER"; break;
            case 2: mt = "OFFER"; break;
            case 3: mt = "REQUEST"; break;
            case 5: mt = "ACK"; break;
            default: mt = QString("TYPE%1").arg(msg_type);
        }
        QString yi = yiaddr ? ipToString(yiaddr) : QString("-");
        QString rip = req_ip ? ipToString(req_ip) : QString("-");
        return QString("DHCP %1 xid=0x%2 yi=%3 req=%4 host=%5")
                .arg(mt).arg(QString::number(xid, 16)).arg(yi).arg(rip).arg(hostname.isEmpty() ? "-" : hostname);
    }

    void processPacket(const struct pcap_pkthdr *h, const u_char *bytes) {
        if (!h || !bytes) return;
        // minimal ethernet + ipv4 parsing
        if (h->caplen < sizeof(struct ether_header)) return;
        const struct ether_header *eth = (const struct ether_header*)bytes;
        uint16_t eth_type = ntohs(eth->ether_type);
        if (eth_type != ETHERTYPE_IP) return;
        size_t ip_off = sizeof(struct ether_header);
        if (h->caplen < ip_off + sizeof(struct ip)) return;
        const struct ip *ip = (const struct ip*)(bytes + ip_off);
        int ihl = ip->ip_hl * 4;
        if (ihl < 20) return;
        if (h->caplen < ip_off + ihl) return;
        uint32_t src_ip = ip->ip_src.s_addr;
        uint32_t dst_ip = ip->ip_dst.s_addr;
        qint64 ts = (qint64)h->ts.tv_sec;
        if (ip->ip_p == IPPROTO_TCP) {
            size_t tcp_off = ip_off + ihl;
            if (h->caplen < tcp_off + sizeof(struct tcphdr)) return;
            const struct tcphdr *tcp = (const struct tcphdr*)(bytes + tcp_off);
            int tcp_hdr_len = tcp->th_off * 4;
            if (tcp_hdr_len < 20) return;
            if (h->caplen < tcp_off + tcp_hdr_len) return;
            size_t payload_off = tcp_off + tcp_hdr_len;
            size_t payload_len = (h->caplen > payload_off) ? (h->caplen - payload_off) : 0;
            const u_char *payload = bytes + payload_off;
            unsigned short sport = ntohs(tcp->th_sport);
            unsigned short dport = ntohs(tcp->th_dport);

            // determine direction: assume local host is the one with a process owning the local port
            // try destination port as local (server) first
            QString proc = getProcessNameForLocalPort("tcp", dport);
            bool localIsDst = (proc != "-");
            if (!localIsDst) {
                proc = getProcessNameForLocalPort("tcp", sport);
                localIsDst = (proc != "-");
            }
            // build key: app, src:port, dst:port (we keep literal src/dst)
            QString src = ipToString(src_ip) + ":" + QString::number(sport);
            QString dst = ipToString(dst_ip) + ":" + QString::number(dport);
            ConnKey key{proc, src, dst};

            QString lastReq;
            // HTTP detection
            if (payload_len > 0 && (dport == 80 || sport == 80)) {
                if (isHttpMethod((const char*)payload, payload_len)) {
                    lastReq = parseHttpRequest(payload, payload_len);
                }
            }
            // TLS SNI
            if (lastReq.isEmpty() && (dport == 443 || sport == 443) && payload_len > 0) {
                QString sni = parseTlsSni(payload, payload_len);
                if (!sni.isEmpty()) lastReq = QString("TLS SNI: %1").arg(sni);
            }
            // default lastReq for other protocols left empty
            // bytes accounting: if local is dst, bytes_in increases by payload_len; if local is src, bytes_out increases
            qint64 bin = 0, bout = 0;
            if (localIsDst) bin = payload_len;
            else bout = payload_len;

            emit packetParsed(key, bin, bout, lastReq, ts);
        } else if (ip->ip_p == IPPROTO_UDP) {
            size_t udp_off = ip_off + ihl;
            if (h->caplen < udp_off + sizeof(struct udphdr)) return;
            const struct udphdr *udp = (const struct udphdr*)(bytes + udp_off);
            size_t payload_off = udp_off + sizeof(struct udphdr);
            size_t payload_len = (h->caplen > payload_off) ? (h->caplen - payload_off) : 0;
            const u_char *payload = bytes + payload_off;
            unsigned short sport = ntohs(udp->uh_sport);
            unsigned short dport = ntohs(udp->uh_dport);

            QString proc = getProcessNameForLocalPort("udp", dport);
            bool localIsDst = (proc != "-");
            if (!localIsDst) {
                proc = getProcessNameForLocalPort("udp", sport);
                localIsDst = (proc != "-");
            }
            QString src = ipToString(src_ip) + ":" + QString::number(sport);
            QString dst = ipToString(dst_ip) + ":" + QString::number(dport);
            ConnKey key{proc, src, dst};

            QString lastReq;
            // DNS
            if (dport == 53 || sport == 53) {
                QString q = parseDnsQuery(payload, payload_len);
                if (!q.isEmpty()) lastReq = QString("DNS Q: %1").arg(q);
            }
            // DHCP (ports 67/68)
            if ((dport == 67 || dport == 68 || sport == 67 || sport == 68) && payload_len > 0) {
                QString dh = parseDhcp(payload, payload_len);
                if (!dh.isEmpty()) lastReq = dh;
            }

            qint64 bin = 0, bout = 0;
            if (localIsDst) bin = payload_len;
            else bout = payload_len;

            emit packetParsed(key, bin, bout, lastReq, ts);
        }
    }
};

// ---------- MainWindow with table ----------
class MainWindow : public QMainWindow {
    Q_OBJECT
public:
    MainWindow(QWidget *parent = nullptr)
        : QMainWindow(parent), dnsCache_(1024) {
        setWindowTitle("TinyDump Qt - Connections");
        resize(1100, 600);

        QWidget *central = new QWidget(this);
        QVBoxLayout *vbox = new QVBoxLayout(central);

        // top controls
        QHBoxLayout *hbox = new QHBoxLayout();
        hbox->addWidget(new QLabel("Interface:"));
        ifaceEdit_ = new QLineEdit(DEFAULT_IFACE);
        hbox->addWidget(ifaceEdit_);
        hbox->addWidget(new QLabel("Filter:"));
        filterEdit_ = new QLineEdit(DEFAULT_FILTER);
        hbox->addWidget(filterEdit_);
        startBtn_ = new QPushButton("Start");
        stopBtn_ = new QPushButton("Stop");
        stopBtn_->setEnabled(false);
        hbox->addWidget(startBtn_);
        hbox->addWidget(stopBtn_);
        vbox->addLayout(hbox);

        // table
        tableView_ = new QTableView(this);
        model_ = new QStandardItemModel(this);
        QStringList headers = {"Application", "Source:Port", "Destination:Port", "Last Request", "MB input", "MB output", "MB/s in", "MB/s out", "Last seen"};
        model_->setHorizontalHeaderLabels(headers);
        tableView_->setModel(model_);
        tableView_->setSortingEnabled(true);
        tableView_->horizontalHeader()->setSectionResizeMode(QHeaderView::Stretch);
        vbox->addWidget(tableView_);

        setCentralWidget(central);

        // timer to update UI
        uiTimer_ = new QTimer(this);
        uiTimer_->setInterval(UPDATE_INTERVAL_MS);
        connect(uiTimer_, &QTimer::timeout, this, &MainWindow::onUiTimer);

        // start/stop
        connect(startBtn_, &QPushButton::clicked, this, &MainWindow::onStart);
        connect(stopBtn_, &QPushButton::clicked, this, &MainWindow::onStop);

        // prepare worker pointer
        worker_ = nullptr;
    }

    ~MainWindow() {
        stopWorker();
    }

public slots:
    void onStart() {
        if (worker_) return;
        QString iface = ifaceEdit_->text().trimmed();
        if (iface.isEmpty()) iface = DEFAULT_IFACE;
        QString filter = filterEdit_->text();
        worker_ = new PcapWorker(iface, filter);
        connect(worker_, &PcapWorker::packetParsed, this, &MainWindow::onPacketParsed, Qt::QueuedConnection);
        connect(worker_, &PcapWorker::error, this, &MainWindow::onWorkerError, Qt::QueuedConnection);
        worker_->start();
        startBtn_->setEnabled(false);
        stopBtn_->setEnabled(true);
        uiTimer_->start();
    }

    void onStop() {
        stopWorker();
        startBtn_->setEnabled(true);
        stopBtn_->setEnabled(false);
        uiTimer_->stop();
    }

    void onWorkerError(const QString &msg) {
        qWarning() << "Worker error:" << msg;
    }

    void onPacketParsed(const ConnKey &key, qint64 bin, qint64 bout, const QString &lastReq, qint64 ts) {
        QMutexLocker locker(&mapMutex_);
        ConnStats &s = stats_[key];
        s.bytes_in += bin;
        s.bytes_out += bout;
        if (!lastReq.isEmpty()) s.last_request = lastReq;
        s.last_seen = ts;
    }

    void onUiTimer() {
        // compute MB and MB/s
        qint64 now = QDateTime::currentSecsSinceEpoch();
        QMutexLocker locker(&mapMutex_);
        model_->removeRows(0, model_->rowCount());
        int row = 0;
        for (auto it = stats_.begin(); it != stats_.end(); ++it) {
            const ConnKey &k = it.key();
            ConnStats &s = it.value();
            // compute MB
            s.mb_in = s.bytes_in / (1024.0 * 1024.0);
            s.mb_out = s.bytes_out / (1024.0 * 1024.0);
            // compute MB/s based on last_bytes_* (delta over interval)
            qint64 delta_in = s.bytes_in - s.last_bytes_in;
            qint64 delta_out = s.bytes_out - s.last_bytes_out;
            s.mbps_in = (delta_in / (1024.0 * 1024.0)) * (1000.0 / UPDATE_INTERVAL_MS);
            s.mbps_out = (delta_out / (1024.0 * 1024.0)) * (1000.0 / UPDATE_INTERVAL_MS);
            s.last_bytes_in = s.bytes_in;
            s.last_bytes_out = s.bytes_out;

            QList<QStandardItem*> items;
            items << new QStandardItem(k.app);
            items << new QStandardItem(k.src);
            items << new QStandardItem(k.dst);
            items << new QStandardItem(s.last_request.isEmpty() ? "-" : s.last_request);
            items << new QStandardItem(QString::number(s.mb_in, 'f', 3));
            items << new QStandardItem(QString::number(s.mb_out, 'f', 3));
            items << new QStandardItem(QString::number(s.mbps_in, 'f', 3));
            items << new QStandardItem(QString::number(s.mbps_out, 'f', 3));
            items << new QStandardItem(QDateTime::fromSecsSinceEpoch(s.last_seen).toString("HH:mm:ss"));

            model_->insertRow(row, items);
            ++row;
        }
    }

private:
    void stopWorker() {
        if (worker_) {
            worker_->stop();
            worker_->wait(2000);
            delete worker_;
            worker_ = nullptr;
        }
    }

    QLineEdit *ifaceEdit_;
    QLineEdit *filterEdit_;
    QPushButton *startBtn_;
    QPushButton *stopBtn_;
    QTableView *tableView_;
    QStandardItemModel *model_;
    QTimer *uiTimer_;
    PcapWorker *worker_;
    QMutex mapMutex_;
    QMap<ConnKey, ConnStats> stats_;
    DnsCache dnsCache_;
};

// ---------- main ----------
int main(int argc, char **argv) {
    QApplication app(argc, argv);
    MainWindow w;
    w.show();
    return app.exec();
}

