// 🔎 stage 1: scanning (lexer)
// -----------------------------------------------------------------------------

int read_char() {
    // ... (unchanged) ...
    int c = character;
    character = fgetc(src_file);
    cursor_pos++;
    if(c == '\n') {
        line_number++;
        cursor_pos = 0;
    }
    return c;
}

int scan() {
space:
    while(isspace(character)) read_char();
    if (character == '/') {
        read_char();
        if (character == '/') { while(character != '\n' && character != lex_eof) read_char(); goto space; } 
        else if (character == '*') { 
            read_char(); while(character != lex_eof) { if (character == '*' && fgetc(src_file) == '/') { read_char(); goto space; } read_char(); }
            error("unclosed multi-line comment");
        } else { character = '/'; }
    }
    if(character == '#') { while(character != '\n' && character != lex_eof) read_char(); goto space; }
    
    if(strchr("-+*/%&|~!=<>;:()[],@{}", character)) {
        int c = read_char();
        if(strchr("<>!=", c) && character == '=') { read_char(); switch(c) { case '<': return lex_le; case '>': return lex_ge; case '=': return lex_eq; case '!': return lex_ne; } }
        else if (c == '&' && character == '&') { read_char(); return lex_log_and; }
        else if (c == '|' && character == '|') { read_char(); return lex_log_or; }
        else if (c == '-' && character == '>') { read_char(); return lex_ptr_op; }
        else if(c == '(' || c == '[' || c == '{') brackets++;
        else if(c == ')' || c == ']' || c == '}') brackets--;
        if(isdigit(character)) neg_number = (c == '-');
        return c;
    }

    if(character == '\'') { /* ... char logic ... */ read_char(); token[0] = '\''; int i = 1; if(character == '\\') token[i++] = read_char(); token[i++] = read_char(); token[i++] = '\''; token[i] = '\0'; if(read_char() != '\'') error("bad character literal"); return lex_char; }
    if(character == '"') { /* ... string logic ... */ int i = 0; read_char(); do { if(character == '\\') token[i++] = read_char(); token[i++] = read_char(); if(i > 1020) error("string too long"); if (character == lex_eof || character == '\n') error("unclosed string literal"); } while(character != '"'); token[i++] = read_char(); token[i] = '\0'; return lex_string; }
    if(isdigit(character)) { /* ... number logic ... */ int i = 0; do { token[i++] = read_char(); if(i > 20) error("number too long"); } while(isdigit(character)); token[i] = '\0'; number = atoll(token); return lex_number; }

    if(isalpha(character) || character == '_') {
        int i = 0; do { token[i++] = read_char(); if(i > 62) error("identifier too long"); } while(isalnum(character) || character == '_');
        token[i] = '\0'; for(i = 0; i < lex_keyword_count; i++) { if(strcmp(token, keywords[i]) == 0) return i; }
        return lex_ident;
    }
    if(character != lex_eof) error("unknown character: %c", character);
    return lex_eof;
}

void read_lexeme() { lexeme = scan(); }

void expect(int l) {
    if(lexeme != l) {
        if(l < lex_keyword_count) error("expected keyword %s", keywords[l]);
        else if (l == lex_ident) error("expected identifier");
        else if (l == lex_number) error("expected number");
        else error("expected '%c'", l);
    }
    read_lexeme();
}

