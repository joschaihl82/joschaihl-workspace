// Simple PCM silence generator
static QByteArray silencePcm(int ms, int sampleRate = 8000, int channels = 1) {
    int samples = (sampleRate * ms) / 1000;
    int bytes = samples * channels * 2;
    QByteArray ba(bytes, 0);
    return ba;
}

// Simple PCM tone generator (sine wave)
static QByteArray tonePcm(int ms, int sampleRate = 8000, int channels = 1, double freq = 440.0) {
    int samples = (sampleRate * ms) / 1000;
    QByteArray ba;
    ba.resize(samples * channels * 2);
    qint16 *ptr = reinterpret_cast<qint16 *>(ba.data());
    for (int i = 0; i < samples; ++i) {
        double t = static_cast<double>(i) / sampleRate;
        double v = sin(2.0 * M_PI * freq * t) * 3000.0;
        qint16 s = static_cast<qint16>(v);
        for (int c = 0; c < channels; ++c) {
            *ptr++ = s;
        }
    }
    return ba;
}

