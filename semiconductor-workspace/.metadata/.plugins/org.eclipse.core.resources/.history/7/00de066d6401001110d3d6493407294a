#include <SDL2/SDL.h>
#include <cmath>
#include <vector>
#include <iostream>

struct Vec2 {
    double x, y;
};

int main(int argc, char** argv) {
    const int NX = 400;   // Breite des Gitters
    const int NY = 200;   // Höhe des Gitters
    const int SCALE = 3;  // Pixel pro Zelle

    // SDL init
    if (SDL_Init(SDL_INIT_VIDEO) != 0) {
        std::cerr << "SDL_Init failed\n";
        return 1;
    }

    SDL_Window* window = SDL_CreateWindow(
        "Lattice Boltzmann Wasserleitungen (D2Q9)",
        SDL_WINDOWPOS_CENTERED, SDL_WINDOWPOS_CENTERED,
        NX * SCALE, NY * SCALE, SDL_WINDOW_SHOWN
    );
    if (!window) {
        std::cerr << "SDL_CreateWindow failed\n";
        SDL_Quit();
        return 1;
    }

    SDL_Renderer* renderer = SDL_CreateRenderer(
        window, -1, SDL_RENDERER_ACCELERATED | SDL_RENDERER_PRESENTVSYNC
    );
    if (!renderer) {
        std::cerr << "SDL_CreateRenderer failed\n";
        SDL_DestroyWindow(window);
        SDL_Quit();
        return 1;
    }

    // D2Q9 LBM Parameter
    const int Q = 9;
    const int ex[Q] = {0, 1, 0, -1, 0, 1, -1, -1, 1};
    const int ey[Q] = {0, 0, 1, 0, -1, 1, 1, -1, -1};
    const double w[Q] = {
        4.0/9.0,
        1.0/9.0, 1.0/9.0, 1.0/9.0, 1.0/9.0,
        1.0/36.0, 1.0/36.0, 1.0/36.0, 1.0/36.0
    };

    const double tau = 0.8; // Relaxationszeit
    const double omega = 1.0 / tau;

    // Gitterfelder: f (aktuell), f_next (nach Streaming)
    std::vector<double> f(NX * NY * Q, 0.0);
    std::vector<double> f_next(NX * NY * Q, 0.0);

    auto idx = [=](int x, int y, int k) {
        return (y * NX + x) * Q + k;
    };

    // Geometrie: 3 Leitungen
    // Oben: dicke Leitung
    int top_y1 = 20;
    int top_y2 = 80;

    // Mitte: mittlere Leitung
    int mid_y1 = 90;
    int mid_y2 = 130;

    // Unten: dünne Leitung
    int bot_y1 = 140;
    int bot_y2 = 160;

    // Maske für feste Wände
    std::vector<bool> is_solid(NX * NY, true);
    auto solid_idx = [=](int x, int y) {
        return y * NX + x;
    };

    for (int y = 0; y < NY; ++y) {
        for (int x = 0; x < NX; ++x) {
            bool fluid = false;
            if (y >= top_y1 && y <= top_y2) fluid = true;
            if (y >= mid_y1 && y <= mid_y2) fluid = true;
            if (y >= bot_y1 && y <= bot_y2) fluid = true;
            is_solid[solid_idx(x, y)] = !fluid;
        }
    }

    // Initialisierung: Ruhe mit leichter Dichte
    for (int y = 0; y < NY; ++y) {
        for (int x = 0; x < NX; ++x) {
            double rho0 = 1.0;
            double ux0 = 0.0;
            double uy0 = 0.0;
            for (int k = 0; k < Q; ++k) {
                double eu = ex[k]*ux0 + ey[k]*uy0;
                double u2 = ux0*ux0 + uy0*uy0;
                double feq = w[k] * rho0 * (1.0 + 3.0*eu + 4.5*eu*eu - 1.5*u2);
                f[idx(x,y,k)] = feq;
            }
        }
    }

    bool running = true;
    SDL_Event e;

    int step = 0;

    while (running) {
        while (SDL_PollEvent(&e)) {
            if (e.type == SDL_QUIT) running = false;
            if (e.type == SDL_KEYDOWN && e.key.keysym.sym == SDLK_ESCAPE)
                running = false;
        }

        // Kollisions- und Streaming-Schritt
        for (int y = 0; y < NY; ++y) {
            for (int x = 0; x < NX; ++x) {
                if (is_solid[solid_idx(x,y)]) {
                    // Wände: werden später per Bounce-Back behandelt
                    for (int k = 0; k < Q; ++k) {
                        f_next[idx(x,y,k)] = 0.0;
                    }
                    continue;
                }

                // Makrogrößen berechnen
                double rho = 0.0;
                double ux = 0.0;
                double uy = 0.0;
                for (int k = 0; k < Q; ++k) {
                    double fk = f[idx(x,y,k)];
                    rho += fk;
                    ux += fk * ex[k];
                    uy += fk * ey[k];
                }
                ux /= rho;
                uy /= rho;

                // Einlass-Bedingung links: unterschiedliche Geschwindigkeiten je Leitung
                if (x == 0) {
                    if (y >= top_y1 && y <= top_y2) {
                        ux = 0.02; // langsam
                        uy = 0.0;
                    }
                    if (y >= mid_y1 && y <= mid_y2) {
                        ux = 0.05; // schneller
                        uy = 0.0;
                    }
                    if (y >= bot_y1 && y <= bot_y2) {
                        ux = 0.09; // am schnellsten
                        uy = 0.0;
                    }
                    rho = 1.0; // konstante Dichte
                }

                // Auslass rechts: einfache "outflow" (hier nur keine spezielle Korrektur)

                // Kollisionsschritt (BGK)
                double u2 = ux*ux + uy*uy;
                for (int k = 0; k < Q; ++k) {
                    double eu = ex[k]*ux + ey[k]*uy;
                    double feq = w[k] * rho * (1.0 + 3.0*eu + 4.5*eu*eu - 1.5*u2);
                    double fk = f[idx(x,y,k)];
                    double f_post = fk - omega * (fk - feq);

                    // Streaming: in Nachbarzelle schreiben
                    int xn = x + ex[k];
                    int yn = y + ey[k];

                    if (xn < 0) xn = 0;
                    if (xn >= NX) xn = NX - 1;
                    if (yn < 0) yn = 0;
                    if (yn >= NY) yn = NY - 1;

                    f_next[idx(xn, yn, k)] += f_post;
                }
            }
        }

        // Bounce-Back an Wänden
        for (int y = 0; y < NY; ++y) {
            for (int x = 0; x < NX; ++x) {
                if (!is_solid[solid_idx(x,y)]) continue;

                // Für D2Q9: gegenüberliegende Richtungen
                // 0 bleibt 0, Paare: (1,3), (2,4), (5,7), (6,8)
                double ftemp[Q];
                for (int k = 0; k < Q; ++k) ftemp[k] = f_next[idx(x,y,k)];

                f_next[idx(x,y,1)] = ftemp[3];
                f_next[idx(x,y,3)] = ftemp[1];
                f_next[idx(x,y,2)] = ftemp[4];
                f_next[idx(x,y,4)] = ftemp[2];
                f_next[idx(x,y,5)] = ftemp[7];
                f_next[idx(x,y,7)] = ftemp[5];
                f_next[idx(x,y,6)] = ftemp[8];
                f_next[idx(x,y,8)] = ftemp[6];
            }
        }

        // Swap f und f_next
        f.swap(f_next);
        std::fill(f_next.begin(), f_next.end(), 0.0);

        // Visualisierung
        SDL_SetRenderDrawColor(renderer, 0, 0, 0, 255);
        SDL_RenderClear(renderer);

        for (int y = 0; y < NY; ++y) {
            for (int x = 0; x < NX; ++x) {
                if (is_solid[solid_idx(x,y)]) {
                    SDL_SetRenderDrawColor(renderer, 30, 30, 30, 255);
                } else {
                    double rho = 0.0;
                    double ux = 0.0;
                    double uy = 0.0;
                    for (int k = 0; k < Q; ++k) {
                        double fk = f[idx(x,y,k)];
                        rho += fk;
                        ux += fk * ex[k];
                        uy += fk * ey[k];
                    }
                    ux /= rho;
                    uy /= rho;
                    double speed = std::sqrt(ux*ux + uy*uy);

                    // einfache Farbskala: blau -> grün -> gelb -> weiß
                    double s = std::min(speed * 20.0, 1.0); // skaliert
                    Uint8 r = (Uint8)(255 * s);
                    Uint8 g = (Uint8)(255 * std::min(1.0, s * 1.2));
                    Uint8 b = (Uint8)(255 * (1.0 - s));

                    SDL_SetRenderDrawColor(renderer, r, g, b, 255);
                }

                SDL_Rect rect;
                rect.x = x * SCALE;
                rect.y = y * SCALE;
                rect.w = SCALE;
                rect.h = SCALE;
                SDL_RenderFillRect(renderer, &rect);
            }
        }

        SDL_RenderPresent(renderer);

        step++;
        // Optional: etwas langsamer machen
        // SDL_Delay(5);
    }

    SDL_DestroyRenderer(renderer);
    SDL_DestroyWindow(window);
    SDL_Quit();
    return 0;
}
