// -----------------------------------------------------------------------------
// AlsaAudioDevice - minimal ALSA wrapper (blocking, simple)
// -----------------------------------------------------------------------------
class AlsaAudioDevice : public QObject {
    Q_OBJECT
public:
    AlsaAudioDevice(const std::string &deviceName = "default", unsigned int sampleRate = 8000, unsigned int channels = 1)
        : m_deviceName(deviceName), m_sampleRate(sampleRate), m_channels(channels),
          m_captureHandle(nullptr), m_playbackHandle(nullptr), m_running(false) {
        logInfo(QString("AlsaAudioDevice created: %1 @ %2 Hz, %3 channels").arg(QString::fromStdString(deviceName)).arg(sampleRate).arg(channels));
    }

    ~AlsaAudioDevice() override {
        stop();
    }

    bool initCapture() {
        std::lock_guard<std::mutex> lock(m_mutex);
        if (m_captureHandle) return true;
        int err;
        snd_pcm_t *handle = nullptr;
        snd_pcm_hw_params_t *params = nullptr;
        if ((err = snd_pcm_open(&handle, m_deviceName.c_str(), SND_PCM_STREAM_CAPTURE, 0)) < 0) {
            logInfo(QString("ALSA capture open error: %1").arg(snd_strerror(err)));
            return false;
        }
        snd_pcm_hw_params_malloc(&params);
        snd_pcm_hw_params_any(handle, params);
        snd_pcm_hw_params_set_access(handle, params, SND_PCM_ACCESS_RW_INTERLEAVED);
        snd_pcm_hw_params_set_format(handle, params, SND_PCM_FORMAT_S16_LE);
        snd_pcm_hw_params_set_channels(handle, params, m_channels);
        unsigned int rate = m_sampleRate;
        snd_pcm_hw_params_set_rate_near(handle, params, &rate, 0);
        snd_pcm_hw_params(handle, params);
        snd_pcm_hw_params_free(params);
        snd_pcm_prepare(handle);
        m_captureHandle = handle;
        logInfo("ALSA capture initialized");
        return true;
    }

    bool initPlayback() {
        std::lock_guard<std::mutex> lock(m_mutex);
        if (m_playbackHandle) return true;
        int err;
        snd_pcm_t *handle = nullptr;
        snd_pcm_hw_params_t *params = nullptr;
        if ((err = snd_pcm_open(&handle, m_deviceName.c_str(), SND_PCM_STREAM_PLAYBACK, 0)) < 0) {
            logInfo(QString("ALSA playback open error: %1").arg(snd_strerror(err)));
            return false;
        }
        snd_pcm_hw_params_malloc(&params);
        snd_pcm_hw_params_any(handle, params);
        snd_pcm_hw_params_set_access(handle, params, SND_PCM_ACCESS_RW_INTERLEAVED);
        snd_pcm_hw_params_set_format(handle, params, SND_PCM_FORMAT_S16_LE);
        snd_pcm_hw_params_set_channels(handle, params, m_channels);
        unsigned int rate = m_sampleRate;
        snd_pcm_hw_params_set_rate_near(handle, params, &rate, 0);
        snd_pcm_hw_params(handle, params);
        snd_pcm_hw_params_free(params);
        snd_pcm_prepare(handle);
        m_playbackHandle = handle;
        logInfo("ALSA playback initialized");
        return true;
    }

    void start() {
        if (m_running.load()) return;
        m_running.store(true);
        m_thread = std::thread([this]() { this->runLoop(); });
    }

    void stop() {
        if (!m_running.load()) return;
        m_running.store(false);
        if (m_thread.joinable()) m_thread.join();
        std::lock_guard<std::mutex> lock(m_mutex);
        if (m_captureHandle) {
            snd_pcm_close(m_captureHandle);
            m_captureHandle = nullptr;
        }
        if (m_playbackHandle) {
            snd_pcm_close(m_playbackHandle);
            m_playbackHandle = nullptr;
        }
    }

    // Read raw PCM frames (16-bit little endian)
    ssize_t readFrames(char *buffer, size_t bytes) {
        std::lock_guard<std::mutex> lock(m_mutex);
        if (!m_captureHandle) return -1;
        snd_pcm_sframes_t frames = snd_pcm_readi(m_captureHandle, buffer, bytes / (2 * m_channels));
        if (frames < 0) {
            frames = snd_pcm_recover(m_captureHandle, frames, 0);
        }
        if (frames < 0) {
            logInfo(QString("ALSA read error: %1").arg(snd_strerror(frames)));
            return -1;
        }
        return frames * (2 * m_channels);
    }

    // Write raw PCM frames (16-bit little endian)
    ssize_t writeFrames(const char *buffer, size_t bytes) {
        std::lock_guard<std::mutex> lock(m_mutex);
        if (!m_playbackHandle) return -1;
        snd_pcm_sframes_t frames = snd_pcm_writei(m_playbackHandle, buffer, bytes / (2 * m_channels));
        if (frames < 0) {
            frames = snd_pcm_recover(m_playbackHandle, frames, 0);
        }
        if (frames < 0) {
            logInfo(QString("ALSA write error: %1").arg(snd_strerror(frames)));
            return -1;
        }
        return frames * (2 * m_channels);
    }

    void setFrameCallback(std::function<void(const QByteArray &)> cb) {
        std::lock_guard<std::mutex> lock(m_mutex);
        m_frameCallback = cb;
    }

private:
    void runLoop() {
        // Simple capture loop that reads frames and calls callback
        const size_t bufferBytes = 3200; // arbitrary buffer size
        std::vector<char> buffer(bufferBytes);
        while (m_running.load()) {
            if (!m_captureHandle) {
                std::this_thread::sleep_for(std::chrono::milliseconds(50));
                continue;
            }
            ssize_t r = readFrames(buffer.data(), buffer.size());
            if (r > 0) {
                QByteArray ba(buffer.data(), static_cast<int>(r));
                std::function<void(const QByteArray &)> cb;
                {
                    std::lock_guard<std::mutex> lock(m_mutex);
                    cb = m_frameCallback;
                }
                if (cb) cb(ba);
            } else {
                std::this_thread::sleep_for(std::chrono::milliseconds(10));
            }
        }
    }

    std::string m_deviceName;
    unsigned int m_sampleRate;
    unsigned int m_channels;
    snd_pcm_t *m_captureHandle;
    snd_pcm_t *m_playbackHandle;
    std::thread m_thread;
    std::atomic<bool> m_running;
    std::mutex m_mutex;
    std::function<void(const QByteArray &)> m_frameCallback;
};

// -----------------------------------------------------------------------------
// CallManager - stub for call control and audio pipeline
// -----------------------------------------------------------------------------
class CallManager : public QObject {
    Q_OBJECT
public:
    CallManager(QObject *parent = nullptr)
        : QObject(parent), m_audioDevice(new AlsaAudioDevice("default", 8000, 1)), m_active(false) {
        logInfo("CallManager created");
        // Hook audio frames to a simple loopback or network send stub
        m_audioDevice->setFrameCallback([this](const QByteArray &frame) {
            this->onCapturedFrame(frame);
        });
    }

    ~CallManager() override {
        stop();
    }

    void start() {
        if (m_active) return;
        if (!m_audioDevice->initCapture()) {
            logInfo("CallManager: failed to init capture");
        }
        if (!m_audioDevice->initPlayback()) {
            logInfo("CallManager: failed to init playback");
        }
        m_audioDevice->start();
        m_active = true;
        logInfo("CallManager started");
    }

    void stop() {
        if (!m_active) return;
        m_audioDevice->stop();
        m_active = false;
        logInfo("CallManager stopped");
    }

    void placeCall(const QString &jid) {
        logInfo(QString("Placing call to %1").arg(jid));
        // In a real implementation, create QXmppCall via QXmppCallManager and handle SDP
        // Here we simulate a call by starting audio and emitting signals
        start();
        emit callStarted(jid);
    }

    void hangupCall(const QString &jid) {
        logInfo(QString("Hanging up call with %1").arg(jid));
        stop();
        emit callEnded(jid);
    }

    void playRemoteAudio(const QByteArray &pcm) {
        // Write to ALSA playback
        if (m_audioDevice) {
            m_audioDevice->writeFrames(pcm.constData(), static_cast<size_t>(pcm.size()));
        }
    }

signals:
    void callStarted(const QString &jid);
    void callEnded(const QString &jid);
    void remoteFrameReceived(const QByteArray &frame);

private:
    void onCapturedFrame(const QByteArray &frame) {
        // In a real implementation, encode and send over RTP
        // For scaffold, we loop back to playback to demonstrate audio path
        // Also emit remoteFrameReceived to simulate incoming audio
        emit remoteFrameReceived(frame);
        // For loopback demo, write back to playback
        playRemoteAudio(frame);
    }

    std::unique_ptr<AlsaAudioDevice> m_audioDevice;
    bool m_active;
};

// -----------------------------------------------------------------------------
// XmppController - manages QXmppClient and roster, presence, basic signaling
// -----------------------------------------------------------------------------
class XmppController : public QObject {
    Q_OBJECT
public:
    XmppController(QObject *parent = nullptr)
        : QObject(parent), m_client(new QXmppClient()), m_callManager(new CallManager(this)) {
        logInfo("XmppController created");
        // Configure QXmpp logger to debug
        QXmppLogger::setLoggingType(QXmppLogger::StdoutLogging);
        connect(m_client.get(), &QXmppClient::connected, this, &XmppController::onConnected);
        connect(m_client.get(), &QXmppClient::disconnected, this, &XmppController::onDisconnected);
        connect(m_client.get(), &QXmppClient::error, this, &XmppController::onError);
        // Roster updates
        connect(&m_client->rosterManager(), &QXmppRosterManager::rosterReceived, this, &XmppController::onRosterReceived);
        connect(&m_client->rosterManager(), &QXmppRosterManager::presenceChanged, this, &XmppController::onPresenceChanged);
        // Call manager integration (QXmppCallManager could be used in real impl)
        connect(m_callManager.get(), &CallManager::callStarted, this, &XmppController::onLocalCallStarted);
        connect(m_callManager.get(), &CallManager::callEnded, this, &XmppController::onLocalCallEnded);
    }

    ~XmppController() override {
        if (m_client->isConnected()) {
            m_client->disconnectFromServer();
        }
    }

    void connectToServer(const QString &jid, const QString &password, const QString &host = QString(), int port = 5222) {
        QXmppConfiguration cfg;
        cfg.setJid(jid);
        cfg.setPassword(password);
        if (!host.isEmpty()) cfg.setHost(host);
        cfg.setPort(port);
        logInfo(QString("XmppController connecting: %1 @ %2:%3").arg(jid).arg(host.isEmpty() ? QString("auto") : host).arg(port));
        m_client->connectToServer(cfg);
    }

    void disconnectFromServer() {
        if (m_client->isConnected()) {
            m_client->disconnectFromServer();
        }
    }

    bool isConnected() const {
        return m_client->isConnected();
    }

    QString currentJid() const {
        return m_client->configuration().jid();
    }

    // Roster access
    QStringList rosterJids() const {
        QStringList list;
        const auto roster = m_client->rosterManager().getRoster();
        for (const auto &item : roster) {
            list << item.jid();
        }
        return list;
    }

    void addRosterItem(const QString &jid) {
        m_client->rosterManager().addItem(jid);
    }

    void removeRosterItem(const QString &jid) {
        m_client->rosterManager().removeItem(jid);
    }

    // Call control
    void placeCall(const QString &jid) {
        m_callManager->placeCall(jid);
    }

    void hangupCall(const QString &jid) {
        m_callManager->hangupCall(jid);
    }

signals:
    void connected();
    void disconnected();
    void rosterUpdated();
    void presenceUpdated(const QString &jid, const QString &status);

private slots:
    void onConnected() {
        logInfo("XmppController: connected");
        emit connected();
    }

    void onDisconnected() {
        logInfo("XmppController: disconnected");
        emit disconnected();
    }

    void onError(QXmppClient::Error error) {
        Q_UNUSED(error);
        logInfo("XmppController: error occurred");
    }

    void onRosterReceived() {
        logInfo("XmppController: roster received");
        emit rosterUpdated();
    }

    void onPresenceChanged(const QString &jid, const QXmppPresence &presence) {
        Q_UNUSED(presence);
        logInfo(QString("Presence changed: %1").arg(jid));
        emit presenceUpdated(jid, QString()); // status stub
    }

    void onLocalCallStarted(const QString &jid) {
        Q_UNUSED(jid);
        logInfo("XmppController: local call started");
    }

    void onLocalCallEnded(const QString &jid) {
        Q_UNUSED(jid);
        logInfo("XmppController: local call ended");
    }

private:
    std::unique_ptr<QXmppClient> m_client;
    std::unique_ptr<CallManager> m_callManager;
};

