// a placeholder for a simple framebuffer
static uint8_t *fb_mem = NULL;

// -------------------------
// cpu state structure
// -------------------------
typedef struct {
    uint64_t rip;
    union {
        uint64_t r64[16];
        uint32_t r32[16];
        uint16_t r16[16];
        uint8_t r8[16];
    } reg;
    // explicit register aliases for common use
    #define rax reg.r64[0]
    #define rcx reg.r64[1]
    #define rdx reg.r64[2]
    #define rbx reg.r64[3]
    #define rsp reg.r64[4]
    #define rbp reg.r64[5]
    #define rsi reg.r64[6]
    #define rdi reg.r64[7]
    #define r8  reg.r64[8]
    #define r9  reg.r64[9]
    #define r10 reg.r64[10]
    #define r11 reg.r64[11]
    #define r12 reg.r64[12]
    #define r13 reg.r64[13]
    #define r14 reg.r64[14]
    #define r15 reg.r64[15]

    uint64_t rflags;

    // segment registers (minimal use in 64-bit flat model)
    uint16_t seg[6]; // cs, ds, es, fs, gs, ss

    // sse/avx registers (minimal sse support)
    uint8_t xmm[16][16];

    // control registers (minimal support)
    uint64_t cr0, cr3, cr4;

    // emulation metadata
    struct {
        uint8_t has_rex;
        uint8_t rex;
        uint8_t prefixes;
        uint8_t opcode;
        uint8_t modrm;
        uint8_t sib;
        int disp_size;
        int imm_size;
        int default_operand_size; // 16, 32, or 64
        int default_addr_size;    // 32 or 64
        uint64_t vaddr;           // target virtual address
        uint64_t paddr;           // target physical address
        uint64_t disp;
        uint64_t imm;
    } decode;

    // trace ring buffer
    struct {
        uint64_t rip;
        uint8_t opcode;
        uint8_t op2;
        uint8_t modrm;
        uint8_t prefixes;
        uint64_t info_a;
        uint64_t info_b;
    } trace[TRACE_RING_SIZE];
    uint32_t trace_head;

} X64CPU;

static X64CPU cpu;

