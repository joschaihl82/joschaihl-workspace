// -----------------------------------------------------------------------------
// ToneGenerator - generates PCM tone patterns (16-bit LE, 8000 Hz mono)
// -----------------------------------------------------------------------------
class ToneGenerator {
public:
    ToneGenerator(int sampleRate = 8000) : m_sampleRate(sampleRate) {}
    QByteArray sineTone(int ms, double freq, double amplitude = 3000.0) {
        int samples = (m_sampleRate * ms) / 1000;
        QByteArray ba;
        ba.resize(samples * 2);
        qint16 *ptr = reinterpret_cast<qint16 *>(ba.data());
        for (int i = 0; i < samples; ++i) {
            double t = static_cast<double>(i) / m_sampleRate;
            double v = sin(2.0 * M_PI * freq * t) * amplitude;
            ptr[i] = static_cast<qint16>(v);
        }
        return ba;
    }
    QByteArray silence(int ms) {
        int samples = (m_sampleRate * ms) / 1000;
        QByteArray ba;
        ba.resize(samples * 2);
        memset(ba.data(), 0, ba.size());
        return ba;
    }
    QByteArray waitingPattern() {
        QByteArray out;
        out.append(sineTone(1000, 440.0, 4000.0));
        out.append(silence(3000));
        return out;
    }
    QByteArray busyPattern() {
        QByteArray out;
        out.append(sineTone(500, 480.0, 3500.0));
        out.append(sineTone(500, 620.0, 3500.0));
        return out;
    }
    QByteArray wrongNumberPattern() {
        QByteArray out;
        out.append(sineTone(200, 600.0, 4000.0));
        out.append(silence(100));
        out.append(sineTone(200, 600.0, 4000.0));
        return out;
    }
    QByteArray ringPattern() {
        QByteArray out;
        out.append(sineTone(200, 440.0, 4000.0));
        out.append(silence(200));
        out.append(sineTone(200, 440.0, 4000.0));
        out.append(silence(2000));
        return out;
    }
private:
    int m_sampleRate;
};

// -----------------------------------------------------------------------------
// G.711 μ-law (PCMU) encoder/decoder
// -----------------------------------------------------------------------------
static const int G711_BIAS = 0x84; // 132
static const int G711_CLIP = 32635;

static inline unsigned char linear2ulaw_sample(int pcm_val) {
    int mask;
    int seg;
    unsigned char uval;
    if (pcm_val < 0) {
        pcm_val = -pcm_val;
        mask = 0x7F;
    } else {
        mask = 0xFF;
    }
    if (pcm_val > G711_CLIP) pcm_val = G711_CLIP;
    pcm_val += G711_BIAS;
    // find segment
    int value = pcm_val;
    seg = 0;
    for (int v = value >> 7; v; v >>= 1) seg++;
    // compute u-law byte
    if (seg >= 8) seg = 7;
    uval = (unsigned char)((seg << 4) | ((pcm_val >> (seg + 3)) & 0x0F));
    uval ^= mask;
    return uval;
}

static inline int ulaw2linear_sample(unsigned char u_val) {
    u_val = ~u_val;
    int sign = (u_val & 0x80);
    int seg = (u_val & 0x70) >> 4;
    int quant = u_val & 0x0F;
    int t = ((quant << 3) + G711_BIAS) << (seg ? (seg - 1) : 0);
    if (seg > 0) t = ((quant << 3) + G711_BIAS) << (seg - 1);
    return sign ? -t : t;
}

static QByteArray pcm16_to_g711u(const QByteArray &pcm16le) {
    int samples = pcm16le.size() / 2;
    QByteArray out;
    out.resize(samples);
    const qint16 *in = reinterpret_cast<const qint16 *>(pcm16le.constData());
    for (int i = 0; i < samples; ++i) {
        int sample = static_cast<int>(in[i]);
        out[i] = static_cast<char>(linear2ulaw_sample(sample));
    }
    return out;
}

static QByteArray g711u_to_pcm16(const QByteArray &g711) {
    int samples = g711.size();
    QByteArray out;
    out.resize(samples * 2);
    qint16 *ptr = reinterpret_cast<qint16 *>(out.data());
    for (int i = 0; i < samples; ++i) {
        unsigned char u = static_cast<unsigned char>(g711.at(i));
        int s = ulaw2linear_sample(u);
        if (s > 32767) s = 32767;
        if (s < -32768) s = -32768;
        ptr[i] = static_cast<qint16>(s);
    }
    return out;
}

// -----------------------------------------------------------------------------
// AlsaAudioEngine - ALSA-only audio engine with AGC and Qt signal
// -----------------------------------------------------------------------------
class AlsaAudioEngine : public QObject {
    Q_OBJECT
public:
    AlsaAudioEngine(QObject *parent = nullptr)
        : QObject(parent),
          m_deviceName("default"),
          m_sampleRate(8000),
          m_channels(1),
          m_captureHandle(nullptr),
          m_playbackHandle(nullptr),
          m_running(false),
          m_agcEnabled(true),
          m_agcTargetRms(1000.0),
          m_agcGain(1.0),
          m_agcAttack(0.02),
          m_agcRelease(0.1),
          m_muted(false)
    {
    }

    ~AlsaAudioEngine() override {
        stop();
    }

    static QStringList availableDevices() {
        QStringList list;
        list << "default";
        void **hints = nullptr;
        if (snd_device_name_hint(-1, "pcm", &hints) == 0 && hints) {
            for (void **n = hints; *n != nullptr; ++n) {
                char *name = snd_device_name_get_hint(*n, "NAME");
                if (name) {
                    QString s = QString::fromLocal8Bit(name);
                    if (!list.contains(s)) list << s;
                    free(name);
                }
            }
            snd_device_name_free_hint(hints);
        }
        return list;
    }

    void setDeviceName(const QString &dev) {
        std::lock_guard<std::mutex> lock(m_mutex);
        m_deviceName = dev.toStdString();
    }

    QString deviceName() const {
        std::lock_guard<std::mutex> lock(m_mutex);
        return QString::fromStdString(m_deviceName);
    }

    void setSampleRate(unsigned int rate) {
        std::lock_guard<std::mutex> lock(m_mutex);
        m_sampleRate = rate;
    }

    unsigned int sampleRate() const {
        std::lock_guard<std::mutex> lock(m_mutex);
        return m_sampleRate;
    }

    void setChannels(unsigned int ch) {
        std::lock_guard<std::mutex> lock(m_mutex);
        m_channels = ch;
    }

    unsigned int channels() const {
        std::lock_guard<std::mutex> lock(m_mutex);
        return m_channels;
    }

    void setAgcEnabled(bool on) { m_agcEnabled = on; }
    void setAgcTargetRms(double v) { m_agcTargetRms = v; }
    void setAgcAttack(double v) { m_agcAttack = v; }
    void setAgcRelease(double v) { m_agcRelease = v; }
    void setMuted(bool m) { m_muted = m; }

    bool init() {
        return initCapture() && initPlayback();
    }

    bool initCapture() {
        std::lock_guard<std::mutex> lock(m_mutex);
        if (m_captureHandle) return true;
        int err;
        snd_pcm_hw_params_t *params = nullptr;
        snd_pcm_t *handle = nullptr;
        if ((err = snd_pcm_open(&handle, m_deviceName.c_str(), SND_PCM_STREAM_CAPTURE, 0)) < 0) {
            qWarning() << "ALSA capture open error:" << snd_strerror(err);
            return false;
        }
        snd_pcm_hw_params_malloc(&params);
        snd_pcm_hw_params_any(handle, params);
        snd_pcm_hw_params_set_access(handle, params, SND_PCM_ACCESS_RW_INTERLEAVED);
        snd_pcm_hw_params_set_format(handle, params, SND_PCM_FORMAT_S16_LE);
        snd_pcm_hw_params_set_channels(handle, params, m_channels);
        unsigned int rate = m_sampleRate;
        snd_pcm_hw_params_set_rate_near(handle, params, &rate, 0);
        snd_pcm_hw_params(handle, params);
        snd_pcm_hw_params_free(params);
        snd_pcm_prepare(handle);
        m_captureHandle = handle;
        return true;
    }

    bool initPlayback() {
        std::lock_guard<std::mutex> lock(m_mutex);
        if (m_playbackHandle) return true;
        int err;
        snd_pcm_hw_params_t *params = nullptr;
        snd_pcm_t *handle = nullptr;
        if ((err = snd_pcm_open(&handle, m_deviceName.c_str(), SND_PCM_STREAM_PLAYBACK, 0)) < 0) {
            qWarning() << "ALSA playback open error:" << snd_strerror(err);
            return false;
        }
        snd_pcm_hw_params_malloc(&params);
        snd_pcm_hw_params_any(handle, params);
        snd_pcm_hw_params_set_access(handle, params, SND_PCM_ACCESS_RW_INTERLEAVED);
        snd_pcm_hw_params_set_format(handle, params, SND_PCM_FORMAT_S16_LE);
        snd_pcm_hw_params_set_channels(handle, params, m_channels);
        unsigned int rate = m_sampleRate;
        snd_pcm_hw_params_set_rate_near(handle, params, &rate, 0);
        snd_pcm_hw_params(handle, params);
        snd_pcm_hw_params_free(params);
        snd_pcm_prepare(handle);
        m_playbackHandle = handle;
        return true;
    }

    void start() {
        if (m_running.load()) return;
        if (!init()) {
            qWarning() << "AlsaAudioEngine: init failed";
            return;
        }
        m_running.store(true);
        m_thread = std::thread([this]() { this->captureLoop(); });
    }

    void stop() {
        if (!m_running.load()) return;
        m_running.store(false);
        if (m_thread.joinable()) m_thread.join();
        std::lock_guard<std::mutex> lock(m_mutex);
        if (m_captureHandle) { snd_pcm_close(m_captureHandle); m_captureHandle = nullptr; }
        if (m_playbackHandle) { snd_pcm_close(m_playbackHandle); m_playbackHandle = nullptr; }
    }

    ssize_t writePlayback(const char *data, size_t bytes) {
        std::lock_guard<std::mutex> lock(m_mutex);
        if (!m_playbackHandle) return -1;
        snd_pcm_sframes_t frames = snd_pcm_writei(m_playbackHandle, data, bytes / (2 * m_channels));
        if (frames < 0) frames = snd_pcm_recover(m_playbackHandle, frames, 0);
        if (frames < 0) {
            qWarning() << "ALSA write error:" << snd_strerror(frames);
            return -1;
        }
        return frames * (2 * m_channels);
    }

    void playPcm(const QByteArray &pcm) {
        if (m_muted) return;
        writePlayback(pcm.constData(), static_cast<size_t>(pcm.size()));
    }

signals:
    void frameCaptured(const QByteArray &pcm);

private:
    void captureLoop() {
        const size_t bufferBytes = 3200;
        std::vector<char> buffer(bufferBytes);
        while (m_running.load()) {
            {
                std::lock_guard<std::mutex> lock(m_mutex);
                if (!m_captureHandle) {
                    std::this_thread::sleep_for(std::chrono::milliseconds(50));
                    continue;
                }
            }
            snd_pcm_sframes_t frames = snd_pcm_readi(m_captureHandle, buffer.data(), bufferBytes / (2 * m_channels));
            if (frames < 0) {
                frames = snd_pcm_recover(m_captureHandle, frames, 0);
            }
            if (frames < 0) {
                std::this_thread::sleep_for(std::chrono::milliseconds(10));
                continue;
            }
            size_t bytes = static_cast<size_t>(frames) * 2 * m_channels;
            QByteArray pcm(buffer.data(), static_cast<int>(bytes));
            if (m_agcEnabled) pcm = applyAgc(pcm);
            QMetaObject::invokeMethod(this, "emitFrameCaptured", Qt::QueuedConnection, Q_ARG(QByteArray, pcm));
        }
    }

    Q_SLOT void emitFrameCaptured(const QByteArray &pcm) {
        emit frameCaptured(pcm);
    }

    QByteArray applyAgc(const QByteArray &pcm) {
        if (pcm.isEmpty()) return pcm;
        int samples = pcm.size() / 2;
        const qint16 *in = reinterpret_cast<const qint16 *>(pcm.constData());
        QByteArray out;
        out.resize(pcm.size());
        qint16 *outPtr = reinterpret_cast<qint16 *>(out.data());
        double sum = 0.0;
        for (int i = 0; i < samples; ++i) {
            double s = static_cast<double>(in[i]);
            sum += s * s;
        }
        double rms = (samples > 0) ? sqrt(sum / samples) : 0.0;
        double desiredGain = 1.0;
        if (rms > 1e-6) desiredGain = m_agcTargetRms / rms;
        if (desiredGain > 10.0) desiredGain = 10.0;
        if (desiredGain < 0.1) desiredGain = 0.1;
        if (desiredGain > m_agcGain) {
            m_agcGain += (desiredGain - m_agcGain) * m_agcAttack;
        } else {
            m_agcGain += (desiredGain - m_agcGain) * m_agcRelease;
        }
        for (int i = 0; i < samples; ++i) {
            double v = static_cast<double>(in[i]) * m_agcGain;
            if (v > 32767.0) v = 32767.0;
            if (v < -32768.0) v = -32768.0;
            outPtr[i] = static_cast<qint16>(v);
        }
        return out;
    }

    // members
    std::string m_deviceName;
    unsigned int m_sampleRate;
    unsigned int m_channels;
    snd_pcm_t *m_captureHandle;
    snd_pcm_t *m_playbackHandle;
    std::thread m_thread;
    std::atomic<bool> m_running;
    std::mutex m_mutex;

    std::atomic<bool> m_agcEnabled;
    double m_agcTargetRms;
    double m_agcGain;
    double m_agcAttack;
    double m_agcRelease;

    std::atomic<bool> m_muted;
};

// -----------------------------------------------------------------------------
// CallManager - integrates with AlsaAudioEngine, uses G.711 for payloads, plays tones
// -----------------------------------------------------------------------------
class CallManager : public QObject {
    Q_OBJECT
public:
    CallManager(AlsaAudioEngine *audio, Logger *logger, QObject *parent = nullptr)
        : QObject(parent), m_audio(audio), m_logger(logger), m_active(false), m_tonePlaying(false),
          m_toneGen(8000), m_mockRemote(false)
    {
        if (m_audio) connect(m_audio, &AlsaAudioEngine::frameCaptured, this, &CallManager::onLocalFrame);
    }

    ~CallManager() override {
        stopCall();
    }

    void startCall(const QString &peerJid) {
        if (m_active) return;
        m_peer = peerJid;
        m_logger->log(QString("Starting call to %1").arg(peerJid));
        if (m_audio) m_audio->start();
        m_active = true;
        playRingback();
        emit callStarted(peerJid);
    }

    void stopCall() {
        if (!m_active) return;
        stopTone();
        if (m_audio) m_audio->stop();
        m_logger->log(QString("Stopped call with %1").arg(m_peer));
        emit callEnded(m_peer);
        m_active = false;
        m_peer.clear();
    }

    void hangup() { stopCall(); }

    void playRingback() {
        stopTone();
        m_tonePlaying = true;
        m_toneTimer = std::make_unique<QTimer>();
        connect(m_toneTimer.get(), &QTimer::timeout, this, [this]() {
            QByteArray p = m_toneGen.waitingPattern();
            if (m_audio) m_audio->playPcm(p);
        });
        if (m_audio) m_audio->playPcm(m_toneGen.waitingPattern());
        m_toneTimer->start(4000);
    }

    void playBusy() {
        stopTone();
        m_tonePlaying = true;
        m_toneTimer = std::make_unique<QTimer>();
        connect(m_toneTimer.get(), &QTimer::timeout, this, [this]() {
            QByteArray p = m_toneGen.busyPattern();
            if (m_audio) m_audio->playPcm(p);
        });
        if (m_audio) m_audio->playPcm(m_toneGen.busyPattern());
        m_toneTimer->start(1000);
    }

    void playWrongNumber() {
        stopTone();
        m_tonePlaying = true;
        QByteArray p = m_toneGen.wrongNumberPattern();
        if (m_audio) m_audio->playPcm(p);
        QTimer::singleShot(1200, this, [this]() { this->m_tonePlaying = false; });
    }

    void playRing() {
        stopTone();
        m_tonePlaying = true;
        m_toneTimer = std::make_unique<QTimer>();
        connect(m_toneTimer.get(), &QTimer::timeout, this, [this]() {
            QByteArray p = m_toneGen.ringPattern();
            if (m_audio) m_audio->playPcm(p);
        });
        if (m_audio) m_audio->playPcm(m_toneGen.ringPattern());
        m_toneTimer->start(2600);
    }

    void stopTone() {
        m_tonePlaying = false;
        if (m_toneTimer) {
            m_toneTimer->stop();
            m_toneTimer.reset();
        }
    }

    void setMockRemote(bool on) { m_mockRemote = on; }

signals:
    void callStarted(const QString &jid);
    void callEnded(const QString &jid);
    void remoteFrame(const QByteArray &pcmEncoded); // encoded G.711 payload

private slots:
    // Called when local PCM frames are captured (16-bit LE)
    void onLocalFrame(const QByteArray &pcm16le) {
        if (!m_active) return;

        // Encode to G.711 μ-law
        QByteArray g711 = pcm16_to_g711u(pcm16le);

        // In a real implementation, send g711 over RTP/SRTP to remote
        // For mock mode, simulate remote receive and playback
        if (m_mockRemote) {
            QByteArray payload = g711;
            QTimer::singleShot(30 + QRandomGenerator::global()->bounded(40), this, [this, payload]() {
                QByteArray pcmOut = g711u_to_pcm16(payload);
                if (m_audio) m_audio->playPcm(pcmOut);
                emit remoteFrame(payload);
            });
        } else {
            // Local loopback for testing: decode and play
            if (!m_tonePlaying && m_audio) {
                QByteArray pcmOut = g711u_to_pcm16(g711);
                m_audio->playPcm(pcmOut);
            }
        }
    }

private:
    AlsaAudioEngine *m_audio;
    Logger *m_logger;
    bool m_active;
    QString m_peer;
    bool m_tonePlaying;
    std::unique_ptr<QTimer> m_toneTimer;
    ToneGenerator m_toneGen;
    bool m_mockRemote;
};

// -----------------------------------------------------------------------------
// XmppController - manages QXmppClient and basic messaging/roster
// -----------------------------------------------------------------------------
class XmppController : public QObject {
    Q_OBJECT
public:
    XmppController(Logger *logger, QObject *parent = nullptr)
        : QObject(parent), m_logger(logger), m_client(new QXmppClient()), m_rosterMgr(nullptr) {
        connect(m_client.get(), &QXmppClient::connected, this, &XmppController::onConnected);
        connect(m_client.get(), &QXmppClient::disconnected, this, &XmppController::onDisconnected);
        connect(m_client.get(), &QXmppClient::error, this, &XmppController::onError);
        connect(m_client.get(), &QXmppClient::messageReceived, this, &XmppController::onMessageReceived);
        m_rosterMgr = m_client->findExtension<QXmppRosterManager>();
        if (m_rosterMgr) {
            connect(m_rosterMgr, &QXmppRosterManager::rosterReceived, this, &XmppController::onRosterReceived);
            connect(m_rosterMgr, &QXmppRosterManager::presenceChanged, this, &XmppController::onPresenceChanged);
        }
    }

    ~XmppController() override {
        if (m_client->isConnected()) m_client->disconnectFromServer();
    }

    void connectToServer(const QString &jid, const QString &password, const QString &host = QString(), int port = 5222) {
        QXmppConfiguration cfg;
        cfg.setJid(jid);
        cfg.setPassword(password);
        if (!host.isEmpty()) cfg.setHost(host);
        cfg.setPort(port);
        m_logger->log(QString("Connecting to XMPP: %1").arg(jid));
        m_client->connectToServer(cfg);
    }

    void disconnectFromServer() {
        if (m_client->isConnected()) {
            m_client->disconnectFromServer();
            m_logger->log("Disconnecting from XMPP");
        }
    }

    bool isConnected() const { return m_client->isConnected(); }
    QString currentJid() const { return m_client->configuration().jid(); }

    QStringList rosterJids() const {
        return m_localRoster;
    }

    void addRosterItem(const QString &jid) {
        if (!m_localRoster.contains(jid)) m_localRoster << jid;
        if (m_rosterMgr) m_rosterMgr->addItem(jid);
        emit rosterUpdated();
    }

    void removeRosterItem(const QString &jid) {
        m_localRoster.removeAll(jid);
        if (m_rosterMgr) m_rosterMgr->removeItem(jid);
        emit rosterUpdated();
    }

    void sendMessage(const QString &to, const QString &body) {
        QXmppMessage msg;
        msg.setTo(to);
        msg.setBody(body);
        m_client->sendPacket(msg);
        m_logger->log(QString("Sent message to %1: %2").arg(to, body));
    }

signals:
    void connected();
    void disconnected();
    void rosterUpdated();
    void presenceUpdated(const QString &jid, const QString &resource);
    void messageReceived(const QString &from, const QString &body);

private slots:
    void onConnected() {
        m_logger->log("XMPP connected");
        emit connected();
    }
    void onDisconnected() {
        m_logger->log("XMPP disconnected");
        emit disconnected();
    }
    void onError(QXmppClient::Error err) {
        Q_UNUSED(err);
        m_logger->log("XMPP error occurred");
    }
    void onRosterReceived() {
        m_logger->log("Roster received");
        emit rosterUpdated();
    }
    void onPresenceChanged(const QString &jid, const QString &resource) {
        m_logger->log(QString("Presence changed: %1 (%2)").arg(jid, resource));
        emit presenceUpdated(jid, resource);
    }
    void onMessageReceived(const QXmppMessage &msg) {
        QString from = msg.from();
        QString body = msg.body();
        m_logger->log(QString("Message received from %1: %2").arg(from, body));
        emit messageReceived(from, body);
    }

private:
    Logger *m_logger;
    std::unique_ptr<QXmppClient> m_client;
    QXmppRosterManager *m_rosterMgr;
    QStringList m_localRoster;
};

