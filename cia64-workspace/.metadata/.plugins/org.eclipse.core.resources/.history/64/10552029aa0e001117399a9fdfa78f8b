/* asm.c
 *
 * Amalgamated assembler: scanner, lexer, parser, AST, two-pass emitter.
 * - Ignores line comments starting with '#' and C-style multiline comments /* ... *\/
 * - Builds an AST, resolves labels in a first pass, emits bytes in a second pass
 * - Produces an 8-byte header (load_addr, payload_size) and payload
 *
 * Build: gcc -O2 -std=c11 -o asm asm.c
 * Usage: ./asm -o out.bin [-a load_addr] in.s
 */

#define _GNU_SOURCE
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <stdint.h>
#include <ctype.h>
#include <stdarg.h>
#include <errno.h>

/* ----------------------------- Configuration ----------------------------- */
#define MAX_LINE 1024
#define MAX_OUTPUT (1<<24) /* 16MB output */

/* ----------------------------- Error helpers ----------------------------- */
static void fatal(const char *fmt, ...) {
    va_list ap; va_start(ap, fmt);
    vfprintf(stderr, fmt, ap);
    va_end(ap);
    exit(1);
}

/* ----------------------------- Label list ----------------------------- */
typedef struct ALabelNode {
    char *name;
    uint32_t addr;
    struct ALabelNode *next;
} ALabelNode;

static ALabelNode *label_head = NULL;

static void add_label(const char *name, uint32_t addr) {
    for (ALabelNode *n = label_head; n; n = n->next) {
        if (strcmp(n->name, name) == 0) {
            fprintf(stderr, "Label redefined: %s\n", name);
            exit(1);
        }
    }
    ALabelNode *node = malloc(sizeof(ALabelNode));
    if (!node) fatal("out of memory\n");
    node->name = strdup(name);
    node->addr = addr;
    node->next = label_head;
    label_head = node;
}

static int find_label(const char *name, uint32_t *addr_out) {
    for (ALabelNode *n = label_head; n; n = n->next) {
        if (strcmp(n->name, name) == 0) {
            *addr_out = n->addr;
            return 1;
        }
    }
    return 0;
}

static void free_labels(void) {
    ALabelNode *n = label_head;
    while (n) {
        ALabelNode *next = n->next;
        free(n->name);
        free(n);
        n = next;
    }
    label_head = NULL;
}

/* ----------------------------- Output buffer ----------------------------- */
static uint8_t *outbuf = NULL;
static size_t outcap = MAX_OUTPUT;
static size_t outpos = 0;
static uint32_t loc = 0; /* location counter (bytes) */

static void emit_word(uint32_t w) {
    if (outpos + 4 > outcap) fatal("output overflow\n");
    outbuf[outpos+0] = w & 0xFF;
    outbuf[outpos+1] = (w>>8) & 0xFF;
    outbuf[outpos+2] = (w>>16) & 0xFF;
    outbuf[outpos+3] = (w>>24) & 0xFF;
    outpos += 4;
    loc += 4;
}
static void emit_byte(uint8_t b) {
    if (outpos + 1 > outcap) fatal("output overflow\n");
    outbuf[outpos++] = b;
    loc += 1;
}
static void emit_bytes(const void *p, size_t n) {
    if (outpos + n > outcap) fatal("output overflow\n");
    memcpy(outbuf + outpos, p, n);
    outpos += n;
    loc += n;
}

/* ----------------------------- Encoding helpers ----------------------------- */
static uint32_t encode_r(uint32_t funct7, uint32_t rs2, uint32_t rs1, uint32_t funct3, uint32_t rd, uint32_t opcode) {
    return (funct7<<25) | (rs2<<20) | (rs1<<15) | (funct3<<12) | (rd<<7) | opcode;
}
static uint32_t encode_i(int32_t imm, uint32_t rs1, uint32_t funct3, uint32_t rd, uint32_t opcode) {
    uint32_t imm12 = (uint32_t)imm & 0xFFF;
    return (imm12<<20) | (rs1<<15) | (funct3<<12) | (rd<<7) | opcode;
}
static uint32_t encode_s(int32_t imm, uint32_t rs2, uint32_t rs1, uint32_t funct3, uint32_t opcode) {
    uint32_t imm11_5 = ((uint32_t)imm >> 5) & 0x7F;
    uint32_t imm4_0 = ((uint32_t)imm) & 0x1F;
    return (imm11_5<<25) | (rs2<<20) | (rs1<<15) | (funct3<<12) | (imm4_0<<7) | opcode;
}
static uint32_t encode_b(int32_t imm, uint32_t rs2, uint32_t rs1, uint32_t funct3, uint32_t opcode) {
    uint32_t imm12 = ((uint32_t)imm >> 12) & 0x1;
    uint32_t imm11 = ((uint32_t)imm >> 11) & 0x1;
    uint32_t imm10_5 = ((uint32_t)imm >> 5) & 0x3F;
    uint32_t imm4_1 = ((uint32_t)imm >> 1) & 0xF;
    return (imm12<<31) | (imm11<<7) | (imm10_5<<25) | (imm4_1<<8) | (rs2<<20) | (rs1<<15) | (funct3<<12) | opcode;
}
static uint32_t encode_j(int32_t imm, uint32_t rd, uint32_t opcode) {
    uint32_t imm20 = ((uint32_t)imm >> 20) & 0x1;
    uint32_t imm10_1 = ((uint32_t)imm >> 1) & 0x3FF;
    uint32_t imm11 = ((uint32_t)imm >> 11) & 0x1;
    uint32_t imm19_12 = ((uint32_t)imm >> 12) & 0xFF;
    return (imm20<<31) | (imm19_12<<12) | (imm11<<20) | (imm10_1<<21) | (rd<<7) | opcode;
}

/* Opcodes */
enum {
    OPC_R = 0x33,
    OPC_I = 0x13,
    OPC_LOAD = 0x03,
    OPC_STORE = 0x23,
    OPC_BRANCH = 0x63,
    OPC_JAL = 0x6F,
    OPC_JALR = 0x67,
    OPC_SYSTEM = 0x73,
    OPC_FP = 0x53,
    OPC_VEC = 0x5B
};

/* ----------------------------- Register helpers ----------------------------- */
static int reg_x_from_str(const char *tok) {
    if (!tok) return -1;
    if (tok[0]=='x' || tok[0]=='X') {
        char *end; long v = strtol(tok+1, &end, 0);
        if (*end==0 && v>=0 && v<32) return (int)v;
    }
    return -1;
}
static int reg_f_from_str(const char *tok) {
    if (!tok) return -1;
    if (tok[0]=='f' || tok[0]=='F') {
        char *end; long v = strtol(tok+1, &end, 0);
        if (*end==0 && v>=0 && v<32) return (int)v;
    }
    return -1;
}
static int reg_v_from_str(const char *tok) {
    if (!tok) return -1;
    if (tok[0]=='v' || tok[0]=='V') {
        char *end; long v = strtol(tok+1, &end, 0);
        if (*end==0 && v>=0 && v<16) return (int)v;
    }
    return -1;
}
static uint32_t parse_imm_str(const char *s) {
    if (!s) return 0;
    if (s[0]=='0' && (s[1]=='x' || s[1]=='X')) return (uint32_t)strtoul(s+2, NULL, 16);
    if (s[0]=='-') return (uint32_t)strtol(s, NULL, 0);
    return (uint32_t)strtoul(s, NULL, 0);
}

/* ----------------------------- Scanner / Lexer ----------------------------- */

/* Token kinds */
typedef enum {
    A_TOK_EOF,
    A_TOK_EOL,
    A_TOK_IDENT,
    A_TOK_NUMBER,
    A_TOK_STRING,
    A_TOK_COMMA,
    A_TOK_COLON,
    A_TOK_LPAREN,
    A_TOK_RPAREN
} ATokenKind;

typedef struct AToken {
    ATokenKind kind;
    char *text; /* owned for IDENT/NUMBER/STRING */
    int lineno;
    struct AToken *next;
} AToken;

/* Scanner state */
static FILE *infile_global = NULL;
static int scan_peek = -1;
static int scan_lineno = 1;

static int next_char(void) {
    int c;
    if (scan_peek != -1) { c = scan_peek; scan_peek = -1; }
    else c = fgetc(infile_global);
    if (c == '\n') scan_lineno++;
    return c;
}
static int peek_char(void) {
    if (scan_peek == -1) scan_peek = fgetc(infile_global);
    return scan_peek;
}

/* Skip whitespace, line comments (#) and C-style /* ... *\/ comments */
static void skip_whitespace_and_comments(void) {
    while (1) {
        int c = peek_char();
        if (c == EOF) return;
        if (isspace((unsigned char)c)) { next_char(); continue; }
        if (c == '#') {
            /* skip to end of line */
            while ((c = next_char()) != EOF && c != '\n') {}
            continue;
        }
        if (c == '/') {
            /* possible multiline comment */
            next_char(); /* consume '/' */
            int p = peek_char();
            if (p == '*') {
                next_char(); /* consume '*' */
                int prev = 0;
                while (1) {
                    int d = next_char();
                    if (d == EOF) fatal("unterminated /* comment at line %d\n", scan_lineno);
                    if (prev == '*' && d == '/') break;
                    prev = d;
                }
                continue;
            } else {
                /* not a comment, push back '/' */
                scan_peek = '/';
                return;
            }
        }
        break;
    }
}

/* Create token helpers */
static AToken *a_token_new(ATokenKind k, const char *text, int lineno) {
    AToken *t = calloc(1, sizeof(*t));
    if (!t) fatal("out of memory\n");
    t->kind = k;
    t->lineno = lineno;
    t->text = text ? strdup(text) : NULL;
    t->next = NULL;
    return t;
}
static void a_token_free(AToken *t) {
    if (!t) return;
    if (t->text) free(t->text);
    free(t);
}

/* Lex next token */
static AToken *lex_next(void) {
    skip_whitespace_and_comments();
    int c = peek_char();
    if (c == EOF) return a_token_new(A_TOK_EOF, NULL, scan_lineno);
    if (c == '\n') { next_char(); return a_token_new(A_TOK_EOL, NULL, scan_lineno-1); }
    if (c == ',') { next_char(); return a_token_new(A_TOK_COMMA, NULL, scan_lineno); }
    if (c == ':') { next_char(); return a_token_new(A_TOK_COLON, NULL, scan_lineno); }
    if (c == '(') { next_char(); return a_token_new(A_TOK_LPAREN, NULL, scan_lineno); }
    if (c == ')') { next_char(); return a_token_new(A_TOK_RPAREN, NULL, scan_lineno); }
    if (c == '"') {
        next_char(); /* consume " */
        char buf[MAX_LINE]; int i = 0;
        while (1) {
            int d = peek_char();
            if (d == EOF) fatal("unterminated string at line %d\n", scan_lineno);
            if (d == '"') { next_char(); break; }
            if (d == '\\') {
                next_char(); int e = next_char();
                if (e == 'n') buf[i++] = '\n';
                else if (e == 't') buf[i++] = '\t';
                else buf[i++] = (char)e;
            } else {
                buf[i++] = (char)next_char();
            }
            if (i >= (int)sizeof(buf)-1) break;
        }
        buf[i] = 0;
        return a_token_new(A_TOK_STRING, buf, scan_lineno);
    }
    /* identifier/number/other token */
    if (isalnum((unsigned char)c) || c=='_' || c=='-' || c=='.' || c=='x' || c=='X' || c=='f' || c=='F' || c=='v' || c=='V') {
        char buf[MAX_LINE]; int i = 0;
        while (1) {
            int p = peek_char();
            if (p == EOF) break;
            if (isspace((unsigned char)p) || p==',' || p==':' || p=='(' || p==')') break;
            buf[i++] = (char)next_char();
            if (i >= (int)sizeof(buf)-1) break;
        }
        buf[i] = 0;
        /* decide number vs ident: number starts with digit or '-' or 0x */
        int isnum = 0;
        if (buf[0]=='-' || isdigit((unsigned char)buf[0]) || (buf[0]=='0' && (buf[1]=='x' || buf[1]=='X'))) isnum = 1;
        return a_token_new(isnum ? A_TOK_NUMBER : A_TOK_IDENT, buf, scan_lineno);
    }
    /* unknown single char: consume and return as ident */
    char tmp[2];
    tmp[0] = (char)next_char();
    tmp[1] = 0;
    return a_token_new(A_TOK_IDENT, tmp, scan_lineno);
}

/* ----------------------------- AST structures ----------------------------- */

typedef enum { A_ST_LABEL, A_ST_DIRECTIVE, A_ST_INST } AStmtKind;
typedef enum { A_OP_REGX, A_OP_REGF, A_OP_REGV, A_OP_IMM, A_OP_MEM, A_OP_LABELREF, A_OP_STRING } AOpKind;

typedef struct AOperand {
    AOpKind kind;
    union {
        int reg;            /* reg index for X/F/V */
        int64_t imm;        /* immediate */
        struct { int64_t off; int base; } mem; /* offset(base) */
        char *label;        /* label reference */
        char *str;          /* string literal */
    } u;
    struct AOperand *next;
} AOperand;

typedef struct AStmt {
    AStmtKind kind;
    int lineno;
    union {
        char *label; /* A_ST_LABEL */
        struct { char *name; AOperand *args; } inst; /* A_ST_INST */
        struct { char *name; char *arg; } dir; /* A_ST_DIRECTIVE */
    } u;
    struct AStmt *next;
} AStmt;

typedef struct {
    AStmt *head;
    AStmt *tail;
} AProgram;

/* AST helpers */
static AOperand *a_op_new(AOpKind k) {
    AOperand *o = calloc(1, sizeof(*o)); if (!o) fatal("out of memory\n"); o->kind = k; return o;
}
static void a_op_free_list(AOperand *o) {
    while (o) {
        AOperand *n = o->next;
        if (o->kind == A_OP_LABELREF && o->u.label) free(o->u.label);
        if (o->kind == A_OP_STRING && o->u.str) free(o->u.str);
        free(o);
        o = n;
    }
}
static AStmt *a_stmt_new_label(const char *name, int lineno) {
    AStmt *s = calloc(1, sizeof(*s)); if (!s) fatal("out of memory\n");
    s->kind = A_ST_LABEL; s->lineno = lineno; s->u.label = strdup(name); return s;
}
static AStmt *a_stmt_new_inst(const char *mn, AOperand *args, int lineno) {
    AStmt *s = calloc(1, sizeof(*s)); if (!s) fatal("out of memory\n");
    s->kind = A_ST_INST; s->lineno = lineno; s->u.inst.name = strdup(mn); s->u.inst.args = args; return s;
}
static AStmt *a_stmt_new_dir(const char *name, const char *arg, int lineno) {
    AStmt *s = calloc(1, sizeof(*s)); if (!s) fatal("out of memory\n");
    s->kind = A_ST_DIRECTIVE; s->lineno = lineno; s->u.dir.name = strdup(name); s->u.dir.arg = arg ? strdup(arg) : NULL; return s;
}
static void a_stmt_free_list(AStmt *s) {
    while (s) {
        AStmt *n = s->next;
        if (s->kind == A_ST_LABEL) free(s->u.label);
        else if (s->kind == A_ST_INST) { free(s->u.inst.name); a_op_free_list(s->u.inst.args); }
        else if (s->kind == A_ST_DIRECTIVE) { free(s->u.dir.name); free(s->u.dir.arg); }
        free(s);
        s = n;
    }
}
static void a_program_append(AProgram *p, AStmt *s) {
    if (!p->head) p->head = p->tail = s;
    else { p->tail->next = s; p->tail = s; }
}

/* ----------------------------- Parser (tokens -> AST) ----------------------------- */

/* Simple token stream with one-token lookahead */
typedef struct {
    FILE *f;
    AToken *cur;
} ATokenStream;

/* Release a token that may be the current peek in the token stream.
   This clears ts->cur if it points to the token to avoid dangling pointers. */
static void ats_release_token(ATokenStream *ts, AToken *t) {
    if (!t) return;
    if (ts && ts->cur == t) ts->cur = NULL;
    a_token_free(t);
}

static AToken *ats_next_token(ATokenStream *ts) {
    if (ts->cur) {
        AToken *t = ts->cur;
        ts->cur = NULL;
        return t;
    }
    return lex_next();
}
static AToken *ats_peek_token(ATokenStream *ts) {
    if (!ts->cur) ts->cur = lex_next();
    return ts->cur;
}

/* Parse operand list: comma-separated operands until EOL or EOF */
static AOperand *parse_operand(ATokenStream *ts);

/* Parse a single statement (label, directive, or instruction) */
static AStmt *parse_stmt(ATokenStream *ts) {
    AToken *t = ats_peek_token(ts);
    if (!t) return NULL;
    if (t->kind == A_TOK_EOF) { AToken *e = ats_next_token(ts); ats_release_token(ts, e); return NULL; }
    if (t->kind == A_TOK_EOL) { AToken *e = ats_next_token(ts); ats_release_token(ts, e); return NULL; }

    /* Label: IDENT ':' */
    if (t->kind == A_TOK_IDENT) {
        AToken *t1 = ats_next_token(ts); /* consume ident */
        AToken *t2 = ats_peek_token(ts);
        if (t2 && t2->kind == A_TOK_COLON) {
            AToken *col = ats_next_token(ts); /* consume colon */
            ats_release_token(ts, col);
            AStmt *s = a_stmt_new_label(t1->text, t1->lineno);
            /* consume rest of line tokens until EOL */
            AToken *r;
            while ((r = ats_peek_token(ts)) && r->kind != A_TOK_EOL && r->kind != A_TOK_EOF) {
                AToken *tmp = ats_next_token(ts); ats_release_token(ts, tmp);
            }
            AToken *e = ats_peek_token(ts);
            if (e && e->kind == A_TOK_EOL) { AToken *ee = ats_next_token(ts); ats_release_token(ts, ee); }
            ats_release_token(ts, t1);
            return s;
        }
        /* Not a label: could be directive (if starts with '.') or instruction */
        if (t1->text[0] == '.') {
            /* directive: consume rest of line as arg */
            char argbuf[MAX_LINE] = {0};
            AToken *r;
            int first = 1;
            while ((r = ats_peek_token(ts)) && r->kind != A_TOK_EOL && r->kind != A_TOK_EOF) {
                AToken *tok = ats_next_token(ts);
                if (!first) strncat(argbuf, " ", sizeof(argbuf)-strlen(argbuf)-1);
                first = 0;
                if (tok->text) strncat(argbuf, tok->text, sizeof(argbuf)-strlen(argbuf)-1);
                ats_release_token(ts, tok);
            }
            AToken *e = ats_peek_token(ts);
            if (e && e->kind == A_TOK_EOL) { AToken *ee = ats_next_token(ts); ats_release_token(ts, ee); }
            AStmt *s = a_stmt_new_dir(t1->text, argbuf[0] ? argbuf : NULL, t1->lineno);
            ats_release_token(ts, t1);
            return s;
        } else {
            /* instruction: mnemonic + operands */
            int lineno = t1->lineno;
            char *mn = strdup(t1->text);
            ats_release_token(ts, t1);
            AOperand *args = NULL;
            AOperand **tail = &args;
            /* parse operands until EOL or EOF */
            while (1) {
                AToken *p = ats_peek_token(ts);
                if (!p || p->kind == A_TOK_EOL || p->kind == A_TOK_EOF) break;
                AOperand *op = parse_operand(ts);
                if (op) { *tail = op; tail = &op->next; }
                AToken *sep = ats_peek_token(ts);
                if (sep && sep->kind == A_TOK_COMMA) { AToken *c = ats_next_token(ts); ats_release_token(ts, c); continue; }
                else break;
            }
            AToken *e = ats_peek_token(ts);
            if (e && e->kind == A_TOK_EOL) { AToken *ee = ats_next_token(ts); ats_release_token(ts, ee); }
            AStmt *s = a_stmt_new_inst(mn, args, lineno);
            free(mn);
            return s;
        }
    }

    /* If token is directive starting with '.' as a single token */
    if (t->kind == A_TOK_NUMBER || t->kind == A_TOK_STRING) {
        /* stray tokens: consume until EOL */
        AToken *r;
        while ((r = ats_peek_token(ts)) && r->kind != A_TOK_EOL && r->kind != A_TOK_EOF) {
            AToken *tmp = ats_next_token(ts); ats_release_token(ts, tmp);
        }
        AToken *e = ats_peek_token(ts);
        if (e && e->kind == A_TOK_EOL) { AToken *ee = ats_next_token(ts); ats_release_token(ts, ee); }
        return NULL;
    }

    /* Unknown: consume token and continue */
    AToken *junk = ats_next_token(ts); ats_release_token(ts, junk);
    return NULL;
}

/* Parse a single operand */
static AOperand *parse_operand(ATokenStream *ts) {
    AToken *t = ats_peek_token(ts);
    if (!t) return NULL;
    if (t->kind == A_TOK_STRING) {
        AToken *s = ats_next_token(ts);
        AOperand *o = a_op_new(A_OP_STRING);
        o->u.str = strdup(s->text);
        ats_release_token(ts, s);
        return o;
    }
    if (t->kind == A_TOK_NUMBER) {
        AToken *n = ats_next_token(ts);
        AOperand *o = a_op_new(A_OP_IMM);
        o->u.imm = (int64_t)parse_imm_str(n->text);
        ats_release_token(ts, n);
        return o;
    }
    if (t->kind == A_TOK_IDENT) {
        AToken *id = ats_next_token(ts);
        /* check for mem operand pattern: offset(base) may have been lexed as single token like "8(x1)" or split.
           Our lexer splits on parentheses, so we may see NUMBER then LPAREN then IDENT then RPAREN.
           Handle both forms: IDENT that contains '(' or sequence IDENT LPAREN IDENT RPAREN */
        char *txt = id->text;
        /* If token contains '(' treat as mem like "8(x1)" */
        char *paren = strchr(txt, '(');
        if (paren) {
            /* split */
            char offbuf[64] = {0};
            strncpy(offbuf, txt, (size_t)(paren - txt));
            char *pbase = paren + 1;
            char *rp = strchr(pbase, ')');
            if (!rp) fatal("line %d: bad mem operand %s\n", id->lineno, txt);
            char basebuf[64] = {0};
            strncpy(basebuf, pbase, (size_t)(rp - pbase));
            AOperand *o = a_op_new(A_OP_MEM);
            o->u.mem.off = (int64_t)parse_imm_str(offbuf);
            o->u.mem.base = reg_x_from_str(basebuf);
            if (o->u.mem.base < 0) fatal("line %d: bad base reg %s\n", id->lineno, basebuf);
            ats_release_token(ts, id);
            return o;
        }
        /* Otherwise, check if next token is LPAREN -> mem with separate tokens */
        AToken *peek = ats_peek_token(ts);
        if (peek && peek->kind == A_TOK_LPAREN) {
            /* pattern: IDENT ( could be offset then LPAREN then base then RPAREN */
            /* id->text is offset or maybe a number; consume LPAREN */
            AToken *lp = ats_next_token(ts); ats_release_token(ts, lp);
            AToken *base = ats_next_token(ts);
            if (!base || base->kind != A_TOK_IDENT) fatal("line %d: bad mem base\n", id->lineno);
            AToken *rp = ats_next_token(ts);
            if (!rp || rp->kind != A_TOK_RPAREN) fatal("line %d: bad mem operand, missing )\n", id->lineno);
            AOperand *o = a_op_new(A_OP_MEM);
            o->u.mem.off = (int64_t)parse_imm_str(id->text);
            o->u.mem.base = reg_x_from_str(base->text);
            if (o->u.mem.base < 0) fatal("line %d: bad base reg %s\n", id->lineno, base->text);
            ats_release_token(ts, id); ats_release_token(ts, base); ats_release_token(ts, rp);
            return o;
        }
        /* Not mem: could be register or labelref */
        int rx = reg_x_from_str(txt);
        if (rx >= 0) {
            AOperand *o = a_op_new(A_OP_REGX); o->u.reg = rx; ats_release_token(ts, id); return o;
        }
        int rf = reg_f_from_str(txt);
        if (rf >= 0) {
            AOperand *o = a_op_new(A_OP_REGF); o->u.reg = rf; ats_release_token(ts, id); return o;
        }
        int rv = reg_v_from_str(txt);
        if (rv >= 0) {
            AOperand *o = a_op_new(A_OP_REGV); o->u.reg = rv; ats_release_token(ts, id); return o;
        }
        /* otherwise label reference */
        AOperand *o = a_op_new(A_OP_LABELREF);
        o->u.label = strdup(txt);
        ats_release_token(ts, id);
        return o;
    }
    /* other tokens: consume and return NULL */
    AToken *junk = ats_next_token(ts); ats_release_token(ts, junk);
    return NULL;
}

/* Parse entire file into Program AST */
static AProgram *parse_program(FILE *f) {
    infile_global = f;
    scan_peek = -1;
    scan_lineno = 1;
    ATokenStream ts = { .f = f, .cur = NULL };
    AProgram *p = calloc(1, sizeof(*p));
    if (!p) fatal("out of memory\n");
    while (1) {
        AStmt *s = parse_stmt(&ts);
        if (!s) {
            AToken *t = ats_peek_token(&ts);
            if (!t) break;
            if (t->kind == A_TOK_EOF) { AToken *e = ats_next_token(&ts); ats_release_token(&ts, e); break; }
            /* else continue */
            ats_release_token(&ts, t);
            continue;
        }
        a_program_append(p, s);
    }
    return p;
}

/* ----------------------------- AST passes ----------------------------- */

/* First pass: collect labels and compute loc (like original first_pass) */
static void first_pass_ast(AProgram *p) {
    loc = 0;
    for (AStmt *s = p->head; s; s = s->next) {
        if (s->kind == A_ST_LABEL) {
            add_label(s->u.label, loc);
        } else if (s->kind == A_ST_DIRECTIVE) {
            if (strcasecmp(s->u.dir.name, ".org") == 0) {
                if (!s->u.dir.arg) fatal("line %d: .org needs address\n", s->lineno);
                uint32_t addr = parse_imm_str(s->u.dir.arg);
                if (addr < loc) fatal("line %d: .org to lower address\n", s->lineno);
                loc = addr;
            } else if (strcasecmp(s->u.dir.name, ".word") == 0) loc += 4;
            else if (strcasecmp(s->u.dir.name, ".byte") == 0) loc += 1;
            else if (strcasecmp(s->u.dir.name, ".ascii") == 0) {
                if (!s->u.dir.arg) fatal("line %d: .ascii needs string\n", s->lineno);
                /* strip surrounding quotes if present */
                const char *a = s->u.dir.arg;
                if (a[0] == '"' && a[strlen(a)-1] == '"') {
                    loc += (uint32_t)(strlen(a) - 2);
                } else loc += (uint32_t)strlen(a);
            } else {
                /* ignore unknown directives in size pass */
            }
        } else if (s->kind == A_ST_INST) {
            loc += 4;
        }
    }
}

/* Helper to compute current loc during emission; we maintain global loc and outpos */
static void emit_directive(AStmt *s) {
    if (strcasecmp(s->u.dir.name, ".org") == 0) {
        uint32_t addr = parse_imm_str(s->u.dir.arg);
        while (loc < addr) emit_byte(0);
    } else if (strcasecmp(s->u.dir.name, ".word") == 0) {
        uint32_t v = parse_imm_str(s->u.dir.arg);
        emit_word(v);
    } else if (strcasecmp(s->u.dir.name, ".byte") == 0) {
        uint32_t v = parse_imm_str(s->u.dir.arg);
        emit_byte((uint8_t)v);
    } else if (strcasecmp(s->u.dir.name, ".ascii") == 0) {
        const char *a = s->u.dir.arg ? s->u.dir.arg : "";
        if (a[0] == '"' && a[strlen(a)-1] == '"') {
            /* emit inner string */
            size_t n = strlen(a) - 2;
            emit_bytes(a+1, n);
        } else {
            emit_bytes(a, strlen(a));
        }
    } else {
        /* ignore unknown directives */
    }
}

/* Emit an instruction from AST node (uses emit_word/emit_byte/emit_bytes) */
static void emit_inst_from_ast(AStmt *s) {
    const char *m = s->u.inst.name;
    AOperand *o = s->u.inst.args;

    /* R-type integer ops */
    if (strcasecmp(m,"ADD")==0 || strcasecmp(m,"SUB")==0 || strcasecmp(m,"SLL")==0 ||
        strcasecmp(m,"SLT")==0 || strcasecmp(m,"SLTU")==0 || strcasecmp(m,"XOR")==0 ||
        strcasecmp(m,"SRL")==0 || strcasecmp(m,"SRA")==0 || strcasecmp(m,"OR")==0 ||
        strcasecmp(m,"AND")==0) {
        if (!o || !o->next || !o->next->next) fatal("line %d: %s needs 3 operands\n", s->lineno, m);
        int rd = lineno; s->u.inst.name = strdup(mn); s->u.inst.args = args; return s;
}
static AStmt *a_stmt_new_dir(const char *name, const char *arg, int lineno) {
    AStmt *s = calloc(1, sizeof(*s)); if (!s) fatal("out of memory\n");
    s->kind = A_ST_DIRECTIVE; s->lineno = lineno; s->u.dir.name = strdup(name); s->u.dir.arg = arg ? strdup(arg) : NULL; return s;
}
static void a_stmt_free_list(AStmt *s) {
    while (s) {
        AStmt *n = s->next;
        if (s->kind == A_ST_LABEL) free(s->u.label);
        else if (s->kind == A_ST_INST) { free(s->u.inst.name); a_op_free_list(s->u.inst.args); }
        else if (s->kind == A_ST_DIRECTIVE) { free(s->u.dir.name); free(s->u.dir.arg); }
        free(s);
        s = n;
    }
}
static void a_program_append(AProgram *p, AStmt *s) {
    if (!p->head) p->head = p->tail = s;
    else { p->tail->next = s; p->tail = s; }
}

/* ----------------------------- Parser (tokens -> AST) ----------------------------- */

/* Simple token stream with one-token lookahead */
typedef struct {
    FILE *f;
    AToken *cur;
} ATokenStream;

/* Release a token that may be the current peek in the token stream.
   This clears ts->cur if it points to the token to avoid dangling pointers. */
static void ats_release_token(ATokenStream *ts, AToken *t) {
    if (!t) return;
    if (ts && ts->cur == t) ts->cur = NULL;
    a_token_free(t);
}

static AToken *ats_next_token(ATokenStream *ts) {
    if (ts->cur) {
        AToken *t = ts->cur;
        ts->cur = NULL;
        return t;
    }
    return lex_next();
}
static AToken *ats_peek_token(ATokenStream *ts) {
    if (!ts->cur) ts->cur = lex_next();
    return ts->cur;
}

/* Parse operand list: comma-separated operands until EOL or EOF */
static AOperand *parse_operand(ATokenStream *ts);

/* Parse a single statement (label, directive, or instruction) */
static AStmt *parse_stmt(ATokenStream *ts) {
    AToken *t = ats_peek_token(ts);
    if (!t) return NULL;
    if (t->kind == A_TOK_EOF) { AToken *e = ats_next_token(ts); ats_release_token(ts, e); return NULL; }
    if (t->kind == A_TOK_EOL) { AToken *e = ats_next_token(ts); ats_release_token(ts, e); return NULL; }

    /* Label: IDENT ':' */
    if (t->kind == A_TOK_IDENT) {
        AToken *t1 = ats_next_token(ts); /* consume ident */
        AToken *t2 = ats_peek_token(ts);
        if (t2 && t2->kind == A_TOK_COLON) {
            AToken *col = ats_next_token(ts); /* consume colon */
            ats_release_token(ts, col);
            AStmt *s = a_stmt_new_label(t1->text, t1->lineno);
            /* consume rest of line tokens until EOL */
            AToken *r;
            while ((r = ats_peek_token(ts)) && r->kind != A_TOK_EOL && r->kind != A_TOK_EOF) {
                AToken *tmp = ats_next_token(ts); ats_release_token(ts, tmp);
            }
            AToken *e = ats_peek_token(ts);
            if (e && e->kind == A_TOK_EOL) { AToken *ee = ats_next_token(ts); ats_release_token(ts, ee); }
            ats_release_token(ts, t1);
            return s;
        }
        /* Not a label: could be directive (if starts with '.') or instruction */
        if (t1->text[0] == '.') {
            /* directive: consume rest of line as arg */
            char argbuf[MAX_LINE] = {0};
            AToken *r;
            int first = 1;
            while ((r = ats_peek_token(ts)) && r->kind != A_TOK_EOL && r->kind != A_TOK_EOF) {
                AToken *tok = ats_next_token(ts);
                if (!first) strncat(argbuf, " ", sizeof(argbuf)-strlen(argbuf)-1);
                first = 0;
                if (tok->text) strncat(argbuf, tok->text, sizeof(argbuf)-strlen(argbuf)-1);
                ats_release_token(ts, tok);
            }
            AToken *e = ats_peek_token(ts);
            if (e && e->kind == A_TOK_EOL) { AToken *ee = ats_next_token(ts); ats_release_token(ts, ee); }
            AStmt *s = a_stmt_new_dir(t1->text, argbuf[0] ? argbuf : NULL, t1->lineno);
            ats_release_token(ts, t1);
            return s;
        } else {
            /* instruction: mnemonic + operands */
            int lineno = t1->lineno;
            char *mn = strdup(t1->text);
            ats_release_token(ts, t1);
            AOperand *args = NULL;
            AOperand **tail = &args;
            /* parse operands until EOL or EOF */
            while (1) {
                AToken *p = ats_peek_token(ts);
                if (!p || p->kind == A_TOK_EOL || p->kind == A_TOK_EOF) break;
                AOperand *op = parse_operand(ts);
                if (op) { *tail = op; tail = &op->next; }
                AToken *sep = ats_peek_token(ts);
                if (sep && sep->kind == A_TOK_COMMA) { AToken *c = ats_next_token(ts); ats_release_token(ts, c); continue; }
                else break;
            }
            AToken *e = ats_peek_token(ts);
            if (e && e->kind == A_TOK_EOL) { AToken *ee = ats_next_token(ts); ats_release_token(ts, ee); }
            AStmt *s = a_stmt_new_inst(mn, args, lineno);
            free(mn);
            return s;
        }
    }

    /* If token is directive starting with '.' as a single token */
    if (t->kind == A_TOK_NUMBER || t->kind == A_TOK_STRING) {
        /* stray tokens: consume until EOL */
        AToken *r;
        while ((r = ats_peek_token(ts)) && r->kind != A_TOK_EOL && r->kind != A_TOK_EOF) {
            AToken *tmp = ats_next_token(ts); ats_release_token(ts, tmp);
        }
        AToken *e = ats_peek_token(ts);
        if (e && e->kind == A_TOK_EOL) { AToken *ee = ats_next_token(ts); ats_release_token(ts, ee); }
        return NULL;
    }

    /* Unknown: consume token and continue */
    AToken *junk = ats_next_token(ts); ats_release_token(ts, junk);
    return NULL;
}

/* Parse a single operand */
static AOperand *parse_operand(ATokenStream *ts) {
    AToken *t = ats_peek_token(ts);
    if (!t) return NULL;
    if (t->kind == A_TOK_STRING) {
        AToken *s = ats_next_token(ts);
        AOperand *o = a_op_new(A_OP_STRING);
        o->u.str = strdup(s->text);
        ats_release_token(ts, s);
        return o;
    }
    if (t->kind == A_TOK_NUMBER) {
        AToken *n = ats_next_token(ts);
        AOperand *o = a_op_new(A_OP_IMM);
        o->u.imm = (int64_t)parse_imm_str(n->text);
        ats_release_token(ts, n);
        return o;
    }
    if (t->kind == A_TOK_IDENT) {
        AToken *id = ats_next_token(ts);
        /* check for mem operand pattern: offset(base) may have been lexed as single token like "8(x1)" or split.
           Our lexer splits on parentheses, so we may see NUMBER then LPAREN then IDENT then RPAREN.
           Handle both forms: IDENT that contains '(' or sequence IDENT LPAREN IDENT RPAREN */
        char *txt = id->text;
        /* If token contains '(' treat as mem like "8(x1)" */
        char *paren = strchr(txt, '(');
        if (paren) {
            /* split */
            char offbuf[64] = {0};
            strncpy(offbuf, txt, (size_t)(paren - txt));
            char *pbase = paren + 1;
            char *rp = strchr(pbase, ')');
            if (!rp) fatal("line %d: bad mem operand %s\n", id->lineno, txt);
            char basebuf[64] = {0};
            strncpy(basebuf, pbase, (size_t)(rp - pbase));
            AOperand *o = a_op_new(A_OP_MEM);
            o->u.mem.off = (int64_t)parse_imm_str(offbuf);
            o->u.mem.base = reg_x_from_str(basebuf);
            if (o->u.mem.base < 0) fatal("line %d: bad base reg %s\n", id->lineno, basebuf);
            ats_release_token(ts, id);
            return o;
        }
        /* Otherwise, check if next token is LPAREN -> mem with separate tokens */
        AToken *peek = ats_peek_token(ts);
        if (peek && peek->kind == A_TOK_LPAREN) {
            /* pattern: IDENT ( could be offset then LPAREN then base then RPAREN */
            /* id->text is offset or maybe a number; consume LPAREN */
            AToken *lp = ats_next_token(ts); ats_release_token(ts, lp);
            AToken *base = ats_next_token(ts);
            if (!base || base->kind != A_TOK_IDENT) fatal("line %d: bad mem base\n", id->lineno);
            AToken *rp = ats_next_token(ts);
            if (!rp || rp->kind != A_TOK_RPAREN) fatal("line %d: bad mem operand, missing )\n", id->lineno);
            AOperand *o = a_op_new(A_OP_MEM);
            o->u.mem.off = (int64_t)parse_imm_str(id->text);
            o->u.mem.base = reg_x_from_str(base->text);
            if (o->u.mem.base < 0) fatal("line %d: bad base reg %s\n", id->lineno, base->text);
            ats_release_token(ts, id); ats_release_token(ts, base); ats_release_token(ts, rp);
            return o;
        }
        /* Not mem: could be register or labelref */
        int rx = reg_x_from_str(txt);
        if (rx >= 0) {
            AOperand *o = a_op_new(A_OP_REGX); o->u.reg = rx; ats_release_token(ts, id); return o;
        }
        int rf = reg_f_from_str(txt);
        if (rf >= 0) {
            AOperand *o = a_op_new(A_OP_REGF); o->u.reg = rf; ats_release_token(ts, id); return o;
        }
        int rv = reg_v_from_str(txt);
        if (rv >= 0) {
            AOperand *o = a_op_new(A_OP_REGV); o->u.reg = rv; ats_release_token(ts, id); return o;
        }
        /* otherwise label reference */
        AOperand *o = a_op_new(A_OP_LABELREF);
        o->u.label = strdup(txt);
        ats_release_token(ts, id);
        return o;
    }
    /* other tokens: consume and return NULL */
    AToken *junk = ats_next_token(ts); ats_release_token(ts, junk);
    return NULL;
}

/* Parse entire file into Program AST */
static AProgram *parse_program(FILE *f) {
    infile_global = f;
    scan_peek = -1;
    scan_lineno = 1;
    ATokenStream ts = { .f = f, .cur = NULL };
    AProgram *p = calloc(1, sizeof(*p));
    if (!p) fatal("out of memory\n");
    while (1) {
        AStmt *s = parse_stmt(&ts);
        if (!s) {
            AToken *t = ats_peek_token(&ts);
            if (!t) break;
            if (t->kind == A_TOK_EOF) { AToken *e = ats_next_token(&ts); ats_release_token(&ts, e); break; }
            /* else continue */
            ats_release_token(&ts, t);
            continue;
        }
        a_program_append(p, s);
    }
    return p;
}

/* ----------------------------- AST passes ----------------------------- */

/* First pass: collect labels and compute loc (like original first_pass) */
static void first_pass_ast(AProgram *p) {
    loc = 0;
    for (AStmt *s = p->head; s; s = s->next) {
        if (s->kind == A_ST_LABEL) {
            add_label(s->u.label, loc);
        } else if (s->kind == A_ST_DIRECTIVE) {
            if (strcasecmp(s->u.dir.name, ".org") == 0) {
                if (!s->u.dir.arg) fatal("line %d: .org needs address\n", s->lineno);
                uint32_t addr = parse_imm_str(s->u.dir.arg);
                if (addr < loc) fatal("line %d: .org to lower address\n", s->lineno);
                loc = addr;
            } else if (strcasecmp(s->u.dir.name, ".word") == 0) loc += 4;
            else if (strcasecmp(s->u.dir.name, ".byte") == 0) loc += 1;
            else if (strcasecmp(s->u.dir.name, ".ascii") == 0) {
                if (!s->u.dir.arg) fatal("line %d: .ascii needs string\n", s->lineno);
                /* strip surrounding quotes if present */
                const char *a = s->u.dir.arg;
                if (a[0] == '"' && a[strlen(a)-1] == '"') {
                    loc += (uint32_t)(strlen(a) - 2);
                } else loc += (uint32_t)strlen(a);
            } else {
                /* ignore unknown directives in size pass */
            }
        } else if (s->kind == A_ST_INST) {
            loc += 4;
        }
    }
}

/* Helper to compute current loc during emission; we maintain global loc and outpos */
static void emit_directive(AStmt *s) {
    if (strcasecmp(s->u.dir.name, ".org") == 0) {
        uint32_t addr = parse_imm_str(s->u.dir.arg);
        while (loc < addr) emit_byte(0);
    } else if (strcasecmp(s->u.dir.name, ".word") == 0) {
        uint32_t v = parse_imm_str(s->u.dir.arg);
        emit_word(v);
    } else if (strcasecmp(s->u.dir.name, ".byte") == 0) {
        uint32_t v = parse_imm_str(s->u.dir.arg);
        emit_byte((uint8_t)v);
    } else if (strcasecmp(s->u.dir.name, ".ascii") == 0) {
        const char *a = s->u.dir.arg ? s->u.dir.arg : "";
        if (a[0] == '"' && a[strlen(a)-1] == '"') {
            /* emit inner string */
            size_t n = strlen(a) - 2;
            emit_bytes(a+1, n);
        } else {
            emit_bytes(a, strlen(a));
        }
    } else {
        /* ignore unknown directives */
    }
}

/* Emit an instruction from AST node (uses emit_word/emit_byte/emit_bytes) */
static void emit_inst_from_ast(AStmt *s) {
    const char *m = s->u.inst.name;
    AOperand *o = s->u.inst.args;

    /* R-type integer ops */
    if (strcasecmp(m,"ADD")==0 || strcasecmp(m,"SUB")==0 || strcasecmp(m,"SLL")==0 ||
        strcasecmp(m,"SLT")==0 || strcasecmp(m,"SLTU")==0 || strcasecmp(m,"XOR")==0 ||
        strcasecmp(m,"SRL")==0 || strcasecmp(m,"SRA")==0 || strcasecmp(m,"OR")==0 ||
        strcasecmp(m,"AND")==0) {
        if (!o || !o->next || !o->next->next) fatal("line %d: %s needs 3 operands\n", s->lineno, m);
        int rd = -1, rs1 = -1, rs2 = -1;
        if (o->kind==A_OP_REGX) rd = o->u.reg;
        if (o->next->kind==A_OP_REGX) rs1 = o->next->u.reg;
        if (o->next->next->kind==A_OP_REGX) rs2 = o->next->next->u.reg;
        if (rd<0||rs1<0||rs2<0) fatal("line %d: invalid register\n", s->lineno);
        uint32_t funct3=0, funct7=0;
        if (strcasecmp(m,"ADD")==0) { funct3=0; funct7=0x00; }
        else if (strcasecmp(m,"SUB")==0) { funct3=0; funct7=0x20; }
        else if (strcasecmp(m,"SLL")==0) { funct3=0x1; funct7=0x00; }
        else if (strcasecmp(m,"SLT")==0) { funct3=0x2; funct7=0x00; }
        else if (strcasecmp(m,"SLTU")==0) { funct3=0x3; funct7=0x00; }
        else if (strcasecmp(m,"XOR")==0) { funct3=0x4; funct7=0x00; }
        else if (strcasecmp(m,"SRL")==0) { funct3=0x5; funct7=0x00; }
        else if (strcasecmp(m,"SRA")==0) { funct3=0x5; funct7=0x20; }
        else if (strcasecmp(m,"OR")==0) { funct3=0x6; funct7=0x00; }
        else if (strcasecmp(m,"AND")==0) { funct3=0x7; funct7=0x00; }
        uint32_t w = encode_r(funct7, rs2, rs1, funct3, rd, OPC_R);
        emit_word(w);
        return;
    }

    /* I-type ALU */
    if (strcasecmp(m,"ADDI")==0 || strcasecmp(m,"SLLI")==0 || strcasecmp(m,"SRLI")==0 || strcasecmp(m,"SRAI")==0) {
        if (!o || !o->next) fatal("line %d: %s needs 2 operands\n", s->lineno, m);
        int rd = (o->kind==A_OP_REGX)?o->u.reg:-1;
        int rs1 = (o->next->kind==A_OP_REGX)?o->next->u.reg:-1;
        if (rd<0||rs1<0) fatal("line %d: invalid register\n", s->lineno);
        if (strcasecmp(m = -1, rs1 = -1, rs2 = -1;
        if (o->kind==A_OP_REGX) rd = o->u.reg;
        if (o->next->kind==A_OP_REGX) rs1 = o->next->u.reg;
        if (o->next,"ADDI")==0) {
            if (!o->next->next) fatal("line %d: ADDI needs imm\n", s->lineno);
            int32_t imm = (int32_t)(o->next->next->kind==A_OP_IMM ? o->next->next->u.imm : 0);
            uint32_t w = encode_i(imm, rs1, 0x0, rd, OPC_I);
            emit_word(w);
            return;
        } else {
            if (!o->next->next) fatal("line %d: shift needs shamt\n", s->lineno);
            int sh = (int)o->next->next->u.imm;
            uint32_t funct3 = (strcasecmp(m,"SLLI")==0)?0x1:0x5;
            uint32_t funct7 = (strcasecmp(m,"SRAI")==0)?0x20:0x00;
            uint32_t imm12 = (sh & 0x3F);
            uint32_t w = (funct7<<25) | (imm12<<20) | (rs1<<15) | (funct3<<12) | (rd<<7) | OPC_I;
            emit_word(w);
            return;
        }
    }

    /* Loads */
    if (strcasecmp(m,"LD")==0 || strcasecmp(m,"LW")==0 || strcasecmp(m,"LH")==0 || strcasecmp(m,"LB")==0 ||
        strcasecmp(m,"LWU")==0 || strcasecmp(m,"LHU")==0 || strcasecmp(m,"LBU")==0) {
        if (!o || !o->next) fatal("line %d: %s needs rd, offset(base)\n", s->lineno, m);
        int rd = (o->kind==A_OP_REGX)?o->u.reg:-1;
        if (rd<0) fatal("line %d: invalid rd\n", s->lineno);
        AOperand *memop = o->next;
        if (memop->kind != A_OP_MEM) fatal("line %d: bad mem operand\n", s->lineno);
        int rs1 = memop->u.mem.base;
        int32_t imm = (int32_t)memop->u.mem.off;
        uint32_t f3 = 0;
        if (strcasecmp(m,"LB")==0) f3=0x0;
        else if (strcasecmp(m,"LH")==0) f3=0x1;
        else if (strcasecmp(m,"LW")==0) f3=0x2;
        else if (strcasecmp(m,"LD")==0) f3=0x3;
        else if (strcasecmp(m,"LBU")==0) f3=0x4;
        else if (strcasecmp(m,"LHU")==0) f3=0x5;
        else if (strcasecmp(m,"LWU")==0) f3=0x6;
        uint32_t w = encode_i(imm, rs1, f3, rd, OPC_LOAD);
        emit_word(w);
        return;
    }

    /* Stores */
    if (strcasecmp(m,"SD")==0 || strcasecmp(m,"SW")==0 || strcasecmp(m,"SH")==0 || strcasecmp(m,"SB")==0) {
        if (!o || !o->next) fatal("line %d: %s needs rs2, offset(base)\n", s->lineno, m);
        int rs2 = (o->kind==A_OP_REGX)?o->u.reg:-1;
        if (rs2<0) fatal("line %d: invalid rs2\n", s->lineno);
        AOperand *memop = o->next;
        if (memop->kind != A_OP_MEM) fatal("line %d: bad mem operand\n", s->lineno);
        int rs1 = memop->u.mem.base;
        int32_t imm = (int32_t)memop->u.mem.off;
        uint32_t f3 = 0;
        if (strcasecmp(m,"SB")==0) f3=0x0;
        else if (strcasecmp(m,"SH")==0) f3=0x1;
        else if (strcasecmp(m,"SW")==0) f3=0x2;
        else if (strcasecmp(m,"SD")==0) f3=0x3;
        uint32_t w = encode_s(imm, rs2, rs1, f3, OPC_STORE);
        emit_word(w);
        return;
    }

    /* Branches */
    if (strcasecmp(m,"BEQ")==0 || strcasecmp(m,"BNE")==0 || strcasecmp(m,"BLT")==0 || strcasecmp(m,"BGE")==0 ||
        strcasecmp(m,"BLTU")==0 || strcasecmp(m,"BGEU")==0) {
        if (!o || !o->next || !o->next->next) fatal("line %d: %s needs rs1, rs2, label\n", s->lineno, m);
        int rs1 = (o->kind==A_OP_REGX)?o->u.reg:-1;
        int rs2 = (o->next->kind==A_OP_REGX)?o->next->u.reg:-1;
        if (rs1<0||rs2<0) fatal("line %d: bad regs\n", s->lineno);
        AOperand *lab = o->next->next;
        if (lab->kind != A_OP_LABELREF) fatal("line %d: branch target must be label\n", s->lineno);
        uint32_t target;
        if (!find_label(lab->u.label, &target)) fatal("line %d: unknown label %s\n", s->lineno, lab->u.label);
        int32_t imm = (int32_t)((int64_t)target - (int64_t)loc);
        uint32_t f3 = 0;
        if (strcasecmp(m,"BEQ")==0) f3=0x0;
        else if (strcasecmp(m,"BNE")==0) f3=0x1;
        else if (strcasecmp(m,"BLT")==0) f3=0x4;
        else if (strcasecmp(m,"BGE")==0) f3=0x5;
        else if (strcasecmp(m,"BLTU")==0) f3=0x6;
        else if (strcasecmp(m,"BGEU")==0) f3=0x7;
        uint32_t w = encode_b(imm, rs2, rs1, f3, OPC_BRANCH);
        emit_word(w);
        return;
    }

    /* JAL */
    if (strcasecmp(m,"JAL")==0) {
        if (!o || !o->next) fatal("line %d: JAL rd, label\n", s->lineno);
        int rd = (o->kind==A_OP_REGX)?o->u.reg:-1;
        if (rd<0) fatal("line %d: bad rd\n", s->lineno);
        AOperand *lab = o->next;
        if (lab->kind != A_OP_LABELREF) fatal("line %d: JAL target must be label\n", s->lineno);
        uint32_t target;
        if (!find_label(lab->u.label, &target)) fatal("line %d: unknown label %s\n", s->lineno, lab->u.label);
        int32_t imm = (int32_t)((int64_t)target - (int64_t)loc);
        uint32_t w = encode_j(imm, rd, OPC_JAL);
        emit_word(w);
        return;
    }

    /* JALR */
    if (strcasecmp(m,"JALR")==0) {
        if (!o || !o->next || !o->next->next) fatal("line %d: JALR rd, rs1, imm\n", s->lineno);
        int rd = (o->kind==A_OP_REGX)?o->u.reg:-1;
        int rs1 = (o->next->kind==A_OP_REGX)?o->next->u.reg:-1;
        if (rd<0||rs1<0) fatal("line %d: bad regs\n", s->lineno);
        int32_t imm = (int32_t)(o->next->next->kind==A_OP_IMM ? o->next->next->u.imm : 0);
        uint32_t w = encode_i(imm, rs1, 0x0, rd, OPC_JALR);
        emit_word(w);
        return;
    }

    /* ECALL */
    if (strcasecmp(m,"ECALL")==0) {
        uint32_t w = 0x00000073;
        emit_word(w);
        return;
    }

    /* FP scalar */
    if (strcasecmp(m,"FADD.D")==0 || strcasecmp(m,"FSUB.D")==0 || strcasecmp(m,"FMUL.D")==0 || strcasecmp(m,"FDIV.D")==0 ||
        strcasecmp(m,"FCVT.D.SI")==0 || strcasecmp(m,"FCVT.SI.D")==0) {
        if (strcasecmp(m,"FCVT.D.SI")==0) {
            if (!o || !o->next) fatal("line %d: FCVT.D.SI rd, rs1\n", s->lineno);
            int rd = (o->kind==A_OP_REGF)?o->u.reg:-1;
            int rs1 = (o->next->kind==A_OP_REGX)?o->next->u.reg:-1;
            if (rd<0||rs1<0) fatal("line %d: bad regs\n", s->lineno);
            uint32_t w = (0x20<<25) | (0<<20) | (rs1<<15) | (0<<12) | (rd<<7) | OPC_FP;
            emit_word(w);
            return;
        } else if (strcasecmp(m,"FCVT.SI.D")==0) {
            if (!o || !o->next) fatal("line %d: FCVT.SI.D rd, rs1\n", s->lineno);
            int rd = (o->kind==A_OP_REGX)?o->u.reg:-1;
            int rs1 = (o->next->kind==A_OP_REGF)?o->next->u.reg:-1;
            if (rd<0||rs1<0) fatal("line %d: bad regs\n", s->lineno);
            uint32_t w = (0x20<<25) | (rs1<<20) | (0<<15) | (1<<12) | (rd<<7) | OPC_FP;
            emit_word(w);
            return;
        } else {
            if (!o || !o->next || !o->next->next) fatal("line %d: %s needs rd, rs1, rs2\n", s->lineno, m);
            int rd = (o->kind==A_OP_REGF)?o->u.reg:-1;
            int rs1 = (o->next->kind==A_OP_REGF)?o->next->u.reg:-1;
            int rs2 = (o->next->next->kind==A_OP_REGF)?o->next->next->u.reg:-1;
            if (rd<0||rs1<0||rs2<0) fatal("line %d: bad fregs\n", s->lineno);
            uint32_t f7=0, f3=0;
            if (strcasecmp(m,"FADD.D")==0) { f7=0x00; f3=0x0; }
            else if (strcasecmp(m,"FSUB.D")==0) { f7=0x00; f3=0x1; }
            else if (strcasecmp(m,"FMUL.D")==0) { f7=0x00; f3=0x2; }
            else if (strcasecmp(m,"FDIV.D")==0) { f7=0x00; f3=0x3; }
            uint32_t w = encode_r(f7, rs2, rs1, f3, rd, OPC_FP);
            emit_word(w);
            return;
        }
    }

    /* Vector */
    if (strcasecmp(m,"VADD.64")==0 || strcasecmp(m,"VMUL.64")==0 || strcasecmp(m,"VADD.32")==0) {
        if (!o || !o->next || !o->next->next) fatal("line %d: %s needs vd, vs1, vs2\n", s->lineno, m);
        int vd = (o->kind==A_OP_REGV)?o->u.reg:-1;
        int vs1 = (o->next->kind==A_OP_REGV)?o->next->u.reg:-1;
        int vs2 = (o->next->next->kind==A_OP_REGV)?o->next->next->u.reg:-1;
        if (vd<0||vs1<0||vs2<0) fatal("line %d: bad vregs\n", s->lineno);
        uint32_t f7=0, f3=0;
        if (strcasecmp(m,"VADD.64")==0) { f7=0x00; f3=0x0; }
        else if (strcasecmp(m,"VMUL.64")==0) { f7=0x00; f3=0x1; }
        else if (strcasecmp(m,"VADD.32")==0) { f7=0x10; f3=0x0; }
        uint32_t w = encode_r(f7, vs2, vs1, f3, vd, OPC_VEC);
        emit_word(w);
        return;
    }
    if (strcasecmp(m,"VLD")==0 || strcasecmp(m,"VST")==0) {
        if (!o || !o->next) fatal("line %d: %s needs vd, offset(base)\n", s->lineno, m);
        int vd = (o->kind==A_OP_REGV)?o->u.reg:-1;
        if (vd<0) fatal("line %d: bad vd\n", s->lineno);
        AOperand *memop = o->next;
        if (memop->kind != A_OP_MEM) fatal("line %d: bad mem operand\n", s->lineno);
        int rs1 = memop->u.mem.base;
        int imm12 = (int)memop->u.mem.off & 0xFFF;
        uint32_t f7 = 0x20;
        uint32_t f3 = (strcasecmp(m,"VLD")==0)?0x0:0x1;
        uint32_t w = (f7<<25) | (imm12<<20) | (rs1<<15) | (f3<<12) | (vd<<7) | OPC_VEC;
        emit_word(w);
        return;
    }

    fatal("line %d: unknown mnemonic: %s\n", s->lineno, m);
}

/* Second pass: emit payload */
static void second_pass_ast(AProgram *p) {
    loc = 0;
    outpos = 0;
    for (AStmt *s = p->head; s; s = s->next) {
        if (s->kind == A_ST_LABEL) {
            /* nothing to emit */
        } else if (s->kind == A_ST_DIRECTIVE) {
            emit_directive(s);
        } else if (s->kind == A_ST_INST) {
            emit_inst_from_ast(s);
        }
    }
}

/* ----------------------------- Output writer ----------------------------- */
static void write_output(const char *outfile, uint32_t load_addr) {
    FILE *fo = fopen(outfile, "wb");
    if (!fo) fatal("fopen %s: %s\n", outfile, strerror(errno));
    uint32_t payload_size = (uint32_t)outpos;
    uint8_t hdr[8];
    hdr[0] = load_addr & 0xFF; hdr[1] = (load_addr>>8)&0xFF; hdr[2] = (load_addr>>16)&0xFF; hdr[3] = (load_addr>>24)&0xFF;
    hdr[4] = payload_size & 0xFF; hdr[5] = (payload_size>>8)&0xFF; hdr[6] = (payload_size>>16)&0xFF; hdr[7] = (payload_size>>24)&0xFF;
    if (fwrite(hdr,1,8,fo) != 8) fatal("fwrite header failed\n");
    if (payload_size) {
        if (fwrite(outbuf,1,payload_size,fo) != payload_size) fatal("fwrite payload failed\n");
    }
    fclose(fo);
    printf("Assembled %u bytes (load addr 0x%08x) -> %s\n", payload_size, load_addr, outfile);
}

/* ----------------------------- Top-level assemble API ----------------------------- */

int assemble_file(const char *infile, const char *outfile, uint32_t load_addr) {
    if (!infile || !outfile) {
        fprintf(stderr, "assemble_file: infile and outfile are required\n");
        return 1;
    }

    FILE *f = fopen(infile, "r");
    if (!f) {
        fprintf(stderr, "assemble_file: cannot open input '%s': %s\n", infile, strerror(errno));
        return 2;
    }

    if (!outbuf) {
        outbuf = malloc(outcap);
        if (!outbuf) {
            fclose(f);
            fprintf(stderr, "assemble_file: out of memory\n");
            return 3;
        }
    }

    /* parse into AST */
    AProgram *p = parse_program(f);

    /* first pass: collect labels and compute sizes */
    first_pass_ast(p);

    /* second pass: emit bytes */
    second_pass_ast(p);

    /* write final file */
    write_output(outfile, load_addr);

    /* cleanup */
    a_stmt_free_list(p->head);
    free(p);
    free(outbuf);
    outbuf = NULL;
    free_labels();

    fclose(f);
    return 0;
}

