/* micro-ops layer */
typedef enum {
    UOP_NONE = 0,
    UOP_ALU_BIN,     /* dst = alu(dst, src) */
    UOP_ALU_BIN_MEM, /* mem = alu(mem, src) */
    UOP_ALU_IMM,     /* dst = alu(dst, imm) */
