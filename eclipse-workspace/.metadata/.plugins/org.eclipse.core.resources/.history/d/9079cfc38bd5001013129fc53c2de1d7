int main(int argc, char **argv)
{
    segment = 1; /* default to .text */

    if (argc > 1) {
        FILE *f = fopen(argv[1], "r");
        if (!f) { perror("fopen"); return 1; }
        char buf[INPUT_LINE_MAX];
        while (fgets(buf, sizeof(buf), f)) process_line(buf);
        fclose(f);
    } else {
        /* Demo program with AT&T syntax to test ELF features */
        const char *program[] = {
            "bits 64",
            ".text",
            ".global main",
            "main:",
            "  movq $0x1, %rax",
            "  movq %rax, %rbx",
            "  addq %rax, %rbx",
            "  jmp target_label",
            "target_label:",
            "  subq %rax, %rbx",
            "  jmp $0x2",
            ".data",
            "global_data: .qword 0xDEADBEEFCAFEBABE",
            ".global global_data",
            ".bss",
            "bss_reserve: .qword 0",
            NULL
        };
        for (int i=0; program[i]; ++i) {
            char line_copy[INPUT_LINE_MAX];
            strncpy(line_copy, program[i], INPUT_LINE_MAX - 1);
            line_copy[INPUT_LINE_MAX - 1] = '\0';
            process_line(line_copy);
        }
    }

    write_output();
    return 0;
}
