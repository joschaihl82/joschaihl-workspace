cmake_minimum_required(VERSION 3.16)
project(MiniGTK4Browser C)

# C standard
set(CMAKE_C_STANDARD 11)
set(CMAKE_C_STANDARD_REQUIRED ON)

# Default build type
if(NOT CMAKE_BUILD_TYPE)
  set(CMAKE_BUILD_TYPE Release CACHE STRING "Build type" FORCE)
endif()

# User overrides for non-standard installs
set(GTK4_ROOT "" CACHE PATH "Prefix where GTK4 is installed (include/ and lib/)")
set(WEBKIT_ROOT "" CACHE PATH "Prefix where WebKitGTK is installed (include/ and lib/)")
set(EXTRA_INCLUDE_DIRS "" CACHE STRING "Extra include directories (semicolon separated)")
set(EXTRA_LIBS "" CACHE STRING "Extra libraries to link (semicolon separated)")
set(EXTRA_LINK_DIRS "" CACHE STRING "Extra library directories (semicolon separated)")

# Build search path lists
set(_search_inc_paths "")
set(_search_lib_paths "")

if(GTK4_ROOT)
  list(APPEND _search_inc_paths "${GTK4_ROOT}/include" "${GTK4_ROOT}/include/gtk-4.0")
  list(APPEND _search_lib_paths "${GTK4_ROOT}/lib" "${GTK4_ROOT}/lib64")
endif()

if(WEBKIT_ROOT)
  list(APPEND _search_inc_paths "${WEBKIT_ROOT}/include" "${WEBKIT_ROOT}/include/webkit2gtk-6.0")
  list(APPEND _search_lib_paths "${WEBKIT_ROOT}/lib" "${WEBKIT_ROOT}/lib64")
endif()

# Add common system include/lib locations
list(APPEND _search_inc_paths
  /usr/include
  /usr/local/include
  /usr/include/gtk-4.0
  /usr/local/include/gtk-4.0
  /usr/include/webkit2gtk-6.0
  /usr/local/include/webkit2gtk-6.0
)
list(APPEND _search_lib_paths
  /usr/lib
  /usr/lib64
  /usr/local/lib
  /usr/lib/x86_64-linux-gnu
)

# Find headers
find_path(GTK4_INCLUDE_DIR
  NAMES gtk/gtk.h
  PATHS ${_search_inc_paths}
)
find_path(WEBKIT_INCLUDE_DIR
  NAMES webkit2/webkit2.h
  PATHS ${_search_inc_paths}
)

# Find main libraries
find_library(GTK4_LIBRARY
  NAMES gtk-4 gtk-4.0
  PATHS ${_search_lib_paths}
)
find_library(WEBKIT_LIBRARY
  NAMES webkit2gtk-6.0 webkit2gtk-4.0 webkit2gtk-4
  PATHS ${_search_lib_paths}
)

# Common dependencies that pkg-config would normally add (try to locate)
find_library(GLIB_LIBRARY NAMES glib-2.0 PATHS ${_search_lib_paths})
find_library(GOBJECT_LIBRARY NAMES gobject-2.0 PATHS ${_search_lib_paths})
find_library(GIO_LIBRARY NAMES gio-2.0 PATHS ${_search_lib_paths})
find_library(GMODULE_LIBRARY NAMES gmodule-2.0 PATHS ${_search_lib_paths})
find_library(GTHREAD_LIBRARY NAMES gthread-2.0 PATHS ${_search_lib_paths})

# Fallback: try system default search if not found yet
if(NOT GTK4_INCLUDE_DIR)
  find_path(GTK4_INCLUDE_DIR NAMES gtk/gtk.h)
endif()
if(NOT WEBKIT_INCLUDE_DIR)
  find_path(WEBKIT_INCLUDE_DIR NAMES webkit2/webkit2.h)
endif()
if(NOT GTK4_LIBRARY)
  find_library(GTK4_LIBRARY NAMES gtk-4 gtk-4.0)
endif()
if(NOT WEBKIT_LIBRARY)
  find_library(WEBKIT_LIBRARY NAMES webkit2gtk-6.0 webkit2gtk-4.0 webkit2gtk-4)
endif()
if(NOT GLIB_LIBRARY)
  find_library(GLIB_LIBRARY NAMES glib-2.0)
endif()
if(NOT GOBJECT_LIBRARY)
  find_library(GOBJECT_LIBRARY NAMES gobject-2.0)
endif()
if(NOT GIO_LIBRARY)
  find_library(GIO_LIBRARY NAMES gio-2.0)
endif()
if(NOT GMODULE_LIBRARY)
  find_library(GMODULE_LIBRARY NAMES gmodule-2.0)
endif()
if(NOT GTHREAD_LIBRARY)
  find_library(GTHREAD_LIBRARY NAMES gthread-2.0)
endif()

# Validate results and provide actionable errors
if(NOT GTK4_INCLUDE_DIR)
  message(FATAL_ERROR "GTK4 headers not found. Set -DGTK4_ROOT=/path/to/gtk4 or install GTK4 development files.")
endif()
if(NOT WEBKIT_INCLUDE_DIR)
  message(FATAL_ERROR "WebKitGTK headers not found. Set -DWEBKIT_ROOT=/path/to/webkit or install WebKitGTK development files.")
endif()
if(NOT GTK4_LIBRARY)
  message(FATAL_ERROR "GTK4 library not found. Set -DGTK4_ROOT or ensure GTK4 dev libs are installed.")
endif()
if(NOT WEBKIT_LIBRARY)
  message(FATAL_ERROR "WebKitGTK library not found. Set -DWEBKIT_ROOT or ensure WebKitGTK dev libs are installed.")
endif()

# Print summary (convert lists to readable strings)
string(REPLACE ";" " " _inc_paths_str "${_search_inc_paths}")
string(REPLACE ";" " " _lib_paths_str "${_search_lib_paths}")
message(STATUS "GTK4 include: ${GTK4_INCLUDE_DIR}")
message(STATUS "GTK4 lib:     ${GTK4_LIBRARY}")
message(STATUS "WebKit include:${WEBKIT_INCLUDE_DIR}")
message(STATUS "WebKit lib:    ${WEBKIT_LIBRARY}")
message(STATUS "Search include paths: ${_inc_paths_str}")
message(STATUS "Search lib paths: ${_lib_paths_str}")

# Source files
set(SRC browser.c)

add_executable(browser ${SRC})

# Include directories
target_include_directories(browser PRIVATE
  ${GTK4_INCLUDE_DIR}
  ${WEBKIT_INCLUDE_DIR}
)

# Add user-specified extra include dirs
if(EXTRA_INCLUDE_DIRS)
  foreach(_inc ${EXTRA_INCLUDE_DIRS})
    target_include_directories(browser PRIVATE ${_inc})
  endforeach()
endif()

# Link directories (user-specified)
if(EXTRA_LINK_DIRS)
  foreach(_ld ${EXTRA_LINK_DIRS})
    link_directories(${_ld})
  endforeach()
endif()

# Link libraries: include common dependencies that pkg-config would normally add
set(_link_libs
  ${WEBKIT_LIBRARY}
  ${GTK4_LIBRARY}
)

if(GLIB_LIBRARY)    list(APPEND _link_libs ${GLIB_LIBRARY})    endif()
if(GOBJECT_LIBRARY) list(APPEND _link_libs ${GOBJECT_LIBRARY}) endif()
if(GIO_LIBRARY)     list(APPEND _link_libs ${GIO_LIBRARY})     endif()
if(GMODULE_LIBRARY) list(APPEND _link_libs ${GMODULE_LIBRARY}) endif()
if(GTHREAD_LIBRARY) list(APPEND _link_libs ${GTHREAD_LIBRARY}) endif()

# Add user-specified extra libs
if(EXTRA_LIBS)
  foreach(_l ${EXTRA_LIBS})
    list(APPEND _link_libs ${_l})
  endforeach()
endif()

target_link_libraries(browser PRIVATE ${_link_libs})

# Common compile options that pkg-config would normally provide
if (CMAKE_C_COMPILER_ID STREQUAL "GNU" OR CMAKE_C_COMPILER_ID MATCHES "Clang")
  target_compile_options(browser PRIVATE -Wall -Wextra -Wpedantic -pthread -D_REENTRANT)
else()
  target_compile_options(browser PRIVATE -D_REENTRANT)
endif()

# Helpful message if linking fails due to missing transitive libs
set(_missing_suggest "")
if(NOT GLIB_LIBRARY OR NOT GOBJECT_LIBRARY OR NOT GIO_LIBRARY)
  set(_missing_suggest "If you get undefined reference errors, re-run cmake with -DEXTRA_LIBS=\"gobject-2.0;gio-2.0;glib-2.0;gmodule-2.0;gthread-2.0\" or set GTK4_ROOT/WEBKIT_ROOT to the correct prefix.")
endif()

# Print link libs in readable form
string(REPLACE ";" " " _link_libs_str "${_link_libs}")
message(STATUS "Link libraries: ${_link_libs_str}")
if(_missing_suggest)
  message(STATUS "${_missing_suggest}")
endif()

# Install
install(TARGETS browser RUNTIME DESTINATION bin)

# Export compile commands for IDEs
set(CMAKE_EXPORT_COMPILE_COMMANDS ON)
