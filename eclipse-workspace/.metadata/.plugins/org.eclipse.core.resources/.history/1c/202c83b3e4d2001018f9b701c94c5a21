/*
 slinker.c - Minimaler ELF64 Linker (x86_64, Linux)
 - Liest mehrere ELF64 ET_REL (.o) Dateien
 - Verbindet .text, .rodata, .data, .bss
 - Löst Symbole aus .symtab
 - Verarbeitet SHT_RELA Relokationen (R_X86_64_64, R_X86_64_PC32)
 - Schreibt ein einfaches statisches ELF64 Executable (ET_EXEC)
 - Einschränkungen siehe Header in Antwort

 Compile:
   gcc -std=c99 -O2 -o slinker slinker.c

 Usage:
   ./slinker file1.o file2.o ... -o output

 Limitations:
   - Only ELF64 little-endian (x86_64)
   - Only SHT_RELA relocations supported
   - Only R_X86_64_64 and R_X86_64_PC32 handled
   - No automatic libc linking; all symbols must be provided
*/

#define _POSIX_C_SOURCE 200809L
#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>
#include <string.h>
#include <inttypes.h>
#include <errno.h>
#include <sys/stat.h>
#include <fcntl.h>
#include <unistd.h>

/* ELF definitions (minimal subset) */
typedef uint16_t Elf64_Half;
typedef uint32_t Elf64_Word;
typedef int32_t  Elf64_Sword;
typedef uint64_t Elf64_Xword;
typedef int64_t  Elf64_Sxword;
typedef uint64_t Elf64_Addr;
typedef uint64_t Elf64_Off;

#define EI_NIDENT 16

typedef struct {
    unsigned char e_ident[EI_NIDENT];
    Elf64_Half e_type;
    Elf64_Half e_machine;
    Elf64_Word e_version;
    Elf64_Addr e_entry;
    Elf64_Off  e_phoff;
    Elf64_Off  e_shoff;
    Elf64_Word e_flags;
    Elf64_Half e_ehsize;
    Elf64_Half e_phentsize;
    Elf64_Half e_phnum;
    Elf64_Half e_shentsize;
    Elf64_Half e_shnum;
    Elf64_Half e_shstrndx;
} Elf64_Ehdr;

typedef struct {
    Elf64_Word sh_name;
    Elf64_Word sh_type;
    Elf64_Xword sh_flags;
    Elf64_Addr sh_addr;
    Elf64_Off  sh_offset;
    Elf64_Xword sh_size;
    Elf64_Word sh_link;
    Elf64_Word sh_info;
    Elf64_Xword sh_addralign;
    Elf64_Xword sh_entsize;
} Elf64_Shdr;

typedef struct {
    Elf64_Word st_name;
    unsigned char st_info;
    unsigned char st_other;
    Elf64_Half st_shndx;
    Elf64_Addr st_value;
    Elf64_Xword st_size;
} Elf64_Sym;

typedef struct {
    Elf64_Addr r_offset;
    Elf64_Xword r_info;
    Elf64_Sxword r_addend;
} Elf64_Rela;

#define ELFCLASS64 2
#define ELFDATA2LSB 1
#define EV_CURRENT 1
#define ET_REL 1
#define ET_EXEC 2
#define EM_X86_64 62

/* Section types */
#define SHT_NULL     0
#define SHT_PROGBITS 1
#define SHT_SYMTAB   2
#define SHT_STRTAB   3
#define SHT_RELA     4
#define SHT_NOBITS   8

/* Relocation macros */
#define ELF64_R_SYM(i) ((i) >> 32)
#define ELF64_R_TYPE(i) ((i) & 0xffffffffL)
#define ELF64_R_INFO(s,t) (((uint64_t)(s) << 32) + (uint64_t)(t))

/* x86_64 relocation types (we support a subset) */
#define R_X86_64_NONE 0
#define R_X86_64_64   1
#define R_X86_64_PC32 2
#define R_X86_64_RELATIVE 8

/* Symbol binding/type helpers */
#define ELF64_ST_BIND(i) ((i) >> 4)
#define ELF64_ST_TYPE(i) ((i) & 0xf)

/* Simple data structures for linking */
typedef struct {
    char *name;
    unsigned char *data;
    size_t size;
    size_t align;
    int is_bss;
} SectionData;

typedef struct {
    char *name;
    Elf64_Sym *symtab;
    char *strtab;
    size_t symcount;
} SymtabData;

typedef struct {
    char *filename;
    SectionData text, rodata, data, bss;
    SymtabData symtab;
    /* relocations: arrays of Elf64_Rela for each section */
    Elf64_Rela *rela_text;
    size_t rela_text_count;
    Elf64_Rela *rela_data;
    size_t rela_data_count;
    Elf64_Rela *rela_rodata;
    size_t rela_rodata_count;
} ObjFile;

/* Global lists */
ObjFile *objs = NULL;
size_t obj_count = 0;

/* Output layout */
unsigned char *out_text = NULL;
size_t out_text_size = 0;
size_t out_text_align = 16;

unsigned char *out_rodata = NULL;
size_t out_rodata_size = 0;
size_t out_rodata_align = 16;

unsigned char *out_data = NULL;
size_t out_data_size = 0;
size_t out_data_align = 8;

size_t out_bss_size = 0;
size_t out_bss_align = 8;

/* Global symbol table (merged) */
typedef struct {
    char *name;
    Elf64_Addr value; /* virtual address in output */
    size_t size;
    int defined; /* 1 if defined, 0 if undefined */
    int is_func;
} GlobalSym;

GlobalSym *gsyms = NULL;
size_t gsym_count = 0;

/* Helpers */
static void *read_file(const char *path, size_t *out_size) {
    FILE *f = fopen(path, "rb");
    if (!f) return NULL;
    if (fseek(f, 0, SEEK_END) != 0) { fclose(f); return NULL; }
    long s = ftell(f);
    if (s < 0) { fclose(f); return NULL; }
    rewind(f);
    unsigned char *buf = malloc(s);
    if (!buf) { fclose(f); return NULL; }
    if (fread(buf, 1, s, f) != (size_t)s) { free(buf); fclose(f); return NULL; }
    fclose(f);
    *out_size = s;
    return buf;
}

static uint64_t align_up(uint64_t v, uint64_t a) {
    if (a == 0) return v;
    return (v + a - 1) & ~(a - 1);
}

/* Parse a single object file (very limited) */
static int parse_obj(const char *path) {
    size_t sz;
    unsigned char *buf = read_file(path, &sz);
    if (!buf) {
        fprintf(stderr, "Error: cannot read %s: %s\n", path, strerror(errno));
        return -1;
    }
    if (sz < sizeof(Elf64_Ehdr)) { free(buf); fprintf(stderr,"%s: too small\n",path); return -1; }
    Elf64_Ehdr *eh = (Elf64_Ehdr*)buf;
    if (eh->e_ident[0] != 0x7f || eh->e_ident[1] != 'E' || eh->e_ident[2] != 'L' || eh->e_ident[3] != 'F') {
        free(buf); fprintf(stderr,"%s: not ELF\n",path); return -1;
    }
    if (eh->e_ident[4] != ELFCLASS64 || eh->e_ident[5] != ELFDATA2LSB) {
        free(buf); fprintf(stderr,"%s: unsupported ELF class/data\n",path); return -1;
    }
    if (eh->e_type != ET_REL) {
        free(buf); fprintf(stderr,"%s: not relocatable object (ET_REL required)\n",path); return -1;
    }
    if (eh->e_machine != EM_X86_64) {
        free(buf); fprintf(stderr,"%s: unsupported machine\n",path); return -1;
    }

    /* Read section headers and section header string table */
    Elf64_Shdr *sh = (Elf64_Shdr*)(buf + eh->e_shoff);
    if (eh->e_shstrndx >= eh->e_shnum) { free(buf); fprintf(stderr,"%s: bad shstrndx\n",path); return -1; }
    Elf64_Shdr *shstr = &sh[eh->e_shstrndx];
    char *shstrtab = (char*)(buf + shstr->sh_offset);

    ObjFile obj;
    memset(&obj, 0, sizeof(obj));
    obj.filename = strdup(path);

    /* iterate sections */
    for (int i = 0; i < eh->e_shnum; ++i) {
        Elf64_Shdr *s = &sh[i];
        const char *name = shstrtab + s->sh_name;
        if (s->sh_type == SHT_PROGBITS || s->sh_type == SHT_NOBITS) {
            if (strcmp(name, ".text") == 0) {
                obj.text.size = s->sh_size;
                obj.text.align = s->sh_addralign ? s->sh_addralign : 16;
                obj.text.is_bss = (s->sh_type == SHT_NOBITS);
                if (!obj.text.is_bss) {
                    obj.text.data = malloc(s->sh_size);
                    memcpy(obj.text.data, buf + s->sh_offset, s->sh_size);
                } else {
                    obj.text.data = NULL;
                }
                obj.text.name = strdup(".text");
            } else if (strcmp(name, ".rodata") == 0 || strcmp(name, ".rdata") == 0) {
                obj.rodata.size = s->sh_size;
                obj.rodata.align = s->sh_addralign ? s->sh_addralign : 16;
                obj.rodata.is_bss = (s->sh_type == SHT_NOBITS);
                if (!obj.rodata.is_bss) {
                    obj.rodata.data = malloc(s->sh_size);
                    memcpy(obj.rodata.data, buf + s->sh_offset, s->sh_size);
                } else obj.rodata.data = NULL;
                obj.rodata.name = strdup(".rodata");
            } else if (strcmp(name, ".data") == 0) {
                obj.data.size = s->sh_size;
                obj.data.align = s->sh_addralign ? s->sh_addralign : 8;
                obj.data.is_bss = (s->sh_type == SHT_NOBITS);
                if (!obj.data.is_bss) {
                    obj.data.data = malloc(s->sh_size);
                    memcpy(obj.data.data, buf + s->sh_offset, s->sh_size);
                } else obj.data.data = NULL;
                obj.data.name = strdup(".data");
            } else if (strcmp(name, ".bss") == 0) {
                obj.bss.size = s->sh_size;
                obj.bss.align = s->sh_addralign ? s->sh_addralign : 8;
                obj.bss.is_bss = 1;
                obj.bss.data = NULL;
                obj.bss.name = strdup(".bss");
            }
        } else if (s->sh_type == SHT_SYMTAB) {
            /* symbol table */
            Elf64_Sym *symtab = (Elf64_Sym*)(buf + s->sh_offset);
            size_t nsyms = s->sh_size / s->sh_entsize;
            /* find linked string table */
            if (s->sh_link >= eh->e_shnum) { free(buf); fprintf(stderr,"%s: bad symtab link\n",path); return -1; }
            Elf64_Shdr *strsh = &sh[s->sh_link];
            char *strtab = (char*)(buf + strsh->sh_offset);
            obj.symtab.symcount = nsyms;
            obj.symtab.symtab = malloc(nsyms * sizeof(Elf64_Sym));
            memcpy(obj.symtab.symtab, symtab, nsyms * sizeof(Elf64_Sym));
            obj.symtab.strtab = malloc(strsh->sh_size + 1);
            memcpy(obj.symtab.strtab, strtab, strsh->sh_size);
            obj.symtab.strtab[strsh->sh_size] = '\0';
            obj.symtab.name = strdup(".symtab");
        } else if (s->sh_type == SHT_RELA) {
            /* relocation section; determine which section it applies to via sh_info */
            if (s->sh_info >= eh->e_shnum) { free(buf); fprintf(stderr,"%s: bad rela sh_info\n",path); return -1; }
            Elf64_Shdr *target = &sh[s->sh_info];
            const char *tname = shstrtab + target->sh_name;
            Elf64_Rela *rela = (Elf64_Rela*)(buf + s->sh_offset);
            size_t nrel = s->sh_size / s->sh_entsize;
            if (strcmp(tname, ".text") == 0) {
                obj.rela_text = malloc(nrel * sizeof(Elf64_Rela));
                memcpy(obj.rela_text, rela, nrel * sizeof(Elf64_Rela));
                obj.rela_text_count = nrel;
            } else if (strcmp(tname, ".data") == 0) {
                obj.rela_data = malloc(nrel * sizeof(Elf64_Rela));
                memcpy(obj.rela_data, rela, nrel * sizeof(Elf64_Rela));
                obj.rela_data_count = nrel;
            } else if (strcmp(tname, ".rodata") == 0) {
                obj.rela_rodata = malloc(nrel * sizeof(Elf64_Rela));
                memcpy(obj.rela_rodata, rela, nrel * sizeof(Elf64_Rela));
                obj.rela_rodata_count = nrel;
            } else {
                /* ignore relocations for other sections */
            }
        }
    }

    /* append to global objs */
    objs = realloc(objs, (obj_count + 1) * sizeof(ObjFile));
    objs[obj_count] = obj;
    obj_count++;

    free(buf);
    return 0;
}

/* Merge sections: concatenate with alignment */
static void layout_sections() {
    /* compute sizes and allocate concatenated buffers */
    size_t tsize = 0, rsize = 0, dsize = 0, bsize = 0;
    for (size_t i = 0; i < obj_count; ++i) {
        ObjFile *o = &objs[i];
        if (o->text.size) {
            tsize = align_up(tsize, o->text.align);
            tsize += o->text.size;
            if (o->text.align > out_text_align) out_text_align = o->text.align;
        }
        if (o->rodata.size) {
            rsize = align_up(rsize, o->rodata.align);
            rsize += o->rodata.size;
            if (o->rodata.align > out_rodata_align) out_rodata_align = o->rodata.align;
        }
        if (o->data.size) {
            dsize = align_up(dsize, o->data.align);
            dsize += o->data.size;
            if (o->data.align > out_data_align) out_data_align = o->data.align;
        }
        if (o->bss.size) {
            bsize = align_up(bsize, o->bss.align);
            bsize += o->bss.size;
            if (o->bss.align > out_bss_align) out_bss_align = o->bss.align;
        }
    }
    out_text_size = tsize;
    out_rodata_size = rsize;
    out_data_size = dsize;
    out_bss_size = bsize;

    if (out_text_size) {
        out_text = malloc(out_text_size);
        memset(out_text, 0x90, out_text_size); /* fill with NOP for safety */
    }
    if (out_rodata_size) {
        out_rodata = malloc(out_rodata_size);
        memset(out_rodata, 0, out_rodata_size);
    }
    if (out_data_size) {
        out_data = malloc(out_data_size);
        memset(out_data, 0, out_data_size);
    }

    /* copy contents and record per-object offsets by storing symbol values later */
    size_t toff = 0, roff = 0, doff = 0, boff = 0;
    for (size_t i = 0; i < obj_count; ++i) {
        ObjFile *o = &objs[i];
        if (o->text.size) {
            toff = align_up(toff, o->text.align);
            if (o->text.data) memcpy(out_text + toff, o->text.data, o->text.size);
            /* store the object's text section virtual offset in sh_addr field? We don't have that; instead we'll compute symbol addresses later by tracking per-object base offsets */
            /* We'll reuse o->text.size and store base offsets in o->text.sh_addr via casting (hack) */
            o->text.sh_offset = toff; /* use sh_offset field as base offset in output text */
            toff += o->text.size;
        } else {
            o->text.sh_offset = (size_t)-1;
        }
        if (o->rodata.size) {
            roff = align_up(roff, o->rodata.align);
            if (o->rodata.data) memcpy(out_rodata + roff, o->rodata.data, o->rodata.size);
            o->rodata.sh_offset = roff;
            roff += o->rodata.size;
        } else {
            o->rodata.sh_offset = (size_t)-1;
        }
        if (o->data.size) {
            doff = align_up(doff, o->data.align);
            if (o->data.data) memcpy(out_data + doff, o->data.data, o->data.size);
            o->data.sh_offset = doff;
            doff += o->data.size;
        } else {
            o->data.sh_offset = (size_t)-1;
        }
        if (o->bss.size) {
            boff = align_up(boff, o->bss.align);
            o->bss.sh_offset = boff;
            boff += o->bss.size;
        } else {
            o->bss.sh_offset = (size_t)-1;
        }
    }
}

/* Build global symbol table: collect defined symbols and compute their output addresses */
static int build_global_symbols(Elf64_Addr base_text_vaddr, Elf64_Addr base_rodata_vaddr, Elf64_Addr base_data_vaddr) {
    /* First pass: collect definitions */
    for (size_t i = 0; i < obj_count; ++i) {
        ObjFile *o = &objs[i];
        if (!o->symtab.symtab) continue;
        for (size_t s = 0; s < o->symtab.symcount; ++s) {
            Elf64_Sym *sym = &o->symtab.symtab[s];
            const char *sname = o->symtab.strtab + sym->st_name;
            if (sname == NULL || sname[0] == '\0') continue;
            int bind = ELF64_ST_BIND(sym->st_info);
            int type = ELF64_ST_TYPE(sym->st_info);
            /* skip local symbols */
            if (bind == 0) continue;
            /* defined? st_shndx != 0 (SHN_UNDEF) */
            if (sym->st_shndx != 0) {
                /* determine which section and compute virtual address */
                Elf64_Addr val = 0;
                if (sym->st_shndx == 1) {
                    /* usually .text? Not reliable; instead we try to match by section offsets: we don't have mapping from st_shndx to section names here.
                       Simpler approach: if symbol value falls within object's section offsets, map accordingly.
                    */
                }
                /* Heuristic: symbol st_value is offset within its section; we need to determine which section contains it.
                   We'll check each section in the object: text, rodata, data, bss.
                */
                if (o->text.sh_offset != (size_t)-1 && sym->st_value < o->text.size) {
                    val = base_text_vaddr + o->text.sh_offset + sym->st_value;
                } else if (o->rodata.sh_offset != (size_t)-1 && sym->st_value < o->rodata.size) {
                    val = base_rodata_vaddr + o->rodata.sh_offset + sym->st_value;
                } else if (o->data.sh_offset != (size_t)-1 && sym->st_value < o->data.size) {
                    val = base_data_vaddr + o->data.sh_offset + sym->st_value;
                } else if (o->bss.sh_offset != (size_t)-1 && sym->st_value < o->bss.size) {
                    val = base_data_vaddr + o->bss.sh_offset + sym->st_value; /* bss placed after data */
                } else {
                    /* fallback: if symbol value is zero and type is FUNC, assume text base */
                    if (type == 2 && o->text.sh_offset != (size_t)-1) {
                        val = base_text_vaddr + o->text.sh_offset + sym->st_value;
                    } else {
                        /* unknown mapping; skip */
                        continue;
                    }
                }
                /* add or update global symbol */
                int found = 0;
                for (size_t g = 0; g < gsym_count; ++g) {
                    if (strcmp(gsyms[g].name, sname) == 0) {
                        /* if already defined, override? For now, error on multiple definitions */
                        if (gsyms[g].defined) {
                            fprintf(stderr, "Error: multiple definition of symbol %s\n", sname);
                            return -1;
                        } else {
                            gsyms[g].value = val;
                            gsyms[g].size = sym->st_size;
                            gsyms[g].defined = 1;
                            gsyms[g].is_func = (type == 2);
                            found = 1;
                            break;
                        }
                    }
                }
                if (!found) {
                    gsyms = realloc(gsyms, (gsym_count + 1) * sizeof(GlobalSym));
                    gsyms[gsym_count].name = strdup(sname);
                    gsyms[gsym_count].value = val;
                    gsyms[gsym_count].size = sym->st_size;
                    gsyms[gsym_count].defined = 1;
                    gsyms[gsym_count].is_func = (type == 2);
                    gsym_count++;
                }
            } else {
                /* undefined symbol: add if not present */
                int found = 0;
                for (size_t g = 0; g < gsym_count; ++g) {
                    if (strcmp(gsyms[g].name, sname) == 0) { found = 1; break; }
                }
                if (!found) {
                    gsyms = realloc(gsyms, (gsym_count + 1) * sizeof(GlobalSym));
                    gsyms[gsym_count].name = strdup(sname);
                    gsyms[gsym_count].value = 0;
                    gsyms[gsym_count].size = 0;
                    gsyms[gsym_count].defined = 0;
                    gsyms[gsym_count].is_func = 0;
                    gsym_count++;
                }
            }
        }
    }
    /* Check for undefined symbols */
    for (size_t g = 0; g < gsym_count; ++g) {
        if (!gsyms[g].defined) {
            fprintf(stderr, "Error: undefined symbol: %s\n", gsyms[g].name);
            return -1;
        }
    }
    return 0;
}

/* Apply relocations: supports R_X86_64_64 and R_X86_64_PC32 */
static int apply_relocations(Elf64_Addr base_text_vaddr, Elf64_Addr base_rodata_vaddr, Elf64_Addr base_data_vaddr) {
    for (size_t i = 0; i < obj_count; ++i) {
        ObjFile *o = &objs[i];
        /* helper to resolve symbol index to address */
        auto resolve_sym = [&](uint32_t symidx)->Elf64_Addr {
            if (!o->symtab.symtab) return 0;
            if (symidx >= o->symtab.symcount) return 0;
            Elf64_Sym *sym = &o->symtab.symtab[symidx];
            const char *sname = o->symtab.strtab + sym->st_name;
            for (size_t g = 0; g < gsym_count; ++g) {
                if (strcmp(gsyms[g].name, sname) == 0) return gsyms[g].value;
            }
            return 0;
        };

        /* process text relocations */
        for (size_t r = 0; r < o->rela_text_count; ++r) {
            Elf64_Rela *rela = &o->rela_text[r];
            uint32_t sym = (uint32_t)ELF64_R_SYM(rela->r_info);
            uint32_t type = (uint32_t)ELF64_R_TYPE(rela->r_info);
            Elf64_Addr where = base_text_vaddr + o->text.sh_offset + rela->r_offset;
            Elf64_Addr S = resolve_sym(sym);
            Elf64_Sxword A = rela->r_addend;
            if (type == R_X86_64_64) {
                uint64_t val = (uint64_t)(S + A);
                /* write val into output at where */
                size_t off = (where - base_text_vaddr);
                if (off + 8 > out_text_size) { fprintf(stderr,"relocation out of range\n"); return -1; }
                memcpy(out_text + off, &val, 8);
            } else if (type == R_X86_64_PC32) {
                /* 32-bit PC relative: S + A - P */
                Elf64_Addr P = where;
                int32_t val32 = (int32_t)((S + A) - P);
                size_t off = (where - base_text_vaddr);
                if (off + 4 > out_text_size) { fprintf(stderr,"relocation out of range\n"); return -1; }
                memcpy(out_text + off, &val32, 4);
            } else {
                fprintf(stderr, "Unsupported relocation type %u in %s\n", type, o->filename);
                return -1;
            }
        }

        /* process data relocations */
        for (size_t r = 0; r < o->rela_data_count; ++r) {
            Elf64_Rela *rela = &o->rela_data[r];
            uint32_t sym = (uint32_t)ELF64_R_SYM(rela->r_info);
            uint32_t type = (uint32_t)ELF64_R_TYPE(rela->r_info);
            Elf64_Addr where = base_data_vaddr + o->data.sh_offset + rela->r_offset;
            Elf64_Addr S = resolve_sym(sym);
            Elf64_Sxword A = rela->r_addend;
            if (type == R_X86_64_64) {
                uint64_t val = (uint64_t)(S + A);
                size_t off = (where - base_data_vaddr);
                if (off + 8 > out_data_size) { fprintf(stderr,"relocation out of range\n"); return -1; }
                memcpy(out_data + off, &val, 8);
            } else if (type == R_X86_64_PC32) {
                Elf64_Addr P = where;
                int32_t val32 = (int32_t)((S + A) - P);
                size_t off = (where - base_data_vaddr);
                if (off + 4 > out_data_size) { fprintf(stderr,"relocation out of range\n"); return -1; }
                memcpy(out_data + off, &val32, 4);
            } else {
                fprintf(stderr, "Unsupported relocation type %u in %s\n", type, o->filename);
                return -1;
            }
        }

        /* process rodata relocations */
        for (size_t r = 0; r < o->rela_rodata_count; ++r) {
            Elf64_Rela *rela = &o->rela_rodata[r];
            uint32_t sym = (uint32_t)ELF64_R_SYM(rela->r_info);
            uint32_t type = (uint32_t)ELF64_R_TYPE(rela->r_info);
            Elf64_Addr where = base_rodata_vaddr + o->rodata.sh_offset + rela->r_offset;
            Elf64_Addr S = resolve_sym(sym);
            Elf64_Sxword A = rela->r_addend;
            if (type == R_X86_64_64) {
                uint64_t val = (uint64_t)(S + A);
                size_t off = (where - base_rodata_vaddr);
                if (off + 8 > out_rodata_size) { fprintf(stderr,"relocation out of range\n"); return -1; }
                memcpy(out_rodata + off, &val, 8);
            } else {
                fprintf(stderr, "Unsupported relocation type %u in %s\n", type, o->filename);
                return -1;
            }
        }
    }
    return 0;
}

/* Write final ELF executable (very simple program headers) */
static int write_output(const char *outpath, Elf64_Addr base_vaddr, Elf64_Addr entry) {
    /* We'll create a minimal ELF with two PT_LOAD segments:
       - text+rodata (RX)
       - data+bss (RW)
       Layout in file: ELF header + program headers + segment data (aligned)
    */
    int fd = open(outpath, O_CREAT | O_TRUNC | O_WRONLY, 0755);
    if (fd < 0) { perror("open output"); return -1; }

    /* compute file offsets */
    size_t phnum = 2;
    size_t ehdr_size = sizeof(Elf64_Ehdr);
    size_t phdr_size = 56; /* Elf64_Phdr size */
    size_t phdrs_total = phnum * phdr_size;
    size_t offset = align_up(ehdr_size + phdrs_total, 0x1000); /* align to page */

    /* segment 0: text+rodata */
    size_t seg0_fileoff = offset;
    size_t seg0_filesz = out_text_size + out_rodata_size;
    size_t seg0_memsz = seg0_filesz;
    offset = seg0_fileoff + seg0_filesz;
    offset = align_up(offset, 0x1000);

    /* segment 1: data + bss */
    size_t seg1_fileoff = offset;
    size_t seg1_filesz = out_data_size;
    size_t seg1_memsz = out_data_size + out_bss_size;
    offset = seg1_fileoff + seg1_filesz;
    /* final file size = offset */

    /* Build ELF header */
    Elf64_Ehdr eh;
    memset(&eh, 0, sizeof(eh));
    eh.e_ident[0] = 0x7f; eh.e_ident[1] = 'E'; eh.e_ident[2] = 'L'; eh.e_ident[3] = 'F';
    eh.e_ident[4] = ELFCLASS64;
    eh.e_ident[5] = ELFDATA2LSB;
    eh.e_ident[6] = EV_CURRENT;
    eh.e_type = ET_EXEC;
    eh.e_machine = EM_X86_64;
    eh.e_version = EV_CURRENT;
    eh.e_entry = entry;
    eh.e_phoff = sizeof(Elf64_Ehdr);
    eh.e_shoff = 0;
    eh.e_ehsize = sizeof(Elf64_Ehdr);
    eh.e_phentsize = phdr_size;
    eh.e_phnum = phnum;

    /* Program header struct (manual layout to avoid defining Elf64_Phdr) */
    unsigned char phdrs[2 * 56];
    memset(phdrs, 0, sizeof(phdrs));
    /* helper to write 64-bit little endian */
    auto write64 = [&](unsigned char *p, uint64_t v){ for (int i=0;i<8;i++) p[i] = (v >> (i*8)) & 0xff; };
    auto write32 = [&](unsigned char *p, uint32_t v){ for (int i=0;i<4;i++) p[i] = (v >> (i*8)) & 0xff; };

    /* PHDR 0: text+rodata RX */
    unsigned char *p0 = phdrs;
    write32(p0 + 0, 1); /* p_type = PT_LOAD */
    write32(p0 + 4, 5); /* p_flags = PF_R | PF_X */
    write64(p0 + 8, seg0_fileoff); /* p_offset */
    write64(p0 + 16, base_vaddr); /* p_vaddr */
    write64(p0 + 24, base_vaddr); /* p_paddr */
    write64(p0 + 32, seg0_filesz); /* p_filesz */
    write64(p0 + 40, seg0_memsz);  /* p_memsz */
    write64(p0 + 48, 0x1000); /* p_align */

    /* PHDR 1: data RW */
    unsigned char *p1 = phdrs + 56;
    write32(p1 + 0, 1); /* PT_LOAD */
    write32(p1 + 4, 6); /* PF_R | PF_W */
    write64(p1 + 8, seg1_fileoff);
    write64(p1 + 16, base_vaddr + seg1_fileoff - seg0_fileoff + base_vaddr); /* approximate vaddr; simpler: place data after text in vaddr space */
    /* Simpler approach: place data vaddr = base_vaddr + seg0_memsz aligned */
    Elf64_Addr data_vaddr = align_up(base_vaddr + seg0_memsz, 0x1000);
    write64(p1 + 16, data_vaddr);
    write64(p1 + 24, data_vaddr);
    write64(p1 + 32, seg1_filesz);
    write64(p1 + 40, seg1_memsz);
    write64(p1 + 48, 0x1000);

    /* Write ELF header */
    if (write(fd, &eh, sizeof(eh)) != sizeof(eh)) { perror("write eh"); close(fd); return -1; }
    /* write program headers */
    if (write(fd, phdrs, phnum * phdr_size) != (ssize_t)(phnum * phdr_size)) { perror("write ph"); close(fd); return -1; }

    /* pad to seg0_fileoff */
    off_t cur = lseek(fd, 0, SEEK_CUR);
    if (cur < 0) { perror("lseek"); close(fd); return -1; }
    if ((size_t)cur > seg0_fileoff) { fprintf(stderr,"internal layout error\n"); close(fd); return -1; }
    size_t pad = seg0_fileoff - (size_t)cur;
    if (pad) {
        unsigned char *z = calloc(1, pad);
        if (!z) { close(fd); return -1; }
        if (write(fd, z, pad) != (ssize_t)pad) { perror("write pad"); free(z); close(fd); return -1; }
        free(z);
    }

    /* write seg0 data: text then rodata */
    if (out_text_size) {
        if (write(fd, out_text, out_text_size) != (ssize_t)out_text_size) { perror("write text"); close(fd); return -1; }
    }
    if (out_rodata_size) {
        if (write(fd, out_rodata, out_rodata_size) != (ssize_t)out_rodata_size) { perror("write rodata"); close(fd); return -1; }
    }

    /* pad to seg1_fileoff */
    cur = lseek(fd, 0, SEEK_CUR);
    if ((size_t)cur > seg1_fileoff) { fprintf(stderr,"internal layout error 2\n"); close(fd); return -1; }
    pad = seg1_fileoff - (size_t)cur;
    if (pad) {
        unsigned char *z = calloc(1, pad);
        if (!z) { close(fd); return -1; }
        if (write(fd, z, pad) != (ssize_t)pad) { perror("write pad2"); free(z); close(fd); return -1; }
        free(z);
    }

    /* write data */
    if (out_data_size) {
        if (write(fd, out_data, out_data_size) != (ssize_t)out_data_size) { perror("write data"); close(fd); return -1; }
    }

    close(fd);
    return 0;
}

/* Find entry symbol (main) */
static Elf64_Addr find_entry_address(Elf64_Addr base_text_vaddr) {
    for (size_t g = 0; g < gsym_count; ++g) {
        if (strcmp(gsyms[g].name, "main") == 0 && gsyms[g].defined) return gsyms[g].value;
    }
    /* fallback: first defined function */
    for (size_t g = 0; g < gsym_count; ++g) {
        if (gsyms[g].defined && gsyms[g].is_func) return gsyms[g].value;
    }
    return base_text_vaddr; /* fallback */
}

/* Main */
int main(int argc, char **argv) {
    if (argc < 3) {
        fprintf(stderr, "Usage: %s file1.o file2.o ... -o output\n", argv[0]);
        return 1;
    }
    const char *outpath = NULL;
    /* parse args */
    for (int i = 1; i < argc; ++i) {
        if (strcmp(argv[i], "-o") == 0 && i + 1 < argc) { outpath = argv[i+1]; i++; }
        else {
            if (parse_obj(argv[i]) != 0) return 1;
        }
    }
    if (!outpath) { fprintf(stderr, "No output specified (-o)\n"); return 1; }
    if (obj_count == 0) { fprintf(stderr, "No input objects\n"); return 1; }

    /* layout sections */
    layout_sections();

    /* choose base virtual addresses */
    Elf64_Addr base_vaddr = 0x400000; /* typical */
    Elf64_Addr base_text_vaddr = base_vaddr + 0x1000; /* after headers */
    Elf64_Addr base_rodata_vaddr = base_text_vaddr + align_up(out_text_size, 0x1000);
    Elf64_Addr base_data_vaddr = align_up(base_rodata_vaddr + out_rodata_size, 0x1000);

    /* build global symbols */
    if (build_global_symbols(base_text_vaddr, base_rodata_vaddr, base_data_vaddr) != 0) {
        return 1;
    }

    /* apply relocations */
    if (apply_relocations(base_text_vaddr, base_rodata_vaddr, base_data_vaddr) != 0) {
        return 1;
    }

    /* find entry */
    Elf64_Addr entry = find_entry_address(base_text_vaddr);

    /* write output */
    if (write_output(outpath, base_vaddr, entry) != 0) {
        fprintf(stderr, "Failed to write output\n");
        return 1;
    }

    printf("Linked %zu objects -> %s (entry 0x%lx)\n", obj_count, outpath, (unsigned long)entry);
    return 0;
}
