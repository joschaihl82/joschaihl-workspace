static void encode_jmp_rel32(struct operand *op)
{
    emit_byte(0xE9);
    if (relocs_count >= MAX_RELOCS) { error("too many relocs"); return; }
    relocs[relocs_count].pos = text_len;
    relocs[relocs_count].sym = op->symbol;
    relocs[relocs_count].size = 4;
    relocs_count++;
    emit_u32(0);
}

