static QMutex g_log_mutex;

static void append_csv_line(const QString &logpath, const QString &line) {
    QMutexLocker locker(&g_log_mutex);
    QFile f(logpath);
    if (!f.open(QIODevice::Append | QIODevice::Text)) {
        return;
    }
    QTextStream out(&f);
    out.setCodec("UTF-8");
    out << line << "\n";
    out.flush();
    f.close();
}

// ---------- adapted sniffer helpers ----------
#define SNAPLEN 65535
#define PROMISC 1
#define TIMEOUT_MS 1000

struct dns_cache_entry {
    uint32_t ip;
    char name[NI_MAXHOST];
    time_t ts;
    int used;
};
static const int DNS_CACHE_SIZE = 256;
static struct dns_cache_entry dns_cache[DNS_CACHE_SIZE];

static inline unsigned int ip_hash(uint32_t ip) {
    return (unsigned int)((ip * 2654435761u) & (DNS_CACHE_SIZE - 1));
}

static void ip_to_str(uint32_t ip_net, char *buf, size_t bufsz) {
    struct in_addr a;
    a.s_addr = ip_net;
    inet_ntop(AF_INET, &a, buf, (socklen_t)bufsz);
}

static const char *resolve_hostname_ipv4_cached(uint32_t ip_net) {
    if (ip_net == 0) return "-";
    unsigned int idx = ip_hash(ip_net);
    time_t now = time(NULL);
    for (unsigned int i = 0; i < DNS_CACHE_SIZE; ++i) {
        unsigned int j = (idx + i) & (DNS_CACHE_SIZE - 1);
        if (dns_cache[j].used) {
            if (dns_cache[j].ip == ip_net) {
                if (now - dns_cache[j].ts <= 60) {
                    return dns_cache[j].name;
                } else {
                    break;
                }
            }
        } else {
            idx = j;
            break;
        }
    }
    struct sockaddr_in sa;
    char hostbuf[NI_MAXHOST];
    sa.sin_family = AF_INET;
    sa.sin_addr.s_addr = ip_net;
    int rc = getnameinfo((struct sockaddr *)&sa, sizeof(sa), hostbuf, sizeof(hostbuf), NULL, 0, NI_NAMEREQD);
    if (rc != 0) {
        ip_to_str(ip_net, hostbuf, sizeof(hostbuf));
    }
    for (unsigned int i = 0; i < DNS_CACHE_SIZE; ++i) {
        unsigned int j = (idx + i) & (DNS_CACHE_SIZE - 1);
        if (!dns_cache[j].used || dns_cache[j].ip == ip_net || (now - dns_cache[j].ts) > 60) {
            dns_cache[j].used = 1;
            dns_cache[j].ip = ip_net;
            dns_cache[j].ts = now;
            strncpy(dns_cache[j].name, hostbuf, sizeof(dns_cache[j].name)-1);
            dns_cache[j].name[sizeof(dns_cache[j].name)-1] = '\0';
            return dns_cache[j].name;
        }
    }
    ip_to_str(ip_net, hostbuf, sizeof(hostbuf));
    return strdup(hostbuf);
}

static int read_file_to_buf_local(const char *path, char *buf, size_t bufsz) {
    FILE *f = fopen(path, "r");
    if (!f) return -1;
    if (!fgets(buf, (int)bufsz, f)) { fclose(f); return -1; }
    size_t len = strlen(buf);
    if (len && buf[len-1] == '\n') buf[len-1] = '\0';
    fclose(f);
    return 0;
}

static void get_process_name_for_local_port_stub(const char *proto, int port, char *outbuf, size_t outbufsz) {
    (void)proto; (void)port;
    strncpy(outbuf, "-", outbufsz-1);
    outbuf[outbufsz-1] = '\0';
}

static int is_http_method_local(const char *s, size_t len) {
    const char *methods[] = {"GET", "POST", "PUT", "DELETE", "HEAD", "OPTIONS", "PATCH", "CONNECT", "TRACE"};
    for (size_t i = 0; i < sizeof(methods)/sizeof(methods[0]); ++i) {
        size_t mlen = strlen(methods[i]);
        if (len >= mlen && strncmp(s, methods[i], mlen) == 0 && s[mlen] == ' ') return 1;
    }
    return 0;
}

static const char *parse_tls_sni_local(const u_char *payload, size_t plen, char *outbuf, size_t outbufsz) {
    if (plen < 5) return NULL;
    const u_char *p = payload;
    uint8_t rec_type = p[0];
    if (rec_type != 22) return NULL;
    uint16_t rec_len = (p[3] << 8) | p[4];
    if (5 + rec_len > plen) return NULL;
    p += 5;
    size_t remain = rec_len;
    if (remain < 4) return NULL;
    uint8_t hs_type = p[0];
    if (hs_type != 1) return NULL;
    uint32_t hs_len = ((uint32_t)p[1] << 16) | ((uint32_t)p[2] << 8) | p[3];
    if (hs_len + 4 > remain) return NULL;
    p += 4;
    size_t hs_rem = hs_len;
    if (hs_rem < 2 + 32 + 1) return NULL;
    p += 2 + 32;
    hs_rem -= 34;
    if (hs_rem < 1) return NULL;
    uint8_t sid_len = p[0];
    p += 1;
    hs_rem -= 1;
    if (hs_rem < sid_len) return NULL;
    p += sid_len;
    hs_rem -= sid_len;
    if (hs_rem < 2) return NULL;
    uint16_t cs_len = (p[0] << 8) | p[1];
    p += 2;
    hs_rem -= 2;
    if (hs_rem < cs_len) return NULL;
    p += cs_len;
    hs_rem -= cs_len;
    if (hs_rem < 1) return NULL;
    uint8_t comp_len = p[0];
    p += 1;
    hs_rem -= 1;
    if (hs_rem < comp_len) return NULL;
    p += comp_len;
    hs_rem -= comp_len;
    if (hs_rem < 2) return NULL;
    uint16_t ext_total = (p[0] << 8) | p[1];
    p += 2;
    hs_rem -= 2;
    if (hs_rem < ext_total) return NULL;
    const u_char *ext_end = p + ext_total;
    while (p + 4 <= ext_end) {
        uint16_t ext_type = (p[0] << 8) | p[1];
        uint16_t ext_len = (p[2] << 8) | p[3];
        p += 4;
        if (p + ext_len > ext_end) break;
        if (ext_type == 0x0000) {
            if (ext_len < 2) break;
            uint16_t list_len = (p[0] << 8) | p[1];
            const u_char *q = p + 2;
            const u_char *qend = p + ext_len;
            while (q + 3 <= qend) {
                uint8_t name_type = q[0];
                uint16_t name_len = (q[1] << 8) | q[2];
                q += 3;
                if (q + name_len > qend) break;
                if (name_type == 0) {
                    size_t copy = name_len < outbufsz-1 ? name_len : outbufsz-1;
                    memcpy(outbuf, q, copy);
                    outbuf[copy] = '\0';
                    return outbuf;
                }
                q += name_len;
            }
            break;
        }
        p += ext_len;
    }
    return NULL;
}

static QString ts_to_iso(const struct pcap_pkthdr *h) {
    char buf[64];
    time_t t = h->ts.tv_sec;
    struct tm tm;
    localtime_r(&t, &tm);
    strftime(buf, sizeof(buf), "%Y-%m-%dT%H:%M:%S", &tm);
    char out[80];
    snprintf(out, sizeof(out), "%s.%06ld", buf, (long)h->ts.tv_usec);
    return QString::fromUtf8(out);
}

struct ProducerContext {
    QString logpath;
};

static void producer_write_csv_record(ProducerContext *ctx,
                                      const char *progpath,
                                      double inputMB,
                                      double outputMB,
                                      double inKBs,
                                      double outKBs,
                                      int pid,
                                      const char *procname,
                                      const QString &ts_iso)
{
    QString line = QString("%1,%2,%3,%4,%5,%6,%7,%8")
                       .arg(QString::fromUtf8(progpath))
                       .arg(QString::number(inputMB, 'f', 6))
                       .arg(QString::number(outputMB, 'f', 6))
                       .arg(QString::number(inKBs, 'f', 2))
                       .arg(QString::number(outKBs, 'f', 2))
                       .arg(pid)
                       .arg(QString::fromUtf8(procname))
                       .arg(ts_iso);
    append_csv_line(ctx->logpath, line);
}

static void pcap_producer_cb(u_char *user, const struct pcap_pkthdr *h, const u_char *bytes) {
    ProducerContext *ctx = reinterpret_cast<ProducerContext *>(user);
    if (!ctx) return;

    if (h->caplen < sizeof(struct ether_header) + sizeof(struct ip)) return;
    const struct ether_header *eth = (const struct ether_header *)bytes;
    uint16_t eth_type = ntohs(eth->ether_type);
    if (eth_type != ETHERTYPE_IP) {
        producer_write_csv_record(ctx, "/non-ip", 0.0, 0.0, 0.0, 0.0, 0, "-", ts_to_iso(h));
        return;
    }

    size_t ip_off = sizeof(struct ether_header);
    if (h->caplen < ip_off + sizeof(struct ip)) return;
    const struct ip *ip = (const struct ip *)(bytes + ip_off);
    int ihl = ip->ip_hl * 4;
    if (ihl < 20) return;
    if (h->caplen < ip_off + ihl) return;

    uint32_t src_ip = ip->ip_src.s_addr;
    uint32_t dst_ip = ip->ip_dst.s_addr;
    const char *src_name = resolve_hostname_ipv4_cached(src_ip);
    const char *dst_name = resolve_hostname_ipv4_cached(dst_ip);

    QString ts = ts_to_iso(h);

    if (ip->ip_p == IPPROTO_TCP) {
        size_t tcp_off = ip_off + ihl;
        if (h->caplen < tcp_off + sizeof(struct tcphdr)) return;
        const struct tcphdr *tcp = (const struct tcphdr *)(bytes + tcp_off);
        unsigned short sport = ntohs(tcp->th_sport);
        unsigned short dport = ntohs(tcp->th_dport);
        int tcp_hdr_len = tcp->th_off * 4;
        size_t payload_off = tcp_off + tcp_hdr_len;
        size_t payload_len = 0;
        if (h->caplen > payload_off) payload_len = h->caplen - payload_off;
        const u_char *payload = bytes + payload_off;

        if ((dport == 80 || sport == 80) && payload_len > 0) {
            if (is_http_method_local((const char *)payload, payload_len)) {
                double inputMB = (double)payload_len / (1024.0 * 1024.0);
                double outputMB = inputMB * 0.2;
                double inKBs = inputMB * 1024.0;
                double outKBs = outputMB * 1024.0;
                int pid = 0;
                char procname[64] = "-";
                get_process_name_for_local_port_stub("tcp", dport, procname, sizeof(procname));
                QString progpath = QString("%1->%2:80").arg(src_name).arg(dst_name);
                producer_write_csv_record(ctx, progpath.toUtf8().constData(), inputMB, outputMB, inKBs, outKBs, pid, procname, ts);
                return;
            }
        }

        if (dport == 443 || sport == 443) {
            char sni[256] = {0};
            const char *s = parse_tls_sni_local(payload, payload_len, sni, sizeof(sni));
            if (s) {
                double inputMB = (double)payload_len / (1024.0 * 1024.0);
                double outputMB = inputMB * 0.1;
                double inKBs = inputMB * 1024.0;
                double outKBs = outputMB * 1024.0;
                int pid = 0;
                char procname[64] = "-";
                get_process_name_for_local_port_stub("tcp", dport, procname, sizeof(procname));
                QString progpath = QString("%1->%2:443").arg(src_name).arg(sni);
                producer_write_csv_record(ctx, progpath.toUtf8().constData(), inputMB, outputMB, inKBs, outKBs, pid, procname, ts);
                return;
            }
        }

        double inputMB = (double)h->len / (1024.0 * 1024.0);
        double outputMB = inputMB * 0.5;
        double inKBs = inputMB * 1024.0;
        double outKBs = outputMB * 1024.0;
        int pid = 0;
        char procname[64] = "-";
        QString progpath = QString("%1->%2:tcp%3").arg(src_name).arg(dst_name).arg(ntohs(tcp->th_dport));
        producer_write_csv_record(ctx, progpath.toUtf8().constData(), inputMB, outputMB, inKBs, outKBs, pid, procname, ts);
        return;
    } else if (ip->ip_p == IPPROTO_UDP) {
        size_t udp_off = ip_off + ihl;
        if (h->caplen < udp_off + sizeof(struct udphdr)) return;
        const struct udphdr *udp = (const struct udphdr *)(bytes + udp_off);
        unsigned short sport = ntohs(udp->uh_sport);
        unsigned short dport = ntohs(udp->uh_dport);
        size_t payload_off = udp_off + sizeof(struct udphdr);
        size_t payload_len = 0;
        if (h->caplen > payload_off) payload_len = h->caplen - payload_off;

        if (dport == 53 || sport == 53) {
            double inputMB = (double)payload_len / (1024.0 * 1024.0);
            double outputMB = 0.0;
            double inKBs = inputMB * 1024.0;
            double outKBs = 0.0;
            int pid = 0;
            char procname[64] = "-";
            QString progpath = QString("%1->%2:dns").arg(src_name).arg(dst_name);
            producer_write_csv_record(ctx, progpath.toUtf8().constData(), inputMB, outputMB, inKBs, outKBs, pid, procname, ts);
            return;
        }

        if (dport == 67 || dport == 68 || sport == 67 || sport == 68) {
            double inputMB = (double)payload_len / (1024.0 * 1024.0);
            double outputMB = 0.0;
            double inKBs = inputMB * 1024.0;
            double outKBs = 0.0;
            int pid = 0;
            char procname[64] = "-";
            QString progpath = QString("%1->%2:dhcp").arg(src_name).arg(dst_name);
            producer_write_csv_record(ctx, progpath.toUtf8().constData(), inputMB, outputMB, inKBs, outKBs, pid, procname, ts);
            return;
        }

        double inputMB = (double)h->len / (1024.0 * 1024.0);
        double outputMB = inputMB * 0.5;
        double inKBs = inputMB * 1024.0;
        double outKBs = outputMB * 1024.0;
        int pid = 0;
        char procname[64] = "-";
        QString progpath = QString("%1->%2:udp%3").arg(src_name).arg(dst_name).arg(dport);
        producer_write_csv_record(ctx, progpath.toUtf8().constData(), inputMB, outputMB, inKBs, outKBs, pid, procname, ts);
        return;
    } else {
        double inputMB = (double)h->len / (1024.0 * 1024.0);
        double outputMB = inputMB * 0.5;
        double inKBs = inputMB * 1024.0;
        double outKBs = outputMB * 1024.0;
        int pid = 0;
        char procname[64] = "-";
        QString progpath = QString("%1->%2:proto%3").arg(src_name).arg(dst_name).arg(ip->ip_p);
        producer_write_csv_record(ctx, progpath.toUtf8().constData(), inputMB, outputMB, inKBs, outKBs, pid, procname, ts);
        return;
    }
}

// ---------- ProducerThread ----------
class ProducerThread : public QThread {
    Q_OBJECT
public:
    ProducerThread(const QString &dev, const QString &filter, const QString &logpath, QObject *parent = nullptr)
        : QThread(parent), m_dev(dev), m_filter(filter), m_logpath(logpath), m_stop(false) {}

    ~ProducerThread() override {
        stop();
        wait();
    }

    void stop() {
        m_stop = true;
    }

protected:
    void run() override {
        char errbuf[PCAP_ERRBUF_SIZE];
        pcap_t *handle = pcap_open_live(m_dev.toUtf8().constData(), SNAPLEN, PROMISC, TIMEOUT_MS, errbuf);
        if (!handle) {
            qWarning() << "pcap_open_live failed:" << errbuf;
            append_csv_line(m_logpath, QString("/pcap_error,0,0,0,0,0,pcap_open_failed,%1").arg(QDateTime::currentDateTimeUtc().toString(Qt::ISODate)));
            return;
        }

        if (!m_filter.isEmpty()) {
            struct bpf_program fp;
            if (pcap_compile(handle, &fp, m_filter.toUtf8().constData(), 1, PCAP_NETMASK_UNKNOWN) == -1 ||
                pcap_setfilter(handle, &fp) == -1) {
                qWarning() << "pcap filter error:" << pcap_geterr(handle);
                pcap_freecode(&fp);
                pcap_close(handle);
                append_csv_line(m_logpath, QString("/pcap_filter_error,0,0,0,0,0,filter_failed,%1").arg(QDateTime::currentDateTimeUtc().toString(Qt::ISODate)));
                return;
            }
            pcap_freecode(&fp);
        }

        ProducerContext ctx;
        ctx.logpath = m_logpath;

        while (!m_stop) {
            int rc = pcap_dispatch(handle, 0, pcap_producer_cb, reinterpret_cast<u_char *>(&ctx));
            if (rc < 0) {
                qWarning() << "pcap_dispatch error:" << pcap_geterr(handle);
                break;
            }
            usleep(5000);
        }

        pcap_close(handle);
    }

private:
    QString m_dev;
    QString m_filter;
    QString m_logpath;
    std::atomic<bool> m_stop;
};

// ---------- ConsumerThread ----------
class ConsumerThread : public QThread {
    Q_OBJECT
public:
    ConsumerThread(const QString &logPath = QStringLiteral("netdump.log"), QObject *parent = nullptr)
        : QThread(parent), m_logPath(logPath), m_stop(false) {}

    ~ConsumerThread() override {
        stop();
        wait();
    }

    void stop() { m_stop = true; }

signals:
    void recordReady(const QStringList &fields);

protected:
    void run() override {
        QFileInfo fi(m_logPath);
        if (!fi.exists()) {
            QFile create(m_logPath);
            if (create.open(QIODevice::WriteOnly)) create.close();
        }

        QFile file(m_logPath);
        if (!file.open(QIODevice::ReadOnly | QIODevice::Text)) {
            qWarning() << "Consumer: cannot open log for reading:" << m_logPath;
            return;
        }

        file.seek(file.size());
        QByteArray buffer;
        while (!m_stop) {
            if (!file.atEnd()) {
                QByteArray chunk = file.readAll();
                if (!chunk.isEmpty()) {
                    buffer.append(chunk);
                    int nl;
                    while ((nl = buffer.indexOf('\n')) != -1) {
                        QByteArray line = buffer.left(nl);
                        buffer.remove(0, nl + 1);
                        QString s = QString::fromUtf8(line).trimmed();
                        if (!s.isEmpty()) {
                            QStringList fields = s.split(',', Qt::KeepEmptyParts);
                            for (QString &p : fields) p = p.trimmed();
                            if (fields.size() >= 8) emit recordReady(fields);
                        }
                    }
                }
            } else {
                usleep(15000);
                QFileInfo newFi(m_logPath);
                if (!newFi.exists()) {
                    usleep(2000);
                    continue;
                }
                if (newFi.size() < file.pos()) {
                    file.close();
                    if (!file.open(QIODevice::ReadOnly | QIODevice::Text)) {
                        usleep(2000);
                        continue;
                    }
                }
            }
        }
        file.close();
    }

private:
    QString m_logPath;
    std::atomic<bool> m_stop;
};

// ---------- SparklineWidget ----------
class SparklineWidget : public QWidget {
    Q_OBJECT
public:
    SparklineWidget(QWidget *parent = nullptr) : QWidget(parent) { setMinimumHeight(48); }
    void addValue(double v) { m_values.push_back(v); if (m_values.size() > 100) m_values.erase(m_values.begin()); update(); }
    void setValues(const QVector<double> &vals) { m_values = vals.toStdVector(); update(); }
protected:
    void paintEvent(QPaintEvent *) override {
        QPainter p(this);
        p.setRenderHint(QPainter::Antialiasing);
        QRect r = rect().adjusted(4, 4, -4, -4);
        p.fillRect(r, palette().color(QPalette::Base));
        if (m_values.empty()) return;
        double maxv = *std::max_element(m_values.begin(), m_values.end());
        double minv = *std::min_element(m_values.begin(), m_values.end());
        if (qFuzzyCompare(maxv, minv)) { maxv += 1.0; minv = 0.0; }
        int n = (int)m_values.size();
        QPainterPath path;
        for (int i = 0; i < n; ++i) {
            double t = (double)i / (n - 1);
            int x = r.left() + (int)(t * r.width());
            double v = m_values[i];
            double norm = (v - minv) / (maxv - minv);
            int y = r.bottom() - (int)(norm * r.height());
            if (i == 0) path.moveTo(x, y); else path.lineTo(x, y);
        }
        QPen pen(Qt::blue, 2);
        p.setPen(pen);
        p.drawPath(path);
    }
private:
    std::vector<double> m_values;
};

// ---------- Row delegate ----------
class TrafficDelegate : public QStyledItemDelegate {
    Q_OBJECT
public:
    TrafficDelegate(QObject *parent = nullptr) : QStyledItemDelegate(parent) {}
    void paint(QPainter *painter, const QStyleOptionViewItem &option, const QModelIndex &index) const override {
        QStyleOptionViewItem opt = option;
        initStyleOption(&opt, index);
        // Input MB is column 4 in source model (ProcessName=0, PID=1, AppName=2, Path=3, InputMB=4)
        QVariant v = index.sibling(index.row(), 4).data();
        double inputMB = v.toDouble();
        QColor bg = opt.backgroundBrush.color();
        if (inputMB > 1.0) {
            bg = QColor(255, 230, 230);
        } else if (inputMB > 0.1) {
            bg = QColor(255, 245, 230);
        } else {
            bg = QColor(245, 255, 245);
        }
        painter->save();
        painter->fillRect(opt.rect, bg);
        QStyledItemDelegate::paint(painter, opt, index);
        painter->restore();
    }
};

// ---------- Details dialog ----------
class DetailsDialog : public QDialog {
    Q_OBJECT
public:
    DetailsDialog(const QString &path, QWidget *parent = nullptr) : QDialog(parent) {
        setWindowTitle(QStringLiteral("Details - %1").arg(path));
        QVBoxLayout *v = new QVBoxLayout(this);
        m_form = new QFormLayout();
        v->addLayout(m_form);
        m_spark = new SparklineWidget(this);
        v->addWidget(m_spark);
        QDialogButtonBox *bb = new QDialogButtonBox(QDialogButtonBox::Ok, this);
        connect(bb, &QDialogButtonBox::accepted, this, &QDialog::accept);
        v->addWidget(bb);
        resize(600, 300);
    }
    void setField(const QString &label, const QString &value) { QLabel *l = new QLabel(value, this); m_form->addRow(label, l); }
    void setSparkValues(const QVector<double> &vals) { m_spark->setValues(vals); }
private:
    QFormLayout *m_form;
    SparklineWidget *m_spark;
};

// ---------- Helper: resolve process name from PID ----------
static QString processNameFromPidString(const QString &pidStr) {
    bool ok = false;
    long pid = pidStr.toLong(&ok);
    if (!ok || pid <= 0) return QString();
    // Try /proc/<pid>/comm
    QString commPath = QString("/proc/%1/comm").arg(pid);
    QFile f(commPath);
    if (f.open(QIODevice::ReadOnly | QIODevice::Text)) {
        QByteArray line = f.readLine().trimmed();
        f.close();
        if (!line.isEmpty()) return QString::fromUtf8(line);
    }
    // Try /proc/<pid>/cmdline (first token)
    QString cmdPath = QString("/proc/%1/cmdline").arg(pid);
    QFile f2(cmdPath);
    if (f2.open(QIODevice::ReadOnly)) {
        QByteArray data = f2.readAll();
        f2.close();
        if (!data.isEmpty()) {
            // cmdline is NUL-separated
            int pos = data.indexOf('\0');
            QByteArray first = (pos > 0) ? data.left(pos) : data;
            // extract basename
            QString s = QString::fromUtf8(first);
            int slash = s.lastIndexOf('/');
            if (slash != -1 && slash + 1 < s.length()) return s.mid(slash + 1);
            if (!s.isEmpty()) return s;
        }
    }
    return QString();
}

// ---------- MainWindow ----------
class MainWindow : public QMainWindow {
    Q_OBJECT
public:
    MainWindow(const QString &dev, const QString &filter, QWidget *parent = nullptr)
        : QMainWindow(parent), m_producer(nullptr), m_consumer(nullptr),
          m_watcher(nullptr), m_proxy(nullptr), m_filterEdit(nullptr)
    {
        m_logpath = QStringLiteral("netdump.log");
        setupUi();
        loadSettings();

        // Watch file and directory
        m_watcher = new QFileSystemWatcher(this);
        QFileInfo fi(m_logpath);
        if (fi.exists()) m_watcher->addPath(fi.absoluteFilePath());
        m_watcher->addPath(fi.absolutePath());
        connect(m_watcher, &QFileSystemWatcher::fileChanged, this, &MainWindow::onLogFileChanged);
        connect(m_watcher, &QFileSystemWatcher::directoryChanged, this, &MainWindow::onLogFileChanged);

        // Start consumer
        startConsumer(m_logpath);

        // Start producer
        m_producer = new ProducerThread(dev, filter, m_logpath, this);
        m_producer->start();
    }

    ~MainWindow() override {
        saveSettings();
        if (m_producer) {
            m_producer->stop();
            m_producer->wait();
            delete m_producer;
            m_producer = nullptr;
        }
        if (m_consumer) {
            m_consumer->stop();
            m_consumer->wait();
            delete m_consumer;
            m_consumer = nullptr;
        }
    }

private slots:
    void onRecordReady(const QStringList &fields) {
        QMutexLocker locker(&m_bufferMutex);
        m_buffer.append(fields);
        if (!m_batchTimer->isActive()) m_batchTimer->start(180); // coalesce 180ms
    }

    void flushBuffer() {
        QVector<QStringList> batch;
        {
            QMutexLocker locker(&m_bufferMutex);
            if (m_buffer.isEmpty()) return;
            batch = m_buffer;
            m_buffer.clear();
        }

        bool modelChanged = false;
        double totalIn = 0.0, totalOut = 0.0;
        for (const QStringList &fields : batch) {
            // CSV fields: path(0), InputMB(1), OutputMB(2), InputKBs(3), OutputKBs(4), PID(5), ProcessName(6), Timestamp(7)
            QString path = fields.value(0, QStringLiteral("-"));
            QString inputMB = fields.value(1, QStringLiteral("0"));
            QString outputMB = fields.value(2, QStringLiteral("0"));
            QString inKBs = fields.value(3, QStringLiteral("0"));
            QString outKBs = fields.value(4, QStringLiteral("0"));
            QString pidStr = fields.value(5, QStringLiteral("0"));
            QString procNameField = fields.value(6, QStringLiteral("-"));
            QString lastSeen = fields.value(7, QDateTime::currentDateTimeUtc().toString(Qt::ISODate));

            double inVal = inputMB.toDouble();
            double outVal = outputMB.toDouble();
            totalIn += inVal;
            totalOut += outVal;

            // Determine process name to show in first column:
            QString procName = QString();
            // 1) If PID present and >0, try /proc lookup
            procName = processNameFromPidString(pidStr);
            // 2) If not found, use procNameField from CSV if it's meaningful
            if (procName.isEmpty() && procNameField != "-" && !procNameField.isEmpty()) procName = procNameField;
            // 3) Fallback: derive from left side of path (before ->) and take last path segment
            if (procName.isEmpty()) {
                int arrow = path.indexOf(QStringLiteral("->"));
                QString left = (arrow != -1) ? path.left(arrow) : path;
                int slash = left.lastIndexOf('/');
                if (slash != -1 && slash + 1 < left.length()) {
                    procName = left.mid(slash + 1);
                } else if (!left.isEmpty()) {
                    procName = left;
                } else {
                    procName = QStringLiteral("-");
                }
            }

            // Derive ApplicationName (same heuristic as before)
            QString appName = QStringLiteral("-");
            int arrow = path.indexOf(QStringLiteral("->"));
            QString left = (arrow != -1) ? path.left(arrow) : path;
            int slash = left.lastIndexOf('/');
            if (slash != -1 && slash + 1 < left.length()) {
                appName = left.mid(slash + 1);
            } else if (!left.isEmpty()) {
                appName = left;
            }

            int row = findRowByPath(path);
            if (row == -1) {
                row = m_model->rowCount();
                m_model->insertRow(row);
                for (int c = 0; c < m_model->columnCount(); ++c) {
                    m_model->setItem(row, c, new QStandardItem(QString()));
                }
            }

            // Column mapping (source model):
            // 0: ProcessName (first column requested)
            // 1: PID
            // 2: ApplicationName
            // 3: /path/programname
            // 4: Input MB
            // 5: Output MB
            // 6: Input KB/s
            // 7: Output KB/s
            // 8: LastSeen

            m_model->item(row, 0)->setText(procName);
            m_model->item(row, 1)->setText(pidStr);
            m_model->item(row, 2)->setText(appName);
            m_model->item(row, 3)->setText(path);
            m_model->item(row, 4)->setText(inputMB);
            m_model->item(row, 5)->setText(outputMB);
            m_model->item(row, 6)->setText(inKBs);
            m_model->item(row, 7)->setText(outKBs);
            m_model->item(row, 8)->setText(lastSeen);

            // maintain sparkline history per path
            QVector<double> &hist = m_history[path];
            hist.append(inVal);
            if (hist.size() > 100) hist.remove(0, hist.size() - 100);

            modelChanged = true;
        }

        if (modelChanged) {
            m_totalInLabel->setText(QStringLiteral("Total In MB: %1").arg(QString::number(totalIn, 'f', 3)));
            m_totalOutLabel->setText(QStringLiteral("Total Out MB: %1").arg(QString::number(totalOut, 'f', 3)));
            // schedule column resize shortly after to avoid frequent resizing
            if (!m_resizeTimer->isActive()) m_resizeTimer->start(120);
        }
    }

    void doResizeColumns() {
        // Resize to contents but keep LastSeen stretchable
        m_view->resizeColumnsToContents();
        // Make LastSeen column stretch to fill remaining space
        int lastCol = m_model->columnCount() - 1;
        m_view->horizontalHeader()->setSectionResizeMode(lastCol, QHeaderView::Stretch);
    }

    void onFilterTextChanged(const QString &text) {
        if (!m_proxy) return;
        QRegularExpression re(QRegularExpression::escape(text), QRegularExpression::CaseInsensitiveOption);
        m_proxy->setFilterRegularExpression(re);
    }

    void onLogFileChanged(const QString &path) {
        Q_UNUSED(path);
        qDebug() << "Log file changed; restarting consumer.";
        restartConsumer(m_logpath);
        QFileInfo fi(m_logpath);
        if (fi.exists()) {
            if (!m_watcher->files().contains(fi.absoluteFilePath())) {
                m_watcher->addPath(fi.absoluteFilePath());
            }
        }
    }

    void onStartStopToggled() {
        if (m_producer && m_producer->isRunning()) {
            m_producer->stop();
            m_producer->wait();
            delete m_producer;
            m_producer = nullptr;
            m_actionStartStop->setIcon(style()->standardIcon(QStyle::SP_MediaPlay));
            m_actionStartStop->setText(QStringLiteral("Start Capture"));
            statusBar()->showMessage(QStringLiteral("Capture stopped"), 3000);
        } else {
            QString dev = m_lastDevice;
            QString filter = m_filterEdit->text();
            m_producer = new ProducerThread(dev, filter, m_logpath, this);
            m_producer->start();
            m_actionStartStop->setIcon(style()->standardIcon(QStyle::SP_MediaStop));
            m_actionStartStop->setText(QStringLiteral("Stop Capture"));
            statusBar()->showMessage(QStringLiteral("Capture started"), 3000);
        }
    }

    void onRefreshClicked() {
        restartConsumer(m_logpath);
        statusBar()->showMessage(QStringLiteral("Refreshed"), 1500);
    }

    void onThemeToggled() {
        m_darkTheme = !m_darkTheme;
        applyTheme();
    }

    void onRowDoubleClicked(const QModelIndex &idx) {
        if (!idx.isValid()) return;
        QModelIndex src = m_proxy->mapToSource(idx);
        QString proc = m_model->item(src.row(), 0)->text();
        QString pid = m_model->item(src.row(), 1)->text();
        QString path = m_model->item(src.row(), 3)->text();
        QString inMB = m_model->item(src.row(), 4)->text();
        QString outMB = m_model->item(src.row(), 5)->text();
        QString last = m_model->item(src.row(), 8)->text();

        DetailsDialog dlg(path, this);
        dlg.setField(QStringLiteral("Process"), proc);
        dlg.setField(QStringLiteral("PID"), pid);
        dlg.setField(QStringLiteral("Path"), path);
        dlg.setField(QStringLiteral("Input MB"), inMB);
        dlg.setField(QStringLiteral("Output MB"), outMB);
        dlg.setField(QStringLiteral("Last Seen"), last);

        QVector<double> vals;
        for (double v : m_history[path]) vals.append(v);
        dlg.setSparkValues(vals);
        dlg.exec();
    }

    void onContextMenuRequested(const QPoint &pt) {
        QModelIndex idx = m_view->indexAt(pt);
        if (!idx.isValid()) return;
        QModelIndex src = m_proxy->mapToSource(idx);
        QString path = m_model->item(src.row(), 3)->text();

        QMenu menu(this);
        QAction *copyAct = menu.addAction(style()->standardIcon(QStyle::SP_DialogSaveButton), QStringLiteral("Copy Path"));
        QAction *detailsAct = menu.addAction(style()->standardIcon(QStyle::SP_FileDialogInfoView), QStringLiteral("Details"));
        QAction *clearAct = menu.addAction(style()->standardIcon(QStyle::SP_TrashIcon), QStringLiteral("Clear Row"));
        QAction *act = menu.exec(m_view->viewport()->mapToGlobal(pt));
        if (act == copyAct) {
            QClipboard *cb = QApplication::clipboard();
            cb->setText(path);
        } else if (act == detailsAct) {
            QModelIndex mapped = m_proxy->mapToSource(idx);
            onRowDoubleClicked(mapped);
        } else if (act == clearAct) {
            m_model->removeRow(src.row());
        }
    }

private:
    void setupUi() {
        QWidget *central = new QWidget(this);
        QVBoxLayout *layout = new QVBoxLayout(central);
        layout->setContentsMargins(8,8,8,8);
        layout->setSpacing(6);

        // Toolbar
        QToolBar *tb = new QToolBar(this);
        tb->setIconSize(QSize(18,18));
        addToolBar(tb);

        m_actionStartStop = tb->addAction(style()->standardIcon(QStyle::SP_MediaPlay), QStringLiteral("Start Capture"));
        connect(m_actionStartStop, &QAction::triggered, this, &MainWindow::onStartStopToggled);

        QAction *refresh = tb->addAction(style()->standardIcon(QStyle::SP_BrowserReload), QStringLiteral("Refresh"));
        connect(refresh, &QAction::triggered, this, &MainWindow::onRefreshClicked);

        QAction *theme = tb->addAction(style()->standardIcon(QStyle::SP_TitleBarMenuButton), QStringLiteral("Toggle Theme"));
        connect(theme, &QAction::triggered, this, &MainWindow::onThemeToggled);

        tb->addSeparator();
        QLabel *devLabel = new QLabel(QStringLiteral("Device:"), this);
        tb->addWidget(devLabel);
        m_deviceCombo = new QComboBox(this);
        m_deviceCombo->addItem(QStringLiteral("wlan0"));
        m_deviceCombo->addItem(QStringLiteral("eth0"));
        tb->addWidget(m_deviceCombo);
        connect(m_deviceCombo, &QComboBox::currentTextChanged, this, [this](const QString &d){ m_lastDevice = d; });

        tb->addSeparator();
        QLabel *filterLabel = new QLabel(QStringLiteral("Filter:"), this);
        tb->addWidget(filterLabel);
        m_filterEdit = new QLineEdit(this);
        m_filterEdit->setPlaceholderText(QStringLiteral("BPF filter (applied to producer)"));
        m_filterEdit->setMaximumWidth(300);
        tb->addWidget(m_filterEdit);
        connect(m_filterEdit, &QLineEdit::textChanged, this, &MainWindow::onFilterTextChanged);

        layout->addWidget(tb);

        // Table filter
        m_tableFilter = new QLineEdit(central);
        m_tableFilter->setPlaceholderText(QStringLiteral("Search table (press Ctrl+F)..."));
        m_tableFilter->setClearButtonEnabled(true);
        layout->addWidget(m_tableFilter);

        // Table and model
        m_view = new QTableView(central);
        m_model = new QStandardItemModel(0, 9, this);
        QStringList headers = {"ProcessName", "PID", "ApplicationName", "/path/programname", "Input MB", "Output MB", "Input KB/s", "Output KB/s", "LastSeen"};
        for (int i = 0; i < headers.size(); ++i) m_model->setHeaderData(i, Qt::Horizontal, headers.at(i));

        QFont headerFont = font();
        headerFont.setBold(true);
        m_view->horizontalHeader()->setFont(headerFont);

        m_proxy = new QSortFilterProxyModel(this);
        m_proxy->setSourceModel(m_model);
        m_proxy->setFilterCaseSensitivity(Qt::CaseInsensitive);
        m_proxy->setFilterKeyColumn(-1);
        m_proxy->setDynamicSortFilter(true);

        m_view->setModel(m_proxy);
        m_view->horizontalHeader()->setSectionResizeMode(QHeaderView::ResizeToContents);
        m_view->setSelectionBehavior(QAbstractItemView::SelectRows);
        m_view->setEditTriggers(QAbstractItemView::NoEditTriggers);
        m_view->setSortingEnabled(true);
        m_view->setItemDelegate(new TrafficDelegate(this));
        m_view->setContextMenuPolicy(Qt::CustomContextMenu);
        m_view->setAlternatingRowColors(true);
        m_view->verticalHeader()->setVisible(false);
        m_view->setShowGrid(false);

        // Make ProcessName column a bit wider by default
        m_view->horizontalHeader()->setMinimumSectionSize(60);

        layout->addWidget(m_view);
        setCentralWidget(central);

        // Status bar
        statusBar();
        m_totalInLabel = new QLabel(QStringLiteral("Total In MB: 0.000"), this);
        m_totalOutLabel = new QLabel(QStringLiteral("Total Out MB: 0.000"), this);
        statusBar()->addPermanentWidget(m_totalInLabel);
        statusBar()->addPermanentWidget(m_totalOutLabel);

        // Connections
        connect(m_tableFilter, &QLineEdit::textChanged, this, &MainWindow::onFilterTextChanged);
        connect(m_view, &QTableView::doubleClicked, this, &MainWindow::onRowDoubleClicked);
        connect(m_view, &QTableView::customContextMenuRequested, this, &MainWindow::onContextMenuRequested);

        // Batch timer
        m_batchTimer = new QTimer(this);
        m_batchTimer->setSingleShot(true);
        connect(m_batchTimer, &QTimer::timeout, this, &MainWindow::flushBuffer);

        // Resize timer (to avoid thrash)
        m_resizeTimer = new QTimer(this);
        m_resizeTimer->setSingleShot(true);
        connect(m_resizeTimer, &QTimer::timeout, this, &MainWindow::doResizeColumns);

        // Defaults & polish
        setWindowTitle(QStringLiteral("nettop - beautiful"));
        resize(1200, 820);
        QFont f = font();
        f.setPointSize(10);
        setFont(f);

        // Shortcuts
        new QShortcut(QKeySequence(Qt::CTRL + Qt::Key_F), this, SLOT(focusSearch()));
    }

    Q_INVOKABLE void focusSearch() { m_tableFilter->setFocus(); }

    int findRowByPath(const QString &path) const {
        // path is stored in column 3 of the source model
        for (int r = 0; r < m_model->rowCount(); ++r) {
            QStandardItem *it = m_model->item(r, 3);
            if (it && it->text() == path) return r;
        }
        return -1;
    }

    void startConsumer(const QString &logpath) {
        if (m_consumer) {
            m_consumer->stop();
            m_consumer->wait();
            delete m_consumer;
            m_consumer = nullptr;
        }
        m_consumer = new ConsumerThread(logpath, this);
        connect(m_consumer, &ConsumerThread::recordReady, this, &MainWindow::onRecordReady, Qt::QueuedConnection);
        m_consumer->start();
    }

    void restartConsumer(const QString &logpath) {
        if (m_consumer) {
            m_consumer->stop();
            m_consumer->wait();
            delete m_consumer;
            m_consumer = nullptr;
        }
        usleep(5000);
        startConsumer(logpath);
    }

    void applyTheme() {
        if (m_darkTheme) {
            qApp->setStyleSheet("QMainWindow { background: #2b2b2b; color: #ddd; }"
                                "QTableView { background: #333; color: #ddd; gridline-color: #444; }"
                                "QHeaderView::section { background: #444; color: #fff; }"
                                "QLineEdit { background: #3a3a3a; color: #fff; }");
        } else {
            qApp->setStyleSheet("");
        }
    }

    void loadSettings() {
        QSettings s("nettop", "nettop");
        restoreGeometry(s.value("geometry").toByteArray());
        m_lastDevice = s.value("lastDevice", QStringLiteral("wlan0")).toString();
        int idx = m_deviceCombo->findText(m_lastDevice);
        if (idx >= 0) m_deviceCombo->setCurrentIndex(idx);
        QString f = s.value("lastFilter", QString()).toString();
        m_filterEdit->setText(f);
        m_tableFilter->setText(s.value("tableFilter", QString()).toString());
        m_darkTheme = s.value("darkTheme", false).toBool();
        applyTheme();
    }

    void saveSettings() {
        QSettings s("nettop", "nettop");
        s.setValue("geometry", saveGeometry());
        s.setValue("lastDevice", m_lastDevice);
        s.setValue("lastFilter", m_filterEdit->text());
        s.setValue("tableFilter", m_tableFilter->text());
        s.setValue("darkTheme", m_darkTheme);
    }

private:
    QString m_logpath;
    QTableView *m_view = nullptr;
    QStandardItemModel *m_model = nullptr;
    QSortFilterProxyModel *m_proxy = nullptr;
    ProducerThread *m_producer = nullptr;
    ConsumerThread *m_consumer = nullptr;
    QFileSystemWatcher *m_watcher = nullptr;
    QLineEdit *m_filterEdit = nullptr;
    QLineEdit *m_tableFilter = nullptr;
    QTimer *m_batchTimer = nullptr;
    QTimer *m_resizeTimer = nullptr;
    QAction *m_actionStartStop = nullptr;
    QLabel *m_totalInLabel = nullptr;
    QLabel *m_totalOutLabel = nullptr;
    QComboBox *m_deviceCombo = nullptr;

    QMutex m_bufferMutex;
    QVector<QStringList> m_buffer;
    QHash<QString, QVector<double>> m_history;
    bool m_darkTheme = false;
    QString m_lastDevice;
};

// ---------------- main ----------------
int main(int argc, char **argv) {
    QApplication app(argc, argv);
    QApplication::setApplicationName("nettop");
    QApplication::setOrganizationName("nettop");

    QString dev = QStringLiteral("wlan0");
    QString filter = QString();

    if (argc == 2) {
        dev = QString::fromLocal8Bit(argv[1]);
    } else if (argc >= 3) {
        dev = QString::fromLocal8Bit(argv[1]);
        filter = QString::fromLocal8Bit(argv[2]);
    }

    MainWindow w(dev, filter);
    w.show();
    return app.exec();
}

