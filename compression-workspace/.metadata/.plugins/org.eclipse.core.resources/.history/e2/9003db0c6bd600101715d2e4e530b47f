 /* process a single compressed or decompressed block for a file
  *
  * Goal: centralize block-level processing for both compression and
  * decompression so callers can stream blocks and update progress.
  */
 static int
 blk_proc(io_ctx_t *c, FILE *out, int is_comp)
 {
     size_t res;
     uint32_t b_sz;

     if (is_comp)
         res = lz4_comp(c->in, c->c_len, c->out, BLK_SIZE * 2);
     else
         res = lz4_dec(c->in, c->c_len, c->out, BLK_SIZE * 2);

     if (res == 0)
         return (-1);

     if (is_comp) {
         b_sz = (uint32_t)res;
         if (io_wr_u32(out, b_sz))
             return (-1);
         if (fwrite(c->out, 1, res, out) != res)
             return (-1);
         g_prg.f_comp += 4 + res;
     } else {
         if (io_write(fileno(out), c->out, res))
             return (-1);
     }
     return (0);
 }

 /* write placeholder size and return its file position
  *
  * Goal: reserve space for the per-file compressed size so it can be
  * updated after streaming all blocks for that file.
  */
 static long
 file_comp_write_placeholder(FILE *arc)
 {
     long pos = ftell(arc);
     io_wr_u32(arc, 0);
     return pos;
 }

 /* finalize placeholder with actual compressed size
  *
  * Goal: update the reserved compressed-size field and restore file pos.
  */
 static int
 file_comp_finalize_placeholder(FILE *arc, long pos)
 {
     long cur = ftell(arc);
     fseek(arc, pos, SEEK_SET);
     io_wr_u32(arc, (uint32_t)g_prg.f_comp);
     fseek(arc, cur, SEEK_SET);
     return 0;
 }

 /* process blocks for compression of a single file
  *
  * Goal: read the input file in block-sized chunks, compress each block,
  * write compressed blocks to the archive, and update progress.
  */
 static int
 file_comp_process_blocks(io_ctx_t *c, FILE *arc)
 {
     size_t r;

     while ((r = io_read(c->fp, c->in, BLK_SIZE)) > 0) {
         c->c_len = (uint32_t)r;
         if (blk_proc(c, arc, 1) != 0)
             return (-1);
         g_prg.proc += r;
         prg_upd(g_prg.proc, g_prg.total);
     }
     return 0;
 }

 /* top-level file compression (refactored)
  *
  * Goal: orchestrate per-file compression with clear failure boundaries:
  *  - reserve header space,
  *  - stream-compress blocks,
  *  - finalize header with compressed size.
  */
 static int
 file_comp(io_ctx_t *c, FILE *arc)
 {
     long sz_pos;

     g_prg.curr = c->path;
     g_prg.f_comp = 0;
     sz_pos = file_comp_write_placeholder(arc);

     if (file_comp_process_blocks(c, arc) != 0)
         return (-1);

     file_comp_finalize_placeholder(arc, sz_pos);
     return (0);
 }

 /* read a block from archive and decompress it to file
  *
  * Goal: stream-decompress a sequence of compressed blocks for a single
  * archived file and write the reconstructed bytes to disk.
  */
 static int
 file_dec_process_blocks(FILE *arc, const char *out, uint32_t c_sz)
 {
     io_ctx_t c;
     FILE *fo;
     uint32_t rem;
     uint32_t b_sz;
     int fd;

     c.in = malloc(BLK_SIZE * 2);
     c.out = malloc(BLK_SIZE * 2);
     c.fp = NULL;
     fd = open(out, O_WRONLY | O_CREAT | O_TRUNC, FILE_MODE);
     fo = (fd >= 0) ? fdopen(fd, "wb") : NULL;
     rem = c_sz;

     while (rem > 0) {
         if (io_rd_u32(arc, &b_sz))
             break;
         rem -= 4;
         c.c_len = b_sz;
         io_read(arc, c.in, b_sz);
         rem -= b_sz;
         blk_proc(&c, fo, 0);
         g_prg.proc += 4 + b_sz;
         prg_upd(g_prg.proc, g_prg.total);
     }
     free(c.in);
     free(c.out);
     if (fo)
         fclose(fo);
     return (0);
 }

 /* wrapper for file_dec */
 static int
 file_dec(FILE *arc, const char *out, uint32_t c_sz)
 {
     return file_dec_process_blocks(arc, out, c_sz);
 }

 /* process a single file entry for compression
  *
  * Goal: isolate the logic that turns a filesystem path into an archive
  * entry. Handles path normalization, writes the archive file header for
  * the entry, and delegates block compression to file_comp.
  */
 static int
 dir_process_entry(const char *path, const char *rt, FILE *arc)
 {
     struct stat st;
     io_ctx_t c;

     if (lstat(path, &st))
         return (-1);
     if (!S_ISREG(st.st_mode))
         return 0;

     const char *rel = path + strlen(rt);
     char relbuf[PATH_MAX];
     if (*rel == '/')
         rel++;
     strncpy(relbuf, rel, sizeof(relbuf));
     relbuf[sizeof(relbuf) - 1] = '\0';

     if (arc_write(arc, relbuf, st.st_size))
         return (-1);

     c.path = relbuf;
     c.fp = fopen(path, "rb");
     if (c.fp == NULL)
         return -1;
     c.in = malloc(BLK_SIZE);
     c.out = malloc(BLK_SIZE * 2);
     file_comp(&c, arc);
     free(c.in);
     free(c.out);
     fclose(c.fp);
     return 0;
 }

 /* recursive directory compression
  *
  * Goal: traverse directories and compress regular files. Skips dotfiles
  * and delegates per-file work to dir_process_entry.
  */
 static int
 rec_comp(const char *in, const char *rt, FILE *arc)
 {
     struct stat st;
     struct dirent *e;
     DIR *d;
     char sub[PATH_MAX];

     if (lstat(in, &st))
         return (-1);
     if (S_ISDIR(st.st_mode)) {
         d = opendir(in);
         if (d == NULL)
             return (-1);
         while ((e = readdir(d))) {
             if (e->d_name[0] == '.')
                 continue;
             path_join(sub, PATH_MAX, in, e->d_name);
             rec_comp(sub, rt, arc);
         }
         closedir(d);
         return (0);
     }
     return dir_process_entry(in, rt, arc);
 }

 /* list archive contents
  *
  * Goal: iterate archive entries and print name, original size and
  * compressed size in human-readable form.
  */
 static int
 act_list(const char *fn)
 {
     FILE *f;
     uint64_t o_sz;
     uint32_t nl, c_sz;
     char nm[PATH_MAX];
     char s1[32], s2[32];

     f = fopen(fn, "rb");
     if (f == NULL)
         err(1, "open");
     while (1) {
         if (io_rd_u32(f, &nl))
             break;
         if (fread(nm, 1, nl, f) != nl)
             break;
         nm[nl] = 0;
         io_rd_u64(f, &o_sz);
         io_rd_u32(f, &c_sz);
         fmt_byte(o_sz, s1, 32);
         fmt_byte(c_sz, s2, 32);
         printf("%s %s %s\n", nm, s1, s2);
         fseek(f, c_sz, SEEK_CUR);
     }
     fclose(f);
     return 0;
 }

 /* top-level archive creation
  *
  * Goal: create an archive file from a path (file or directory). Computes
  * total size for progress reporting, then recursively compresses entries.
  */
 static void
 act_comp(const char *in, const char *out)
 {
     FILE *arc;
     char out_fn[PATH_MAX];
     char rt[PATH_MAX];
     char *dir;

     if (out == NULL)
         snprintf(out_fn, sizeof(out_fn), "%s.lz4", in);
     else
         strncpy(out_fn, out, sizeof(out_fn));

     arc = fopen(out_fn, "wb");
     if (arc == NULL)
         err(1, "create");

     strncpy(rt, in, sizeof(rt));
     if (rec_size(in, &g_prg.total))
         err(1, "scan");

     dir = dirname(rt);
     rec_comp(in, dir, arc);
     fclose(arc);
 }

 /* top-level archive extraction
  *
  * Goal: read archive entries and reconstruct files into the destination
  * directory (or current working directory if out == NULL).
  */
 static void
 act_dec(const char *in, const char *out)
 {
     FILE *f;
     struct stat st;
     uint64_t o_sz;
     uint32_t nl, c_sz;
     char nm[PATH_MAX];
     char dst[PATH_MAX];

     f = fopen(in, "rb");
     if (f == NULL)
         err(1, "open");

     stat(in, &st);
     g_prg.total = st.st_size;

     while (1) {
         if (io_rd_u32(f, &nl))
             break;
         if (fread(nm, 1, nl, f) != nl)
             break;
         nm[nl] = 0;
         io_rd_u64(f, &o_sz);
         io_rd_u32(f, &c_sz);

         if (out != NULL)
             path_join(dst, PATH_MAX, out, nm);
         else
             strncpy(dst, nm, PATH_MAX);

         dir_mk(dst);
         file_dec(f, dst, c_sz);
     }
     fclose(f);
 }

 /* create directories for a path
  *
  * Goal: ensure parent directories exist for a given path. Returns 0 on
  * success or if directory already exists.
  */
 static int
 dir_mk(const char *p)
 {
     struct stat st;
     char tmp[PATH_MAX];
     char *sl;

     strncpy(tmp, p, sizeof(tmp) - 1);
     tmp[sizeof(tmp) - 1] = '\0';
     sl = strrchr(tmp, '/');
     if (sl == NULL || sl == tmp)
         return (0);
     *sl = 0;
     if (stat(tmp, &st) == 0 && S_ISDIR(st.st_mode))
         return (0);
     dir_mk(tmp);
     return (mkdir(tmp, DIR_MODE) == 0 || errno == EEXIST ? 0 : -1);
 }

 /* recursively compute total size for progress reporting
  *
  * Goal: sum sizes of regular files under a path. Skips non-regular
  * entries and dotfiles.
  */
 static int
 rec_size(const char *p, uint64_t *sz)
 {
     struct stat st;
     struct dirent *e;
     DIR *d;
     char sub[PATH_MAX];

     if (lstat(p, &st))
         return (-1);
     if (S_ISREG(st.st_mode)) {
         *sz += st.st_size;
         return (0);
     }
     if (!S_ISDIR(st.st_mode))
         return (0);

     d = opendir(p);
     if (d == NULL)
         return (-1);
     while ((e = readdir(d))) {
         if (e->d_name[0] == '.')
             continue;
         path_join(sub, PATH_MAX, p, e->d_name);
         rec_size(sub, sz);
     }
     closedir(d);
     return (0);
 }

 /* program entry point (unchanged)
  *
  * Usage: program -c|-d|-l <in> [out]
  */
 int
 main(int ac, char **av)
 {
     if (ac < 3) {
         fprintf(stderr, "use: %s -c|-d|-l <in> [out]\n", av[0]);
         return (1);
     }
     gettimeofday(&g_prg.start, NULL);

     if (strcmp(av[1], "-l") == 0)
         act_list(av[2]);
     else if (strcmp(av[1], "-c") == 0)
         act_comp(av[2], ac > 3 ? av[3] : NULL);
     else if (strcmp(av[1], "-d") == 0)
         act_dec(av[2], ac > 3 ? av[3] : NULL);
     else
         return (1);

     return (0);
 }

