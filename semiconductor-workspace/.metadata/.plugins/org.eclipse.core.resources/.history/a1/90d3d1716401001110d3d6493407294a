Gute Präzisierung, machen wir das Ganze in sauberem C.

### Kurzüberblick

- **Sprache:** C (C99), keine C++-Headers, keine iostream.
- **Libs:** `SDL2/SDL.h`, `math.h`, `stdio.h`, `stdlib.h`.
- **Modell:** D2Q9-LBM, drei horizontale Leitungen mit unterschiedlicher Breite und Einlassgeschwindigkeit.

Kompilieren z.B. so:

```bash
gcc lbm_pipes_sdl2.c -o lbm_pipes_sdl2 `sdl2-config --cflags --libs` -O2
```

### Vollständiger C-Code (Single File)

```c
#include <SDL2/SDL.h>
#include <math.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

typedef struct {
    double x;
    double y;
} Vec2;

int main(int argc, char** argv) {
    const int NX = 400;
    const int NY = 200;
    const int SCALE = 3;

    if (SDL_Init(SDL_INIT_VIDEO) != 0) {
        fprintf(stderr, "SDL_Init failed: %s\n", SDL_GetError());
        return 1;
    }

    SDL_Window* window = SDL_CreateWindow(
        "Lattice Boltzmann Wasserleitungen (D2Q9, C)",
        SDL_WINDOWPOS_CENTERED, SDL_WINDOWPOS_CENTERED,
        NX * SCALE, NY * SCALE, SDL_WINDOW_SHOWN
    );
    if (!window) {
        fprintf(stderr, "SDL_CreateWindow failed: %s\n", SDL_GetError());
        SDL_Quit();
        return 1;
    }

    SDL_Renderer* renderer = SDL_CreateRenderer(
        window, -1, SDL_RENDERER_ACCELERATED | SDL_RENDERER_PRESENTVSYNC
    );
    if (!renderer) {
        fprintf(stderr, "SDL_CreateRenderer failed: %s\n", SDL_GetError());
        SDL_DestroyWindow(window);
        SDL_Quit();
        return 1;
    }

    /* D2Q9 Parameter */
    const int Q = 9;
    int ex[9] = {0, 1, 0, -1, 0, 1, -1, -1, 1};
    int ey[9] = {0, 0, 1, 0, -1, 1, 1, -1, -1};
    double w[9] = {
        4.0/9.0,
        1.0/9.0, 1.0/9.0, 1.0/9.0, 1.0/9.0,
        1.0/36.0, 1.0/36.0, 1.0/36.0, 1.0/36.0
    };

    const double tau = 0.8;
    const double omega = 1.0 / tau;

    /* Speicher für Verteilungsfunktionen */
    size_t total_cells = (size_t)NX * (size_t)NY;
    size_t total_f = total_cells * (size_t)Q;

    double* f = (double*)malloc(total_f * sizeof(double));
    double* f_next = (double*)malloc(total_f * sizeof(double));
    if (!f || !f_next) {
        fprintf(stderr, "malloc failed\n");
        SDL_DestroyRenderer(renderer);
        SDL_DestroyWindow(window);
        SDL_Quit();
        return 1;
    }

    int* is_solid = (int*)malloc(total_cells * sizeof(int));
    if (!is_solid) {
        fprintf(stderr, "malloc failed\n");
        free(f);
        free(f_next);
        SDL_DestroyRenderer(renderer);
        SDL_DestroyWindow(window);
        SDL_Quit();
        return 1;
    }

    /* Index-Hilfsfunktionen */
    #define IDX(x,y,k) (((y) * NX + (x)) * Q + (k))
    #define SOLID_IDX(x,y) ((y) * NX + (x))

    /* Geometrie: drei Leitungen */
    int top_y1 = 20;
    int top_y2 = 80;

    int mid_y1 = 90;
    int mid_y2 = 130;

    int bot_y1 = 140;
    int bot_y2 = 160;

    /* Wände/Fluid markieren */
    {
        int x, y;
        for (y = 0; y < NY; ++y) {
            for (x = 0; x < NX; ++x) {
                int fluid = 0;
                if (y >= top_y1 && y <= top_y2) fluid = 1;
                if (y >= mid_y1 && y <= mid_y2) fluid = 1;
                if (y >= bot_y1 && y <= bot_y2) fluid = 1;
                is_solid[SOLID_IDX(x,y)] = fluid ? 0 : 1;
            }
        }
    }

    /* Initialisierung: Ruhe */
    {
        int x, y, k;
        for (y = 0; y < NY; ++y) {
            for (x = 0; x < NX; ++x) {
                double rho0 = 1.0;
                double ux0 = 0.0;
                double uy0 = 0.0;
                double u2 = ux0*ux0 + uy0*uy0;
                for (k = 0; k < Q; ++k) {
                    double eu = ex[k]*ux0 + ey[k]*uy0;
                    double feq = w[k] * rho0 * (1.0 + 3.0*eu + 4.5*eu*eu - 1.5*u2);
                    f[IDX(x,y,k)] = feq;
                }
            }
        }
        memset(f_next, 0, total_f * sizeof(double));
    }

    int running = 1;
    SDL_Event e;
    int step = 0;

    while (running) {
        while (SDL_PollEvent(&e)) {
            if (e.type == SDL_QUIT) running = 0;
            if (e.type == SDL_KEYDOWN && e.key.keysym.sym == SDLK_ESCAPE)
                running = 0;
        }

        /* Kollisions- und Streaming-Schritt */
        {
            int x, y, k;
            for (y = 0; y < NY; ++y) {
                for (x = 0; x < NX; ++x) {
                    if (is_solid[SOLID_IDX(x,y)]) {
                        for (k = 0; k < Q; ++k) {
                            f_next[IDX(x,y,k)] = 0.0;
                        }
                        continue;
                    }

                    double rho = 0.0;
                    double ux = 0.0;
                    double uy = 0.0;

                    for (k = 0; k < Q; ++k) {
                        double fk = f[IDX(x,y,k)];
                        rho += fk;
                        ux += fk * ex[k];
                        uy += fk * ey[k];
                    }
                    ux /= rho;
                    uy /= rho;

                    /* Einlass links mit unterschiedlichen Geschwindigkeiten */
                    if (x == 0) {
                        if (y >= top_y1 && y <= top_y2) {
                            ux = 0.02;
                            uy = 0.0;
                        }
                        if (y >= mid_y1 && y <= mid_y2) {
                            ux = 0.05;
                            uy = 0.0;
                        }
                        if (y >= bot_y1 && y <= bot_y2) {
                            ux = 0.09;
                            uy = 0.0;
                        }
                        rho = 1.0;
                    }

                    /* Kollisionsschritt */
                    {
                        double u2 = ux*ux + uy*uy;
                        for (k = 0; k < Q; ++k) {
                            double eu = ex[k]*ux + ey[k]*uy;
                            double feq = w[k] * rho * (1.0 + 3.0*eu + 4.5*eu*eu - 1.5*u2);
                            double fk = f[IDX(x,y,k)];
                            double f_post = fk - omega * (fk - feq);

                            int xn = x + ex[k];
                            int yn = y + ey[k];

                            if (xn < 0) xn = 0;
                            if (xn >= NX) xn = NX - 1;
                            if (yn < 0) yn = 0;
                            if (yn >= NY) yn = NY - 1;

                            f_next[IDX(xn, yn, k)] += f_post;
                        }
                    }
                }
            }
        }

        /* Bounce-Back an Wänden */
        {
            int x, y;
            for (y = 0; y < NY; ++y) {
                for (x = 0; x < NX; ++x) {
                    if (!is_solid[SOLID_IDX(x,y)]) continue;

                    double ftemp[9];
                    int k;
                    for (k = 0; k < Q; ++k) {
                        ftemp[k] = f_next[IDX(x,y,k)];
                    }

                    f_next[IDX(x,y,1)] = ftemp[3];
                    f_next[IDX(x,y,3)] = ftemp[1];
                    f_next[IDX(x,y,2)] = ftemp[4];
                    f_next[IDX(x,y,4)] = ftemp[2];
                    f_next[IDX(x,y,5)] = ftemp[7];
                    f_next[IDX(x,y,7)] = ftemp[5];
                    f_next[IDX(x,y,6)] = ftemp[8];
                    f_next[IDX(x,y,8)] = ftemp[6];
                }
            }
        }

        /* Swap f und f_next */
        {
            double* tmp = f;
            f = f_next;
            f_next = tmp;
            memset(f_next, 0, total_f * sizeof(double));
        }

        /* Visualisierung */
        SDL_SetRenderDrawColor(renderer, 0, 0, 0, 255);
        SDL_RenderClear(renderer);

        {
            int x, y, k;
            for (y = 0; y < NY; ++y) {
                for (x = 0; x < NX; ++x) {
                    if (is_solid[SOLID_IDX(x,y)]) {
                        SDL_SetRenderDrawColor(renderer, 30, 30, 30, 255);
                    } else {
                        double rho = 0.0;
                        double ux = 0.0;
                        double uy = 0.0;
                        for (k = 0; k < Q; ++k) {
                            double fk = f[IDX(x,y,k)];
                            rho += fk;
                            ux += fk * ex[k];
                            uy += fk * ey[k];
                        }
                        ux /= rho;
                        uy /= rho;
                        double speed = sqrt(ux*ux + uy*uy);

                        double s = speed * 20.0;
                        if (s > 1.0) s = 1.0;
                        if (s < 0.0) s = 0.0;

                        Uint8 r = (Uint8)(255.0 * s);
                        Uint8 g = (Uint8)(255.0 * (s * 1.2 > 1.0 ? 1.0 : s * 1.2));
                        Uint8 b = (Uint8)(255.0 * (1.0 - s));

                        SDL_SetRenderDrawColor(renderer, r, g, b, 255);
                    }

                    SDL_Rect rect;
                    rect.x = x * SCALE;
                    rect.y = y * SCALE;
                    rect.w = SCALE;
                    rect.h = SCALE;
                    SDL_RenderFillRect(renderer, &rect);
                }
            }
        }

        SDL_RenderPresent(renderer);
        step++;
        /* Optional: etwas bremsen */
        /* SDL_Delay(5); */
    }

    free(f);
    free(f_next);
    free(is_solid);
    SDL_DestroyRenderer(renderer);
    SDL_DestroyWindow(window);
    SDL_Quit();
    return 0;
}
