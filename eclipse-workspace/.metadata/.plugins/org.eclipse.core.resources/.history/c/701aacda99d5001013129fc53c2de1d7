/* ---------------------------
   modr/m emission
   --------------------------- */
static void emit_modrm_for_operands(sectionkind s, operand *op_dst, operand *op_src, instrdef *d) {
    uint8_t modrm = 0;
    int r_reg = -1;
    int r_rm = -1;
    int ext_reg = 0;
    int ext_rm = 0;
    int op_code_ext = -1; /* for instructions that use the reg field as an opcode extension (e.g., cmpq) */

    /* determine reg (r) and r/m (rm) indices */
    if (d->pat_len == 2) {
        /* case 1: two registers (reg, reg or reg, mem or mem, reg) */
        if (op_dst->kind == op_reg && op_src->kind == op_reg) {
            r_reg = reg_index(op_dst->reg);
            r_rm = reg_index(op_src->reg);
        } else if (op_dst->kind == op_reg && op_src->kind == op_mem_reg) {
            r_reg = reg_index(op_dst->reg);
            r_rm = reg_index(op_src->reg);
        } else if (op_dst->kind == op_mem_reg && op_src->kind == op_reg) {
            r_reg = reg_index(op_src->reg);
            r_rm = reg_index(op_dst->reg);
        } else if (op_dst->kind == op_imm_num && op_src->kind == op_reg && strcmp(d->mnemonic, "cmpq") == 0) {
            r_rm = reg_index(op_src->reg);
            op_code_ext = 7; /* /7 for cmp */
        }
    } else if (d->pat_len == 1 && d->pat[0] == pat_mem_reg) {
        /* case 2: one memory operand (e.g., pushq/popq) */
        r_rm = reg_index(op_dst->reg);
    }

    if (r_reg != -1) {
        ext_reg = (r_reg & 8) >> 3;
        r_reg = r_reg & 7;
    }
    if (r_rm != -1) {
        ext_rm = (r_rm & 8) >> 3;
        r_rm = r_rm & 7;
    }

    /* calculate rex prefix */
    uint8_t rex = 0x40 | (d->opcode[0] & 0xF8); /* 0x48 for 64-bit ops */
    if (d->opcode[0] == 0x48 || d->opcode[0] == 0x49) {
        rex = d->opcode[0];
    } else if (d->opcode_len > 0 && (d->opcode[0] == 0x0F || d->opcode[0] == 0x05) && (d->pat[0] == pat_reg || d->pat[1] == pat_reg) && (r_reg != -1 || r_rm != -1)) {
        /* for sse/non-rex instructions, we might need an r-bit or b-bit, but not w */
        rex = 0x40;
    } else if (d->opcode_len > 0 && (d->opcode[0] == 0x83 || d->opcode[0] == 0x89) && (r_rm != -1)) {
        rex = 0x48;
    } else {
        rex = 0; /* no rex prefix if not needed */
    }

    /* apply r-bit (extension for reg field) and b-bit (extension for r/m field) */
    if (r_reg != -1 && ext_reg) rex |= 0x4;
    if (r_rm != -1 && ext_rm) rex |= 0x1;

    if (rex) emit_u8(s, rex);

    /* calculate modr/m byte */
    if (op_code_ext != -1) {
        /* special case for opcodes that use the reg field as an extension (e.g., cmpq imm8, reg -> /7) */
        /* mod=11 (register direct addressing), reg/opcode=7, r/m=reg_index */
        modrm = 0xC0 | ((op_code_ext & 7) << 3) | (r_rm & 7);
        emit_u8(s, modrm);
        return;
    }

    if (op_dst->kind == op_reg && op_src->kind == op_reg) {
        /* mod=11 (register direct) */
        modrm = 0xC0 | ((r_reg & 7) << 3) | (r_rm & 7);
        emit_u8(s, modrm);
    } else if (op_dst->kind == op_reg && op_src->kind == op_mem_reg) {
        /* mod=00 (memory with no displacement) */
        /* r/m is base register, reg is destination register (e.g., movq (%rax), %rcx) */
        if (r_rm == 4) { /* sib byte needed for %rsp */
            modrm = 0x04 | ((r_reg & 7) << 3); /* mod=00, r/m=4 (sib byte follows) */
            emit_u8(s, modrm);
            emit_u8(s, 0x24); /* sib: scale=0, index=4(%rsp, none), base=4(%rsp) */
        } else {
            modrm = (r_rm & 7) | ((r_reg & 7) << 3); /* mod=00, r/m=base, reg=dest */
            emit_u8(s, modrm);
        }
    } else if (op_dst->kind == op_mem_reg && op_src->kind == op_reg) {
        /* mod=00 (memory with no displacement) */
        /* r/m is base register, reg is source register (e.g., movq %rcx, (%rax)) */
        if (r_rm == 4) { /* sib byte needed for %rsp */
            modrm = 0x04 | ((r_reg & 7) << 3); /* mod=00, r/m=4 (sib byte follows) */
            emit_u8(s, modrm);
            emit_u8(s, 0x24); /* sib: scale=0, index=4(%rsp, none), base=4(%rsp) */
        } else {
            modrm = (r_rm & 7) | ((r_reg & 7) << 3); /* mod=00, r/m=base, reg=src */
            emit_u8(s, modrm);
        }
    }
}

/* ---------------------------
   instruction lookup & emission
   --------------------------- */
static const char *opkind_name(int k) {
    switch (k) {
    case op_reg: return "op_reg";
    case op_imm_sym: return "op_imm_sym";
    case op_imm_num: return "op_imm_num";
    case op_mem_reg: return "op_mem_reg";
    default: return "op_unknown";
    }
}

static int pat_matches_operand(patkind pk, operand *op) {
    if (pk == pat_reg) return op->kind == op_reg;
    if (pk == pat_imm_num) return op->kind == op_imm_num;
    if (pk == pat_imm_sym) return op->kind == op_imm_sym;
    if (pk == pat_mem_reg) return op->kind == op_mem_reg;
    return 0;
}

static instrdef *find_instr(const char *mn, node *n) {
    for (instrdef *d = instr_table; d->mnemonic; ++d) {
        if (strcmp(d->mnemonic, mn) != 0) continue;
        if (d->pat_len != n->opcnt) continue;
        int ok = 1;
        for (int i = 0; i < d->pat_len; ++i) {
            if (!pat_matches_operand(d->pat[i], &n->ops[i])) { ok = 0; break; }
        }
        if (ok) return d;
    }

    /* no match found — print helpful diagnostic */
    fprintf(stderr, "find_instr: no matching entry for '%s' (opcnt=%d)\n", mn, n->opcnt);
    for (int i = 0; i < n->opcnt; ++i) {
        operand *o = &n->ops[i];
        fprintf(stderr, "  operand %d: kind=%s", i, opkind_name(o->kind));
        if (o->reg) fprintf(stderr, " reg=%s", o->reg);
        if (o->sym) fprintf(stderr, " sym=%s", o->sym);
        if (o->kind == op_imm_num) fprintf(stderr, " imm=%lld", (long long)o->imm);
        fprintf(stderr, "\n");
    }

    /* also print the table entries for this mnemonic to help debugging */
    fprintf(stderr, "available patterns for '%s':\n", mn);
    for (instrdef *d = instr_table; d->mnemonic; ++d) {
        if (strcmp(d->mnemonic, mn) != 0) continue;
        fprintf(stderr, "  pat_len=%d pat=", d->pat_len);
        for (int i = 0; i < d->pat_len; ++i) {
            switch (d->pat[i]) {
            case pat_reg: fprintf(stderr, "reg"); break;
            case pat_imm_num: fprintf(stderr, "imm_num"); break;
            case pat_imm_sym: fprintf(stderr, "imm_sym"); break;
            case pat_mem_reg: fprintf(stderr, "mem_reg"); break;
            default: fprintf(stderr, "??"); break;
            }
            if (i + 1 < d->pat_len) fprintf(stderr, ",");
        }
        fprintf(stderr, "\n");
    }

    return NULL;
}

static void emit_inst_table(node *n) {
    sectionkind s = n->sec;
    instrdef *d = find_instr(n->mnemonic, n);
    if (!d) { fprintf(stderr, "unsupported instruction or operand pattern: %s\n", n->mnemonic); exit(1); }

    /* special handling for movabs imm64, reg which changes the opcode byte */
    uint8_t opcode_bytes[8];
    memcpy(opcode_bytes, d->opcode, d->opcode_len);
    int opcode_len = d->opcode_len;

    if (strcmp(n->mnemonic, "movq") == 0 && (n->ops[0].kind == op_imm_num || n->ops[0].kind == op_imm_sym) && n->ops[1].kind == op_reg) {
        int reg = reg_index(n->ops[1].reg);
        if (reg >= 0) {
            uint8_t rex = 0x48;
            if (reg >= 8) rex |= 0x01; /* b-bit for extended registers */
            emit_u8(s, rex);
            opcode_bytes[1] = 0xb8 | (reg & 7);
            emit_bytes(s, opcode_bytes, 2);
        } else {
            /* fallback: emit base opcode bytes */
            emit_bytes(s, opcode_bytes, opcode_len);
        }
    } else {
        /* standard opcode emission */
        emit_bytes(s, opcode_bytes, opcode_len);
    }


    if (d->needs_modrm) {
        if (d->pat_len == 2 && d->pat[0] == pat_reg && d->pat[1] == pat_reg) {
            emit_modrm_for_operands(s, &n->ops[1], &n->ops[0], d); /* mov reg, reg (op_dst, op_src) */
        } else if (d->pat_len == 2 && d->pat[0] == pat_mem_reg && d->pat[1] == pat_reg) {
            emit_modrm_for_operands(s, &n->ops[1], &n->ops[0], d); /* addq (mem), reg (op_dst, op_src) */
        } else if (d->pat_len == 2 && d->pat[0] == pat_reg && d->pat[1] == pat_mem_reg) {
            emit_modrm_for_operands(s, &n->ops[1], &n->ops[0], d); /* movaps reg, (mem) (op_dst, op_src) */
        } else if (d->pat_len == 2 && d->pat[0] == pat_imm_num && d->pat[1] == pat_reg && strcmp(n->mnemonic, "cmpq") == 0) {
            emit_modrm_for_operands(s, &n->ops[0], &n->ops[1], d); /* cmpq imm, reg (op_imm, op_reg) uses reg as r/m, /7 opcode extension */
        } else {
            /* fallthrough, maybe should have handled this elsewhere */
            emit_u8(s, 0x00);
        }
    }

    /* immediate data emission */
    if (d->imm_bytes == 8) {
        if (n->ops[0].kind == op_imm_num) emit_u64(s, (uint64_t)n->ops[0].imm);
        else if (n->ops[0].kind == op_imm_sym) emit_rel64(s, n->ops[0].sym, 0);
        else emit_u64(s, 0);
    } else if (d->imm_bytes == 4) {
        if (d->reloc_type == r_x86_64_pc32) {
            /* pc-relative relocation: addend = -(instruction length) */
            int inst_len = (d->opcode_len + (d->needs_modrm ? 1 : 0) + d->imm_bytes);
            if (strcmp(n->mnemonic, "movq") == 0 && (n->ops[0].kind == op_imm_num || n->ops[0].kind == op_imm_sym) && n->ops[1].kind == op_reg) {
                inst_len = 10; /* movabs imm64, reg is 10 bytes (rex + opcode + imm8) */
            }
            int addend = -inst_len;

            /* special case: addps with pc-relative operand */
            if (strcmp(n->mnemonic, "addps") == 0 && n->ops[0].kind == op_imm_sym) {
                addend = -inst_len;
            }

            emit_rel32(s, n->ops[0].sym, addend);
        } else {
            if (n->ops[0].kind == op_imm_num) emit_u32(s, (uint32_t)n->ops[0].imm);
            else emit_u32(s, 0);
        }
    } else if (d->imm_bytes == 1) {
        if (n->ops[0].kind == op_imm_num) emit_u8(s, (uint8_t)n->ops[0].imm);
        else emit_u8(s, 0);
    } else {
        /* some opcodes include a 0x05 and expect a disp32 already in opcode sequence (handled above) */
    }
}

/* ---------------------------
   directives emission
   --------------------------- */
static void emit_directive(node *n) {
    if (!n->dir) return;
    if (strcmp(n->dir, ".global") == 0) {
        if (n->dir_arg) { sym *s = sym_get_or_create(n->dir_arg); s->global = 1; }
        return;
    }
    if (strcmp(n->dir, ".align") == 0) {
        if (n->dir_arg) {
            int a = atoi(n->dir_arg);
            uint64_t align = (a > 0 && a <= 16) ? ((uint64_t)1 << a) : (uint64_t)a;
            if (align == 0) align = 1;
            uint64_t cur = sects[n->sec].buf.len;
            uint64_t pad = (align - (cur % align)) % align;
            for (uint64_t i = 0; i < pad; ++i) emit_u8(n->sec, 0);
        }
        return;
    }
    if (strcmp(n->dir, ".ascii") == 0) {
        if (n->dir_arg) {
            buf_put(&sects[n->sec].buf, n->dir_arg, strlen(n->dir_arg));
        }
        return;
    }
    if (strcmp(n->dir, ".byte") == 0) {
        if (n->dir_arg) {
            char *s = strdup(n->dir_arg);
            char *tok = strtok(s, " ");
            while (tok) {
                long v = strtol(tok, NULL, 0);
                emit_u8(n->sec, (uint8_t)v);
                tok = strtok(NULL, " ");
            }
            free(s);
        }
        return;
    }
    if (strcmp(n->dir, ".skip") == 0 || strcmp(n->dir, ".space") == 0) {
        if (n->dir_arg) {
            int cnt = atoi(n->dir_arg);
            for (int i = 0; i < cnt; ++i) emit_u8(n->sec, 0);
        }
        return;
    }
}

/* ---------------------------
   two-pass assembly
   --------------------------- */
static void first_pass(node *nodes) {
    section_init(&sects[sec_text], sec_text);
    section_init(&sects[sec_data], sec_data);
    section_init(&sects[sec_bss], sec_bss);

    node *n = nodes;
    while (n) {
        if (n->kind == node_label) {
            char *lab = strdup(n->label);
            if (lab[strlen(lab) - 1] == ':') lab[strlen(lab) - 1] = 0;
            sym *s = sym_get_or_create(lab);
            s->sec = n->sec;
            if (n->sec == sec_text) s->value = sects[sec_text].buf.len;
            else if (n->sec == sec_data) s->value = sects[sec_data].buf.len;
            else if (n->sec == sec_bss) s->value = sects[sec_bss].buf.len;
            s->defined = 1;
            free(lab);
        } else if (n->kind == node_dir) {
            if (strcmp(n->dir, ".ascii") == 0 && n->dir_arg) {
                sects[n->sec].buf.len += strlen(n->dir_arg);
            } else if (strcmp(n->dir, ".byte") == 0 && n->dir_arg) {
                char *s = strdup(n->dir_arg);
                int cnt = 0;
                char *tok = strtok(s, " ");
                while (tok) { cnt++; tok = strtok(NULL, " "); }
                free(s);
                sects[n->sec].buf.len += cnt;
            } else if (strcmp(n->dir, ".align") == 0 && n->dir_arg) {
                int a = atoi(n->dir_arg);
                uint64_t align = (a > 0 && a <= 16) ? ((uint64_t)1 << a) : (uint64_t)a;
                if (align == 0) align = 1;
                uint64_t cur = sects[n->sec].buf.len;
                uint64_t pad = (align - (cur % align)) % align;
                sects[n->sec].buf.len += pad;
            } else if ((strcmp(n->dir, ".skip") == 0 || strcmp(n->dir, ".space") == 0) && n->dir_arg) {
                sects[n->sec].buf.len += atoi(n->dir_arg);
            } else if (strcmp(n->dir, ".global") == 0 && n->dir_arg) {
                sym *s = sym_get_or_create(n->dir_arg);
                s->global = 1;
            }
        } else if (n->kind == node_inst) {
            instrdef *d = find_instr(n->mnemonic, n);
            if (!d) { fprintf(stderr, "unknown instruction in first pass: %s\n", n->mnemonic); exit(1); }
            /* special case: movabs imm64, reg is 10 bytes */
            if (strcmp(n->mnemonic, "movq") == 0 && (n->ops[0].kind == op_imm_num || n->ops[0].kind == op_imm_sym) && n->ops[1].kind == op_reg) {
                sects[n->sec].buf.len += 10;
            } else {
                sects[n->sec].buf.len += d->size_est;
            }
        }
        n = n->next;
    }
}

static void second_pass(node *nodes) {
    buf_free(&sects[sec_text].buf); buf_init(&sects[sec_text].buf);
    buf_free(&sects[sec_data].buf); buf_init(&sects[sec_data].buf);
    buf_free(&sects[sec_bss].buf); buf_init(&sects[sec_bss].buf);

    node *n = nodes;
    while (n) {
        if (n->kind == node_label) {
            char *lab = strdup(n->label);
            if (lab[strlen(lab) - 1] == ':') lab[strlen(lab) - 1] = 0;
            sym *s = sym_get_or_create(lab);
            s->sec = n->sec;
            if (n->sec == sec_text) s->value = sects[sec_text].buf.len;
            else if (n->sec == sec_data) s->value = sects[sec_data].buf.len;
            else if (n->sec == sec_bss) s->value = sects[sec_bss].buf.len;
            s->defined = 1;
            free(lab);
        } else if (n->kind == node_dir) {
            emit_directive(n);
        } else if (n->kind == node_inst) {
            emit_inst_table(n);
        }
        n = n->next;
    }
}

/* ---------------------------
   elf writer
   --------------------------- */
#pragma pack(push,1)
typedef struct { unsigned char e_ident[16]; uint16_t e_type; uint16_t e_machine; uint32_t e_version; uint64_t e_entry; uint64_t e_phoff; uint64_t e_shoff; uint32_t e_flags; uint16_t e_ehsize; uint16_t e_phentsize; uint16_t e_phnum; uint16_t e_shentsize; uint16_t e_shnum; uint16_t e_shstrndx; } elf64_ehdr;
typedef struct { uint32_t sh_name; uint32_t sh_type; uint64_t sh_flags; uint64_t sh_addr; uint64_t sh_offset; uint64_t sh_size; uint32_t sh_link; uint32_t sh_info; uint64_t sh_addralign; uint64_t sh_entsize; } elf64_shdr;
typedef struct { uint32_t st_name; unsigned char st_info; unsigned char st_other; uint16_t st_shndx; uint64_t st_value; uint64_t st_size; } elf64_sym;
typedef struct { uint32_t r_offset; uint32_t r_info; int32_t r_addend; } elf64_rela;
#pragma pack(pop)

/* section types */
enum { SHT_NULL = 0, SHT_PROGBITS = 1, SHT_SYMTAB = 2, SHT_STRTAB = 3, SHT_RELA = 4, SHT_NOBITS = 8 };

/* section flags */
enum { SHF_WRITE = 0x1, SHF_ALLOC = 0x2, SHF_EXECINSTR = 0x4 };

/* symbol bindings/types */
#define ELF64_ST_INFO(b,t) (((b)<<4)+((t)&0xF))
enum { STB_LOCAL = 0, STB_GLOBAL = 1 };
enum { STT_NOTYPE = 0, STT_OBJECT = 1, STT_FUNC = 2 };

/* ---------------------------
   helper: write little-endian values to file
   (unused functions removed to fix warnings)
   --------------------------- */

/* ---------------------------
   build ELF object file (.o)
   --------------------------- */
static size_t align_up(size_t v, size_t a) { return (v + a - 1) & ~(a - 1); }

static void write_elf(const char *outpath) {
    /* build section name string table */
    buf shstr; buf_init(&shstr);
    /* index 0 is empty */
    buf_put(&shstr, "\0", 1);
    uint32_t off_text_name = shstr.len; buf_put(&shstr, ".text\0", 6);
    uint32_t off_data_name = shstr.len; buf_put(&shstr, ".data\0", 6);
    uint32_t off_bss_name  = shstr.len; buf_put(&shstr, ".bss\0", 5);
    buf_put(&shstr, ".shstrtab\0", 10); // off_shstrtab variable removed (unused variable warning)
    uint32_t off_symtab_name = shstr.len; buf_put(&shstr, ".symtab\0", 8);
    uint32_t off_strtab_name = shstr.len; buf_put(&shstr, ".strtab\0", 8);
    uint32_t off_rela_text = shstr.len; buf_put(&shstr, ".rela.text\0", 11);
    uint32_t off_rela_data = shstr.len; buf_put(&shstr, ".rela.data\0", 11);

    /* build symbol string table */
    buf strtab; buf_init(&strtab);
    buf_put(&strtab, "\0", 1);
    /* assign symbol indices */
    int symcount = 1; /* index 0 is stn_undef */
    for (sym *s = symtab; s; s = s->next) {
        s->index = symcount++;
        buf_put(&strtab, s->name, strlen(s->name)+1);
    }

    /* count relocations */
    int rela_text_count = 0, rela_data_count = 0;
    for (reloc *r = sects[sec_text].relocs; r; r = r->next) rela_text_count++;
    for (reloc *r = sects[sec_data].relocs; r; r = r->next) rela_data_count++;

    /* prepare symbol table entries */
    buf symtab_buf; buf_init(&symtab_buf);
    /* first null symbol */
    elf64_sym zero_sym;
    memset(&zero_sym,0,sizeof(zero_sym));
    buf_put(&symtab_buf, &zero_sym, sizeof(zero_sym));
    /* now symbols: local first (we'll mark all as local/global later) */
    for (sym *s = symtab; s; s = s->next) {
        elf64_sym es;
        memset(&es,0,sizeof(es));
        /* find name offset in strtab */
        uint32_t name_off = 0;
        const char *p = (const char*)strtab.data;
        uint32_t idx = 0;
        while (idx < strtab.len) {
            if (strcmp(p, s->name) == 0) { name_off = idx; break; }
            idx += strlen(p) + 1;
            p = (const char*)strtab.data + idx;
        }
        es.st_name = name_off;
        es.st_info = ELF64_ST_INFO(s->global ? STB_GLOBAL : STB_LOCAL, STT_NOTYPE);
        es.st_other = 0;
        if (s->defined) {
            if (s->sec == sec_text) es.st_shndx = 1; /* .text will be section 1 */
            else if (s->sec == sec_data) es.st_shndx = 2;
            else if (s->sec == sec_bss) es.st_shndx = 3;
            else es.st_shndx = 0;
            es.st_value = s->value;
        } else {
            es.st_shndx = 0;
            es.st_value = 0;
        }
        es.st_size = 0;
        buf_put(&symtab_buf, &es, sizeof(es));
    }

    /* compute offsets */
    size_t ehdr_size = sizeof(elf64_ehdr);
    size_t shdr_size = sizeof(elf64_shdr);
    int has_rela_text = (rela_text_count > 0);
    int has_rela_data = (rela_data_count > 0);
    int extra = 1 /*shstr*/ + 1 /*symtab*/ + 1 /*strtab*/ + (has_rela_text?1:0) + (has_rela_data?1:0);
    int total_sh = 1 + 3 + extra;
    size_t offset = ehdr_size;

    size_t off_text = offset; offset += sects[sec_text].buf.len;
    offset = align_up(offset, 8);
    size_t off_data = offset; offset += sects[sec_data].buf.len;
    offset = align_up(offset, 8);
    size_t off_bss = offset; /* bss is nobits, no data */
    size_t off_shstr = offset;
    offset += shstr.len;
    offset = align_up(offset, 8);
    size_t off_symtab = offset;
    offset += symtab_buf.len;
    offset = align_up(offset, 8);
    size_t off_strtab = offset;
    offset += strtab.len;
    offset = align_up(offset, 8);

    if (has_rela_text) {
        off_rela_text = (uint32_t)offset;
        offset += rela_text_count * sizeof(elf64_rela);
        offset = align_up(offset, 8);
    }
    if (has_rela_data) {
        off_rela_data = (uint32_t)offset;
        offset += rela_data_count * sizeof(elf64_rela);
        offset = align_up(offset, 8);
    }

    size_t off_shdrs = offset;
    offset += total_sh * shdr_size;

    /* open file and write */
    FILE *f = fopen(outpath, "wb");
    if (!f) { fprintf(stderr, "failed to open %s: %s\n", outpath, strerror(errno)); exit(1); }

    /* elf header */
    elf64_ehdr eh;
    memset(&eh,0,sizeof(eh));
    eh.e_ident[0] = 0x7f; eh.e_ident[1] = 'e'; eh.e_ident[2] = 'l'; eh.e_ident[3] = 'f';
    eh.e_ident[4] = 2; /* 64-bit */
    eh.e_ident[5] = 1; /* little endian */
    eh.e_ident[6] = 1; /* version */
    eh.e_type = 1; /* relocatable */
    eh.e_machine = 0x3e; /* x86-64 */
    eh.e_version = 1;
    eh.e_entry = 0;
    eh.e_phoff = 0;
    eh.e_shoff = off_shdrs;
    eh.e_ehsize = sizeof(eh);
    eh.e_shentsize = shdr_size;
    eh.e_shnum = total_sh;
    eh.e_shstrndx = 4; /* index of shstrtab: null(0), .text(1), .data(2), .bss(3), .shstrtab(4) ... */
    fwrite(&eh, sizeof(eh), 1, f);

    /* write section data */
    if (sects[sec_text].buf.len) fwrite(sects[sec_text].buf.data, 1, sects[sec_text].buf.len, f);
    /* pad to 8 */
    size_t cur = ftell(f);
    while (cur % 8) { fputc(0,f); cur++; }
    if (sects[sec_data].buf.len) fwrite(sects[sec_data].buf.data, 1, sects[sec_data].buf.len, f);
    cur = ftell(f);
    while (cur % 8) { fputc(0,f); cur++; }
    /* bss has no data */

    /* shstrtab */
    fwrite(shstr.data, 1, shstr.len, f);
    cur = ftell(f);
    while (cur % 8) { fputc(0,f); cur++; }

    /* symtab */
    fwrite(symtab_buf.data, 1, symtab_buf.len, f);
    cur = ftell(f);
    while (cur % 8) { fputc(0,f); cur++; }

    /* strtab */
    fwrite(strtab.data, 1, strtab.len, f);
    cur = ftell(f);
    while (cur % 8) { fputc(0,f); cur++; }

    /* rela.text */
    if (has_rela_text) {
        /* write reloc entries for text */
        for (reloc *r = sects[sec_text].relocs; r; r = r->next) {
            elf64_rela ra;
            ra.r_offset = (uint32_t)r->offset;
            ra.r_info = (uint32_t)r->type;
            ra.r_addend = (int32_t)r->addend;
            fwrite(&ra, sizeof(ra), 1, f);
        }
        cur = ftell(f);
        while (cur % 8) { fputc(0,f); cur++; }
    }

    if (has_rela_data) {
        for (reloc *r = sects[sec_data].relocs; r; r = r->next) {
            elf64_rela ra;
            ra.r_offset = (uint32_t)r->offset;
            ra.r_info = (uint32_t)r->type;
            ra.r_addend = (int32_t)r->addend;
            fwrite(&ra, sizeof(ra), 1, f);
        }
        cur = ftell(f);
        while (cur % 8) { fputc(0,f); cur++; }
    }

    /* section headers */
    /* null header */
    elf64_shdr sh0; memset(&sh0,0,sizeof(sh0)); fwrite(&sh0,sizeof(sh0),1,f);

    /* .text (index 1) */
    elf64_shdr sh;
    memset(&sh,0,sizeof(sh));
    sh.sh_name = off_text_name;
    sh.sh_type = SHT_PROGBITS;
    sh.sh_flags = SHF_ALLOC | SHF_EXECINSTR;
    sh.sh_addr = 0;
    sh.sh_offset = off_text;
    sh.sh_size = sects[sec_text].buf.len;
    sh.sh_link = 0;
    sh.sh_info = 0;
    sh.sh_addralign = 16;
    sh.sh_entsize = 0;
    fwrite(&sh,sizeof(sh),1,f);

    /* .data (index 2) */
    memset(&sh,0,sizeof(sh));
    sh.sh_name = off_data_name;
    sh.sh_type = SHT_PROGBITS;
    sh.sh_flags = SHF_ALLOC | SHF_WRITE;
    sh.sh_offset = off_data;
    sh.sh_size = sects[sec_data].buf.len;
    sh.sh_addralign = 8;
    fwrite(&sh,sizeof(sh),1,f);

    /* .bss (index 3) */
    memset(&sh,0,sizeof(sh));
    sh.sh_name = off_bss_name;
    sh.sh_type = SHT_NOBITS;
    sh.sh_flags = SHF_ALLOC | SHF_WRITE;
    sh.sh_offset = off_bss;
    sh.sh_size = sects[sec_bss].buf.len;
    sh.sh_addralign = 8;
    fwrite(&sh,sizeof(sh),1,f);

    /* .shstrtab (index 4) */
    memset(&sh,0,sizeof(sh));
    sh.sh_name = off_shstr;
    sh.sh_type = SHT_STRTAB;
    sh.sh_offset = off_shstr;
    sh.sh_size = shstr.len;
    sh.sh_addralign = 1;
    fwrite(&sh,sizeof(sh),1,f);

    /* .symtab (index 5) */
    memset(&sh,0,sizeof(sh));
    sh.sh_name = off_symtab_name;
    sh.sh_type = SHT_SYMTAB;
    sh.sh_offset = off_symtab;
    sh.sh_size = symtab_buf.len;
    sh.sh_link = 6; /* index of strtab */
    sh.sh_info = 1; /* index of first non-local symbol */
    sh.sh_entsize = sizeof(elf64_sym);
    sh.sh_addralign = 8;
    fwrite(&sh,sizeof(sh),1,f);

    /* .strtab (index 6) */
    memset(&sh,0,sizeof(sh));
    sh.sh_name = off_strtab_name;
    sh.sh_type = SHT_STRTAB;
    sh.sh_offset = off_strtab;
    sh.sh_size = strtab.len;
    sh.sh_addralign = 1;
    fwrite(&sh,sizeof(sh),1,f);

    /* .rela.text (index 7 if present) */
    if (has_rela_text) {
        memset(&sh,0,sizeof(sh));
        sh.sh_name = off_rela_text;
        sh.sh_type = SHT_RELA;
        sh.sh_offset = off_rela_text;
        sh.sh_size = rela_text_count * sizeof(elf64_rela);
        sh.sh_link = 5; /* index of .symtab */
        sh.sh_info = 1; /* index of section being relocated (.text) */
        sh.sh_addralign = 8;
        fwrite(&sh,sizeof(sh),1,f);
    }

    /* .rela.data (index 8 if present) */
    if (has_rela_data) {
        memset(&sh,0,sizeof(sh));
        sh.sh_name = off_rela_data;
        sh.sh_type = SHT_RELA;
        sh.sh_offset = off_rela_data;
        sh.sh_size = rela_data_count * sizeof(elf64_rela);
        sh.sh_link = 5; /* index of .symtab */
        sh.sh_info = 2; /* index of section being relocated (.data) */
        sh.sh_addralign = 8;
        fwrite(&sh,sizeof(sh),1,f);
    }

    fclose(f);

    buf_free(&shstr);
    buf_free(&strtab);
    buf_free(&symtab_buf);
}

/* ---------------------------
   utility: free ast and symbols
   --------------------------- */
static void free_nodes(node *n) {
    while (n) {
        node *nx = n->next;
        if (n->dir) free(n->dir);
        if (n->dir_arg) free(n->dir_arg);
        if (n->label) free(n->label);
        if (n->mnemonic) free(n->mnemonic);
        for (int i = 0; i < n->opcnt; ++i) {
            if (n->ops[i].reg) free(n->ops[i].reg);
            if (n->ops[i].sym) free(n->ops[i].sym);
        }
        free(n);
        n = nx;
    }
}
static void free_symtab() {
    while (symtab) {
        sym *s = symtab->next;
        free(symtab->name);
        free(symtab);
        symtab = s;
    }
}
static void free_relocs(section *sec) {
    reloc *r = sec->relocs;
    while (r) {
        reloc *nx = r->next;
        free(r->sym);
        free(r);
        r = nx;
    }
}

/* ---------------------------
   main
   --------------------------- */
int main(int argc, char **argv) {
    if (argc < 3) {
        fprintf(stderr, "usage: %s input.s out.o\n", argv[0]);
        return 1;
    }
    const char *inpath = argv[1];
    const char *outpath = argv[2];

    FILE *f = fopen(inpath, "rb");
    if (!f) { fprintf(stderr, "failed to open %s: %s\n", inpath, strerror(errno)); return 1; }
    fseek(f, 0, SEEK_END);
    long sz = ftell(f);
    fseek(f, 0, SEEK_SET);
    char *src = malloc(sz + 1);
    if (!src) { fclose(f); fprintf(stderr, "out of memory\n"); return 1; }
    fread(src, 1, sz, f);
    src[sz] = 0;
    fclose(f);

    parser p;
    parser_init(&p, src);
    node *nodes = parse_all(&p);

    first_pass(nodes);
    second_pass(nodes);

    write_elf(outpath);

    /* cleanup */
    free_nodes(nodes);
    free_symtab();
    free_relocs(&sects[sec_text]);
    free_relocs(&sects[sec_data]);
    buf_free(&sects[sec_text].buf);
    buf_free(&sects[sec_data].buf);
    buf_free(&sects[sec_bss].buf);
    free(src);

    return 0;
}
