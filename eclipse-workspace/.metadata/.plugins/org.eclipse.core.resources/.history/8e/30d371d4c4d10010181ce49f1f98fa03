// -------------------------
// memory access
// -------------------------
static inline uint8_t *get_memory_ptr(uint64_t paddr) {
    if (paddr >= ram_size) {
        // simple out-of-bounds check
        trace_printf("fatal: memory access out of bounds at 0x%" prix64 "\n", paddr);
        exit(1);
    }
    // simple linear address mapping (no paging support yet)
    return ram_mem + paddr;
}

static inline uint8_t read_mem8(uint64_t paddr) {
    return *get_memory_ptr(paddr);
}

static inline uint16_t read_mem16(uint64_t paddr) {
    uint16_t v;
    memcpy(&v, get_memory_ptr(paddr), 2);
    return v;
}

static inline uint32_t read_mem32(uint64_t paddr) {
    uint32_t v;
    memcpy(&v, get_memory_ptr(paddr), 4);
    return v;
}

static inline uint64_t read_mem64(uint64_t paddr) {
    uint64_t v;
    memcpy(&v, get_memory_ptr(paddr), 8);
    return v;
}

static inline void write_mem8(uint64_t paddr, uint8_t v) {
    *get_memory_ptr(paddr) = v;
}

static inline void write_mem16(uint64_t paddr, uint16_t v) {
    memcpy(get_memory_ptr(paddr), &v, 2);
}

static inline void write_mem32(uint64_t paddr, uint32_t v) {
    memcpy(get_memory_ptr(paddr), &v, 4);
}

static inline void write_mem64(uint64_t paddr, uint64_t v) {
    memcpy(get_memory_ptr(paddr), &v, 8);
}

// -------------------------
// instruction fetch
// -------------------------
static uint64_t fetch_pc;
static uint64_t fetch_rip;

static inline uint8_t fetch_byte(void) {
    uint8_t byte = read_mem8(fetch_pc);
    fetch_pc++;
    return byte;
}

static inline uint32_t fetch_imm32(void) {
    uint32_t imm;
    memcpy(&imm, get_memory_ptr(fetch_pc), 4);
    fetch_pc += 4;
    return imm;
}

static inline uint64_t fetch_imm64(void) {
    uint64_t imm;
    memcpy(&imm, get_memory_ptr(fetch_pc), 8);
    fetch_pc += 8;
    return imm;
}

// -------------------------
// flag manipulation and helpers
// -------------------------
static inline void set_flag(uint64_t flag, int value) {
    if (value) {
        cpu.rflags |= flag;
    } else {
        cpu.rflags &= ~flag;
    }
}

static inline int get_flag(uint64_t flag) {
    return (cpu.rflags & flag) != 0;
}

// update flags (cf, zf, sf, of, pf) for a 64-bit result
static inline void update_flags_arith(uint64_t old_a, uint64_t old_b, uint66_t result, int size) {
    uint64_t a = old_a;
    uint64_t b = old_b;

    set_flag(flag_cf, (result >> size) & 1);
    set_flag(flag_zf, (result & ( (1ULL << size) - 1 ) ) == 0);
    set_flag(flag_sf, (result >> (size - 1)) & 1);

    // parity flag (pf): even number of set bits in the low 8 bits
    uint8_t low_byte = result & 0xff;
    int parity = 0;
    for (int i = 0; i < 8; ++i) {
        if ((low_byte >> i) & 1) {
            parity = !parity;
        }
    }
    set_flag(flag_pf, !parity);

    // overflow flag (of) for addition: (a & b & ~r) | (~a & ~b & r)
    // where a, b, r are the most significant bits of the operands and result.
    if (size == 64) {
        uint64_t sbit = 1ULL << 63;
        int of = ((a & sbit) == (b & sbit)) && ((a & sbit) != (result & sbit));
        set_flag(flag_of, of);
    } else if (size == 32) {
        uint32_t sa = a; uint32_t sb = b; uint32_t sr = result;
        uint32_t sbit = 1U << 31;
        int of = ((sa & sbit) == (sb & sbit)) && ((sa & sbit) != (sr & sbit));
        set_flag(flag_of, of);
    } else {
        set_flag(flag_of, 0); // simpler for smaller sizes
    }
}

// -------------------------
// breakpoint support
// -------------------------
#if enable_soft_breakpoints
static uint64_t breakpoints[max_soft_bp];
static int bp_count = 0;

static int bp_add(uint64_t addr) {
    if (bp_count >= max_soft_bp) return -1;
    for (int i = 0; i < bp_count; i++) {
        if (breakpoints[i] == addr) return 0; // already set
    }
    breakpoints[bp_count++] = addr;
    return 0;
}

static int bp_check(uint64_t addr) {
    for (int i = 0; i < bp_count; i++) {
        if (breakpoints[i] == addr) return 1;
    }
    return 0;
}
#else
#define bp_add(a) 0
#define bp_check(a) 0
#endif

