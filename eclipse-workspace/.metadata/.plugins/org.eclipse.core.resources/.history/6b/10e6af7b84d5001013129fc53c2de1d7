/* -------------------------
   Parser implementation
   ------------------------- */

bool is_function() {
  Token *tok = token;
  basetype();
  bool is_func = consume_ident() && consume("(");
  token = tok;
  return is_func;
}

Program *program() {
  Function head = {};
  Function *cur = &head;
  globals = NULL;

  while (!at_eof()) {
    if (is_function()) {
      cur->next = function();
      cur = cur->next;
    } else {
      global_var();
    }
  }

  Program *prog = calloc(1, sizeof(Program));
  prog->globals = globals;
  prog->fns = head.next;
  return prog;
}

bool is_type_name(Token *tok) {
  return peek("char") || peek("int") || peek("struct") || find_typedef(token);
}

Type *basetype() {
  if (!is_type_name(token)) {
    error_tok(token, "unknown type name");
  }

  Type *type;
  if (consume("char")) {
    type = char_type;
  } else if (consume("int")) {
    type = int_type;
  } else if (consume("struct")) {
    type = struct_decl();
  } else {
    type = find_var(consume_ident())->type_def;
  }

  while (consume("*")) {
    type = pointer_to(type);
  }

  return type;
}

void push_tag_scope(Token *tok, Type *type) {
  TagScope *sc = calloc(1, sizeof(TagScope));
  sc->next = tag_scope;
  sc->name = strndup(tok->str, tok->len);
  sc->type = type;
  tag_scope = sc;
}

Type *struct_decl() {
  Token *tag = consume_ident();
  if (tag && !peek("{")) {
    TagScope *sc = find_tag(tag);
    if (!sc) error_tok(tag, "unknown struct type");
    return sc->type;
  }

  expect("{");
  Member head = {};
  Member *cur = &head;
  while (!consume("}")) {
    cur->next = struct_member();
    cur = cur->next;
  }

  Type *type = calloc(1, sizeof(Type));
  type->kind = TYPE_STRUCT;
  type->members = head.next;

  int offset = 0;
  for (Member *m = type->members; m; m = m->next) {
    offset = align_to(offset, m->type->align);
    m->offset = offset;
    offset += m->type->size;
    if (type->align < m->type->align) type->align = m->type->align;
  }
  type->size = align_to(offset, type->align);

  if (tag) push_tag_scope(tag, type);
  return type;
}

Type *read_type_suffix(Type *base) {
  if (!consume("[")) return base;
  int size = expect_number();
  expect("]");
  base = read_type_suffix(base);
  return array_of(base, size);
}

Member *struct_member() {
  Member *m = calloc(1, sizeof(Member));
  m->type = basetype();
  m->name = expect_ident();
  m->type = read_type_suffix(m->type);
  expect(";");
  return m;
}

void global_var() {
  Type *type = basetype();
  char *name = expect_ident();
  type = read_type_suffix(type);
  expect(";");
  new_global_var(name, type);
}

VarList *read_func_param() {
  Type *type = basetype();
  char *name = expect_ident();
  type = read_type_suffix(type);
  return new_var_list(new_local_var(name, type));
}

VarList *read_func_params() {
  if (consume(")")) return NULL;
  VarList *head = read_func_param();
  VarList *cur = head;
  while (!consume(")")) {
    expect(",");
    cur->next = read_func_param();
    cur = cur->next;
  }
  return head;
}

Function *function() {
  locals = NULL;
  basetype();
  char *name = expect_ident();
  expect("(");
  Scope *sc = enter_scope();
  VarList *params = read_func_params();
  expect("{");
  Node head = {};
  Node *cur = &head;
  while (!consume("}")) {
    cur->next = stmt();
    cur = cur->next;
  }
  leave_scope(sc);
  Function *fn = calloc(1, sizeof(Function));
  fn->name = name;
  fn->params = params;
  fn->node = head.next;
  fn->locals = locals;
  return fn;
}

Node *read_expr_stmt() {
  Token *tok = token;
  return new_unary(ND_EXPR_STMT, expr(), tok);
}

Node *stmt() {
  Node *node = stmt_inner();
  add_type(node);
  return node;
}

Node *stmt_inner() {
  Token *tok;
  if ((tok = consume("if"))) {
    Node *node = new_node(ND_IF, tok);
    expect("(");
    node->cond = expr();
    expect(")");
    node->cons = stmt();
    if (consume("else")) node->alt = stmt();
    return node;
  }

  if ((tok = consume("while"))) {
    Node *node = new_node(ND_WHILE, tok);
    expect("(");
    node->cond = expr();
    expect(")");
    node->cons = stmt();
    return node;
  }

  if ((tok = consume("for"))) {
    Node *node = new_node(ND_FOR, tok);
    expect("(");
    if (!consume(";")) { node->init = read_expr_stmt(); expect(";"); }
    if (!consume(";")) { node->cond = expr(); expect(";"); }
    if (!consume(")")) { node->updt = read_expr_stmt(); expect(")"); }
    node->cons = stmt();
    return node;
  }

  if ((tok = consume("return"))) {
    Node *node = new_unary(ND_RETURN, expr(), tok);
    expect(";");
    return node;
  }

  if ((tok = consume("{"))) {
    Node head = {};
    Node *cur = &head;
    Scope *sc = enter_scope();
    while (!consume("}")) {
      cur->next = stmt();
      cur = cur->next;
    }
    leave_scope(sc);
    Node *node = new_node(ND_BLOCK, tok);
    node->body = head.next;
    return node;
  }

  if ((tok = consume("typedef"))) {
    Type *type = basetype();
    char *name = expect_ident();
    type = read_type_suffix(type);
    expect(";");
    push_scope(name)->type_def = type;
    return new_node(ND_NULL, tok);
  }

  if (is_type_name(token)) return declaration();

  Node *node = read_expr_stmt();
  expect(";");
  return node;
}

Node *declaration() {
  Token *tok = token;
  Type *type = basetype();
  if (consume(";")) return new_node(ND_NULL, tok);
  char *name = expect_ident();
  type = read_type_suffix(type);
  Var *var = new_local_var(name, type);
  if (consume(";")) return new_node(ND_NULL, tok);
  expect("=");
  Node *lhs = new_var_node(var, tok);
  Node *rhs = expr();
  expect(";");
  Node *node = new_binary(ND_ASSIGN, lhs, rhs, tok);
  return new_unary(ND_EXPR_STMT, node, tok);
}

Node *expr() { return assign(); }

Node *assign() {
  Node *node = equality();
  Token *tok = consume("=");
  if (tok) node = new_binary(ND_ASSIGN, node, assign(), tok);
  return node;
}

Node *equality() {
  Node *node = relational();
  Token *tok;
  for (;;) {
    if ((tok = consume("=="))) node = new_binary(ND_EQ, node, relational(), tok);
    else if ((tok = consume("!="))) node = new_binary(ND_NE, node, relational(), tok);
    else return node;
  }
}

Node *relational() {
  Node *node = add();
  Token *tok;
  for (;;) {
    if ((tok = consume("<"))) node = new_binary(ND_LT, node, add(), tok);
    else if ((tok = consume("<="))) node = new_binary(ND_LE, node, add(), tok);
    else if ((tok = consume(">"))) node = new_binary(ND_LT, add(), node, tok);
    else if ((tok = consume(">="))) node = new_binary(ND_LE, add(), node, tok);
    else return node;
  }
}

Node *new_add(Node *lhs, Node *rhs, Token *tok) {
  add_type(lhs);
  add_type(rhs);
  if (is_integer(lhs->type) && is_integer(rhs->type)) return new_binary(ND_ADD, lhs, rhs, tok);
  else if (lhs->type->base && is_integer(rhs->type)) return new_binary(ND_PTR_ADD, lhs, rhs, tok);
  else if (is_integer(lhs->type) && rhs->type->base) return new_binary(ND_PTR_ADD, rhs, lhs, tok);
  error_tok(tok, "invalid operands");
  return NULL;
}

Node *new_sub(Node *lhs, Node *rhs, Token *tok) {
  add_type(lhs);
  add_type(rhs);
  if (is_integer(lhs->type) && is_integer(rhs->type)) return new_binary(ND_SUB, lhs, rhs, tok);
  else if (lhs->type->base && is_integer(rhs->type)) return new_binary(ND_PTR_SUB, lhs, rhs, tok);
  else if (lhs->type->base && rhs->type->base) return new_binary(ND_PTR_DIFF, lhs, rhs, tok);
  error_tok(tok, "invalid operands");
  return NULL;
}

Node *add() {
  Node *node = mul();
  Token *tok;
  for (;;) {
    if ((tok = consume("+"))) node = new_add(node, mul(), tok);
    else if ((tok = consume("-"))) node = new_sub(node, mul(), tok);
    else return node;
  }
}

Node *mul() {
  Node *node = unary();
  Token *tok;
  for (;;) {
    if ((tok = consume("*"))) node = new_binary(ND_MUL, node, unary(), tok);
    else if ((tok = consume("/"))) node = new_binary(ND_DIV, node, unary(), tok);
    else return node;
  }
}

Node *unary() {
  Token *tok;
  if ((tok = consume("+"))) return unary();
  else if ((tok = consume("-"))) return new_binary(ND_SUB, new_num(0, tok), unary(), tok);
  else if ((tok = consume("&"))) return new_unary(ND_ADDR, unary(), tok);
  else if ((tok = consume("*"))) return new_unary(ND_DEREF, unary(), tok);
  else if ((tok = consume("sizeof"))) { Node *node = unary(); add_type(node); return new_num(node->type->size, tok); }
  else return postfix();
}

Member *find_member(Type *type, char *name) {
  for (Member *m = type->members; m; m = m->next) if (!strcmp(m->name, name)) return m;
  return NULL;
}

Node *struct_ref(Node *lhs) {
  add_type(lhs);
  if (lhs->type->kind != TYPE_STRUCT) error_tok(lhs->tok, "not a struct");
  Token *tok = token;
  Member *m = find_member(lhs->type, expect_ident());
  if (!m) error_tok(tok, "no such member");
  Node *node = new_unary(ND_MEMBER, lhs, tok);
  node->member = m;
  return node;
}

Node *postfix() {
  Node *node = primary();
  Token *tok;
  for (;;) {
    if ((tok = consume("["))) {
      Node *idx = new_add(node, expr(), tok);
      expect("]");
      node = new_unary(ND_DEREF, idx, tok);
      continue;
    }
    if ((tok = consume("."))) { node = struct_ref(node); continue; }
    if ((tok = consume("->"))) { node = struct_ref(new_unary(ND_DEREF, node, tok)); continue; }
    return node;
  }
}

/* -------------------------
   Label generator
   ------------------------- */

char *new_label() {
  static int cnt = 0;
  char buf[32];
  snprintf(buf, sizeof(buf), ".L%d", cnt++);
  return strndup(buf, (int)strlen(buf));
}

/* -------------------------
   Parser: primary, stmt_expr, func_args
   ------------------------- */

Node *func_args() {
  if (consume(")")) return NULL;
  Node *head = NULL;
  Node *cur = NULL;
  while (1) {
    Node *arg = expr();
    if (!head) { head = arg; cur = arg; } else { cur->next = arg; cur = cur->next; }
    if (consume(")")) break;
    expect(",");
  }
  return head;
}

Node *stmt_expr() {
  Token *tok = token;
  expect("{");
  Node head = {};
  Node *cur = &head;
  while (!peek("}")) { cur->next = stmt(); cur = cur->next; }
  expect("}");
  Node *node = new_node(ND_STMT_EXPR, tok);
  node->body = head.next;
  return node;
}

Node *primary() {
  Token *tok;
  if (consume("(") && peek("{")) {
    token = token; // already consumed "("
    Node *n = stmt_expr();
    expect(")");
    return n;
  }
  if (consume("(")) { Node *node = expr(); expect(")"); return node; }
  if (token->kind == TK_IDENT) {
    tok = token;
    char *name = strndup(tok->str, tok->len);
    token = token->next;
    if (consume("(")) {
      Node *node = new_node(ND_CALL, tok);
      node->func_name = name;
      node->args = func_args();
      return node;
    }
    VarScope *sc = find_var(tok);
    if (!sc || !sc->var) error_tok(tok, "undefined variable");
    return new_var_node(sc->var, tok);
  }
  if (token->kind == TK_STR) {
    Token *t = token;
    token = token->next;
    Node *node = new_node(ND_NUM, t);
    char *label = new_label();
    Var *g = new_global_var(label, array_of(char_type, t->cont_len));
    g->contents = t->contents;
    g->cont_len = t->cont_len;
    node->val = 0;
    node->type = g->type;
    Node *addr = new_unary(ND_ADDR, new_var_node(g, t), t);
    return addr;
  }
  if (token->kind == TK_NUM) {
    Node *node = new_num(token->val, token);
    token = token->next;
    return node;
  }
  error_tok(token, "expected an expression");
  return NULL;
}

/* -------------------------
   Code generation
   ------------------------- */

static void gen(Node *node);

static void push_rax() { printf("  push rax\n"); }
static void pop_rdi() { printf("  pop rdi\n"); }
static void pop_rax() { printf("  pop rax\n"); }

static void gen_lval(Node *node);

static void gen_addr(Node *node) {
  if (node->kind == ND_VAR) {
    Var *v = node->var;
    if (v->is_local) { printf("  lea rax, [rbp-%d]\n", v->offset); push_rax(); return; }
    else { printf("  lea rax, %s[rip]\n", v->name); push_rax(); return; }
  }
  if (node->kind == ND_DEREF) { gen(node->lhs); return; }
  if (node->kind == ND_MEMBER) {
    gen_addr(node->lhs);
    pop_rax();
    printf("  add rax, %d\n", node->member->offset);
    push_rax();
    return;
  }
  error_tok(node->tok, "not an lvalue");
}

static void gen_lval(Node *node) {
  if (node->kind == ND_DEREF) { gen(node->lhs); return; }
  if (node->kind == ND_VAR) {
    Var *v = node->var;
    if (v->is_local) { printf("  lea rax, [rbp-%d]\n", v->offset); push_rax(); return; }
    else { printf("  lea rax, %s[rip]\n", v->name); push_rax(); return; }
  }
  if (node->kind == ND_MEMBER) {
    gen_addr(node->lhs);
    pop_rax();
    printf("  add rax, %d\n", node->member->offset);
    push_rax();
    return;
  }
  error_tok(node->tok, "not an lvalue");
}

static void gen(Node *node) {
  if (!node) return;
  switch (node->kind) {
  case ND_NUM:
    printf("  mov rax, %ld\n", node->val);
    push_rax();
    return;
  case ND_NULL:
    printf("  mov rax, 0\n");
    push_rax();
    return;
  case ND_VAR:
    gen_lval(node);
    pop_rax();
    printf("  mov rax, [rax]\n");
    push_rax();
    return;
  case ND_ADDR:
    gen_addr(node->lhs);
    return;
  case ND_DEREF:
    gen(node->lhs);
    pop_rax();
    printf("  mov rax, [rax]\n");
    push_rax();
    return;
  case ND_MEMBER:
    gen_addr(node->lhs);
    pop_rax();
    printf("  mov rax, [rax]\n");
    push_rax();
    return;
  case ND_ASSIGN:
    gen_lval(node->lhs);
    gen(node->rhs);
    pop_rax(); // rhs value
    pop_rdi(); // lval address
    printf("  mov [rdi], rax\n");
    push_rax();
    return;
  case ND_RETURN:
    gen(node->lhs);
    pop_rax();
    printf("  mov rsp, rbp\n");
    printf("  pop rbp\n");
    printf("  ret\n");
    return;
  case ND_IF: {
    char *else_label = new_label();
    char *end_label = new_label();
    gen(node->cond);
    pop_rax();
    printf("  cmp rax, 0\n");
    if (node->alt) {
      printf("  je %s\n", else_label);
      gen(node->cons);
      printf("  jmp %s\n", end_label);
      printf("%s:\n", else_label);
      gen(node->alt);
      printf("%s:\n", end_label);
    } else {
      printf("  je %s\n", end_label);
      gen(node->cons);
      printf("%s:\n", end_label);
    }
    return;
  }
  case ND_WHILE: {
    char *begin = new_label();
    char *end = new_label();
    printf("%s:\n", begin);
    gen(node->cond);
    pop_rax();
    printf("  cmp rax, 0\n");
    printf("  je %s\n", end);
    gen(node->cons);
    printf("  jmp %s\n", begin);
    printf("%s:\n", end);
    return;
  }
  case ND_FOR: {
    char *begin = new_label();
    char *end = new_label();
    if (node->init) gen(node->init);
    printf("%s:\n", begin);
    if (node->cond) { gen(node->cond); pop_rax(); printf("  cmp rax, 0\n"); printf("  je %s\n", end); }
    gen(node->cons);
    if (node->updt) gen(node->updt);
    printf("  jmp %s\n", begin);
    printf("%s:\n", end);
    return;
  }
  case ND_BLOCK: {
    for (Node *n = node->body; n; n = n->next) {
      gen(n);
      if (n->kind != ND_RETURN) pop_rax();
    }
    printf("  mov rax, 0\n");
    push_rax();
    return;
  }
  case ND_EXPR_STMT:
    gen(node->lhs);
    return;
  case ND_STMT_EXPR: {
    for (Node *n = node->body; n; n = n->next) {
      gen(n);
      if (n->next) pop_rax();
    }
    return;
  }
  case ND_CALL: {
    const char *argregs[] = {"rdi", "rsi", "rdx", "rcx", "r8", "r9"};
    int nargs = 0;
    for (Node *a = node->args; a; a = a->next) nargs++;
    Node *args[16];
    int i = 0;
    for (Node *a = node->args; a; a = a->next) args[i++] = a;
    for (int j = i - 1; j >= 0; j--) gen(args[j]);
    for (int j = 0; j < i && j < 6; j++) { pop_rax(); printf("  mov %s, rax\n", argregs[j]); }
    printf("  mov rax, 0\n");
    printf("  call %s\n", node->func_name);
    push_rax();
    return;
  }
  case ND_ADD:
  case ND_SUB:
  case ND_MUL:
  case ND_DIV:
  case ND_EQ:
  case ND_NE:
  case ND_LT:
  case ND_LE:
  case ND_PTR_ADD:
  case ND_PTR_SUB:
  case ND_PTR_DIFF: {
    gen(node->lhs);
    gen(node->rhs);
    pop_rax(); // rhs
    pop_rdi(); // lhs
    if (node->kind == ND_ADD || node->kind == ND_PTR_ADD) {
      if (node->kind == ND_PTR_ADD) {
        int sz = node->rhs->type->size;
        if (sz != 1) printf("  imul rax, %d\n", sz);
      }
      printf("  add rax, rdi\n");
      push_rax();
      return;
    }
    if (node->kind == ND_SUB || node->kind == ND_PTR_SUB) {
      if (node->kind == ND_PTR_SUB && node->rhs->type->kind != TYPE_ARRAY) {
        int sz = node->rhs->type->size;
        if (sz != 1) printf("  imul rax, %d\n", sz);
      }
      printf("  sub rdi, rax\n");
      printf("  mov rax, rdi\n");
      push_rax();
      return;
    }
    if (node->kind == ND_PTR_DIFF) {
      printf("  sub rdi, rax\n");
      int sz = node->lhs->type->base->size;
      if (sz != 1) printf("  cqo\n  mov rdx, %d\n  idiv rdx\n", sz);
      push_rax();
      return;
    }
    if (node->kind == ND_MUL) { printf("  imul rax, rdi\n"); push_rax(); return; }
    if (node->kind == ND_DIV) {
      printf("  mov rdx, 0\n");
      printf("  mov rbx, rdi\n");
      printf("  mov rdi, rax\n");
      printf("  mov rax, rbx\n");
      printf("  cqo\n");
      printf("  idiv rdi\n");
      printf("  mov rax, rax\n");
      push_rax();
      return;
    }
    if (node->kind == ND_EQ || node->kind == ND_NE || node->kind == ND_LT || node->kind == ND_LE) {
      printf("  cmp rdi, rax\n");
      if (node->kind == ND_EQ) printf("  sete al\n");
      if (node->kind == ND_NE) printf("  setne al\n");
      if (node->kind == ND_LT) printf("  setl al\n");
      if (node->kind == ND_LE) printf("  setle al\n");
      printf("  movzb rax, al\n");
      push_rax();
      return;
    }
    return;
  }
  default:
    error_tok(node->tok, "codegen: unsupported node kind");
  }
}

/* -------------------------
   Top-level codegen: emit assembly
   ------------------------- */

static int assign_lvar_offsets(Function *fn) {
  int offset = 0;
  for (VarList *vl = fn->locals; vl; vl = vl->next) {
    Var *v = vl->var;
    offset = align_to(offset + v->type->size, v->type->align);
    v->offset = offset;
  }
  if (offset % 16) offset = align_to(offset, 16);
  return offset;
}

void codegen(Program *prog) {
  printf("  .intel_syntax noprefix\n");
  printf("  .data\n");
  for (VarList *vl = prog->globals; vl; vl = vl->next) {
    Var *g = vl->var;
    printf("%s:\n", g->name);
    if (g->contents) {
      // escape quotes in contents for .string
      printf("  .string \"");
      for (char *p = g->contents; *p; p++) {
        if (*p == '"' || *p == '\\') putchar('\\');
        putchar(*p);
      }
      printf("\"\n");
    } else {
      int n = g->type->size;
      if (n > 0) printf("  .zero %d\n", n);
    }
  }

  printf("  .text\n");
  for (Function *fn = prog->fns; fn; fn = fn->next) {
    printf("  .global %s\n", fn->name);
    printf("%s:\n", fn->name);
    printf("  push rbp\n");
    printf("  mov rbp, rsp\n");
    int stack_size = assign_lvar_offsets(fn);
    if (stack_size > 0) printf("  sub rsp, %d\n", stack_size);
    const char *argregs[] = {"rdi", "rsi", "rdx", "rcx", "r8", "r9"};
    int i = 0;
    for (VarList *vl = fn->params; vl; vl = vl->next) {
      Var *v = vl->var;
      if (i < 6) {
        printf("  mov rax, %s\n", argregs[i++]);
        printf("  mov [rbp-%d], rax\n", v->offset);
      } else {
        i++;
      }
    }
    for (Node *n = fn->node; n; n = n->next) {
      gen(n);
      if (n->kind != ND_RETURN) printf("  pop rax\n");
    }
    printf("  mov rsp, rbp\n");
    printf("  pop rbp\n");
    printf("  ret\n");
  }
}

/* -------------------------
   Main: read file, tokenize, parse, codegen
   ------------------------- */

static char *read_file(char *path) {
  FILE *fp = fopen(path, "rb");
  if (!fp) { fprintf(stderr, "cannot open %s: %s\n", path, strerror(errno)); exit(1); }
  if (fseek(fp, 0, SEEK_END) != 0) { fclose(fp); perror("fseek"); exit(1); }
  long sz = ftell(fp);
  if (sz < 0) { fclose(fp); perror("ftell"); exit(1); }
  rewind(fp);
  char *buf = malloc((size_t)sz + 1);
  if (!buf) { fclose(fp); perror("malloc"); exit(1); }
  if (fread(buf, 1, (size_t)sz, fp) != (size_t)sz) { fclose(fp); free(buf); perror("fread"); exit(1); }
  buf[sz] = '\0';
  fclose(fp);
  return buf;
}

int main(int argc, char **argv) {
  if (argc != 2) { fprintf(stderr, "Usage: %s <input.c>\n", argv[0]); return 1; }
  filename = argv[1];
  user_input = read_file(filename);
  token = tokenize();
  Program *prog = program();
  codegen(prog);
  return 0;
}
