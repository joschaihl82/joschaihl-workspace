}

/* SSE dispatcher (completed) */

static int try_encode_sse(const char *mnemonic)
{
    if (!strcmp(mnemonic,"movaps")) {
        /* AT&T: src, dst */
        if (nr_operands==2 && (operands[1].flags & O_REG_XMM) && operands[0].kind==OPERAND_MEM) {
            /* mem -> xmm (load): opcode 0F 28 /r */
            encode_sse_rm(0, 0x0F, 0x28, 1, operands[1].reg, 1, operands[0].reg);
            return 0;
        }
        if (nr_operands==2 && (operands[0].flags & O_REG_XMM) && operands[1].kind==OPERAND_MEM) {
            /* xmm -> mem (store): opcode 0F 29 /r */
            encode_sse_rm(0, 0x0F, 0x29, 0, operands[0].reg, 1, operands[1].reg);
            return 0;
        }
        error("unsupported movaps form");
        return -1;
    } else if (!strcmp(mnemonic,"movups")) {
        if (nr_operands==2 && (operands[1].flags & O_REG_XMM) && operands[0].kind==OPERAND_MEM) {
            encode_sse_rm(0, 0x0F, 0x10, 1, operands[1].reg, 1, operands[0].reg);
            return 0;
        }
        if (nr_operands==2 && (operands[0].flags & O_REG_XMM) && operands[1].kind==OPERAND_MEM) {
            encode_sse_rm(0, 0x0F, 0x11, 0, operands[0].reg, 1, operands[1].reg);
            return 0;
        }
        error("unsupported movups form");
        return -1;
    } else if (!strcmp(mnemonic,"addps") || !strcmp(mnemonic,"subps") || !strcmp(mnemonic,"mulps") || !strcmp(mnemonic,"xorps") || !strcmp(mnemonic,"andps") || !strcmp(mnemonic,"orps")) {
        unsigned char opc = 0x58; /* addps */
        if (!strcmp(mnemonic,"subps")) opc = 0x5C;
        else if (!strcmp(mnemonic,"mulps")) opc = 0x59;
        else if (!strcmp(mnemonic,"xorps")) opc = 0x57;
        else if (!strcmp(mnemonic,"andps")) opc = 0x54;
        else if (!strcmp(mnemonic,"orps"))  opc = 0x56;
        if (nr_operands==2) {
            /* AT&T: src, dst */
            if ((operands[1].flags & O_REG_XMM) && operands[0].kind==OPERAND_MEM) {
                /* mem -> xmm */
                encode_sse_rm(0, 0x0F, opc, 1, operands[1].reg, 1, operands[0].reg);
                return 0;
            }
            if ((operands[1].flags & O_REG_XMM) && (operands[0].flags & O_REG_XMM)) {
                /* xmm -> xmm */
                encode_sse_rm(0, 0x0F, opc, 1, operands[1].reg, 0, operands[0].reg);
                return 0;
            }
        }
        error("unsupported SSE form");
        return -1;
    }
    return -1;
}

/* ===== Instruction dispatch & encoding (simplified) ===== */

static void encode_instruction(const char *mnemonic)
{
    /* Try SSE first */
    if (try_encode_sse(mnemonic) == 0) return;

    /* Handle a few mnemonics explicitly */
    if (strcmp(mnemonic,"jmp")==0) {
        if (nr_operands==1) { encode_jmp_rel32(&operands[0]); return; }
    } else if (strcmp(mnemonic,"call")==0) {
        if (nr_operands==1) { encode_call_rel32(&operands[0]); return; }
    } else if (strcmp(mnemonic,"je")==0 || strcmp(mnemonic,"jz")==0) {
        if (nr_operands==1) { encode_jcc_rel32(0x84); return; }
    } else if (strcmp(mnemonic,"jne")==0 || strcmp(mnemonic,"jnz")==0) {
        if (nr_operands==1) { encode_jcc_rel32(0x85); return; }
    } else if (strcmp(mnemonic,"ret")==0) {
        emit_byte(0xC3); return;
    } else if (strcmp(mnemonic,"nop")==0) {
        emit_byte(0x90); return;
    } else if (strcmp(mnemonic,"leave")==0) {
        emit_byte(0xC9); return;
    } else if (strcmp(mnemonic,"syscall")==0) {
        emit_byte(0x0F); emit_byte(0x05); return;
    } else if (strcmp(mnemonic,"pushq")==0) {
        if (nr_operands==1 && operands[0].kind==OPERAND_REG) { encode_push_r64(operands[0].reg); return; }
    } else if (strcmp(mnemonic,"popq")==0) {
        if (nr_operands==1 && operands[0].kind==OPERAND_REG) { encode_pop_r64(operands[0].reg); return; }
    } else if (strcmp(mnemonic,"movq")==0) {
        if (nr_operands==2) {
            /* AT&T: src, dst */
            if (operands[0].kind==OPERAND_REG && operands[1].kind==OPERAND_MEM) {
                encode_mov_reg_to_rm64(operands[0].reg, &operands[1]); return;
            }
            if (operands[0].kind==OPERAND_MEM && operands[1].kind==OPERAND_REG) {
                encode_mov_rm_to_reg64(&operands[0], operands[1].reg); return;
            }
            if (operands[0].kind==OPERAND_IMM && operands[1].kind==OPERAND_REG) {
                /* immediate to reg */
                unsigned imm32 = (unsigned)(operands[0].offset & 0xFFFFFFFFu);
                encode_mov_r64_imm32(operands[1].reg, imm32); return;
            }
        }
        error("encoding for instruction 'movq' not implemented or unsupported operand forms");
        return;
    } else if (strcmp(mnemonic,"addq")==0) {
        if (nr_operands==2) {
            /* AT&T: src, dst (src r/m, dst reg) */
            if (operands[1].kind==OPERAND_REG) {
                encode_reg_rm_op(0x01, &operands[0], operands[1].reg); return;
            }
        }
        error("encoding for instruction 'addq' not implemented or unsupported operand forms");
        return;
    } else if (strcmp(mnemonic,"subq")==0) {
        if (nr_operands==2) {
            if (operands[1].kind==OPERAND_REG) {
                encode_reg_rm_op(0x29, &operands[0], operands[1].reg); return;
            }
        }
        error("encoding for instruction 'subq' not implemented or unsupported operand forms");
        return;
    } else if (strcmp(mnemonic,"cmpq")==0) {
        if (nr_operands==2) {
            if (operands[1].kind==OPERAND_REG) {
                encode_reg_rm_op(0x39, &operands[0], operands[1].reg); return;
            }
        }
        error("encoding for instruction 'cmpq' not implemented or unsupported operand forms");
        return;
    } else if (strcmp(mnemonic,"andq")==0) {
        if (nr_operands==2 && operands[1].kind==OPERAND_REG) {
            encode_reg_rm_op(0x21, &operands[0], operands[1].reg); return;
        }
        error("encoding for instruction 'andq' not implemented or unsupported operand forms");
        return;
    } else if (strcmp(mnemonic,"orq")==0) {
        if (nr_operands==2 && operands[1].kind==OPERAND_REG) {
            encode_reg_rm_op(0x09, &operands[0], operands[1].reg); return;
        }
        error("encoding for instruction 'orq' not implemented or unsupported operand forms");
        return;
    } else if (strcmp(mnemonic,"xorq")==0) {
        if (nr_operands==2 && operands[1].kind==OPERAND_REG) {
            encode_reg_rm_op(0x31, &operands[0], operands[1].reg); return;
        }
        error("encoding for instruction 'xorq' not implemented or unsupported operand forms");
        return;
    } else if (strcmp(mnemonic,"testq")==0) {
        if (nr_operands==2 && operands[0].kind==OPERAND_REG && operands[1].kind==OPERAND_REG) {
            int r = operands[0].reg;
            int s = operands[1].reg;
            int rex_r = (r >> 3) & 1;
            int rex_b = (s >> 3) & 1;
            emit_rex(1, rex_r, 0, rex_b);
            emit_byte(0x85);
            emit_modrm(3, r, s);
            return;
        }
        error("encoding for instruction 'testq' not implemented or unsupported operand forms");
        return;
    }

    error("unknown instruction '%s'", (char*)mnemonic);
}

/* ===== Directive handling: normalize dot-prefixed names ===== */

/* Example pseudo-op table mapping names to functions (simplified) */
struct pseudo_entry {
    const char *name;
    int (*fn)(void);
};

static struct pseudo_entry pseudo_table[] = {
    { "byte", pseudo_byte },
    { "word", pseudo_word },
    { "dword", pseudo_dword },
    { "qword", pseudo_qword },
    { "align", pseudo_align },
    { "skip", pseudo_skip },
    { "fill", pseudo_fill },
    { "ascii", pseudo_ascii },
    { "global", pseudo_global },
    { "text", pseudo_text },
    { "data", pseudo_data },
    { "bss", pseudo_bss },
    { "org", pseudo_org },
    { "bits", pseudo_bits },
    { NULL, NULL }
};

static int handle_directive_name(const char *rawname)
{
    const char *name = rawname;
    if (name[0] == '.') name++;
    for (int i = 0; pseudo_table[i].name; ++i) {
        if (strcmp(name, pseudo_table[i].name) == 0) {
            /* call the pseudo function; number_token/name_token should be set by caller */
            return pseudo_table[i].fn();
        }
    }
    error("unknown directive '%s'", rawname);
    return -1;
}

/* ===== Relocation resolution (simple) ===== */

static void resolve_relocs(void)
{
    for (int i = 0; i < relocs_count; ++i) {
        struct reloc *r = &relocs[i];
        if (!r->sym) continue;
        long target = 0;
        if (r->sym->segment == 1) {
            target = r->sym->offset; /* text symbol */
        } else if (r->sym->segment == 2) {
            /* data placed after text */
            target = text_len + r->sym->offset;
        } else {
            /* bss or unknown: treat as 0 */
            target = 0;
        }
        /* displacement = target - (place + 4) where place is the address of the rel32 field */
        long place = r->pos;
        long disp = target - (place + 4);
        /* write disp little-endian into the buffer where relocation was emitted */
        if (r->section == 1) {
            if (r->pos + 4 <= text_len) {
                unsigned d = (unsigned)disp;
                text_buf[r->pos + 0] = (unsigned char)(d & 0xFF);
                text_buf[r->pos + 1] = (unsigned char)((d >> 8) & 0xFF);
                text_buf[r->pos + 2] = (unsigned char)((d >> 16) & 0xFF);
                text_buf[r->pos + 3] = (unsigned char)((d >> 24) & 0xFF);
            } else {
                error("relocation out of range");
            }
        } else if (r->section == 2) {
            if (r->pos + 4 <= data_len) {
                unsigned d = (unsigned)disp;
                data_buf[r->pos + 0] = (unsigned char)(d & 0xFF);
                data_buf[r->pos + 1] = (unsigned char)((d >> 8) & 0xFF);
                data_buf[r->pos + 2] = (unsigned char)((d >> 16) & 0xFF);
                data_buf[r->pos + 3] = (unsigned char)((d >> 24) & 0xFF);
            } else {
                error("relocation out of range (data)");
            }
        }
    }
}

/* ===== Output helpers ===== */

static void hexdump_section(const char *name, unsigned char *buf, long len)
{
    printf("section %s: %ld bytes\n", name, len);
    for (long i = 0; i < len; i += 16) {
        printf("%08lx  ", (unsigned long)i);
        for (long j = 0; j < 16; ++j) {
            if (i + j < len) printf("%02x ", buf[i+j]);
            else printf("   ");
        }
        printf(" ");
        for (long j = 0; j < 16; ++j) {
            if (i + j < len) {
                unsigned char c = buf[i+j];
                printf("%c", (c >= 32 && c < 127) ? c : '.');
            }
        }
        printf("\n");
    }
}

/* ===== Main assembler loop ===== */

/* Assemble a single line where input_pos points to the start of the line */
static void process_line(void)
{
    next_token();
    if (tkind == T_EOF) return;

    /* Label? ident ':' */
    if (tkind == T_IDENT) {
        char saved_ident[256];
        strcpy(saved_ident, tok_text);
        next_token();
        if (tkind == T_COLON) {
            /* define label */
            struct name *n = lookup_name(saved_ident, (int)strlen(saved_ident));
            struct obj_symbol *sym = ensure_symbol_for_name(n);
            if (segment == 1) sym->offset = text_len;
            else if (segment == 2) sym->offset = data_len;
            else if (segment == 3) sym->offset = data_len; /* bss offset tracked in data_bytes */
            else sym->offset = 0;
            sym->segment = (segment == 0) ? 1 : segment; /* default to text if none */
            next_token();
            /* continue parsing rest of line (could be directive or instruction) */
        } else {
            /* not a label: rewind to ident token */
            input_pos -= strlen(tok_text);
            /* reset token to ident */
            strcpy(tok_text, saved_ident);
            tkind = T_IDENT;
        }
    }

    /* Directive? starts with '.' or ident that matches pseudo */
    if (tkind == T_IDENT && tok_text[0] == '.') {
        /* directive */
        char dname[256];
        strcpy(dname, tok_text);
        next_token();
        /* parse optional argument into number_token or name_token */
        number_token = 0;
        name_token = NULL;
        if (tkind == T_NUMBER) { number_token = tok_number; next_token(); }
        else if (tkind == T_STRING) { name_token = lookup_name(tok_text, (int)strlen(tok_text)); next_token(); }
        else if (tkind == T_IDENT) { name_token = lookup_name(tok_text, (int)strlen(tok_text)); next_token(); }
        handle_directive_name(dname);
        return;
    }

    /* If ident and matches pseudo without dot (allow both) */
    if (tkind == T_IDENT) {
        /* check if it's a pseudo-op (no dot) */
        int is_pseudo = 0;
        for (int i = 0; pseudo_table[i].name; ++i) {
            if (strcmp(tok_text, pseudo_table[i].name) == 0) { is_pseudo = 1; break; }
        }
        if (is_pseudo) {
            char dname[256];
            strcpy(dname, tok_text);
            next_token();
            number_token = 0;
            name_token = NULL;
            if (tkind == T_NUMBER) { number_token = tok_number; next_token(); }
            else if (tkind == T_STRING) { name_token = lookup_name(tok_text, (int)strlen(tok_text)); next_token(); }
            else if (tkind == T_IDENT) { name_token = lookup_name(tok_text, (int)strlen(tok_text)); next_token(); }
            handle_directive_name(dname);
            return;
        }
    }

    /* Instruction mnemonic? */
    if (tkind == T_IDENT) {
        char mnemonic[256];
        strcpy(mnemonic, tok_text);
        next_token();
        /* parse operands separated by commas until end of line */
        nr_operands = 0;
        while (tkind != T_EOF) {
            if (nr_operands >= MAX_OPERANDS) { error("too many operands"); break; }
            if (tkind == T_COMMA) { next_token(); continue; }
            if (parse_operand(&operands[nr_operands]) != 0) break;
            nr_operands++;
            if (tkind == T_COMMA) { next_token(); continue; }
            else break;
        }
        encode_instruction(mnemonic);
        return;
    }

    /* Unknown token at start */
    error("unexpected token at start of line");
}

/* ===== Main ===== */

int main(int argc, char **argv)
{
    /* default to text segment */
    segment = 1;

    line_number = 0;
    while (fgets(input_line, sizeof(input_line), stdin)) {
        line_number++;
        input_pos = input_line;
        process_line();
    }

    /* Resolve relocations */
    resolve_relocs();

    /* Emit sections and symbol table */
    hexdump_section(".text", text_buf, text_len);
    hexdump_section(".data", data_buf, data_len);

    printf("\nSymbols (%d):\n", symbols_count);
    for (int i = 0; i < symbols_count; ++i) {
        struct obj_symbol *s = &symbols[i];
        const char *segname = (s->segment == 1) ? "seg=1" : (s->segment == 2) ? "seg=2" : (s->segment == 3) ? "seg=3" : "seg=?";
        printf("%4d: %-20s %s off=%ld glob=%d\n", i, s->n->data, segname, s->offset, s->is_global);
    }

    /* Print relocations summary */
    if (relocs_count) {
        printf("\nRelocations (%d):\n", relocs_count);
        for (int i = 0; i < relocs_count; ++i) {
            struct reloc *r = &relocs[i];
            printf("%4d: pos=%ld size=%d section=%d sym=%s\n", i, r->pos, r->size, r->section, r->sym ? r->sym->n->data : "(null)");
        }
    }

    return 0;
}
