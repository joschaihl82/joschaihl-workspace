/* -------------------------
   configuration switches
   ------------------------- */
#define USE_INLINE_ASM_FASTMEM 1
#define USE_INLINE_ASM_FETCH 1
#define USE_INLINE_ASM_STACK 1
#define USE_FB_STREAMING 1

/* MOVDQA alignment: 0=warn+copy, 1=trap (exit) */
#define STRICT_MOVDQA_ALIGNMENT 0

/* Trace/Breakpoints config */
#define TRACE_RING_SIZE (1 << 15) /* 32K entries */
#define ENABLE_SOFT_BREAKPOINTS 1
#define MAX_SOFT_BP 64

/* -------------------------
   basic sizes and globals
   ------------------------- */
#define RAM_SIZE (64ULL * 1024 * 1024) /* 64 MiB */

static uint8_t *ram_mem = NULL;
static uint8_t *fb_mem = NULL;

/* minimal xmm type */
typedef struct { uint64_t lo; uint64_t hi; } XMM;

/* trace entry */
typedef struct {
    uint64_t rip;
    uint8_t  opcode;
    uint8_t  op2;
    uint8_t  modrm;
    uint8_t  prefixes; /* bit0:66, bit1:F2, bit2:F3, bit3:REX.W */
    uint64_t info_a;   /* e.g., dst reg idx or EA */
    uint64_t info_b;   /* src reg idx or imm */
} TraceEntry;

/* soft breakpoint */
typedef struct {
    int active;
    uint64_t addr;
} SoftBP;

/* minimal cpu type */
typedef struct {
    uint64_t gpr[16];    /* rax..r15 */
    uint64_t rflags;
    uint64_t rip;
    XMM xmm[16];

    /* decode state */
    int op_size;  /* 16/32/64 */
    int addr_size;/* 32/64 */
    int has_rex;
    int rex_w, rex_r, rex_x, rex_b;

    /* legacy prefixes */
    int pref_66;
    int pref_f2;
    int pref_f3;

    int modrm_mod, modrm_reg, modrm_rm;
    uint8_t last_opcode;

    /* trace ring buffer */
    TraceEntry trace[TRACE_RING_SIZE];
    uint32_t trace_head;

    /* soft breakpoints */
    SoftBP bp[MAX_SOFT_BP];
} X64CPU;

static X64CPU cpu;

