static void fb_draw_char(uint32_t cx, uint32_t cy, unsigned char ch) {
    if (!fb_base) return;
    if (ch < 32 || ch > 127) ch = '?';
    const uint8_t *glyph = font8x8[ch - 32];
    uint8_t *base = (uint8_t*)fb_base + cy * fb_pitch + cx * 4;
    for (int row=0; row<8; row++) {
        uint32_t *pix = (uint32_t*)(base + row*fb_pitch);
        uint8_t bits = glyph[row];
        for (int col=0; col<8; col++) {
            uint32_t color = (bits & (1 << (7 - col))) ? fg_rgb : bg_rgb;
            pix[col] = color;
        }
    }
}

static void fb_putc(char ch) {
    if (!fb_base) return;
    if (ch == '\n') {
        cursor_x = 0;
        cursor_y += 8;
        if (cursor_y + 8 >= fb_height) { fb_clear(); }
        return;
    }
    fb_draw_char(cursor_x, cursor_y, (unsigned char)ch);
    cursor_x += 8;
    if (cursor_x + 8 >= fb_width) { cursor_x = 0; cursor_y += 8; }
    if (cursor_y + 8 >= fb_height) { fb_clear(); }
}

static void fb_write(const char *s, size_t n) {
    for (size_t i=0; i<n; i++) fb_putc(s[i]);
}

// ---- Simple ramfs and file descriptors ----
#define MAX_FD 32
typedef struct { const uint8_t *data; uint64_t size; uint64_t pos; int used; } fd_t;
static fd_t fdtab[MAX_FD];

typedef struct { const char *name; const uint8_t *data; uint64_t size; } ramfs_file_t;
extern uint8_t _binary_init_sh_start[], _binary_init_sh_end[];

static const char profile_txt[] =
    "echo Welcome to minimal UEFI OS\n"
    "echo Running /etc/profile.sh via /bin/sh\n";

static ramfs_file_t ramfs[] = {
    { "/bin/sh", _binary_init_sh_start, 0 },
    { "/etc/profile.sh", (const uint8_t*)profile_txt, sizeof(profile_txt)-1 },
    { NULL, NULL, 0 }
};

static const ramfs_file_t* ramfs_find(const char *path) {
    for (int i=0; ramfs[i].name; i++) if (strcmp(ramfs[i].name, path)==0) return &ramfs[i];
    return NULL;
}

static int alloc_fd(const uint8_t *data, uint64_t size) {
    for (int i=0;i<MAX_FD;i++) if (!fdtab[i].used) { fdtab[i]=(fd_t){data,size,0,1}; return i; }
    return -1;
}

static uint64_t sys_open(const char *path, uint64_t flags) {
    (void)flags;
    const ramfs_file_t *f = ramfs_find(path);
    if (!f) return (uint64_t)-2;
    int fd = alloc_fd(f->data, f->size);
    return fd < 0 ? (uint64_t)-24 : (uint64_t)fd;
}
static uint64_t sys_close(uint64_t fd) {
    if (fd >= MAX_FD || !fdtab[fd].used) return (uint64_t)-9;
    fdtab[fd].used = 0; return 0;
}
static uint64_t sys_read(uint64_t fd, void *buf, uint64_t len) {
    if (fd >= MAX_FD || !fdtab[fd].used) return (uint64_t)-9;
    fd_t *e = &fdtab[fd];
    uint64_t rem = e->size - e->pos; if (len > rem) len = rem;
    memcpy(buf, e->data + e->pos, len);
    e->pos += len; return len;
}
static uint64_t sys_write(uint64_t fd, const void *buf, uint64_t len) {
    (void)fd;
    fb_write((const char*)buf, (size_t)len);
    return len;
}
static uint64_t sys_lseek(uint64_t fd, int64_t off, uint64_t whence) {
    if (fd >= MAX_FD || !fdtab[fd].used) return (uint64_t)-9;
    fd_t *e = &fdtab[fd];
    uint64_t np = e->pos;
    if (whence == 0) np = off;
    else if (whence == 1) np += off;
    else if (whence == 2) np = e->size + off;
    if (np > e->size) return (uint64_t)-22;
    e->pos = np; return np;
}
static uint64_t sys_exit(int code) { (void)code; for(;;) __asm__ __volatile__("hlt"); return 0; }
static uint64_t sys_getpid(void) { return 1; }
static uint8_t *user_heap_brk  = (uint8_t*)0x40000000ULL;
static uint64_t sys_brk(void *addr) { if (!addr) return (uint64_t)user_heap_brk; user_heap_brk = addr; return (uint64_t)user_heap_brk; }

static uint64_t syscall_dispatch(uint64_t num, uint64_t a0, uint64_t a1, uint64_t a2, uint64_t a3, uint64_t a4, uint64_t a5) {
    (void)a3; (void)a4; (void)a5;
    switch (num) {
        case 1: return sys_write(a0, (const void*)a1, a2);
        case 0: return sys_read(a0, (void*)a1, a2);
        case 2: return sys_open((const char*)a0, a1);
        case 3: return sys_close(a0);
        case 8: return sys_lseek(a0, (int64_t)a1, a2);
        case 60: return sys_exit((int)a0);
        case 12: return sys_brk((void*)a0);
        case 39: return sys_getpid();
        default: return (uint64_t)-38;
    }
}

uint64_t syscall_handler_asm(void) {
    register uint64_t nr __asm__("rdi");
    register uint64_t a0 __asm__("rsi");
    register uint64_t a1 __asm__("rdx");
    register uint64_t a2 __asm__("r10");
    register uint64_t a3 __asm__("r8");
    register uint64_t a4 __asm__("r9");
    return syscall_dispatch(nr, a0, a1, a2, a3, a4, 0);
}

// ---- Enter user mode ----
extern void enter_user(void *rip, void *rsp, uint64_t arg);
__asm__(
".global enter_user\n"
"enter_user:\n"
"    mov $0x23, %ax; mov %ax, %ds; mov %ax, %es; mov %ax, %ss;\n"
"    mov %rsi, %rsp\n"
"    pushq $0x23\n"
"    pushq %rsi\n"
"    pushq $0x202\n"
"    pushq $0x23\n"
"    pushq %rdi\n"
"    iretq\n"
);

// ---- GOP init before ExitBootServices ----
static void gop_init(EFI_BOOT_SERVICES *bs) {
    EFI_GRAPHICS_OUTPUT_PROTOCOL *gop = NULL;
    if (bs->LocateProtocol((void*)&EFI_GRAPHICS_OUTPUT_PROTOCOL_GUID, NULL, (void**)&gop) != EFI_SUCCESS || !gop)
        return;
    EFI_GRAPHICS_OUTPUT_MODE_INFORMATION *info = (EFI_GRAPHICS_OUTPUT_MODE_INFORMATION*)gop->Info;
    fb_base = gop->FrameBufferBase;
    fb_height = info->VerticalResolution;
    fb_width  = info->HorizontalResolution;
    fb_pitch  = info->PixelsPerScanLine * 4; // assume 32bpp
    fb_bpp    = 32;
    fb_clear();
}

// ---- UEFI console output (pre-exit) ----
static EFI_SYSTEM_TABLE *Sys = NULL;
static void efi_puts(const char *s) {
    if (!Sys || !Sys->ConOut) return;
    uint16_t buf[256]; size_t i = 0;
    while (s[i] && i < 255) { buf[i] = (uint16_t)s[i]; i++; }
    buf[i] = 0;
    EFI_SIMPLE_TEXT_OUTPUT_STRING out = *(EFI_SIMPLE_TEXT_OUTPUT_STRING*)((uint8_t*)Sys->ConOut);
    if (out) out(Sys->ConOut, buf);
}

// ---- Exec /bin/sh ----
static void map_user_region(uint64_t gva, uint64_t size) { (void)gva; (void)size; /* identity for demo */ }

static uint64_t sys_execve(const char *path, char *const argv[], char *const envp[]) {
    (void)argv; (void)envp;
    const ramfs_file_t *f = ramfs_find(path);
    if (!f) return (uint64_t)-2;
    uint64_t user_code = 0x00400000ULL;
    uint64_t user_stack = 0x00800000ULL;
    map_user_region(user_code, f->size);
    map_user_region(user_stack, PAGE_SIZE * 4);
    memcpy((void*)user_code, f->data, f->size);
    enter_user((void*)user_code, (void*)user_stack, 0);
    return 0;
}

// ---- UEFI entry ----
EFI_STATUS efi_main(EFI_HANDLE ImageHandle, EFI_SYSTEM_TABLE *SystemTable) {
    Sys = SystemTable;
    BS = Sys->BootServices;

    // Fill sizes for ramfs entries
    ramfs[0].size = (uint64_t)(_binary_init_sh_end - _binary_init_sh_start);

    efi_puts("Booting minimal UEFI OS...\r\n");

    gdt_init();
    idt_init();
    paging_init_identity_1g();
    syscall_init();

    // Initialize GOP for framebuffer console
    gop_init(BS);
    fb_write("Framebuffer ready.\n", 19);

    // Exit Boot Services
    uint64_t MapSize=0, MapKey=0, DescSize=0; uint32_t DescVer=0;
    BS->GetMemoryMap(&MapSize, NULL, &MapKey, &DescSize, &DescVer);
    void *MemMap = NULL; BS->AllocatePool(0, MapSize + 4096, &MemMap);
    BS->GetMemoryMap(&MapSize, MemMap, &MapKey, &DescSize, &DescVer);
    BS->ExitBootServices(ImageHandle, MapKey);

    fb_write("Minimal x64-UEFI OS with userspace shell\n", 39);

    // Exec /bin/sh
    sys_execve("/bin/sh", NULL, NULL);

    for(;;) __asm__ __volatile__("hlt");
    return EFI_SUCCESS;
}
