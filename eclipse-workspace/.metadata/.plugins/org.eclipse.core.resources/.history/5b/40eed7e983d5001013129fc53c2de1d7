// --- ii. utility and error functions ---

// reads a file content into a malloc'ed buffer
char *read_file_to_buffer(const char *path) {
    FILE *fp = fopen(path, "r");
    if (!fp) {
        fprintf(stderr, "cannot open file: %s: %s\n", path, strerror(errno));
        exit(1);
    }

    // get file size
    // fix: changed seek_end to seek_end
    if (fseek(fp, 0, SEEK_END) == -1) {
        perror("fseek");
        exit(1);
    }
    size_t size = ftell(fp);
    // fix: changed seek_set to seek_set
    if (fseek(fp, 0, SEEK_SET) == -1) {
        perror("fseek");
        exit(1);
    }

    char *buf = malloc(size + 1);
    if (!buf) {
        perror("malloc");
        exit(1);
    }

    // read file
    if (fread(buf, size, 1, fp) != 1) {
        // only error if read size != expected size and not at eof
        if (feof(fp) == 0) {
            fprintf(stderr, "error reading file: %s\n", path);
            exit(1);
        }
    }

    fclose(fp);
    buf[size] = '\0';
    return buf;
}

// reports an error location and exits
void error_at(char *loc, char *fmt, ...) {
    va_list ap;
    va_start(ap, fmt);

    // find start of line
    char *line = loc;
    while (user_input < line && line[-1] != '\n') line--;

    // find end of line
    char *end = loc;
    while (*end != '\n' && *end != '\0') end++;

    // print file content around error location
    int linelen = end - line;
    fprintf(stderr, "%.*s\n", linelen, line);

    // print indicator
    int pos = loc - line;
    for (int i = 0; i < pos; i++) fprintf(stderr, " ");
    fprintf(stderr, "^ ");

    // print error message
    vfprintf(stderr, fmt, ap);
    fprintf(stderr, "\n");
    exit(1);
}

void error_tok(token *tok, char *fmt, ...) {
    if (!tok || tok->kind == tk_eof) {
        fprintf(stderr, "error at eof: ");
    } else {
        error_at(tok->file_pos, fmt);
        return;
    }

    va_list ap;
    va_start(ap, fmt);
    vfprintf(stderr, fmt, ap);
    fprintf(stderr, "\n");
    exit(1);
}

// aligns `n` to `align` boundary
int align_to(int n, int align) {
    return (n + align - 1) & ~(align - 1);
}

// --- iii. type helpers ---

ty *new_type(type_kind kind, int size, int align) {
    ty *t = calloc(1, sizeof(ty));
    t->kind = kind;
    t->size = size;
    t->align = align;
    return t;
}
ty *ty_void_def() { return new_type(ty_void, 0, 1); }
ty *ty_int_def() { return new_type(ty_int, 4, 4); }
ty *ty_char_def() { return new_type(ty_char, 1, 1); }
ty *ty_long_def() { return new_type(ty_long, 8, 8); }
ty *new_type_ptr(ty *base) {
    ty *t = new_type(ty_ptr, 8, 8);
    t->base = base;
    return t;
}
ty *new_type_array(ty *base, size_t len) {
    int total_size = (int)(base->size * len);
    ty *t = new_type(ty_array, total_size, base->align);
    t->base = base;
    t->array_len = len;
    return t;
}
ty *new_type_struct() {
    // size and alignment are calculated when members are added
    return new_type(ty_struct, 0, 1);
}

ty *find_struct_tag(token *tok) {
    for (struct_tag *t = struct_tags; t; t = t->next) {
        if (t->len == tok->len && strncmp(t->name, tok->str, tok->len) == 0) return t->type;
    }
    return NULL;
}

member *get_struct_member(ty *type, token *tok) {
    for (member *m = type->members; m; m = m->next) {
        if (m->len == tok->len && strncmp(m->name, tok->str, tok->len) == 0) return m;
    }
    return NULL;
}

void add_type(node *n) {
    if (!n || n->type) return;

    add_type(n->lhs);
    add_type(n->rhs);
    add_type(n->els);
    if (n->next) add_type(n->next); // for block nodes

    switch (n->kind) {
        case nd_addr: n->type = new_type_ptr(n->lhs->type); return;
        case nd_deref:
            if (n->lhs->type->kind != ty_ptr && n->lhs->type->kind != ty_array) error_tok(current_token, "cannot dereference non-pointer/non-array type");
            n->type = n->lhs->type->base;
            return;
        case nd_assign:
        case nd_add_assign: case nd_sub_assign: case nd_mul_assign: case nd_div_assign: case nd_mod_assign:
        case nd_shl_assign: case nd_shr_assign: case nd_band_assign: case nd_bor_assign: case nd_bxor_assign:
            n->type = n->lhs->type; return;
        case nd_add: case nd_sub:
            // pointer arithmetic check
            if (n->lhs->type->kind == ty_ptr || n->lhs->type->kind == ty_array) {
                n->type = (n->lhs->type->kind == ty_array) ? new_type_ptr(n->lhs->type->base) : n->lhs->type;
                return;
            }
            // fallthrough
        case nd_mul: case nd_div: case nd_mod: case nd_shl: case nd_shr: case nd_band: case nd_bor: case nd_bxor:
        case nd_logical_and: case nd_logical_or:
            n->type = ty_long_def();
            return;
        case nd_eq: case nd_ne: case nd_lt: case nd_le:
        case nd_not: case nd_bitnot:
            n->type = ty_int_def(); return;
        case nd_cond:
            n->type = ty_long_def();
            return;
        case nd_lvar:
            // array/function names decay to pointers
            if (n->var->type->kind == ty_array || n->var->type->kind == ty_func) {
                n->type = new_type_ptr(n->var->type->base);
            } else {
                n->type = n->var->type;
            }
            return;
        case nd_member:
            n->type = n->mem->type;
            return;
        case nd_num:
            n->type = (n->val > 2147483647l) ? ty_long_def() : ty_int_def();
            return;
        case nd_funcall:
            n->type = ty_long_def(); // default to long for return value
            return;
        case nd_local_init:
            // this is a statement node, not an expression, type is void/ignored.
            return;
        default: break;
    }
}

// --- iv. variable and global data management ---

lvar *find_lvar(token *tok, ty *type, int is_static) {
    if (current_func) {
        for (lvar *l = current_func->locals; l; l = l->next) {
            if (l->len == tok->len && strncmp(l->name, tok->str, tok->len) == 0) return l;
        }
    }

    if (!current_func && !is_static) error_tok(tok, "variable declaration must be inside a function or be static/global");

    lvar *l = calloc(1, sizeof(lvar));
    l->next = current_func ? current_func->locals : NULL;
    l->name = tok->str;
    l->len = tok->len;
    l->type = type;
    l->is_static = is_static;

    if (current_func) current_func->locals = l;

    if (is_static) {
        l->gname = malloc(32);
        snprintf(l->gname, 32, ".lstatic%d", static_var_count++);
    } else {
        int offset = current_func->stack_size + l->type->size;
        offset = align_to(offset, l->type->align);
        l->offset = offset;
        current_func->stack_size = l->offset;
    }

    return l;
}

gvar *find_global_var(token *tok) {
    for (gvar *g = global_vars; g; g = g->next) {
        if (g->name && tok->len == (int)strlen(g->name) && strncmp(tok->str, g->name, tok->len) == 0) {
            return g;
        }
    }
    return NULL;
}

// --- v. preprocessor (minimal working version) ---

char *preprocess_includes_and_macros(const char *input, int depth) {
    // simplified preprocessing: strips comments, handles simple object-like macros, no #include support.
    char *p = strdup(input);

    // 1. strip comments, handle line continuation
    char *r = p;
    char *w = p;

    while (*r) {
        // FIX: Handle backslash-newline line continuation (correct C spec)
        if (*r == '\\' && r[1] == '\n') {
            r += 2; // skip both '\' and '\n'
            continue;
        }

        if (r[0] == '/' && r[1] == '/') { // line comment
            while (*r && *r != '\n') r++;
            continue;
        }
        if (r[0] == '/' && r[1] == '*') { // block comment
            char *q = strstr(r + 2, "*/");
            if (!q) error_at(r, "unterminated block comment");
            r = q + 2;
            continue;
        }

        if (*r == '"' || *r == '\'') { // skip string/char literals
            char quote = *r;
            *w++ = *r++;
            while (*r && *r != quote) {
                if (*r == '\\') *w++ = *r++;
                *w++ = *r++;
            }
            if (*r) *w++ = *r++;
            continue;
        }

        if (*r == '#') {
            // minimal line skip for preprocessor directives
            while (*r && *r != '\n') r++;
            if (*r == '\n') r++; // keep newline to preserve line numbers (somewhat)
            continue;
        }

        *w++ = *r++;
    }
    *w = '\0';
    return p;
}

// --- vi. lexer implementation ---

token *new_token(token_kind kind, token *cur, char *str, int len) {
    token *tok = calloc(1, sizeof(token));
    tok->kind = kind;
    tok->str = str;
    tok->len = len;
    tok->file_pos = str;
    cur->next = tok;
    return tok;
}

int is_ident_char(char c) { return isalnum((unsigned char)c) || c == '_'; }

char *read_string_literal(char *p, token *cur) {
    char *q = p + 1;
    while (*q && *q != '"') {
        if (*q == '\\') q++;
        q++;
    }
    if (!*q) error_at(p, "unterminated string literal");

    cur->kind = tk_string;
    cur->str = p;
    cur->len = q - p + 1;
    return q + 1;
}

token *tokenize(char *p) {
    token head = {0};
    token *cur = &head;

    while (*p) {
        if (isspace((unsigned char)*p)) { p++; continue; }

        // string literal
        if (*p == '"') {
            cur = new_token(tk_string, cur, p, 0);
            p = read_string_literal(p, cur);
            continue;
        }

        // char literal (simplified: just consumes the literal)
        if (*p == '\'') {
            char *q = p + 1;
            while (*q && *q != '\'') {
                if (*q == '\\') q++;
                q++;
            }
            if (!*q) error_at(p, "unterminated char literal");
            // simplified: treat char literal as a number token for now
            cur = new_token(tk_num, cur, p, q - p + 1);
            // very basic char to long: the character value is the second character if not escaped
            cur->val = *p == '\0' ? 0 : *q == '\'' ? (long)p[1] : 0;
            p = q + 1;
            continue;
        }

        // multi-character operators (>= 2 chars)
        if (strncmp(p, "==", 2) == 0 || strncmp(p, "!=", 2) == 0 || strncmp(p, "<=", 2) == 0 || strncmp(p, ">=", 2) == 0 || strncmp(p, "->", 2) == 0 || strncmp(p, "&&", 2) == 0 || strncmp(p, "||", 2) == 0 || strncmp(p, "<<", 2) == 0 || strncmp(p, ">>", 2) == 0) {
            // handle compound assignments (3 chars)
            int len = 2;
            if (p[2] == '=') {
                if (p[0] == '+' || p[0] == '-' || p[0] == '*' || p[0] == '/' || p[0] == '%' || p[0] == '&' || p[0] == '|' || p[0] == '^' || (p[0] == '<' && p[1] == '<') || (p[0] == '>' && p[1] == '>')) len = 3;
            } else if (p[0] == '+' || p[0] == '-') { // ++ or --
                if (p[0] == p[1]) len = 2;
            }
            cur = new_token(tk_reserved, cur, p, len); p += len; continue;
        }

        // single-character operators and delimiters
        if (strchr("+-*/%()=;{},&<>!~[]?:.", *p)) { cur = new_token(tk_reserved, cur, p++, 1); continue; }

        // keywords
        for (int i = 0; keywords[i].name; i++) {
            if (strncmp(p, keywords[i].name, keywords[i].len) == 0 && !is_ident_char(p[keywords[i].len])) {
                cur = new_token(tk_keyword, cur, p, keywords[i].len);
                p += keywords[i].len;
                goto next_char;
            }
        }

        // identifiers
        if (isalpha((unsigned char)*p) || *p == '_') {
            char *q = p++;
            while (is_ident_char(*p)) p++;
            cur = new_token(tk_ident, cur, q, p - q);
            continue;
        }

        // numbers
        if (isdigit((unsigned char)*p)) {
            char *q = p;
            cur = new_token(tk_num, cur, p, 0);
            cur->val = strtol(p, &p, 0);
            cur->len = p - q;
            continue;
        }

        error_at(p, "invalid token");

        next_char:;
    }

    new_token(tk_eof, cur, p, 0);
    return head.next;
}

int consume(char *op) {
    if (current_token->kind != tk_reserved || current_token->len != (int)strlen(op) || strncmp(current_token->str, op, current_token->len) != 0) return 0;
    current_token = current_token->next;
    return 1;
}

int consume_keyword(char *kw) {
    if (current_token->kind != tk_keyword || current_token->len != (int)strlen(kw) || strncmp(current_token->str, kw, current_token->len) != 0) return 0;
    current_token = current_token->next;
    return 1;
}

token *expect_ident() {
    if (current_token->kind != tk_ident) error_tok(current_token, "expected identifier");
    token *t = current_token;
    current_token = current_token->next;
    return t;
}

void expect(char *op) {
    if (!consume(op)) error_tok(current_token, "expected '%s'", op);
}

long expect_number() {
    if (current_token->kind != tk_num) error_tok(current_token, "expected number");
    long val = current_token->val;
    current_token = current_token->next;
    return val;
}

token *peek() { return current_token; }

int is_type_token(token *tok) {
    if (tok->kind == tk_keyword) {
        return strncmp(tok->str, "int", tok->len) == 0 ||
               strncmp(tok->str, "char", tok->len) == 0 ||
               strncmp(tok->str, "long", tok->len) == 0 ||
               strncmp(tok->str, "unsigned", tok->len) == 0 ||
               strncmp(tok->str, "static", tok->len) == 0 ||
               strncmp(tok->str, "extern", tok->len) == 0 ||
               strncmp(tok->str, "struct", tok->len) == 0 ||
               strncmp(tok->str, "void", tok->len) == 0;
    }
    return 0;
}

// --- vii. ast node constructors ---

node *new_node(node_kind kind, node *lhs, node *rhs) {
    node *n = calloc(1, sizeof(node));
    n->kind = kind;
    n->lhs = lhs;
    n->rhs = rhs;
    add_type(n); // call add_type here for immediate type check
    return n;
}

node *new_num_node(long val) {
    node *n = calloc(1, sizeof(node));
    n->kind = nd_num;
    n->val = val;
    add_type(n);
    return n;
}

node *new_lvar_node(lvar *var) {
    node *n = calloc(1, sizeof(node));
    n->kind = nd_lvar;
    n->var = var;
    add_type(n);
    return n;
}

// --- viii. parser implementation (recursive descent) ---

// member_access = ("." | "->") ident
node *member_access(node *n) {
    for (;;) {
        if (consume("->")) {
            // "->" is equivalent to (*n).member
            n = new_node(nd_deref, n, NULL);
            add_type(n);
            if (n->type->kind != ty_struct) error_tok(current_token, "operand of '->' must be a pointer to struct");
        } else if (consume(".")) {
            if (n->type->kind != ty_struct) error_tok(current_token, "operand of '.' must be a struct");
        } else {
            return n;
        }

        node *mem = calloc(1, sizeof(node));
        mem->kind = nd_member;

        ty *type = n->type;
        token *tok = expect_ident();

        mem->mem = get_struct_member(type, tok);
        if (!mem->mem) error_tok(tok, "no such member in struct");

        mem->lhs = n;
        n = mem;
        add_type(n);
    }
}

// primary = "(" expr ")" | "sizeof" unary | ident ("(" (assign ("," assign)*)? ")")? | num | string
node *primary() {
    if (consume("(")) {
        node *n = expr();
        expect(")");
        return n;
    }

    if (consume_keyword("sizeof")) {
        node *un = unary();
        add_type(un);
        return new_num_node(un->type->size);
    }

    if (current_token->kind == tk_ident) {
        token *tok = current_token;
        current_token = current_token->next;

        if (consume("(")) { // function call
            node *n = calloc(1, sizeof(node));
            n->kind = nd_funcall;
            n->name = strndup(tok->str, tok->len);

            node head = {};
            node *cur = &head;
            while (!consume(")")) {
                if (cur != &head) expect(",");
                cur->next = assign();
                cur = cur->next;
            }
            n->rhs = head.next;
            add_type(n);
            return n;
        }

        // variable lookup (local, then global)
        if (current_func) {
            for (lvar *l = current_func->locals; l; l = l->next) {
                if (l->len == tok->len && strncmp(l->name, tok->str, tok->len) == 0) return new_lvar_node(l);
            }
        }

        gvar *g = find_global_var(tok);
        if (g) {
            // treat global as a special static lvar for address calculation
            lvar *l = calloc(1, sizeof(lvar));
            l->name = g->name;
            l->len = (int)strlen(g->name);
            l->is_static = 1;
            l->gname = g->name;
            // simplified type for global vars when just retrieving address
            l->type = new_type_array(ty_char_def(), g->size);
            return new_lvar_node(l);
        }

        error_tok(tok, "undeclared identifier: %s", strndup(tok->str, tok->len));
    }

    if (current_token->kind == tk_num) {
        return new_num_node(expect_number());
    }

    if (current_token->kind == tk_string) {
        token *tok = current_token;
        current_token = current_token->next;

        // create a global variable entry for the string literal
        gvar *g = calloc(1, sizeof(gvar));
        g->name = malloc(32);
        snprintf(g->name, 32, ".str%d", string_label_count++);
        g->size = tok->len - 1; // includes null terminator

        sinit *init = calloc(1, sizeof(sinit));
        init->kind = init_string;
        init->str_content = strndup(tok->str + 1, tok->len - 2); // remove quotes
        init->size = g->size;
        g->initializer = init;

        g->next = global_vars;
        global_vars = g;

        // return a node that evaluates to the address of the global string
        lvar *l = calloc(1, sizeof(lvar));
        l->name = g->name;
        l->len = (int)strlen(g->name);
        l->is_static = 1;
        l->gname = g->name;
        l->type = new_type_array(ty_char_def(), g->size);

        return new_lvar_node(l); // array decays to pointer
    }

    error_tok(current_token, "expected expression");
    return NULL;
}

// postfix = primary ("[" expr "]" | "++" | "--" | member_access)*
node *postfix() {
    node *n = primary();
    for (;;) {
        if (consume("[")) {
            node *idx = expr();
            expect("]");
            // a[i] is equivalent to *(a + i)
            node *add = new_node(nd_add, n, idx);
            n = new_node(nd_deref, add, NULL);
        } else if (peek()->kind == tk_reserved && (peek()->str[0] == '.' || (peek()->len == 2 && peek()->str[0] == '-' && peek()->str[1] == '>'))) {
            n = member_access(n);
        } else {
            return n;
        }
    }
}

// unary = ("+" | "-" | "*" | "&" | "!" | "~")? postfix
node *unary() {
    if (consume("+")) return unary();
    if (consume("-")) return new_node(nd_sub, new_num_node(0), unary());
    if (consume("*")) return new_node(nd_deref, unary(), NULL);
    if (consume("&")) return new_node(nd_addr, unary(), NULL);
    if (consume("!")) return new_node(nd_not, unary(), NULL);
    if (consume("~")) return new_node(nd_bitnot, unary(), NULL);
    return postfix();
}

node *mul() { node *n = unary(); for (;;) { if (consume("*")) n = new_node(nd_mul, n, unary()); else if (consume("/")) n = new_node(nd_div, n, unary()); else if (consume("%")) n = new_node(nd_mod, n, unary()); else return n; } }
node *add() { node *n = mul(); for (;;) { if (consume("+")) n = new_node(nd_add, n, mul()); else if (consume("-")) n = new_node(nd_sub, n, mul()); else return n; } }
node *shift() { node *n = add(); for (;;) { if (consume("<<")) n = new_node(nd_shl, n, add()); else if (consume(">>")) n = new_node(nd_shr, n, add()); else return n; } }
node *relational() { node *n = shift(); for (;;) { if (consume("<")) n = new_node(nd_lt, n, shift()); else if (consume("<=")) n = new_node(nd_le, n, shift()); else if (consume(">")) n = new_node(nd_lt, shift(), n); else if (consume(">=")) n = new_node(nd_le, shift(), n); else return n; } }
node *equality() { node *n = relational(); for (;;) { if (consume("==")) n = new_node(nd_eq, n, relational()); else if (consume("!=")) n = new_node(nd_ne, n, relational()); else return n; } }
node *band() { node *n = equality(); for (;;) { if (consume("&")) n = new_node(nd_band, n, equality()); else return n; } }
node *exclusive_or() { node *n = band(); for (;;) { if (consume("^")) n = new_node(nd_bxor, n, band()); else return n; } }
node *inclusive_or() { node *n = exclusive_or(); for (;;) { if (consume("|")) n = new_node(nd_bor, n, exclusive_or()); else return n; } }

node *logical_and() { node *n = inclusive_or(); for (;;) { if (consume("&&")) n = new_node(nd_logical_and, n, inclusive_or()); else return n; } }
node *logical_or() { node *n = logical_and(); for (;;) { if (consume("||")) n = new_node(nd_logical_or, n, logical_and()); else return n; } }

node *conditional() {
    node *n = logical_or();
    if (!consume("?")) return n;
    node *rhs = expr();
    expect(":");
    node *els = conditional();
    n->kind = nd_cond;
    n->rhs = rhs;
    n->els = els;
    add_type(n);
    return n;
}

node *assign() {
    node *n = conditional();

    if (consume("=")) return new_node(nd_assign, n, assign());
    if (consume("+=")) return new_node(nd_add_assign, n, assign());
    if (consume("-=")) return new_node(nd_sub_assign, n, assign());
    if (consume("*=")) return new_node(nd_mul_assign, n, assign());
    if (consume("/=")) return new_node(nd_div_assign, n, assign());
    if (consume("%=")) return new_node(nd_mod_assign, n, assign());
    if (consume("<<=")) return new_node(nd_shl_assign, n, assign());
    if (consume(">>=")) return new_node(nd_shr_assign, n, assign());
    if (consume("&=")) return new_node(nd_band_assign, n, assign());
    if (consume("|=")) return new_node(nd_bor_assign, n, assign());
    if (consume("^=")) return new_node(nd_bxor_assign, n, assign());

    return n;
}

node *expr() { return assign(); }

// --- ix. struct definition and initializer parsing ---

// parses struct members and calculates total size/alignment
ty *parse_struct_specifier() {
    token *tag = NULL;
    if (peek()->kind == tk_ident) {
        tag = expect_ident();
    }

    ty *type = NULL;

    if (consume("{")) { // full definition
        type = new_type_struct();
        if (tag) { // save anonymous/named tag
            struct_tag *st = calloc(1, sizeof(struct_tag));
            st->name = strndup(tag->str, tag->len);
            st->len = tag->len;
            st->type = type;
            st->next = struct_tags;
            struct_tags = st;
        }

        int offset = 0;
        int max_align = 1;
        member head = {};
        member *cur = &head;

        while (!consume("}")) {
            int is_unsigned = 0, is_static = 0, is_extern = 0;
            ty *base = parse_type_specifier(&is_unsigned, &is_static, &is_extern);

            do {
                token *ident_tok = NULL;
                ty *mem_type = parse_declarator(base, &ident_tok);
                if (!ident_tok) error_tok(current_token, "expected member name");

                offset = align_to(offset, mem_type->align);
                member *m = calloc(1, sizeof(member));
                m->name = strndup(ident_tok->str, ident_tok->len);
                m->len = ident_tok->len;
                m->type = mem_type;
                m->offset = offset;

                cur->next = m;
                cur = cur->next;

                offset += mem_type->size;
                if (mem_type->align > max_align) max_align = mem_type->align;

            } while (consume(","));
            expect(";");
        }

        type->members = head.next;
        type->align = max_align;
        type->size = align_to(offset, max_align);

    } else if (tag) { // forward declaration or existing definition lookup
        type = find_struct_tag(tag);
        if (!type) error_tok(tag, "unknown struct tag '%s'", strndup(tag->str, tag->len));
    } else {
        error_tok(current_token, "expected '{' or a struct tag");
    }

    return type;
}

// parses a constant expression (a node) and attempts to resolve it to a constant sinit
sinit *parse_scalar_initializer(ty *type) {
    // simplified: only supports integer constants or address-of for now
    node *rhs = conditional();
    sinit *init = calloc(1, sizeof(sinit));
    init->type = type;
    init->size = type->size;

    if (rhs->kind == nd_num) {
        init->kind = init_int;
        init->val = rhs->val;
    } else if (rhs->kind == nd_lvar && rhs->var->is_static) {
        // pointer to global/static variable (address of)
        init->kind = init_ptr;
        init->str_label = strdup(rhs->var->gname);
    } else if (rhs->kind == nd_addr && rhs->lhs->kind == nd_lvar && rhs->lhs->var->is_static) {
        // address of global/static variable
        init->kind = init_ptr;
        init->str_label = strdup(rhs->lhs->var->gname);
    } else {
        error_tok(current_token, "initializer must be a constant expression or an address of a global/static variable");
    }
    return init;
}

sinit *parse_initializer_recursive(ty *type, int *offset_ptr) {
    sinit head = {};
    sinit *cur = &head;

    if (type->kind == ty_array) {
        if (type->base->kind == ty_char && peek()->kind == tk_string) {
            error_tok(current_token, "string literal array initializer should be parsed by parse_initializer()");
            return NULL;
        }

        size_t index = 0;
        if (!consume("{")) {
            // single element initializer, only allowed for array of size 1 (or incomplete)
            if (type->array_len > 1) error_tok(current_token, "expected array initializer list { ... }");

            cur->next = parse_scalar_initializer(type->base);
            cur = cur->next;
            cur->offset = (*offset_ptr);

        } else {
            // array initialization list
            while (!consume("}")) {
                if (index > 0) consume(",");

                if (type->array_len > 0 && index >= type->array_len) error_tok(current_token, "too many elements in array initializer");

                // pass null for recursive offset_ptr since we calculate it based on index/base_size
                sinit *child = parse_initializer_recursive(type->base, NULL);
                child->offset = (*offset_ptr) + (int)(index * type->base->size);
                cur->next = child;
                cur = cur->next;
                index++;
            }
        }

        sinit *arr_init = calloc(1, sizeof(sinit));
        arr_init->kind = init_array;
        arr_init->children = head.next;
        arr_init->type = type;
        arr_init->size = type->size;
        return arr_init;

    } else if (type->kind == ty_struct) {
        member *m = type->members;
        if (!consume("{")) error_tok(current_token, "expected struct initializer list { ... }");

        while (!consume("}")) {
            if (m) {
                if (m != type->members) expect(",");

                // pass null for recursive offset_ptr
                sinit *child = parse_initializer_recursive(m->type, NULL);
                child->offset = (*offset_ptr) + m->offset;
                cur->next = child;
                cur = cur->next;
                m = m->next;
            } else {
                error_tok(current_token, "too many members in struct initializer");
            }
        }

        sinit *struct_init = calloc(1, sizeof(sinit));
        struct_init->kind = init_struct;
        struct_init->children = head.next;
        struct_init->type = type;
        struct_init->size = type->size;
        return struct_init;

    } else {
        // scalar initializer
        sinit *scalar = parse_scalar_initializer(type);
        scalar->offset = (*offset_ptr);
        return scalar;
    }
    return NULL;
}

sinit *parse_initializer(ty *type) {
    // special case: char array initialized by string literal
    if (type->kind == ty_array && type->base->kind == ty_char && peek()->kind == tk_string) {
        token *tok = current_token;
        current_token = current_token->next;

        sinit *init = calloc(1, sizeof(sinit));
        init->kind = init_string;
        // string length = content length + 1 (for null terminator)
        size_t str_len = tok->len - 1;
        init->size = (int)str_len;
        init->str_content = strndup(tok->str + 1, tok->len - 2);

        // adjust array length if it was incomplete
        if (type->array_len == 0) {
            type->array_len = str_len;
            type->size = (int)(type->base->size * str_len);
        } else if (type->array_len < str_len) {
            error_tok(tok, "string literal is too long for the array");
        }

        sinit *arr_init = calloc(1, sizeof(sinit));
        arr_init->kind = init_array;
        arr_init->children = init;
        arr_init->type = type;
        arr_init->size = type->size;
        return arr_init;
    }

    int dummy_offset = 0;
    return parse_initializer_recursive(type, &dummy_offset);
}

// type_specifier = ("void" | "char" | "int" | "long" | "unsigned" | "static" | "extern" | "struct" struct_specifier) +
ty *parse_type_specifier(int *is_unsigned_ptr, int *is_static_ptr, int *is_extern_ptr) {
    ty *base = ty_int_def();

    int type_found = 0;
    int sign_found = 0;
    int storage_found = 0;

    for (;;) {
        if (consume_keyword("unsigned")) {
            if (sign_found) error_tok(current_token, "duplicate type specifier");
            *is_unsigned_ptr = 1;
            sign_found = 1;
            continue;
        }
        if (consume_keyword("static")) {
            if (storage_found) error_tok(current_token, "duplicate storage specifier");
            *is_static_ptr = 1;
            storage_found = 1;
            continue;
        }
        if (consume_keyword("extern")) {
            if (storage_found) error_tok(current_token, "duplicate storage specifier");
            *is_extern_ptr = 1;
            storage_found = 1;
            continue;
        }
        if (consume_keyword("void")) {
            if (type_found) error_tok(current_token, "duplicate type specifier");
            base = ty_void_def();
            type_found = 1;
            continue;
        }
        if (consume_keyword("char")) {
            if (type_found) error_tok(current_token, "duplicate type specifier");
            base = ty_char_def();
            type_found = 1;
            continue;
        }
        if (consume_keyword("int")) {
            // int is the default, skip checks if it's the first type specifier
            if (type_found && base->kind != ty_int) error_tok(current_token, "duplicate type specifier");
            type_found = 1;
            continue;
        }
        if (consume_keyword("long")) {
            if (type_found && base->kind != ty_int) error_tok(current_token, "duplicate type specifier");
            base = ty_long_def();
            type_found = 1;
            continue;
        }
        if (consume_keyword("struct")) {
            if (type_found) error_tok(current_token, "duplicate type specifier");
            base = parse_struct_specifier();
            type_found = 1;
            continue;
        }
        break; // no type specifier found
    }

    if (*is_unsigned_ptr) base->is_unsigned = 1;

    // if no base type was explicitly specified (e.g., just 'unsigned'), it defaults to 'int'
    if (!type_found) base = ty_int_def();

    return base;
}

// declarator = ("*")* ident ("[" num "]")*
ty *parse_declarator(ty *base, token **ident_tok_ptr) {
    ty *type = base;
    int ptr_count = 0;
    while (consume("*")) ptr_count++;

    // if it's a function declaration, we expect the identifier inside parentheses
    if (peek()->kind == tk_ident) {
        *ident_tok_ptr = expect_ident();
    } else {
        *ident_tok_ptr = NULL; // anonymous declaration (e.g., struct member)
    }

    // apply pointer types
    for (int i = 0; i < ptr_count; i++) {
        type = new_type_ptr(type);
    }

    // parse array dimensions: ident [a] [b] ...
    while (consume("[")) {
        size_t len = expect_number();
        expect("]");
        type = new_type_array(type, len);
    }

    // handle function arguments: only the type is needed
    if (consume("(")) {
        type = new_type(ty_func, 0, 0); // Placeholder type
        // skip argument list (simplified)
        while (!consume(")")) {
            // allows void f() or f(void)
            if (consume_keyword("void") && peek()->kind == tk_reserved && peek()->str[0] == ')') continue;

            int is_unsigned = 0, is_static = 0, is_extern = 0;
            ty *base_param = parse_type_specifier(&is_unsigned, &is_static, &is_extern);
            token *dummy_ident = NULL;
            parse_declarator(base_param, &dummy_ident);

            if (consume("...")) {
                type->is_variadic = 1;
                expect(")");
                break;
            }

            if (!consume(")")) expect(",");
            else break;
        }
        type->base = base; // return type is the base type
    }


    return type;
}

// declaration = type_specifier declarator ("=" initializer)? ("," declarator ("=" initializer)? )* ";"
node *declaration(int is_global) {
    int is_unsigned = 0, is_static = 0, is_extern = 0;
    ty *base = parse_type_specifier(&is_unsigned, &is_static, &is_extern);

    node head = {};
    node *cur = &head;

    do {
        token *ident_tok = NULL;
        ty *type = parse_declarator(base, &ident_tok);
        if (!ident_tok) error_tok(current_token, "expected identifier after type");

        if (is_global) {
            gvar *g = calloc(1, sizeof(gvar));
            g->name = strndup(ident_tok->str, ident_tok->len);
            g->size = type->size;
            g->is_extern = is_extern;

            if (consume("=")) {
                if (is_extern) error_tok(ident_tok, "extern declarations cannot be initialized");
                g->initializer = parse_initializer(type);
            }

            g->next = global_vars;
            global_vars = g;

            // no ast node returned for global variable
            continue;
        }

        // local variable declaration
        lvar *var = find_lvar(ident_tok, type, is_static);
        node *lhs = new_lvar_node(var);

        if (consume("=")) {
            if (is_static) {
                // static locals use global initializer logic
                if (is_extern) error_tok(ident_tok, "extern declarations cannot be initialized");

                gvar *g = calloc(1, sizeof(gvar));
                g->name = strdup(var->gname);
                g->size = type->size;
                g->initializer = parse_initializer(type);

                g->next = global_vars;
                global_vars = g;

            } else if (type->kind == ty_array || type->kind == ty_struct) {
                // local array/struct initialization
                node *init_stmt = calloc(1, sizeof(node));
                init_stmt->kind = nd_local_init;
                init_stmt->lhs = lhs; // target variable
                init_stmt->type = lhs->type;
                init_stmt->init_list = parse_initializer(type);

                cur->next = init_stmt;
                cur = cur->next;

            } else {
                // scalar initialization
                node *rhs = assign();
                cur->next = new_node(nd_assign, lhs, rhs);
                cur = cur->next;
            }
        }
    } while (consume(","));

    expect(";");
    return head.next;
}

// stmt = declaration | "if" ... | "while" ... | "for" ... | "return" expr ";" | "break" ";" | "continue" ";" | "switch" ... | "case" ... | "default" ... | "{" block "}" | expr ";" | ";"
node *stmt() {
    if (is_type_token(peek())) return declaration(0);

    if (consume_keyword("return")) {
        node *n = calloc(1, sizeof(node));
        n->kind = nd_return;
        n->lhs = expr();
        expect(";");
        return n;
    }

    if (consume_keyword("if")) {
        expect("(");
        node *cond = expr();
        expect(")");
        node *then = stmt();
        node *els = NULL;
        if (consume_keyword("else")) els = stmt();

        node *n = calloc(1, sizeof(node));
        n->kind = nd_if;
        n->lhs = cond;
        n->rhs = then;
        n->els = els;
        return n;
    }

    if (consume_keyword("while")) {
        int l = label_count++;
        int c = label_count++;

        continue_break_labels *new_labels = calloc(1, sizeof(continue_break_labels));
        new_labels->continue_label = c;
        new_labels->break_label = l;
        new_labels->next = loop_or_switch_labels;
        loop_or_switch_labels = new_labels;

        expect("(");
        node *cond = expr();
        expect(")");
        node *body = stmt();

        loop_or_switch_labels = new_labels->next;

        node *n = calloc(1, sizeof(node));
        n->kind = nd_while;
        n->lhs = cond;
        n->rhs = body;
        n->val = l; // l for break
        n->els = new_num_node(c); // c for continue
        return n;
    }

    if (consume_keyword("for")) {
        int l = label_count++;
        int c = label_count++;

        continue_break_labels *new_labels = calloc(1, sizeof(continue_break_labels));
        new_labels->continue_label = c;
        new_labels->break_label = l;
        new_labels->next = loop_or_switch_labels;
        loop_or_switch_labels = new_labels;

        expect("(");
        node *init = NULL;
        if (!consume(";")) {
            init = is_type_token(peek()) ? declaration(0) : new_node(nd_expr_stmt, expr(), NULL);
            expect(";");
        }

        node *cond = NULL;
        if (!consume(";")) {
            cond = expr();
            expect(";");
        } else {
            cond = new_num_node(1);
        }

        node *inc = NULL;
        if (!consume(")")) {
            inc = expr();
            expect(")");
        }

        node *body = stmt();

        loop_or_switch_labels = new_labels->next;

        node *n = calloc(1, sizeof(node));
        n->kind = nd_for;
        n->lhs = init; // init
        n->rhs = cond; // condition
        n->els = body; // body
        n->next = inc; // increment
        n->val = l; // break label
        n->mem = (member *)new_num_node(c); // continue label (misusing member field to store node*)

        return n;
    }

    if (consume_keyword("break")) {
        if (!loop_or_switch_labels) error_tok(current_token, "break statement not within loop or switch");
        node *n = calloc(1, sizeof(node));
        n->kind = nd_break;
        n->val = loop_or_switch_labels->break_label;
        expect(";");
        return n;
    }

    if (consume_keyword("continue")) {
        if (!loop_or_switch_labels || loop_or_switch_labels->break_label == loop_or_switch_labels->continue_label) error_tok(current_token, "continue statement not within loop");
        node *n = calloc(1, sizeof(node));
        n->kind = nd_continue;
        n->val = loop_or_switch_labels->continue_label;
        expect(";");
        return n;
    }

    if (consume_keyword("switch")) {
        expect("(");
        node *cond = expr();
        expect(")");

        int l = label_count++;
        continue_break_labels *new_labels = calloc(1, sizeof(continue_break_labels));
        new_labels->break_label = l;
        new_labels->continue_label = l; // not used, but sets context
        new_labels->next = loop_or_switch_labels;
        loop_or_switch_labels = new_labels;

        node *body = stmt();

        loop_or_switch_labels = new_labels->next;

        node *n = calloc(1, sizeof(node));
        n->kind = nd_switch;
        n->lhs = cond;
        n->rhs = body;
        n->val = l;
        return n;
    }

    if (consume_keyword("case")) {
        node *n = calloc(1, sizeof(node));
        n->kind = nd_case;
        n->val = expect_number();
        expect(":");
        n->lhs = stmt();
        return n;
    }

    if (consume_keyword("default")) {
        node *n = calloc(1, sizeof(node));
        n->kind = nd_case;
        n->val = 2147483647l + 1; // max int + 1 to denote default
        expect(":");
        n->lhs = stmt();
        return n;
    }

    if (consume("{")) {
        node head = {};
        node *cur = &head;
        while (!consume("}")) {
            cur->next = stmt();
            cur = cur->next;
        }

        node *n = calloc(1, sizeof(node));
        n->kind = nd_block;
        n->next = head.next;
        return n;
    }

    if (consume(";")) {
        // empty statement
        return calloc(1, sizeof(node));
    }

    // expression statement
    node *n = new_node(nd_expr_stmt, expr(), NULL);
    expect(";");
    return n;
}

// fundef_or_global = (type_specifier declarator ";" )* | (type_specifier declarator "{" block)
void parse_fundef_or_global() {
    int is_unsigned = 0, is_static = 0, is_extern = 0;
    ty *base = parse_type_specifier(&is_unsigned, &is_static, &is_extern);

    do {
        token *ident_tok = NULL;
        ty *type = parse_declarator(base, &ident_tok);
        if (!ident_tok) error_tok(current_token, "expected identifier after type");

        if (type->kind == ty_func) {
            // function definition
            if (consume("{")) {
                function *func = calloc(1, sizeof(function));
                func->name = strndup(ident_tok->str, ident_tok->len);
                func->is_static = is_static;
                func->is_variadic = type->is_variadic;

                current_func = func;
                current_func->stack_size = 0;
                func->body = stmt();
                func->num_params = 0;

                // reset local stack for function
                current_func = NULL;

                // link function to program head
                func->next = program_head;
                program_head = func;

            } else {
                // function declaration
                expect(";");
            }
            return;
        }

        // global variable declaration
        if (is_extern) {
            expect(";");
        } else {
            node *global_decl = declaration(1);
            if (global_decl) {
                // This shouldn't happen, as declaration(1) handles globals internally.
                error_tok(current_token, "unexpected node from global declaration");
            }
        }
    } while (is_type_token(peek()));
}

// --- x. code generator (x86-64 assembly) ---

// registers used for parameter passing
char *argreg[] = {"rdi", "rsi", "rdx", "rcx", "r8", "r9"};

int get_size(ty *type) {
    if (type->kind == ty_array) return type->base->size;
    return type->size;
}

void emit_gvar_initializer(sinit *init, ty *type) {
    if (init->kind == init_struct || init->kind == init_array) {
        int offset = 0;
        for (sinit *child = init->children; child; child = child->next) {
            int padding = child->offset - offset;
            if (padding > 0) printf("  .zero %d\n", padding);
            emit_gvar_initializer(child, child->type);
            offset = child->offset + child->size;
        }
        int padding = type->size - offset;
        if (padding > 0) printf("  .zero %d\n", padding);
        return;
    }

    if (init->kind == init_int) {
        if (type->size == 1) printf("  .byte %ld\n", init->val);
        else if (type->size == 4) printf("  .long %ld\n", init->val);
        else printf("  .quad %ld\n", init->val);
        return;
    }

    if (init->kind == init_ptr) {
        printf("  .quad %s\n", init->str_label);
        return;
    }

    if (init->kind == init_string) {
        // print string content as ascii, followed by null terminator
        printf("  .ascii \"%s\"\n", init->str_content);
        printf("  .byte 0\n");
        return;
    }

    if (init->kind == init_zero) {
        printf("  .zero %d\n", init->size);
        return;
    }
}

// pushes the address of a variable onto the stack
void emit_addr(node *n) {
    if (n->kind == nd_lvar) {
        if (n->var->is_static) {
            printf("  lea rax, %s[rip]\n", n->var->gname);
        } else {
            printf("  lea rax, [rbp - %d]\n", n->var->offset);
        }
        printf("  push rax\n");
        return;
    }

    if (n->kind == nd_deref) {
        emit_expr(n->lhs);
        return;
    }

    if (n->kind == nd_member) {
        emit_addr(n->lhs);
        printf("  pop rax\n");
        printf("  add rax, %d\n", n->mem->offset);
        printf("  push rax\n");
        return;
    }

    error_tok(current_token, "cannot get address of non-lvalue expression");
}

// loads value from the address on stack top
void emit_load(ty *type) {
    printf("  pop rax\n");
    if (type->kind == ty_array || type->kind == ty_struct) return;

    if (type->size == 1) {
        printf("  movsx rax, byte ptr [rax]\n");
    } else if (type->size == 4) {
        printf("  movsxd rax, dword ptr [rax]\n");
    } else {
        printf("  mov rax, [rax]\n");
    }
    printf("  push rax\n");
}

// stores value (rdi) to the address (rax) on stack top
void emit_store(ty *type) {
    printf("  pop rdi\n");
    printf("  pop rax\n");

    if (type->kind == ty_array || type->kind == ty_struct) {
        // block copy for struct/array
        printf("  mov rcx, %d\n", type->size);
        printf("  mov r8, rax\n");
        printf("  mov r9, rdi\n");
        printf(".lcopy%d:\n", label_count);
        printf("  cmp rcx, 0\n");
        printf("  je .lend%d\n", label_count);
        printf("  mov al, [r9]\n");
        printf("  mov [r8], al\n");
        printf("  inc r9\n");
        printf("  inc r8\n");
        printf("  dec rcx\n");
        printf("  jmp .lcopy%d\n", label_count);
        printf(".lend%d:\n", label_count++);
        printf("  push rdi\n");
        return;
    }

    if (type->size == 1) {
        printf("  mov [rax], dil\n");
    } else if (type->size == 4) {
        printf("  mov [rax], edi\n");
    } else {
        printf("  mov [rax], rdi\n");
    }
    printf("  push rdi\n");
}

// local array/struct initializer emitter
void emit_local_initializer(node *n, sinit *init_list) {
    emit_addr(n->lhs); // push address of the target variable

    for (sinit *init = init_list; init; init = init->next) {
        if (init->kind == init_int) {
            printf("  pop rax\n");
            printf("  mov rdi, %ld\n", init->val);
            printf("  mov rsi, rax\n");
            printf("  add rsi, %d\n", init->offset);
            printf("  mov [rsi], rdi\n");
            printf("  push rax\n");
        } else if (init->kind == init_ptr) {
            printf("  pop rax\n");
            printf("  mov rdi, %s\n", init->str_label);
            printf("  mov rsi, rax\n");
            printf("  add rsi, %d\n", init->offset);
            printf("  mov [rsi], rdi\n");
            printf("  push rax\n");
        } else if (init->kind == init_struct || init->kind == init_array) {
            // recursive calls for nested struct/array
            emit_local_initializer(n, init->children);
        } else {
            error_tok(current_token, "unsupported local initializer kind");
        }
    }
}

// generates code for an ast node
void emit_expr(node *n) {
    add_type(n);

    switch (n->kind) {
        case nd_num:
            printf("  push %ld\n", n->val);
            return;
        case nd_lvar:
            emit_addr(n);
            if (n->type->kind != ty_array && n->type->kind != ty_func) emit_load(n->type);
            return;
        case nd_member:
            emit_addr(n);
            if (n->type->kind != ty_array) emit_load(n->type);
            return;
        case nd_assign:
            emit_addr(n->lhs);
            emit_expr(n->rhs);
            emit_store(n->type);
            return;
        case nd_addr:
            emit_addr(n->lhs);
            return;
        case nd_deref:
            emit_expr(n->lhs);
            if (n->type->kind != ty_array && n->type->kind != ty_struct) emit_load(n->type);
            return;
        case nd_funcall: {
            int arg_count = 0;
            for (node *arg = n->rhs; arg; arg = arg->next) {
                emit_expr(arg);
                arg_count++;
            }
            for (int i = arg_count - 1; i >= 0; i--) {
                printf("  pop %s\n", argreg[i]);
            }
            printf("  mov rax, 0\n"); // set number of float arguments to 0
            printf("  call %s\n", n->name);
            printf("  push rax\n");
            return;
        }

        // compound assignments (op=)
        case nd_add_assign: case nd_sub_assign:
        case nd_mul_assign: case nd_div_assign: case nd_mod_assign:
        case nd_shl_assign: case nd_shr_assign:
        case nd_band_assign: case nd_bor_assign: case nd_bxor_assign: {
            emit_addr(n->lhs); // [addr]
            printf("  push [rsp]\n"); // [addr, addr]
            emit_load(n->type); // [addr, lhs_val]
            emit_expr(n->rhs); // [addr, lhs_val, rhs_val]
            printf("  pop rdi\n"); // [addr, lhs_val], rdi = rhs_val
            printf("  pop rax\n"); // [addr], rax = lhs_val

            // perform operation
            if (n->kind == nd_add_assign) printf("  add rax, rdi\n");
            else if (n->kind == nd_sub_assign) printf("  sub rax, rdi\n");
            else if (n->kind == nd_mul_assign) printf("  imul rax, rdi\n");
            else if (n->kind == nd_div_assign) {
                printf("  cqo\n");
                printf("  idiv rdi\n");
            } else if (n->kind == nd_mod_assign) {
                printf("  cqo\n");
                printf("  idiv rdi\n");
                printf("  mov rax, rdx\n"); // remainder in rdx
            } else if (n->kind == nd_shl_assign) printf("  mov cl, dil\n  shl rax, cl\n");
            else if (n->kind == nd_shr_assign) printf("  mov cl, dil\n  sar rax, cl\n");
            else if (n->kind == nd_band_assign) printf("  and rax, rdi\n");
            else if (n->kind == nd_bor_assign) printf("  or rax, rdi\n");
            else if (n->kind == nd_bxor_assign) printf("  xor rax, rdi\n");

            printf("  push rax\n"); // [addr, result]
            emit_store(n->type); // [result]
            return;
        }

        case nd_cond: {
            emit_expr(n->lhs); // condition
            printf("  pop rax\n");
            int els_label = label_count++;
            int end_label = label_count++;
            printf("  cmp rax, 0\n");
            printf("  je .l%d\n", els_label);

            emit_expr(n->rhs); // then
            printf("  jmp .l%d\n", end_label);

            printf(".l%d:\n", els_label);
            emit_expr(n->els); // else

            printf(".l%d:\n", end_label);
            return;
        }

        default:
            break;
    }

    emit_expr(n->lhs);
    emit_expr(n->rhs);

    printf("  pop rdi\n");
    printf("  pop rax\n");

    if (n->kind == nd_add) {
        if (n->type->kind == ty_ptr || n->type->kind == ty_array) {
            printf("  imul rdi, %d\n", n->type->base->size);
        }
        printf("  add rax, rdi\n");
    } else if (n->kind == nd_sub) {
        if (n->lhs->type->kind == ty_ptr || n->lhs->type->kind == ty_array) {
            // pointer subtraction: (p1 - p2) / sizeof(base)
            if (n->rhs->type->kind == ty_ptr || n->rhs->type->kind == ty_array) {
                printf("  sub rax, rdi\n");
                printf("  mov rdi, %d\n", n->lhs->type->base->size);
                printf("  cqo\n");
                printf("  idiv rdi\n");
            } else {
                // pointer/int subtraction
                printf("  imul rdi, %d\n", n->lhs->type->base->size);
                printf("  sub rax, rdi\n");
            }
        } else {
            printf("  sub rax, rdi\n");
        }
    } else if (n->kind == nd_mul) {
        printf("  imul rax, rdi\n");
    } else if (n->kind == nd_div) {
        printf("  cqo\n");
        printf("  idiv rdi\n");
    } else if (n->kind == nd_mod) {
        printf("  cqo\n");
        printf("  idiv rdi\n");
        printf("  mov rax, rdx\n"); // remainder is in rdx
    } else if (n->kind == nd_eq) {
        printf("  cmp rax, rdi\n");
        printf("  sete al\n");
        printf("  movzb rax, al\n");
    } else if (n->kind == nd_ne) {
        printf("  cmp rax, rdi\n");
        printf("  setne al\n");
        printf("  movzb rax, al\n");
    } else if (n->kind == nd_lt) {
        printf("  cmp rax, rdi\n");
        printf("  setl al\n");
        printf("  movzb rax, al\n");
    } else if (n->kind == nd_le) {
        printf("  cmp rax, rdi\n");
        printf("  setle al\n");
        printf("  movzb rax, al\n");
    } else if (n->kind == nd_shl) {
        printf("  mov cl, dil\n");
        printf("  shl rax, cl\n");
    } else if (n->kind == nd_shr) {
        printf("  mov cl, dil\n");
        printf("  sar rax, cl\n");
    } else if (n->kind == nd_band) {
        printf("  and rax, rdi\n");
    } else if (n->kind == nd_bor) {
        printf("  or rax, rdi\n");
    } else if (n->kind == nd_bxor) {
        printf("  xor rax, rdi\n");
    } else if (n->kind == nd_logical_and) {
        printf("  cmp rax, 0\n");
        printf("  setne al\n");
        printf("  cmp rdi, 0\n");
        printf("  setne dil\n");
        printf("  and al, dil\n");
        printf("  movzb rax, al\n");
    } else if (n->kind == nd_logical_or) {
        printf("  cmp rax, 0\n");
        printf("  setne al\n");
        printf("  cmp rdi, 0\n");
        printf("  setne dil\n");
        printf("  or al, dil\n");
        printf("  movzb rax, al\n");
    }

    printf("  push rax\n");
}

void emit_stmt(node *n) {
    if (!n) return;

    switch (n->kind) {
        case nd_return:
            emit_expr(n->lhs);
            printf("  pop rax\n");
            printf("  mov rsp, rbp\n");
            printf("  pop rbp\n");
            printf("  ret\n");
            return;
        case nd_expr_stmt:
            emit_expr(n->lhs);
            printf("  pop rax\n");
            return;
        case nd_block:
        case nd_local_init: {
            for (node *cur = n->next; cur; cur = cur->next) {
                if (cur->kind == nd_local_init) {
                    emit_local_initializer(cur, cur->init_list);
                } else {
                    emit_stmt(cur);
                }
            }
            return;
        }
        case nd_if: {
            emit_expr(n->lhs);
            printf("  pop rax\n");
            int els_label = label_count++;
            int end_label = label_count++;
            printf("  cmp rax, 0\n");
            printf("  je .l%d\n", els_label);
            emit_stmt(n->rhs); // then
            printf("  jmp .l%d\n", end_label);
            printf(".l%d:\n", els_label);
            emit_stmt(n->els); // else
            printf(".l%d:\n", end_label);
            return;
        }
        case nd_while: {
            int loop = (int)n->val;
            int cont = (int)n->els->val;
            printf(".l%d:\n", cont); // continue target
            emit_expr(n->lhs); // condition
            printf("  pop rax\n");
            printf("  cmp rax, 0\n");
            printf("  je .l%d\n", loop);
            emit_stmt(n->rhs); // body
            printf("  jmp .l%d\n", cont);
            printf(".l%d:\n", loop); // break target
            return;
        }
        case nd_for: {
            int loop = (int)n->val;
            int cont = (int)n->mem->val;
            emit_stmt(n->lhs); // init
            printf(".l%d:\n", cont); // continue target
            emit_expr(n->rhs); // condition
            printf("  pop rax\n");
            printf("  cmp rax, 0\n");
            printf("  je .l%d\n", loop);
            emit_stmt(n->els); // body
            emit_expr(n->next); // increment
            printf("  pop rax\n");
            printf("  jmp .l%d\n", cont);
            printf(".l%d:\n", loop); // break target
            return;
        }
        case nd_break:
            printf("  jmp .l%ld\n", n->val);
            return;
        case nd_continue:
            printf("  jmp .l%ld\n", n->val);
            return;
        case nd_switch: {
            emit_expr(n->lhs); // condition
            printf("  pop r10\n"); // save condition value in r10

            node *cur = n->rhs;
            while (cur) {
                if (cur->kind == nd_case) {
                    printf("  cmp r10, %ld\n", cur->val);
                    printf("  je .l%ld\n", cur->val);
                }
                cur = cur->next;
            }

            // no match, jump to break label (default)
            printf("  jmp .l%ld\n", n->val);

            // emit case bodies
            cur = n->rhs;
            while (cur) {
                if (cur->kind == nd_case) {
                    printf(".l%ld:\n", cur->val);
                    emit_stmt(cur->lhs);
                }
                cur = cur->next;
            }

            printf(".l%ld:\n", n->val); // break label
            return;
        }
        default: break;
    }
}

void codegen_program(function *funcs) {
    printf(".intel_syntax noprefix\n");

    // 1. global variable definitions
    gvar *cur_gvar = global_vars;
    while (cur_gvar) {
        if (!cur_gvar->is_extern) {
            printf(".data\n");
            printf(".globl %s\n", cur_gvar->name);
            printf(".type %s, @object\n", cur_gvar->name);
            printf(".size %s, %d\n", cur_gvar->name, cur_gvar->size);
            printf("%s:\n", cur_gvar->name);
            if (cur_gvar->initializer) {
                emit_gvar_initializer(cur_gvar->initializer, new_type(ty_void, cur_gvar->size, 1));
            } else {
                printf("  .zero %d\n", cur_gvar->size);
            }
        }
        cur_gvar = cur_gvar->next;
    }

    // 2. function definitions
    printf(".text\n");
    function *func = funcs;
    while (func) {
        if (!func->is_static) printf(".globl %s\n", func->name);
        printf(".type %s, @function\n", func->name);
        printf("%s:\n", func->name);

        // prologue
        printf("  push rbp\n");
        printf("  mov rbp, rsp\n");
        printf("  sub rsp, %d\n", align_to(func->stack_size, 16));

        // 6 parameters max (rdi, rsi, rdx, rcx, r8, r9)
        int param_count = 0;
        for (lvar *l = func->locals; l; l = l->next) {
            if (l->offset != 0 && param_count < 6) {
                printf("  mov [rbp - %d], %s\n", l->offset, argreg[param_count++]);
                func->num_params++;
            }
        }

        // body
        emit_stmt(func->body);

        // epilogue
        printf("  mov rsp, rbp\n");
        printf("  pop rbp\n");
        printf("  ret\n");

        func = func->next;
    }
}

// --- main driver ---

int main(int argc, char **argv) {
    if (argc < 2) {
        fprintf(stderr, "usage: cc file.c\n");
        return 1;
    }

    // concatenate all input files into one buffer with preprocessing
    char *combined = NULL;
    size_t combined_len = 0;
    for (int i = 1; i < argc; i++) {
        char *buf = read_file_to_buffer(argv[i]);
        // preprocess includes and macros per file (simplified)
        char *pp = preprocess_includes_and_macros(buf, 0);
        free(buf);

        if (!combined) {
            combined = pp;
            combined_len = strlen(combined);
        } else {
            size_t newlen = combined_len + strlen(pp) + 2;
            combined = realloc(combined, newlen);
            if (!combined) { perror("realloc"); exit(1); }
            // add a newline to separate files in the buffer
            combined[combined_len++] = '\n';
            memcpy(combined + combined_len, pp, strlen(pp));
            combined_len += strlen(pp);
            combined[combined_len] = '\0';
            free(pp);
        }
    }

    user_input = combined;

    // tokenize
    token *tok = tokenize(user_input);
    current_token = tok;

    // parse all function definitions and global declarations until eof
    while (current_token->kind != tk_eof) {
        parse_fundef_or_global();
    }

    // generate code
    codegen_program(program_head);

    return 0;
}
