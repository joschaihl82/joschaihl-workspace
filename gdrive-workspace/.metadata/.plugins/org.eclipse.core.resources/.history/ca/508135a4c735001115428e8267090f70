/* ---------------------------
   HTTP helpers
   --------------------------- */
static int http_post(const char *url, const char *postfields, struct mem *out, struct curl_slist *headers) {
    CURL *curl = curl_easy_init();
    if (!curl) return -1;
    curl_easy_setopt(curl, CURLOPT_URL, url);
    curl_easy_setopt(curl, CURLOPT_POSTFIELDS, postfields);
    curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, write_cb);
    curl_easy_setopt(curl, CURLOPT_WRITEDATA, out);
    if (headers) curl_easy_setopt(curl, CURLOPT_HTTPHEADER, headers);
    CURLcode res = curl_easy_perform(curl);
    curl_easy_cleanup(curl);
    return (res == CURLE_OK) ? 0 : -1;
}

static int http_get_auth(const char *url, const char *bearer, struct mem *out) {
    CURL *curl = curl_easy_init();
    if (!curl) return -1;
    struct curl_slist *hdrs = NULL;
    char auth[1024];
    snprintf(auth, sizeof(auth), "Authorization: Bearer %s", bearer);
    hdrs = curl_slist_append(hdrs, auth);
    curl_easy_setopt(curl, CURLOPT_URL, url);
    curl_easy_setopt(curl, CURLOPT_HTTPHEADER, hdrs);
    curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, write_cb);
    curl_easy_setopt(curl, CURLOPT_WRITEDATA, out);
    CURLcode res = curl_easy_perform(curl);
    curl_slist_free_all(hdrs);
    curl_easy_cleanup(curl);
    return (res == CURLE_OK) ? 0 : -1;
}

/* ---------------------------
   Filesystem helpers
   --------------------------- */
static int save_file(const char *path, const char *data, size_t len) {
    FILE *f = fopen(path, "wb");
    if (!f) return -1;
    if (fwrite(data, 1, len, f) != len) { fclose(f); return -1; }
    fclose(f);
    return 0;
}

static int ensure_dir_recursive(const char *path) {
    char tmp[4096];
    snprintf(tmp, sizeof(tmp), "%s", path);
    for (char *p = tmp + 1; *p; p++) {
        if (*p == '/') {
            *p = 0;
            if (mkdir(tmp, 0755) && errno != EEXIST) return -1;
            *p = '/';
        }
    }
    if (mkdir(tmp, 0755) && errno != EEXIST) return -1;
    return 0;
}

static int save_path_create(const char *fullpath) {
    char *dir = strdup(fullpath);
    if (!dir) return -1;
    char *slash = strrchr(dir, '/');
    if (slash) {
        *slash = 0;
        if (ensure_dir_recursive(dir) != 0) { free(dir); return -1; }
    }
    free(dir);
    return 0;
}

/* ---------------------------
   OAuth: Refresh token -> Access token
   --------------------------- */
static int refresh_access_token(const char *refresh_token, char **out_access_token, int *out_expires_in) {
    if (!CLIENT_ID || !CLIENT_SECRET || !refresh_token) return -1;
    char post[4096];
    snprintf(post, sizeof(post),
             "client_id=%s&client_secret=%s&refresh_token=%s&grant_type=refresh_token",
             CLIENT_ID, CLIENT_SECRET, refresh_token);

    struct mem resp = {0};
    struct curl_slist *hdrs = curl_slist_append(NULL, "Content-Type: application/x-www-form-urlencoded");
    int rc = http_post(OAUTH2_TOKEN_URL, post, &resp, hdrs);
    curl_slist_free_all(hdrs);
    if (rc != 0) { if (resp.data) free(resp.data); return -1; }

    json_error_t jerr;
    json_t *root = json_loads(resp.data ? resp.data : "{}", 0, &jerr);
    free(resp.data);
    if (!root) return -1;

    json_t *err = json_object_get(root, "error");
    if (err) {
        const char *estr = json_string_value(err);
        json_t *ed = json_object_get(root, "error_description");
        const char *edstr = ed ? json_string_value(ed) : NULL;
        fprintf(stderr, "Token endpoint error: %s %s\n", estr ? estr : "", edstr ? edstr : "");
        json_decref(root);
        return -1;
    }

    const char *at = json_string_value(json_object_get(root, "access_token"));
    int ex = json_integer_value(json_object_get(root, "expires_in"));
    if (at) *out_access_token = strdup(at);
    if (out_expires_in) *out_expires_in = ex;
    json_decref(root);
    return (at) ? 0 : -1;
}

/* ---------------------------
   Export mime mapping
   --------------------------- */
static const char *export_mime_for(const char *mime) {
    if (strcmp(mime, "application/vnd.google-apps.document") == 0) return "application/pdf";
    if (strcmp(mime, "application/vnd.google-apps.spreadsheet") == 0) return "text/csv";
    if (strcmp(mime, "application/vnd.google-apps.presentation") == 0) return "application/pdf";
    return NULL;
}

/* ---------------------------
   Download helpers
   --------------------------- */
static int download_file_content(const char *fileId, const char *mimeType, const char *bearer, struct mem *out) {
    char url[1024];
    const char *export_mime = export_mime_for(mimeType);
    if (export_mime) {
        char *esc = curl_easy_escape(NULL, export_mime, 0);
        snprintf(url, sizeof(url), DRIVE_API "/files/%s/export?mimeType=%s", fileId, esc);
        curl_free(esc);
    } else {
        snprintf(url, sizeof(url), DRIVE_API "/files/%s?alt=media", fileId);
    }
    return http_get_auth(url, bearer, out);
}

static int write_downloaded_file(const char *base_dir, const char *rel_path, const char *data, size_t len) {
    char full[4096];
    snprintf(full, sizeof(full), "%s/%s", base_dir, rel_path);
    if (save_path_create(full) != 0) return -1;
    return save_file(full, data, len);
}

/* ---------------------------
   Traverse & download recursively
   --------------------------- */
static int traverse_and_download(const char *parentId, const char *base_dir, const char *path_prefix, const char *bearer) {
    char q[1024];
    snprintf(q, sizeof(q), "('%s' in parents) and trashed=false", parentId);
    char url[2048];
    char *qenc = curl_easy_escape(NULL, q, 0);
    snprintf(url, sizeof(url), DRIVE_API "/files?pageSize=1000&q=%s&fields=nextPageToken,files(id,name,mimeType,parents)", qenc);
    curl_free(qenc);

    struct mem out = {0};
    if (http_get_auth(url, bearer, &out) != 0) {
        if (out.data) free(out.data);
        return -1;
    }

    json_error_t err;
    json_t *resp = json_loads(out.data ? out.data : "{}", 0, &err);
    free(out.data);
    if (!resp) return -1;

    json_t *files = json_object_get(resp, "files");
    if (!files) { json_decref(resp); return 0; }

    size_t idx;
    json_t *f;
    json_array_foreach(files, idx, f) {
        const char *id = json_string_value(json_object_get(f, "id"));
        const char *name = json_string_value(json_object_get(f, "name"));
        const char *mime = json_string_value(json_object_get(f, "mimeType"));
        if (!id || !name || !mime) continue;
        char relpath[4096];
        if (path_prefix && strlen(path_prefix) > 0) snprintf(relpath, sizeof(relpath), "%s/%s", path_prefix, name);
        else snprintf(relpath, sizeof(relpath), "%s", name);

        if (strncmp(mime, "application/vnd.google-apps.folder", 34) == 0) {
            char dirfull[4096];
            snprintf(dirfull, sizeof(dirfull), "%s/%s", base_dir, relpath);
            ensure_dir_recursive(dirfull);
            traverse_and_download(id, base_dir, relpath, bearer);
        } else {
            struct mem filedata = {0};
            if (download_file_content(id, mime, bearer, &filedata) == 0) {
                const char *export_mime = export_mime_for(mime);
                char save_rel[4096];
                if (export_mime) {
                    const char *ext = strstr(export_mime, "pdf") ? ".pdf" : (strstr(export_mime, "csv") ? ".csv" : ".bin");
                    snprintf(save_rel, sizeof(save_rel), "%s%s", relpath, ext);
                } else {
                    snprintf(save_rel, sizeof(save_rel), "%s", relpath);
                }
                if (write_downloaded_file(base_dir, save_rel, filedata.data, filedata.size) != 0) {
                    fprintf(stderr, "Failed to save %s\n", save_rel);
                } else {
                    printf("Saved: %s\n", save_rel);
                }
                free(filedata.data);
            } else {
                fprintf(stderr, "Failed to download file %s (%s)\n", name, id);
            }
        }
    }

    json_decref(resp);
    return 0;
}

/* ---------------------------
   Main
   --------------------------- */
int main(void) {
    curl_global_init(CURL_GLOBAL_DEFAULT);

    if (!CLIENT_ID || !CLIENT_SECRET || !REFRESH_TOKEN ||
        strcmp(CLIENT_ID, "REPLACE_WITH_YOUR_CLIENT_ID") == 0 ||
        strcmp(CLIENT_SECRET, "REPLACE_WITH_YOUR_CLIENT_SECRET") == 0 ||
        strcmp(REFRESH_TOKEN, "REPLACE_WITH_YOUR_REFRESH_TOKEN") == 0) {
        fprintf(stderr, "CLIENT_ID, CLIENT_SECRET or REFRESH_TOKEN not set. Edit gdrive.c and replace placeholders.\n");
        return 1;
    }

    const char *home = getenv(BASE_DIR_ENV);
    if (!home) { fprintf(stderr, "HOME not set\n"); return 1; }
    char base_dir[4096];
    snprintf(base_dir, sizeof(base_dir), "%s/%s", home, TARGET_SUBDIR);
    ensure_dir_recursive(base_dir);

    char *access_token = NULL;
    int expires = 0;
    if (refresh_access_token(REFRESH_TOKEN, &access_token, &expires) != 0) {
        fprintf(stderr, "Failed to obtain access token from refresh token.\n");
        curl_global_cleanup();
        return 1;
    }

    if (!access_token) {
        fprintf(stderr, "No access token obtained\n");
        curl_global_cleanup();
        return 1;
    }

    if (traverse_and_download("root", base_dir, "", access_token) != 0) {
        fprintf(stderr, "Error during traversal\n");
    }

    free(access_token);
    curl_global_cleanup();
    return 0;
}
