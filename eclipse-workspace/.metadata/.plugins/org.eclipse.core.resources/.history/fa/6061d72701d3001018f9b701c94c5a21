    time_t start_time_epoch;          // time at the start of the current epoch
    double accumulated_time_total;    // total accumulated time across all batches (seconds)
    double accumulated_time_epoch;    // accumulated time in current epoch (seconds)
    double time_per_batch_avg;        // moving average time per batch (seconds)
} timer_state;


// --- utility functions for timing and progress bar ---

/**
 * @brief converts seconds to DD::HH::MM::SS format.
 */
void format_time(double seconds, char * buffer, size_t buffer_size) {
    long days = (long)(seconds / 86400);
    seconds -= (double)(days * 86400);
    long hours = (long)(seconds / 3600);
    seconds -= (double)(hours * 3600);
    long minutes = (long)(seconds / 60);
    seconds -= (double)(minutes * 60);
    long secs = (long)seconds;

    snprintf(buffer, buffer_size, "%ld::%02ld::%02ld::%02ld", days, hours, minutes, secs);
}

/**
 * @brief displays a detailed progress bar with loss and time metrics.
 */
void print_progress_bar(
    const timer_state * timer,
    int epoch, int total_epochs,
    int batch_idx, int total_batches,
    int iteration, int total_iterations,
    float loss
) {
    const int bar_width = 40;
    double progress = (double)(batch_idx + 1) / total_batches;
    int filled_width = (int)(progress * bar_width);

    // 1. render the bar
    fprintf(stderr, "\r[");
    for (int i = 0; i < bar_width; ++i) {
        if (i < filled_width) {
            fprintf(stderr, "=");
        } else if (i == filled_width) {
            fprintf(stderr, ">");
        } else {
            fprintf(stderr, " ");
        }
    }
    fprintf(stderr, "] %.1f%%", progress * 100.0);

    // 2. calculate time metrics
    char time_elapsed_str[32];
    char time_epoch_str[32];
    char time_total_str[32];

    // average time calculation
    double total_elapsed_s = timer->accumulated_time_total;
    double time_per_batch = timer->time_per_batch_avg;

    // epoch eta
    double batches_remaining_epoch = total_batches - (batch_idx + 1);
    double eta_epoch_s = batches_remaining_epoch * time_per_batch;

    // total eta
    double total_batches_done = (double)iteration;
    double total_batches_remaining = (double)total_iterations - total_batches_done;
    double eta_total_s = total_batches_remaining * time_per_batch;

    format_time(total_elapsed_s, time_elapsed_str, sizeof(time_elapsed_str));
    format_time(eta_epoch_s, time_epoch_str, sizeof(time_epoch_str));
    format_time(eta_total_s, time_total_str, sizeof(time_total_str));

    // 3. print detailed metrics
    fprintf(stderr, " | epoch: %d/%d", epoch + 1, total_epochs);
    fprintf(stderr, " | iter: %d/%d", batch_idx + 1, total_batches);
    fprintf(stderr, " | loss: %.4f", loss);
    fprintf(stderr, " | elapsed: %s", time_elapsed_str);
    fprintf(stderr, " | batch_time: %.4fs", time_per_batch);
    fprintf(stderr, " | ETA(epoch): %s", time_epoch_str);
    fprintf(stderr, " | ETA(total): %s", time_total_str);

    fflush(stderr);
}


