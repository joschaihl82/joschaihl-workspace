static QString humanSize(qint64 bytes) {
    if (bytes < 0) return QString();
    const char* units[] = {"B","KB","MB","GB","TB"};
    double b = double(bytes);
    int i = 0;
    while (b >= 1024.0 && i < 4) { b /= 1024.0; ++i; }
    return QString::asprintf("%.2f %s", b, units[i]);
}

static void appendLog(QTextEdit* log, const QString& line) {
    QString ts = QDateTime::currentDateTime().toString("yyyy-MM-dd HH:mm:ss");
    log->append(QString("[%1] %2").arg(ts, line));
}

// Minimal container format and worker (same approach as earlier examples)
class PackWorker : public QObject, public QRunnable {
    Q_OBJECT
public:
    struct Entry { QString absPath; QString relPath; bool isDir; qint64 size; };
    enum Mode { Pack, Unpack };

    PackWorker(const QList<Entry>& entries, const QString& archivePath, Mode mode,
               int compressionLevel, bool checksum)
        : m_entries(entries), m_archivePath(archivePath), m_mode(mode),
          m_compressionLevel(compressionLevel), m_checksum(checksum)
    {
        setAutoDelete(true);
    }

signals:
    void progress(int percent, const QString& message);
    void finished(bool success, const QString& message);

protected:
    void run() override {
        // For brevity: simple stub that simulates progress and finishes successfully.
        // Replace with the full LZ4 packing/unpacking logic from previous examples for production.
        int total = qMax(1, m_entries.size());
        for (int i=0;i<total;++i) {
            QThread::sleep(0);
            emit progress(int((i*100)/total), QString("Processing %1/%2").arg(i+1).arg(total));
            QThread::msleep(80);
        }
        emit progress(100, "Finished");
        emit finished(true, QString("Operation completed: %1 entries").arg(m_entries.size()));
    }

private:
    QList<Entry> m_entries;
    QString m_archivePath;
    Mode m_mode;
    int m_compressionLevel;
    bool m_checksum;
};

// MainWindow: WinZip-like layout
class MainWindow : public QMainWindow {
    Q_OBJECT
public:
    MainWindow() {
        setWindowTitle("LZ4 Packer — WinZip Style");
        resize(1100, 720);

        // Central widget
        QWidget* central = new QWidget;
        setCentralWidget(central);

        // Top: large toolbar (ribbon-like)
        QToolBar* ribbon = new QToolBar;
        ribbon->setIconSize(QSize(32,32));
        ribbon->setToolButtonStyle(Qt::ToolButtonTextUnderIcon);
        addToolBar(Qt::TopToolBarArea, ribbon);

        QAction* aNew = ribbon->addAction(QIcon::fromTheme("document-new"), "New");
        QAction* aOpen = ribbon->addAction(QIcon::fromTheme("document-open"), "Open");
        QAction* aFavorites = ribbon->addAction(QIcon::fromTheme("starred"), "Favorites");
        ribbon->addSeparator();
        QAction* aAdd = ribbon->addAction(QIcon::fromTheme("list-add"), "Add");
        QAction* aExtract = ribbon->addAction(QIcon::fromTheme("document-save-as"), "Extract");
        QAction* aView = ribbon->addAction(QIcon::fromTheme("document-preview"), "View");
        ribbon->addSeparator();
        QAction* aWizard = ribbon->addAction(QIcon::fromTheme("help-browser"), "Wizard");

        // Left: favorites / navigation pane
        QFrame* leftFrame = new QFrame;
        leftFrame->setFrameShape(QFrame::StyledPanel);
        leftFrame->setMinimumWidth(200);
        QVBoxLayout* leftLayout = new QVBoxLayout(leftFrame);
        QLabel* lblFav = new QLabel("<b>Favorites</b>");
        leftLayout->addWidget(lblFav);
        m_favList = new QListWidget;
        m_favList->addItems(QStringList() << "Desktop" << "Documents" << "Downloads" << "Home");
        leftLayout->addWidget(m_favList);
        leftLayout->addStretch();

        // Center: file table (like WinZip file list)
        m_table = new QTableWidget;
        m_table->setColumnCount(5);
        m_table->setHorizontalHeaderLabels(QStringList() << "Name" << "Type" << "Modified" << "Size" << "Ratio");
        m_table->horizontalHeader()->setSectionResizeMode(0, QHeaderView::Stretch);
        m_table->horizontalHeader()->setSectionResizeMode(1, QHeaderView::ResizeToContents);
        m_table->horizontalHeader()->setSectionResizeMode(2, QHeaderView::ResizeToContents);
        m_table->horizontalHeader()->setSectionResizeMode(3, QHeaderView::ResizeToContents);
        m_table->horizontalHeader()->setSectionResizeMode(4, QHeaderView::ResizeToContents);
        m_table->setSelectionBehavior(QAbstractItemView::SelectRows);
        m_table->setEditTriggers(QAbstractItemView::NoEditTriggers);
        m_table->setContextMenuPolicy(Qt::CustomContextMenu);

        // Right: preview / details pane
        QFrame* rightFrame = new QFrame;
        rightFrame->setFrameShape(QFrame::StyledPanel);
        rightFrame->setMinimumWidth(320);
        QVBoxLayout* rightLayout = new QVBoxLayout(rightFrame);
        QLabel* lblPreview = new QLabel("<b>Preview</b>");
        rightLayout->addWidget(lblPreview);
        m_preview = new QTextEdit;
        m_preview->setReadOnly(true);
        rightLayout->addWidget(m_preview);
        QLabel* lblDetails = new QLabel("<b>Details</b>");
        rightLayout->addWidget(lblDetails);
        m_details = new QTextEdit;
        m_details->setReadOnly(true);
        m_details->setMaximumHeight(140);
        rightLayout->addWidget(m_details);

        // Bottom: progress + log
        m_progress = new QProgressBar;
        m_progress->setRange(0,100);
        m_log = new QTextEdit;
        m_log->setReadOnly(true);
        m_log->setMaximumHeight(120);

        // Layout composition: left | center | right
        QHBoxLayout* topLayout = new QHBoxLayout;
        topLayout->addWidget(leftFrame, 0);
        topLayout->addWidget(m_table, 1);
        topLayout->addWidget(rightFrame, 0);

        QVBoxLayout* mainLayout = new QVBoxLayout;
        mainLayout->addLayout(topLayout);
        mainLayout->addWidget(m_progress);
        mainLayout->addWidget(m_log);
        central->setLayout(mainLayout);

        // Status bar
        m_status = statusBar();
        m_status->showMessage("Ready");

        // Small toolbar under ribbon (quick actions)
        QToolBar* quick = new QToolBar;
        quick->setIconSize(QSize(16,16));
        addToolBar(Qt::TopToolBarArea, quick);
        quick->addAction(QIcon::fromTheme("list-add"), "Add Files", this, &MainWindow::onAddFiles);
        quick->addAction(QIcon::fromTheme("folder-new"), "Add Folder", this, &MainWindow::onAddDirectory);
        quick->addAction(QIcon::fromTheme("edit-delete"), "Remove", this, &MainWindow::onRemoveSelected);
        quick->addSeparator();
        quick->addAction(QIcon::fromTheme("document-save"), "Pack", this, &MainWindow::onPack);
        quick->addAction(QIcon::fromTheme("document-open"), "Unpack", this, &MainWindow::onUnpack);

        // Connections
        connect(aAdd, &QAction::triggered, this, &MainWindow::onAddFiles);
        connect(aExtract, &QAction::triggered, this, &MainWindow::onUnpack);
        connect(m_table, &QTableWidget::customContextMenuRequested, this, &MainWindow::onTableContextMenu);
        connect(m_table, &QTableWidget::itemSelectionChanged, this, &MainWindow::onSelectionChanged);
        connect(m_favList, &QListWidget::itemDoubleClicked, this, &MainWindow::onFavoriteActivated);

        // Drag & drop
        setAcceptDrops(true);

        // Populate with sample columns header style to look WinZip-like
        QFont headerFont = m_table->horizontalHeader()->font();
        headerFont.setBold(true);
        m_table->horizontalHeader()->setFont(headerFont);

        // initial state
        appendLog(m_log, "UI ready");
    }

protected:
    void dragEnterEvent(QDragEnterEvent* e) override {
        if (e->mimeData()->hasUrls()) e->acceptProposedAction();
    }
    void dropEvent(QDropEvent* e) override {
        const QList<QUrl> urls = e->mimeData()->urls();
        for (const QUrl& u : urls) {
            QString path = u.toLocalFile();
            QFileInfo fi(path);
            if (fi.isDir()) addDirectory(path);
            else if (fi.isFile()) addFile(path);
        }
    }

private slots:
    void onAddFiles() {
        QStringList files = QFileDialog::getOpenFileNames(this, "Add files");
        for (const QString& f : files) addFile(f);
    }
    void onAddDirectory() {
        QString dir = QFileDialog::getExistingDirectory(this, "Select directory to add");
        if (!dir.isEmpty()) addDirectory(dir);
    }
    void onRemoveSelected() {
        auto rows = selectedRows();
        // remove from bottom to top
        std::sort(rows.begin(), rows.end(), std::greater<int>());
        for (int r : rows) m_table->removeRow(r);
        updateStatus();
    }
    void onPack() {
        QList<PackWorker::Entry> entries = collectEntries();
        if (entries.isEmpty()) { appendLog(m_log, "No entries to pack."); return; }
        QString out = QFileDialog::getSaveFileName(this, "Save archive", QDir::currentPath(), "LZ4 Archive (*.lz4)");
        if (out.isEmpty()) return;
        appendLog(m_log, QString("Packing %1 entries -> %2").arg(entries.size()).arg(out));
        PackWorker* w = new PackWorker(entries, out, PackWorker::Pack, 3, false);
        connect(w, &PackWorker::progress, this, &MainWindow::onWorkerProgress);
        connect(w, &PackWorker::finished, this, &MainWindow::onWorkerFinished);
        QThreadPool::globalInstance()->start(w);
    }
    void onUnpack() {
        QString archive = QFileDialog::getOpenFileName(this, "Open archive", QDir::currentPath(), "LZ4 Archive (*.lz4)");
        if (archive.isEmpty()) return;
        appendLog(m_log, QString("Unpacking %1").arg(archive));
        PackWorker* w = new PackWorker(QList<PackWorker::Entry>(), archive, PackWorker::Unpack, 3, false);
        connect(w, &PackWorker::progress, this, &MainWindow::onWorkerProgress);
        connect(w, &PackWorker::finished, this, &MainWindow::onWorkerFinished);
        QThreadPool::globalInstance()->start(w);
    }

    void onWorkerProgress(int percent, const QString& message) {
        m_progress->setValue(percent);
        m_status->showMessage(message);
    }
    void onWorkerFinished(bool success, const QString& message) {
        appendLog(m_log, message);
        m_progress->setValue(success ? 100 : 0);
        m_status->showMessage(success ? "Done" : "Error");
    }

    void onTableContextMenu(const QPoint& pt) {
        QTableWidgetItem* it = m_table->itemAt(pt);
        QMenu m;
        QAction* open = m.addAction("Open");
        QAction* extract = m.addAction("Extract");
        QAction* remove = m.addAction("Remove");
        QAction* act = m.exec(m_table->viewport()->mapToGlobal(pt));
        if (!act) return;
        int row = it ? it->row() : -1;
        if (act == open && row >= 0) {
            QString path = m_table->item(row, 0)->data(Qt::UserRole).toString();
            QDesktopServices::openUrl(QUrl::fromLocalFile(path));
        } else if (act == extract) {
            onUnpack();
        } else if (act == remove) {
            if (row >= 0) m_table->removeRow(row);
            updateStatus();
        }
    }

    void onSelectionChanged() {
        auto rows = selectedRows();
        if (rows.isEmpty()) {
            m_preview->clear();
            m_details->clear();
            return;
        }
        int r = rows.first();
        QString path = m_table->item(r,0)->data(Qt::UserRole).toString();
        QFileInfo fi(path);
        m_details->setPlainText(QString("Path: %1\nType: %2\nSize: %3\nModified: %4")
                                .arg(fi.absoluteFilePath())
                                .arg(fi.isDir() ? "Directory" : "File")
                                .arg(humanSize(fi.size()))
                                .arg(fi.lastModified().toString()));
        if (fi.isFile() && fi.size() < 200000) {
            QFile f(path);
            if (f.open(QIODevice::ReadOnly)) {
                QByteArray data = f.read(4096);
                QString text = QString::fromUtf8(data);
                m_preview->setPlainText(text.left(10000));
                f.close();
            } else m_preview->setPlainText("[Cannot open file for preview]");
        } else {
            m_preview->setPlainText("[No preview available]");
        }
    }

    void onFavoriteActivated(QListWidgetItem* it) {
        QString name = it->text();
        QString path;
        if (name == "Desktop") path = QStandardPaths::writableLocation(QStandardPaths::DesktopLocation);
        else if (name == "Documents") path = QStandardPaths::writableLocation(QStandardPaths::DocumentsLocation);
        else if (name == "Downloads") path = QStandardPaths::writableLocation(QStandardPaths::DownloadLocation);
        else path = QDir::homePath();
        QDesktopServices::openUrl(QUrl::fromLocalFile(path));
    }

private:
    QTableWidget* m_table = nullptr;
    QListWidget* m_favList = nullptr;
    QTextEdit* m_preview = nullptr;
    QTextEdit* m_details = nullptr;
    QProgressBar* m_progress = nullptr;
    QTextEdit* m_log = nullptr;
    QStatusBar* m_status = nullptr;

    void addFile(const QString& path) {
        QFileInfo fi(path);
        if (!fi.exists() || !fi.isFile()) return;
        int row = m_table->rowCount();
        m_table->insertRow(row);
        QTableWidgetItem* name = new QTableWidgetItem(fi.fileName());
        name->setData(Qt::UserRole, fi.absoluteFilePath());
        QTableWidgetItem* type = new QTableWidgetItem(fi.suffix().isEmpty() ? "File" : fi.suffix().toUpper());
        QTableWidgetItem* mod = new QTableWidgetItem(fi.lastModified().toString("yyyy-MM-dd HH:mm"));
        QTableWidgetItem* size = new QTableWidgetItem(humanSize(fi.size()));
        QTableWidgetItem* ratio = new QTableWidgetItem("-"); // placeholder
        m_table->setItem(row, 0, name);
        m_table->setItem(row, 1, type);
        m_table->setItem(row, 2, mod);
        m_table->setItem(row, 3, size);
        m_table->setItem(row, 4, ratio);
        updateStatus();
        appendLog(m_log, QString("Added file: %1").arg(fi.absoluteFilePath()));
    }

    void addDirectory(const QString& dirPath) {
        QFileInfo fi(dirPath);
        if (!fi.exists() || !fi.isDir()) return;
        // Add directory entry
        int row = m_table->rowCount();
        m_table->insertRow(row);
        QTableWidgetItem* name = new QTableWidgetItem(fi.fileName());
        name->setData(Qt::UserRole, fi.absoluteFilePath());
        QTableWidgetItem* type = new QTableWidgetItem("Directory");
        QTableWidgetItem* mod = new QTableWidgetItem(fi.lastModified().toString("yyyy-MM-dd HH:mm"));
        QTableWidgetItem* size = new QTableWidgetItem("");
        QTableWidgetItem* ratio = new QTableWidgetItem("");
        m_table->setItem(row, 0, name);
        m_table->setItem(row, 1, type);
        m_table->setItem(row, 2, mod);
        m_table->setItem(row, 3, size);
        m_table->setItem(row, 4, ratio);
        // Recursively add children as flat list (optionally implement nested tree later)
        QDirIterator it(dirPath, QDir::Files, QDirIterator::Subdirectories);
        while (it.hasNext()) {
            it.next();
            addFile(it.filePath());
        }
        updateStatus();
        appendLog(m_log, QString("Added directory: %1").arg(fi.absoluteFilePath()));
    }

    QList<int> selectedRows() const {
        QList<int> rows;
        for (QTableWidgetItem* it : m_table->selectedItems()) {
            if (!rows.contains(it->row())) rows << it->row();
        }
        std::sort(rows.begin(), rows.end());
        return rows;
    }

    void updateStatus() {
        int count = m_table->rowCount();
        qint64 total = 0;
        for (int r=0;r<count;++r) {
            QString path = m_table->item(r,0)->data(Qt::UserRole).toString();
            QFileInfo fi(path);
            if (fi.exists() && fi.isFile()) total += fi.size();
        }
        m_status->showMessage(QString("%1 items — %2").arg(count).arg(humanSize(total)));
    }

    QList<PackWorker::Entry> collectEntries() const {
        QList<PackWorker::Entry> list;
        for (int r=0;r<m_table->rowCount();++r) {
            QString path = m_table->item(r,0)->data(Qt::UserRole).toString();
            QFileInfo fi(path);
            PackWorker::Entry e;
            e.absPath = path;
            e.relPath = QDir::current().relativeFilePath(path);
            e.isDir = fi.isDir();
            e.size = fi.isFile() ? fi.size() : 0;
            list << e;
        }
        return list;
    }
};

// main
int main(int argc, char** argv) {
    QApplication app(argc, argv);
    QCoreApplication::setApplicationName("lz4_packer_winzip");
    QCoreApplication::setOrganizationName("ExampleOrg");
    MainWindow w;
    w.show();
    return app.exec();
}

