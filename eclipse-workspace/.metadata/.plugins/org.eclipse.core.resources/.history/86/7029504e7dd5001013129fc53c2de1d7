// --- i. data structures and global state ---

// type system
typedef enum { ty_int, ty_char, ty_long, ty_ptr, ty_array, ty_struct } type_kind;
typedef struct ty {
    type_kind kind;
    struct ty *base; // used for pointers and arrays
    int size;        // 1, 4, 8, or arbitrary for struct/array
    int align;       // alignment requirement
    int is_unsigned;
    size_t array_len; // length if ty_array
} ty;

// local variables
typedef struct lvar {
    struct lvar *next;
    char *name;
    int len;
    int offset;
    ty *type;
    int is_static;   // 1 if this local is static (stored in data)
    char *gname;     // global label name for static locals
} lvar;

// global static variable descriptor (for emission)
typedef struct gvar {
    struct gvar *next;
    char *name;
    int size;
} gvar;

// Global array initialization data (for keywords[])
typedef struct sdata {
    struct sdata *next;
    char *label;        // global label name (e.g., "keywords")
    size_t size;        // total size in bytes
    struct sinit *inits;
} sdata;

typedef enum { init_ptr, init_int } init_kind;
typedef struct sinit {
    struct sinit *next;
    init_kind kind;
    long val;             // for init_int
    char *str_label;      // for init_ptr (string content initially, then the label)
    int offset;           // offset from start of struct/array
    int size;             // size of data (4, 8)
} sinit;

sdata *static_data_list = NULL; // List of static data arrays/structs

// functions
typedef struct function {
    struct function *next;
    char *name;
    struct node *body;
    lvar *locals;
    int stack_size;
    int num_params;
    int is_variadic;
    int is_static;
} function;

// tokenizer
typedef enum { tk_eof, tk_reserved, tk_keyword, tk_num, tk_ident } token_kind;
typedef struct token {
    token_kind kind;
    struct token *next;
    long val;
    char *str;
    int len;
    char *file_pos; // start of the token for error reporting
    ty *type;
} token;

// ast nodes
typedef enum {
    nd_num, nd_lvar, nd_assign, nd_funcall, nd_return,
    nd_if, nd_while, nd_for, nd_block, nd_expr_stmt,
    nd_add, nd_sub, nd_mul, nd_div, nd_mod,
    nd_eq, nd_ne, nd_lt, nd_le,
    nd_addr, nd_deref, nd_break, nd_continue, nd_switch, nd_case,
    nd_shl, nd_shr, nd_band, nd_bor, nd_bxor, nd_logical_and, nd_logical_or,
    nd_not, nd_bitnot,
    nd_cond,
    // Compound Assignments
    nd_add_assign, nd_sub_assign, nd_mul_assign, nd_div_assign, nd_mod_assign,
    nd_shl_assign, nd_shr_assign, nd_band_assign, nd_bor_assign, nd_bxor_assign,
    nd_array_init_zero // for local array zero initialization
} node_kind;

typedef struct node {
    node_kind kind;
    struct node *lhs; // condition for nd_cond, lhs for binary
    struct node *rhs; // then expression for nd_cond, rhs for binary
    struct node *els; // else expression for nd_cond, else for nd_if/nd_for
    struct node *next;
    long val;
    char *name;
    ty *type;
    lvar *var;
} node;

// control flow labels for break/continue
typedef struct continue_break_labels {
    int continue_label;
    int break_label;
    struct continue_break_labels *next;
} continue_break_labels;

