        goto endOp;
    }
    labPop8F: { /* pop r/m64 */
        funDecMr();
        uint64_t val = funPop64();
        if (objCpu.valMod==3) FUN_SET_R64(objCpu.valRm, valRxb, val);
        else funMemW64(funCalEa(), val);
        goto endOp;
    }

    /* ========================================================================
       XCHG RAX (90-97) - FULLY UNROLLED
       ======================================================================== */
    labXch90: { /* nop or xchg rax, rax */
        if (objCpu.flgRex || objCpu.valLst != 0x90) goto labErr; /* only nop/xchg if no prefixes */
        if (objCpu.valRxb) { /* REX.B is 1 -> R8 */
            uint64_t *r0 = &objCpu.arrGpr[0];
            uint64_t *rB = &objCpu.arrGpr[8];
            uint64_t tmp = *r0; *r0 = *rB; *rB = tmp;
        }
        goto endOp;
    }
    labXch91: { uint64_t *r0 = &objCpu.arrGpr[0]; uint64_t *r = &objCpu.arrGpr[1 | (objCpu.valRxb<<3)]; uint64_t tmp = *r0; *r0 = *r; *r = tmp; goto endOp; }
    labXch92: { uint64_t *r0 = &objCpu.arrGpr[0]; uint64_t *r = &objCpu.arrGpr[2 | (objCpu.valRxb<<3)]; uint64_t tmp = *r0; *r0 = *r; *r = tmp; goto endOp; }
    labXch93: { uint64_t *r0 = &objCpu.arrGpr[0]; uint64_t *r = &objCpu.arrGpr[3 | (objCpu.valRxb<<3)]; uint64_t tmp = *r0; *r0 = *r; *r = tmp; goto endOp; }
    labXch94: { uint64_t *r0 = &objCpu.arrGpr[0]; uint64_t *r = &objCpu.arrGpr[4 | (objCpu.valRxb<<3)]; uint64_t tmp = *r0; *r0 = *r; *r = tmp; goto endOp; }
    labXch95: { uint64_t *r0 = &objCpu.arrGpr[0]; uint64_t *r = &objCpu.arrGpr[5 | (objCpu.valRxb<<3)]; uint64_t tmp = *r0; *r0 = *r; *r = tmp; goto endOp; }
    labXch96: { uint64_t *r0 = &objCpu.arrGpr[0]; uint64_t *r = &objCpu.arrGpr[6 | (objCpu.valRxb<<3)]; uint64_t tmp = *r0; *r0 = *r; *r = tmp; goto endOp; }
    labXch97: { uint64_t *r0 = &objCpu.arrGpr[0]; uint64_t *r = &objCpu.arrGpr[7 | (objCpu.valRxb<<3)]; uint64_t tmp = *r0; *r0 = *r; *r = tmp; goto endOp; }


    /* ========================================================================
       STRING OPS (MOVS/STOS) - REPEAT HANDLING
       ======================================================================== */
    labMovA4: { /* movsb */
        uint64_t *ptrRsi = &objCpu.arrGpr[6]; /* rsi */
        uint64_t *ptrRdi = &objCpu.arrGpr[7]; /* rdi */
        int d = (objCpu.valFlg & NUM_FLG_DF) ? -1 : 1;
        do {
            uint8_t v = funMemR8(*ptrRsi); funMemW8(*ptrRdi, v);
            *ptrRsi += d; *ptrRdi += d;
            if (objCpu.numRep) objCpu.arrGpr[1]--; /* rcx-- */
        } while (objCpu.numRep && objCpu.arrGpr[1] != 0);
        goto endOp;
    }
    labMovA5: { /* movsq */
        uint64_t *ptrRsi = &objCpu.arrGpr[6]; /* rsi */
        uint64_t *ptrRdi = &objCpu.arrGpr[7]; /* rdi */
        int d = (objCpu.valFlg & NUM_FLG_DF) ? -8 : 8;
        do {
            uint64_t v = funMemR64(*ptrRsi); funMemW64(*ptrRdi, v);
            *ptrRsi += d; *ptrRdi += d;
            if (objCpu.numRep) objCpu.arrGpr[1]--; /* rcx-- */
        } while (objCpu.numRep && objCpu.arrGpr[1] != 0);
        goto endOp;
    }
    labStoAA: { /* stosb */
        uint64_t *ptrRdi = &objCpu.arrGpr[7]; /* rdi */
        uint8_t v = (uint8_t)objCpu.arrGpr[0]; /* al */
        int d = (objCpu.valFlg & NUM_FLG_DF) ? -1 : 1;
        do {
            funMemW8(*ptrRdi, v);
            *ptrRdi += d;
            if (objCpu.numRep) objCpu.arrGpr[1]--; /* rcx-- */
        } while (objCpu.numRep && objCpu.arrGpr[1] != 0);
        goto endOp;
    }
    labStoAB: { /* stosq */
        uint64_t *ptrRdi = &objCpu.arrGpr[7]; /* rdi */
        uint64_t v = objCpu.arrGpr[0]; /* rax */
        int d = (objCpu.valFlg & NUM_FLG_DF) ? -8 : 8;
        do {
            funMemW64(*ptrRdi, v);
            *ptrRdi += d;
            if (objCpu.numRep) objCpu.arrGpr[1]--; /* rcx-- */
        } while (objCpu.numRep && objCpu.arrGpr[1] != 0);
        goto endOp;
    }


    /* ========================================================================
       MOV IMMEDIATE (B0-BF) - FULLY UNROLLED
       ======================================================================== */
    labMovB0: FUN_SET_R8_L(0, valRxb, funFet8()); goto endOp;
    labMovB1: FUN_SET_R8_L(1, valRxb, funFet8()); goto endOp;
    labMovB2: FUN_SET_R8_L(2, valRxb, funFet8()); goto endOp;
    labMovB3: FUN_SET_R8_L(3, valRxb, funFet8()); goto endOp;
    labMovB4: FUN_SET_R8_L(4, valRxb, funFet8()); goto endOp;
    labMovB5: FUN_SET_R8_L(5, valRxb, funFet8()); goto endOp;
    labMovB6: FUN_SET_R8_L(6, valRxb, funFet8()); goto endOp;
    labMovB7: FUN_SET_R8_L(7, valRxb, funFet8()); goto endOp;

    labMovB8: FUN_SET_R64(0, valRxb, (objCpu.valRxw ? funFet64() : (uint64_t)(int64_t)(int32_t)funFet32())); goto endOp;
    labMovB9: FUN_SET_R64(1, valRxb, (objCpu.valRxw ? funFet64() : (uint64_t)(int64_t)(int32_t)funFet32())); goto endOp;
    labMovBA: FUN_SET_R64(2, valRxb, (objCpu.valRxw ? funFet64() : (uint64_t)(int64_t)(int32_t)funFet32())); goto endOp;
    labMovBB: FUN_SET_R64(3, valRxb, (objCpu.valRxw ? funFet64() : (uint64_t)(int64_t)(int32_t)funFet32())); goto endOp;
    labMovBC: FUN_SET_R64(4, valRxb, (objCpu.valRxw ? funFet64() : (uint64_t)(int64_t)(int32_t)funFet32())); goto endOp;
    labMovBD: FUN_SET_R64(5, valRxb, (objCpu.valRxw ? funFet64() : (uint64_t)(int64_t)(int32_t)funFet32())); goto endOp;
    labMovBE: FUN_SET_R64(6, valRxb, (objCpu.valRxw ? funFet64() : (uint64_t)(int64_t)(int32_t)funFet32())); goto endOp;
    labMovBF: FUN_SET_R64(7, valRxb, (objCpu.valRxw ? funFet64() : (uint64_t)(int64_t)(int32_t)funFet32())); goto endOp;

    /* ========================================================================
       SHIFTS & MISC
       ======================================================================== */
    labShfC0: { /* shift r/m8, imm8 */
        funDecMr();
        uint8_t amt = funFet8() & 0x1F;
        uint8_t *ptr = (objCpu.valMod==3)?(uint8_t*)&objCpu.arrGpr[FUN_IDX_R64(objCpu.valRm, valRxb)]:NULL;
        uint8_t val = ptr?*ptr:funMemR8(funCalEa());
        uint8_t res = val;
        CLR_FLG_ALU();
        if (amt == 0) goto endOp;

        switch(objCpu.valReg) {
            case 4: /* SHL */ res <<= amt; objCpu.valFlg |= (val >> (8 - amt)) & NUM_FLG_CF; break;
            case 5: /* SHR */ res >>= amt; objCpu.valFlg |= (val << (amt - 1)) & NUM_FLG_CF; break;
            case 7: /* SAR */ res = (int8_t)res >> amt; objCpu.valFlg |= (val << (amt - 1)) & NUM_FLG_CF; break;
            default: goto labErr;
        }
        if (ptr) *ptr = res; else funMemW8(funCalEa(), res);
        SET_FLG_SZP8(res);
        goto endOp;
    }
    labShfC1: { /* shift r/m64, imm8 */
        funDecMr();
        uint8_t amt = funFet8() & 0x3F;
        uint64_t *ptr = (objCpu.valMod==3)?&objCpu.arrGpr[FUN_IDX_R64(objCpu.valRm, valRxb)]:NULL;
        uint64_t val = ptr?*ptr:funMemR64(funCalEa());
        uint64_t res = val;
        CLR_FLG_ALU();
        if (amt == 0) goto endOp;

        switch(objCpu.valReg) {
            case 4: /* SHL */ res <<= amt; objCpu.valFlg |= (val >> (64 - amt)) & NUM_FLG_CF; break;
            case 5: /* SHR */ res >>= amt; objCpu.valFlg |= (val << (amt - 1)) & NUM_FLG_CF; break;
            case 7: /* SAR */ res = (int64_t)res >> amt; objCpu.valFlg |= (val << (amt - 1)) & NUM_FLG_CF; break;
            default: goto labErr;
        }
        if (ptr) *ptr = res; else funMemW64(funCalEa(), res);
        SET_FLG_SZP64(res);
        goto endOp;
    }

    labRetC3: objCpu.valRip = funPop64(); goto endOp;

    labMovC6: { /* mov r/m8, imm8 */
        funDecMr();
        uint8_t imm = funFet8();
        if (objCpu.valMod==3) FUN_SET_R8_L(objCpu.valRm, valRxb, imm);
        else funMemW8(funCalEa(), imm);
        goto endOp;
    }
    labMovC7: { /* mov r/m64, imm32 (sign extended) */
        funDecMr();
        uint64_t imm = (uint64_t)(int64_t)(int32_t)funFet32();
        if (objCpu.valMod==3) FUN_SET_R64(objCpu.valRm, valRxb, imm);
        else funMemW64(funCalEa(), imm);
        goto endOp;
    }

    labShfD0: /* shift by 1 */
    labShfD1: /* shift 64 by 1 */
    labShfD2: /* shift 8 by cl */
    labShfD3: /* shift 64 by cl */
        /* fully unrolling these groups would be another massive step, for now error */
        goto labErr;

    labCalE8: { /* call rel32 */
        int32_t rel = (int32_t)funFet32();
        funPsh64(objCpu.valRip); objCpu.valRip += rel;
        goto endOp;
    }
    labJmpE9: { /* jmp rel32 */
        objCpu.valRip += (int64_t)(int33_t)funFet32();
        goto endOp;
    }
    labJmpEB: { /* jmp rel8 */
        objCpu.valRip += (int64_t)(int8_t)funFet8();
        goto endOp;
    }

    /* ========================================================================
       GROUP 3 (F6/F7) - PARTIAL IMPLEMENTATION
       ======================================================================== */
    labGrp3F6: { /* group 3 r/m8 */
        funDecMr();
        uint8_t val = (objCpu.valMod==3) ? FUN_GET_R8_L(objCpu.valRm, valRxb) : funMemR8(funCalEa());
        uint8_t res = val;
        switch(objCpu.valReg) {
            case 2: /* NOT r/m8 */ res = ~val; break;
            case 3: /* NEG r/m8 */ res = 0 - val; CLR_FLG_ALU(); /* flags logic missing for simplicity */ break;
            default: goto labErr;
        }
        if (objCpu.valMod==3) FUN_SET_R8_L(objCpu.valRm, valRxb, res);
        else funMemW8(funCalEa(), res);
        goto endOp;
    }
    labGrp3F7: { /* group 3 r/m64 */
        funDecMr();
        uint64_t val = (objCpu.valMod==3) ? FUN_GET_R64(objCpu.valRm, valRxb) : funMemR64(funCalEa());
        uint64_t res = val;
        switch(objCpu.valReg) {
            case 2: /* NOT r/m64 */ res = ~val; break;
            case 3: /* NEG r/m64 */ res = 0 - val; CLR_FLG_ALU(); SET_FLG_SUB64(0, val, res); SET_FLG_SZP64(res); break;
            default: goto labErr;
        }
        if (objCpu.valMod==3) FUN_SET_R64(objCpu.valRm, valRxb, res);
        else funMemW64(funCalEa(), res);
        goto endOp;
    }

    labGrpFEO: { /* inc/dec r/m8 */
        funDecMr();
        uint8_t *ptr = (objCpu.valMod==3)?(uint8_t*)&objCpu.arrGpr[FUN_IDX_R64(objCpu.valRm, valRxb)]:NULL;
        uint8_t val = ptr?*ptr:funMemR8(funCalEa());
        uint8_t res = val;
        if (objCpu.valReg==0) res++; /* inc */ else res--; /* dec */
        if (ptr)*ptr=res; else funMemW8(funCalEa(), res);
        /* AF, OF, ZF, SF, PF affected (CF is NOT affected for INC/DEC) */
        objCpu.valFlg &= ~(NUM_FLG_OF | NUM_FLG_ZF | NUM_FLG_SF | NUM_FLG_PF);
        SET_FLG_SZP8(res);
        goto endOp;
    }
    labGrpFF: { /* inc/dec/call/jmp r/m64 */
        funDecMr();
        uint64_t *ptr = (objCpu.valMod==3)?&objCpu.arrGpr[FUN_IDX_R64(objCpu.valRm, valRxb)]:NULL;
        uint64_t val = ptr?*ptr:funMemR64(funCalEa());
        uint64_t res = val;
        switch(objCpu.valReg) {
            case 0: /* inc */ res++; if(ptr)*ptr=res; else funMemW64(funCalEa(), res); goto endOp; /* flags ignored for brevity */
            case 1: /* dec */ res--; if(ptr)*ptr=res; else funMemW64(funCalEa(), res); goto endOp; /* flags ignored for brevity */
            case 2: /* call */ funPsh64(objCpu.valRip); objCpu.valRip = val; break;
            case 4: /* jmp */ objCpu.valRip = val; break;
            case 6: /* push */ funPsh64(val); break;
            default: goto labErr;
        }
        goto endOp;
    }

    /* ========================================================================
       TWO BYTE PREFIX (0F) - CONDITIONAL MOVES UNROLLED
       ======================================================================== */
    labTwo0F: {
        uint8_t op2 = funFet8();
        if (op2 >= 0x80 && op2 <= 0x8F) { /* jcc rel32 (fully unrolled) */
            int32_t d = (int32_t)funFet32();
            if (funTstCnd(op2 & 0x0F)) objCpu.valRip += d;
            goto endOp;
        } else if (op2 >= 0x40 && op2 <= 0x4F) { /* cmovcc r64, r/m64 */
            funDecMr();
            if (funTstCnd(op2 & 0x0F)) {
                uint64_t val = (objCpu.valMod==3) ? FUN_GET_R64(objCpu.valRm, valRxb) : funMemR64(funCalEa());
                FUN_SET_R64(objCpu.valReg, valRxr, val);
            }
            goto endOp;
        } else {
            /* other 0F ops like IMUL/SETO/MOVSX/MOVZX would go here */
            fprintf(stderr, "unimplemented 0f %02x @ %016" PRIx64 "\n", op2, objCpu.valRip-2);
            goto labErr;
        }
    }

    labErr:
        fprintf(stderr, "crash: op %02x @ %016" PRIx64 "\n", objCpu.valLst, objCpu.valRip-1);
        exit(1);

    endOp:;
    }
}
