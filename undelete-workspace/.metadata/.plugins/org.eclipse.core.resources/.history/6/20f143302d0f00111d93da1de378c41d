/*
 * linear_inode_scan.c
 *
 * Scan a block device/image linearly from offset 0 to device end in fixed-size
 * chunks equal to inode_size. Treat each chunk as a candidate ext4 inode;
 * if it looks like a directory, parse direct blocks for directory entries.
 * Reconstruct full paths from collected directory entries and print only
 * those paths that are missing from the mounted tree (lstat -> ENOENT).
 *
 * Limitations:
 *  - Only direct blocks (i_block[0..11]) are parsed for directory entries.
 *  - This linear scan will encounter many non-inode data; filtering is heuristic.
 *
 * Build:
 *   gcc -O2 -o linear_inode_scan linear_inode_scan.c
 *
 * Usage:
 *   sudo ./linear_inode_scan /dev/sdXN
 *
 * Warning: run on a copy of the device when possible.
 */

#define _GNU_SOURCE
#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>
#include <unistd.h>
#include <fcntl.h>
#include <string.h>
#include <errno.h>
#include <ctype.h>
#include <sys/types.h>
#include <sys/stat.h>
#include <sys/mount.h>
#include <limits.h>
#include <time.h>
#include <sys/time.h>

#define EXT4_SUPER_OFFSET 1024
#define EXT4_NAME_LEN 255

/* Minimal ext4 on-disk structures (packed) */
struct ext4_super {
    uint32_t s_inodes_count;
    uint32_t s_blocks_count_lo;
    uint32_t s_r_blocks_count_lo;
    uint32_t s_free_blocks_count_lo;
    uint32_t s_free_inodes_count;
    uint32_t s_first_data_block;
    uint32_t s_log_block_size;
    uint32_t s_log_cluster_size;
    uint32_t s_blocks_per_group;
    uint32_t s_clusters_per_group;
    uint32_t s_inodes_per_group;
    uint32_t s_mtime;
    uint32_t s_wtime;
    uint16_t s_mnt_count;
    uint16_t s_max_mnt_count;
    uint16_t s_magic;
    uint16_t s_state;
    uint16_t s_errors;
    uint16_t s_minor_rev_level;
    uint32_t s_lastcheck;
    uint32_t s_checkinterval;
    uint32_t s_creator_os;
    uint32_t s_rev_level;
    uint16_t s_def_resuid;
    uint16_t s_def_resgid;
    uint32_t s_first_ino;
    uint16_t s_inode_size;
    uint16_t s_block_group_nr;
    uint32_t s_feature_compat;
    uint32_t s_feature_incompat;
    uint32_t s_feature_ro_compat;
    uint8_t  s_uuid[16];
    char     s_volume_name[16];
    char     s_last_mounted[64];
} __attribute__((packed));

struct ext4_group_desc {
    uint32_t bg_block_bitmap_lo;
    uint32_t bg_inode_bitmap_lo;
    uint32_t bg_inode_table_lo;
    uint16_t bg_free_blocks_count_lo;
    uint16_t bg_free_inodes_count_lo;
    uint16_t bg_used_dirs_count_lo;
    uint16_t bg_flags;
    uint32_t bg_exclude_bitmap_lo;
    uint16_t bg_block_bitmap_csum_lo;
    uint16_t bg_inode_bitmap_csum_lo;
    uint16_t bg_itable_unused;
    uint16_t bg_checksum;
} __attribute__((packed));

struct ext4_inode {
    uint16_t i_mode;
    uint16_t i_uid;
    uint32_t i_size_lo;
    uint32_t i_atime;
    uint32_t i_ctime;
    uint32_t i_mtime;
    uint32_t i_dtime;
    uint16_t i_gid;
    uint16_t i_links_count;
    uint32_t i_blocks_lo;
    uint32_t i_flags;
    uint32_t i_osd1;
    uint32_t i_block[15];
    uint32_t i_generation;
    uint32_t i_file_acl_lo;
    uint32_t i_size_high;
    uint32_t i_obso_faddr;
    uint8_t  i_osd2[12];
} __attribute__((packed));

struct ext2_dir_entry {
    uint32_t inode;
    uint16_t rec_len;
    uint8_t  name_len;
    uint8_t  file_type;
    char     name[]; /* not NUL-terminated */
} __attribute__((packed));

/* helpers */
static ssize_t pread_all(int fd, void *buf, size_t count, off_t offset) {
    size_t done = 0;
    while (done < count) {
        ssize_t r = pread(fd, (char*)buf + done, count - done, offset + done);
        if (r < 0) return -1;
        if (r == 0) break;
        done += r;
    }
    return done;
}
static uint16_t le16(const void *p) {
    const uint8_t *b = p;
    return (uint16_t)b[0] | ((uint16_t)b[1] << 8);
}
static uint32_t le32(const void *p) {
    const uint8_t *b = p;
    return (uint32_t)b[0] | ((uint32_t)b[1] << 8) | ((uint32_t)b[2] << 16) | ((uint32_t)b[3] << 24);
}

/* Data structures to hold directory entries and parent links */
struct dir_entry {
    uint64_t parent_inode; /* use 64-bit to hold pseudo inode index */
    uint64_t child_inode;
    char name[EXT4_NAME_LEN + 1];
};

struct dir_entry_list {
    struct dir_entry *items;
    size_t used;
    size_t cap;
};

static void de_list_init(struct dir_entry_list *l) {
    l->items = NULL; l->used = 0; l->cap = 0;
}
static void de_list_free(struct dir_entry_list *l) {
    free(l->items); l->items = NULL; l->used = l->cap = 0;
}
static int de_list_add(struct dir_entry_list *l, uint64_t parent, uint64_t child, const char *name) {
    if (l->used == l->cap) {
        size_t ncap = l->cap ? l->cap * 2 : 4096;
        struct dir_entry *n = realloc(l->items, ncap * sizeof(*n));
        if (!n) return -1;
        l->items = n; l->cap = ncap;
    }
    l->items[l->used].parent_inode = parent;
    l->items[l->used].child_inode = child;
    strncpy(l->items[l->used].name, name, EXT4_NAME_LEN);
    l->items[l->used].name[EXT4_NAME_LEN] = '\0';
    l->used++;
    return 0;
}

/* Find name for child inode under given parent (linear search) */
static const char *find_name_under_parent(struct dir_entry_list *l, uint64_t parent, uint64_t child) {
    for (size_t i = 0; i < l->used; ++i) {
        if (l->items[i].parent_inode == parent && l->items[i].child_inode == child) {
            return l->items[i].name;
        }
    }
    return NULL;
}

/* Reconstruct full path for an entry (parent_inode, child_inode, name) */
static char *reconstruct_path(struct dir_entry_list *l, uint64_t parent, uint64_t child, const char *name) {
    size_t comps_cap = 16;
    size_t comps_len = 0;
    char **comps = malloc(comps_cap * sizeof(char*));
    if (!comps) return NULL;

    comps[comps_len++] = strdup(name);
    uint64_t cur_dir = parent;
    const uint64_t ROOT_INO = 2; /* best-effort */

    while (cur_dir != 0 && cur_dir != ROOT_INO) {
        uint64_t parent_of_cur = 0;
        for (size_t i = 0; i < l->used; ++i) {
            if (l->items[i].parent_inode == cur_dir && strcmp(l->items[i].name, "..") == 0) {
                parent_of_cur = l->items[i].child_inode;
                break;
            }
        }
        if (parent_of_cur == 0) break;

        const char *dir_name = find_name_under_parent(l, parent_of_cur, cur_dir);
        char *tofree = NULL;
        if (!dir_name) {
            char tmp[64];
            snprintf(tmp, sizeof(tmp), "[ino:%llu]", (unsigned long long)cur_dir);
            tofree = strdup(tmp);
            if (!tofree) break;
            dir_name = tofree;
        }

        if (comps_len == comps_cap) {
            comps_cap *= 2;
            char **n = realloc(comps, comps_cap * sizeof(char*));
            if (!n) { free(tofree); break; }
            comps = n;
        }
        comps[comps_len++] = strdup(dir_name);
        if (tofree) free(tofree);
        cur_dir = parent_of_cur;
    }

    /* join components in reverse */
    size_t total_len = 1;
    for (size_t i = 0; i < comps_len; ++i) total_len += strlen(comps[i]) + 1;
    char *path = malloc(total_len + 1);
    if (!path) {
        for (size_t i = 0; i < comps_len; ++i) free(comps[i]);
        free(comps);
        return NULL;
    }
    char *p = path;
    *p++ = '/';
    *p = '\0';
    for (size_t i = 0; i < comps_len; ++i) {
        const char *comp = comps[comps_len - 1 - i];
        size_t l = strlen(comp);
        memcpy(p, comp, l);
        p += l;
        if (i + 1 < comps_len) *p++ = '/';
        *p = '\0';
    }

    for (size_t i = 0; i < comps_len; ++i) free(comps[i]);
    free(comps);
    return path;
}

/* Progress bar helpers */
static double time_diff_seconds(struct timeval *start, struct timeval *end) {
    return (double)(end->tv_sec - start->tv_sec) + (double)(end->tv_usec - start->tv_usec) / 1e6;
}
static void format_seconds(double s, char *out, size_t outlen) {
    if (s < 0) s = 0;
    int hours = (int)(s / 3600);
    int minutes = (int)((s - hours * 3600) / 60);
    int seconds = (int)(s - hours * 3600 - minutes * 60);
    if (hours > 99) {
        snprintf(out, outlen, "%02dh+%02dm", hours, minutes);
    } else {
        snprintf(out, outlen, "%02d:%02d:%02d", hours, minutes, seconds);
    }
}
static void print_progress_bytes(off_t processed, off_t total, struct timeval *start) {
    struct timeval now;
    gettimeofday(&now, NULL);
    double elapsed = time_diff_seconds(start, &now);
    double percent = total ? (double)processed / (double)total : 0.0;
    double eta = 0.0;
    if (processed > 0 && percent > 0.0) {
        double est_total = elapsed / percent;
        eta = est_total - elapsed;
    }
    int bar_width = 40;
    int filled = (int)(percent * bar_width + 0.5);
    if (filled > bar_width) filled = bar_width;
    char elapsed_s[32], eta_s[32];
    format_seconds(elapsed, elapsed_s, sizeof(elapsed_s));
    format_seconds(eta, eta_s, sizeof(eta_s));
    fprintf(stderr, "\r[");
    for (int i = 0; i < filled; ++i) fputc('=', stderr);
    for (int i = filled; i < bar_width; ++i) fputc(' ', stderr);
    fprintf(stderr, "] %6.2f%% %lld/%lld bytes elapsed=%s ETA=%s",
            percent * 100.0,
            (long long)processed, (long long)total, elapsed_s, eta_s);
    fflush(stderr);
}

/* Check /proc/mounts for an existing mountpoint for 'device' */
static int find_existing_mountpoint(const char *device, char *out_mount, size_t out_len) {
    FILE *f = fopen("/proc/mounts", "r");
    if (!f) return -1;
    char line[4096];
    while (fgets(line, sizeof(line), f)) {
        char dev[PATH_MAX], mnt[PATH_MAX], fstype[64], opts[256];
        if (sscanf(line, "%4095s %4095s %63s %255s", dev, mnt, fstype, opts) >= 2) {
            if (strcmp(dev, device) == 0) {
                strncpy(out_mount, mnt, out_len - 1);
                out_mount[out_len - 1] = '\0';
                fclose(f);
                return 0;
            }
        }
    }
    fclose(f);
    return -1;
}

/* Create a temporary mountpoint under /tmp and mount the device read-only. */
static int mount_device_ro(const char *device, char *out_mount, size_t out_len, int *mounted_by_us) {
    if (find_existing_mountpoint(device, out_mount, out_len) == 0) {
        if (mounted_by_us) *mounted_by_us = 0;
        return 0;
    }

    char tmpl[] = "/tmp/scanmnt.XXXXXX";
    char *tmp = mkdtemp(tmpl);
    if (!tmp) {
        fprintf(stderr, "mkdtemp failed: %s\n", strerror(errno));
        return -1;
    }

    unsigned long flags = MS_RDONLY | MS_NOSUID | MS_NODEV | MS_NOEXEC | MS_DIRSYNC;
    int rc = mount(device, tmp, "auto", flags, NULL);
    if (rc != 0) {
        rc = mount(device, tmp, "ext4", flags, NULL);
        if (rc != 0) {
            int saved = errno;
            rmdir(tmp);
            fprintf(stderr, "mount failed: %s\n", strerror(saved));
            return -1;
        }
    }

    strncpy(out_mount, tmp, out_len - 1);
    out_mount[out_len - 1] = '\0';
    if (mounted_by_us) *mounted_by_us = 1;
    return 0;
}
static void unmount_and_cleanup(const char *mountpoint) {
    if (!mountpoint || mountpoint[0] == '\0') return;
    if (umount2(mountpoint, MNT_DETACH) != 0) {
        umount2(mountpoint, 0);
    }
    rmdir(mountpoint);
}

/* Read superblock to get inode_size and block_size; return 0 on success */
static int read_superblock(int fd, uint16_t *out_inode_size, uint32_t *out_block_size) {
    struct ext4_super sb;
    if (pread_all(fd, &sb, sizeof(sb), EXT4_SUPER_OFFSET) != sizeof(sb)) {
        return -1;
    }
    if (le16(&sb.s_magic) != 0xEF53) return -1;
    uint16_t inode_size = le16(&sb.s_inode_size);
    if (inode_size == 0) inode_size = 128;
    uint32_t log_block = le32(&sb.s_log_block_size);
    uint32_t block_size = 1024U << log_block;
    *out_inode_size = inode_size;
    *out_block_size = block_size;
    return 0;
}

/* Linear scan: read device size, iterate offsets 0..end-inode_size step inode_size */
static int linear_scan_inodes(int fd, struct dir_entry_list *list, uint16_t inode_size, uint32_t block_size) {
    off_t end = lseek(fd, 0, SEEK_END);
    if (end == (off_t)-1) {
        fprintf(stderr, "lseek(SEEK_END) failed: %s\n", strerror(errno));
        return -1;
    }
    if (inode_size == 0) inode_size = 128;
    if (block_size == 0) block_size = 4096;

    off_t total_bytes = end;
    off_t processed = 0;
    struct timeval start;
    gettimeofday(&start, NULL);
    print_progress_bytes(processed, total_bytes, &start);

    uint8_t *buf = malloc(inode_size);
    if (!buf) return -1;

    /* iterate */
    for (off_t off = 0; off + inode_size <= end; off += inode_size) {
        ssize_t r = pread_all(fd, buf, inode_size, off);
        if (r != (ssize_t)inode_size) {
            /* skip and continue */
            processed = off + inode_size;
            if (processed > total_bytes) processed = total_bytes;
            if ((off / inode_size) % 256 == 0) print_progress_bytes(processed, total_bytes, &start);
            continue;
        }

        /* Interpret as inode */
        struct ext4_inode inode;
        memset(&inode, 0, sizeof(inode));
        memcpy(&inode, buf, sizeof(inode) < inode_size ? sizeof(inode) : inode_size);

        uint16_t mode = le16(&inode.i_mode);
        /* plausible mode check: file/dir/char/block/symlink/socket/fifo bits */
        uint16_t type = mode & 0xF000;
        if (type == 0x4000 /* directory */ || type == 0x8000 /* regular file */ || type == 0xA000 /* symlink */) {
            /* If directory, parse direct blocks for directory entries */
            if (type == 0x4000) {
                /* compute a pseudo inode number based on offset */
                uint64_t pseudo_inode = (uint64_t)(off / inode_size) + 1;
                for (int bi = 0; bi < 12; ++bi) {
                    uint32_t blk = le32(&inode.i_block[bi]);
                    if (blk == 0) continue;
                    off_t block_off = (off_t)blk * block_size;
                    if (block_off + block_size > end) continue;
                    uint8_t *block = malloc(block_size);
                    if (!block) continue;
                    if (pread_all(fd, block, block_size, block_off) != (ssize_t)block_size) {
                        free(block);
                        continue;
                    }
                    uint32_t pos = 0;
                    while (pos + sizeof(struct ext2_dir_entry) < block_size) {
                        struct ext2_dir_entry *de = (struct ext2_dir_entry *)(block + pos);
                        uint32_t inode_no = le32(&de->inode);
                        uint16_t rec_len = le16(&de->rec_len);
                        uint8_t name_len = de->name_len;
                        if (rec_len == 0) break;
                        if (inode_no != 0 && name_len > 0 && name_len <= EXT4_NAME_LEN && pos + rec_len <= block_size) {
                            char name[EXT4_NAME_LEN + 1];
                            if (name_len > EXT4_NAME_LEN) name_len = EXT4_NAME_LEN;
                            memcpy(name, de->name, name_len);
                            name[name_len] = '\0';
                            /* store mapping: parent=pseudo_inode, child=inode_no (child is on-disk inode number if valid) */
                            de_list_add(list, pseudo_inode, (uint64_t)inode_no, name);
                        }
                        pos += rec_len;
                    }
                    free(block);
                }
            }
        }

        /* update progress occasionally */
        processed = off + inode_size;
        if ((off / inode_size) % 256 == 0 || processed == total_bytes) {
            print_progress_bytes(processed, total_bytes, &start);
        }
    }

    /* final progress */
    print_progress_bytes(total_bytes, total_bytes, &start);
    fprintf(stderr, "\n");
    free(buf);
    return 0;
}

/* Build full path and check lstat against mounted root; print only if lstat fails with ENOENT */
static void print_deleted_only(struct dir_entry_list *list, const char *mountroot) {
    if (!mountroot) return;
    size_t mountroot_len = strlen(mountroot);
    int need_slash = (mountroot_len == 0 || mountroot[mountroot_len - 1] != '/');

    for (size_t i = 0; i < list->used; ++i) {
        const char *name = list->items[i].name;
        if (strcmp(name, ".") == 0 || strcmp(name, "..") == 0) continue;
        uint64_t parent = list->items[i].parent_inode;
        uint64_t child = list->items[i].child_inode;
        char *relpath = reconstruct_path(list, parent, child, name);
        if (!relpath) continue;

        /* build full path: mountroot + relpath */
        size_t full_len = mountroot_len + (need_slash ? 1 : 0) + strlen(relpath) + 1;
        char *full = malloc(full_len);
        if (!full) { free(relpath); continue; }
        strcpy(full, mountroot);
        if (need_slash) strcat(full, "/");
        if (relpath[0] == '/') strcat(full, relpath + 1); else strcat(full, relpath);

        struct stat st;
        if (lstat(full, &st) == -1) {
            if (errno == ENOENT) {
                printf("%s\n", relpath);
            }
        }
        free(full);
        free(relpath);
    }
}

int main(int argc, char **argv) {
    if (argc != 2) {
        fprintf(stderr, "Usage: %s <device-or-image>\n", argv[0]);
        return 1;
    }
    const char *device = argv[1];

    if (geteuid() != 0) {
        fprintf(stderr, "This program requires root privileges to mount devices and read raw images.\n");
        return 1;
    }

    char mountpoint[PATH_MAX] = {0};
    int mounted_by_us = 0;
    if (mount_device_ro(device, mountpoint, sizeof(mountpoint), &mounted_by_us) != 0) {
        fprintf(stderr, "Failed to find or create a mountpoint for %s\n", device);
        return 2;
    }
    fprintf(stderr, "Using mountpoint: %s (mounted_by_us=%d)\n", mountpoint, mounted_by_us);

    int fd = open(device, O_RDONLY);
    if (fd < 0) {
        fprintf(stderr, "Failed to open %s: %s\n", device, strerror(errno));
        if (mounted_by_us) unmount_and_cleanup(mountpoint);
        return 3;
    }

    uint16_t inode_size = 128;
    uint32_t block_size = 4096;
    if (read_superblock(fd, &inode_size, &block_size) == 0) {
        fprintf(stderr, "Superblock read: inode_size=%u block_size=%u\n", inode_size, block_size);
    } else {
        fprintf(stderr, "Superblock not found or unreadable; using defaults inode_size=%u block_size=%u\n", inode_size, block_size);
    }

    struct dir_entry_list list;
    de_list_init(&list);

    if (linear_scan_inodes(fd, &list, inode_size, block_size) != 0) {
        fprintf(stderr, "Linear scan failed\n");
    } else {
        print_deleted_only(&list, mountpoint);
    }

    de_list_free(&list);
    close(fd);

    if (mounted_by_us) unmount_and_cleanup(mountpoint);
    return 0;
}
