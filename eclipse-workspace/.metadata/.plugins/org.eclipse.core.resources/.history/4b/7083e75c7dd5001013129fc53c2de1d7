int main(int argc, char **argv) {
    if (argc < 2) {
        fprintf(stderr, "usage: cc file.c\n");
        return 1;
    }

    char *combined = NULL;
    // ... (omitted: file reading and minimal preprocessing logic)

    // minimal stub for file reading to avoid unhandled error
    combined = strdup("int main() { return 0; }");

    user_input = combined;

    // tokenize
    token *tok = tokenize(user_input);
    current_token = tok;

    // parse all function definitions and global declarations until eof
    while (current_token->kind != tk_eof) {
        parse_fundef_or_global();
    }

    // code generation
    codegen_program(program_head);

    return 0;
}
