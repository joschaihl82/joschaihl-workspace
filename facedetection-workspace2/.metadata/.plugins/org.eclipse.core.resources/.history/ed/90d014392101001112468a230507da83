// rf_eye_detector.c
// Plain C Random-Forest eye detector using V4L2 and SDL2
// Compile: gcc -O3 -std=c11 rf_eye_detector.c -o rf_eye_detector -lSDL2

#define _POSIX_C_SOURCE 200809L
#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>
#include <string.h>
#include <errno.h>
#include <fcntl.h>
#include <unistd.h>
#include <sys/ioctl.h>
#include <sys/mman.h>
#include <linux/videodev2.h>
#include <SDL2/SDL.h>

#define PATCH_W 24
#define PATCH_H 24
#define PATCH_SZ (PATCH_W*PATCH_H)
#define MAX_DETECTIONS 1024

// --- Simple forest structures ---
typedef struct {
    uint16_t a, b; // pixel indices in flattened patch
} Pair;

typedef struct {
    int32_t feature; // -1 => leaf
    int32_t left;
    int32_t right;
    int32_t value; // leaf value 0/1
} Node;

typedef struct {
    uint32_t K;
    uint32_t W, H;
    uint32_t num_trees;
    Pair *pairs; // K entries
    Node **trees; // array of pointers to node arrays
    uint32_t *tree_node_counts;
} Forest;

// --- V4L2 capture helpers (single buffer mmap) ---
struct buffer {
    void *start;
    size_t length;
};

static int xioctl(int fd, int request, void *arg) {
    int r;
    do r = ioctl(fd, request, arg);
    while (r == -1 && errno == EINTR);
    return r;
}

int open_camera(const char *dev, int *fd_out, int *width, int *height) {
    int fd = open(dev, O_RDWR | O_NONBLOCK, 0);
    if (fd < 0) {
        perror("open camera");
        return -1;
    }
    struct v4l2_capability cap;
    if (xioctl(fd, VIDIOC_QUERYCAP, &cap) < 0) {
        perror("VIDIOC_QUERYCAP");
        close(fd);
        return -1;
    }
    struct v4l2_format fmt;
    memset(&fmt,0,sizeof(fmt));
    fmt.type = V4L2_BUF_TYPE_VIDEO_CAPTURE;
    fmt.fmt.pix.width = 640;
    fmt.fmt.pix.height = 480;
    fmt.fmt.pix.pixelformat = V4L2_PIX_FMT_YUYV;
    fmt.fmt.pix.field = V4L2_FIELD_INTERLACED;
    if (xioctl(fd, VIDIOC_S_FMT, &fmt) < 0) {
        perror("VIDIOC_S_FMT");
        close(fd);
        return -1;
    }
    *width = fmt.fmt.pix.width;
    *height = fmt.fmt.pix.height;
    // request buffers
    struct v4l2_requestbuffers req;
    memset(&req,0,sizeof(req));
    req.count = 4;
    req.type = V4L2_BUF_TYPE_VIDEO_CAPTURE;
    req.memory = V4L2_MEMORY_MMAP;
    if (xioctl(fd, VIDIOC_REQBUFS, &req) < 0) {
        perror("VIDIOC_REQBUFS");
        close(fd);
        return -1;
    }
    struct buffer *buffers = calloc(req.count, sizeof(*buffers));
    for (unsigned int i=0;i<req.count;i++) {
        struct v4l2_buffer buf;
        memset(&buf,0,sizeof(buf));
        buf.type = V4L2_BUF_TYPE_VIDEO_CAPTURE;
        buf.memory = V4L2_MEMORY_MMAP;
        buf.index = i;
        if (xioctl(fd, VIDIOC_QUERYBUF, &buf) < 0) {
            perror("VIDIOC_QUERYBUF");
            free(buffers);
            close(fd);
            return -1;
        }
        buffers[i].length = buf.length;
        buffers[i].start = mmap(NULL, buf.length, PROT_READ | PROT_WRITE, MAP_SHARED, fd, buf.m.offset);
        if (buffers[i].start == MAP_FAILED) {
            perror("mmap");
            free(buffers);
            close(fd);
            return -1;
        }
    }
    // queue buffers
    for (unsigned int i=0;i<req.count;i++) {
        struct v4l2_buffer buf;
        memset(&buf,0,sizeof(buf));
        buf.type = V4L2_BUF_TYPE_VIDEO_CAPTURE;
        buf.memory = V4L2_MEMORY_MMAP;
        buf.index = i;
        if (xioctl(fd, VIDIOC_QBUF, &buf) < 0) {
            perror("VIDIOC_QBUF");
            // continue
        }
    }
    // start
    enum v4l2_buf_type type = V4L2_BUF_TYPE_VIDEO_CAPTURE;
    if (xioctl(fd, VIDIOC_STREAMON, &type) < 0) {
        perror("VIDIOC_STREAMON");
        // continue
    }
    *fd_out = fd;
    // store buffers pointer in fd via malloc? For simplicity, we will re-query buffers on each read.
    // But we need buffers pointer later; instead, store globally via static pointer.
    // To keep code simple, we will re-query buffer on dequeue and use mmaped pointers from earlier.
    // Save buffers in static global:
    static struct buffer *g_buffers = NULL;
    static unsigned int g_buf_count = 0;
    if (g_buffers) free(g_buffers);
    g_buffers = buffers;
    g_buf_count = req.count;
    // store via environment? We'll use helper functions that reference g_buffers via extern-like static functions below.
    // For simplicity, we keep them static in this function's scope by using static variables above and helper functions below will access them.
    return 0;
}

// To access the static buffers created above, we declare accessor functions:
static struct buffer *get_buffers_ptr(unsigned int *count) {
    extern struct buffer *__g_v4l2_buffers;
    // hack: we can't access the static inside open_camera from here; instead, re-implement open_camera to set global.
    return NULL;
}

