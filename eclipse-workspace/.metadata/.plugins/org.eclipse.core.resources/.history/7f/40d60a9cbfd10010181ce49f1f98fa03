// ============================================================================
// emu_mega.c - x64 massive amalgamation edition
// - dramatischer code-zuwachs durch vollständiges unrolling der alu-ops
// - inline-flag-berechnung in jedem befehl für maximale größe und performance
// - implementiert korrigierte rex-präfix- und flag-logik
// - strikte anwendung der 3.5 namensregel (fun, val, num, ptr, arr)
// ============================================================================
#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>
#include <inttypes.h>
#include <string.h>
#include <stdarg.h>
#include <unistd.h>
#include <SDL2/SDL.h>

/* -------------------------
   con fig (config)
   ------------------------- */
#define VAL_RAM_SIZ (64ULL * 1024 * 1024) /* 64 mib */

static uint8_t *ptrMem = NULL;
static uint8_t *ptrFb = NULL;

/* -------------------------
   cpu struct
   ------------------------- */
typedef struct {
    uint64_t arrGpr[16];    /* rax..r15 */
    uint64_t valFlg;        /* rflags */
    uint64_t valRip;        /* rip */
    int numOps;             /* op_size */
    int numAds;             /* addr_size */
    int flgRex;             /* has_rex */
    int valRxw, valRxr, valRxx, valRxb;
    int valMod, valReg, valRm; /* modrm parts */
    uint8_t valLst;         /* last opcode */
    int numRep;             /* repeat prefix (0=none, 1=rep, 2=repne) */
} ObjCpu;

static ObjCpu objCpu;

/* -------------------------
   flag bit positions
   ------------------------- */
#define NUM_FLG_CF  (1ULL << 0)
#define NUM_FLG_PF  (1ULL << 2)
#define NUM_FLG_AF  (1ULL << 4)
#define NUM_FLG_ZF  (1ULL << 6)
#define NUM_FLG_SF  (1ULL << 7)
#define NUM_FLG_TF  (1ULL << 8)
#define NUM_FLG_IF  (1ULL << 9)
#define NUM_FLG_DF  (1ULL << 10)
#define NUM_FLG_OF  (1ULL << 11)

/* -------------------------
   register access macros (massive code generation)
   ------------------------- */
/* get 64-bit register index */
#define FUN_IDX_R64(reg_part, rex_part) (reg_part | (objCpu.rex_part << 3))

/* get 8-bit register (low byte) */
#define FUN_GET_R8_L(reg_part, rex_part) ((uint8_t)objCpu.arrGpr[FUN_IDX_R64(reg_part, rex_part)])

/* get 64-bit register value */
#define FUN_GET_R64(reg_part, rex_part) objCpu.arrGpr[FUN_IDX_R64(reg_part, rex_part)]

/* set 8-bit register (low byte) */
#define FUN_SET_R8_L(reg_part, rex_part, val) \
    objCpu.arrGpr[FUN_IDX_R64(reg_part, rex_part)] = \
    (objCpu.arrGpr[FUN_IDX_R64(reg_part, rex_part)] & ~0xFFULL) | (uint64_t)val;

/* set 64-bit register */
#define FUN_SET_R64(reg_part, rex_part, val) \
    objCpu.arrGpr[FUN_IDX_R64(reg_part, rex_part)] = val;


/* -------------------------
   helper decls
   ------------------------- */
uint8_t funMemR8(uint64_t valAdr);
uint64_t funMemR64(uint64_t valAdr);
void funMemW8(uint64_t valAdr, uint8_t valVal);
void funMemW64(uint64_t valAdr, uint64_t valVal);
uint8_t funFet8(void);
uint32_t funFet32(void);
uint64_t funFet64(void);
void funDecMr(void);
uint64_t funCalEa(void);

/* -------------------------
   mem access
   ------------------------- */
static inline uint8_t *ptrGetPtr(uint64_t valAdr) {
    if (!ptrMem) return NULL;
    return &ptrMem[valAdr % VAL_RAM_SIZ];
}
uint8_t funMemR8(uint64_t valAdr) {
    uint8_t *ptr = ptrGetPtr(valAdr); return ptr ? *ptr : 0;
}
uint64_t funMemR64(uint64_t valAdr) {
    uint8_t *ptr = ptrGetPtr(valAdr);
    uint64_t val = 0; if (ptr) memcpy(&val, ptr, 8); return val;
}
void funMemW8(uint64_t valAdr, uint8_t valVal) {
    uint8_t *ptr = ptrGetPtr(valAdr); if (ptr) *ptr = valVal;
}
void funMemW64(uint64_t valAdr, uint64_t valVal) {
    uint8_t *ptr = ptrGetPtr(valAdr); if (ptr) memcpy(ptr, &valVal, 8);
}

/* -------------------------
   fetch logic
   ------------------------- */
uint8_t funFet8(void) {
    uint8_t val = funMemR8(objCpu.valRip); objCpu.valRip++; return val;
}
uint32_t funFet32(void) {
    uint32_t val = funMemR32(objCpu.valRip); objCpu.valRip += 4; return val;
}
uint64_t funFet64(void) {
    uint64_t val = funMemR64(objCpu.valRip); objCpu.valRip += 8; return val;
}

/* -------------------------
   decode logic
   ------------------------- */
void funDecMr(void) {
    uint8_t val = funFet8();
    objCpu.valMod = (val >> 6) & 3;
    objCpu.valReg = (val >> 3) & 7;
    objCpu.valRm  = val & 7;
}

uint64_t funCalEa(void) {
    uint64_t valAdr = 0;
    int numRm = objCpu.valRm | (objCpu.valRxb << 3);

    /* sib byte handling (simplified: base only) */
    if (objCpu.valRm == 4) {
        uint8_t valSib = funFet8();
        int numBase = valSib & 7;
        if (numBase == 5 && objCpu.valMod == 0) {
            valAdr = (int64_t)(int32_t)funFet32();
            return valAdr;
        }
        numRm = numBase | (objCpu.valRxb << 3);
    }

    if (objCpu.valMod == 0) {
        if ((numRm & 7) == 5) { /* rip relative or disp32 (absolute, simplified) */
            valAdr = objCpu.valRip + (int64_t)(int32_t)funFet32();
        } else {
            valAdr = objCpu.arrGpr[numRm];
        }
    } else if (objCpu.valMod == 1) {
        valAdr = objCpu.arrGpr[numRm] + (int64_t)(int8_t)funFet8();
    } else if (objCpu.valMod == 2) {
        valAdr = objCpu.arrGpr[numRm] + (int64_t)(int32_t)funFet32();
    }
    return valAdr;
}

/* -------------------------
   flag macros (massive inline expansion)
   ------------------------- */
static inline int funPar8(uint8_t val) {
    val ^= val >> 4; val &= 0xF; return (0x6996 >> val) & 1;
}

/* general flag clearing (massive inline expansion) */
#define CLR_FLG_ALU() \
    objCpu.valFlg &= ~ (NUM_FLG_CF | NUM_FLG_PF | NUM_FLG_AF | NUM_FLG_ZF | NUM_FLG_SF | NUM_FLG_OF);

/* set sf, zf, pf for 8-bit result */
#define SET_FLG_SZP8(res) \
    if ((res) == 0) objCpu.valFlg |= NUM_FLG_ZF; else objCpu.valFlg &= ~NUM_FLG_ZF; \
    if ((res) & 0x80) objCpu.valFlg |= NUM_FLG_SF; else objCpu.valFlg &= ~NUM_FLG_SF; \
    if (funPar8((uint8_t)res)) objCpu.valFlg |= NUM_FLG_PF; else objCpu.valFlg &= ~NUM_FLG_PF;

/* set sf, zf, pf for 64-bit result */
#define SET_FLG_SZP64(res) \
    if ((res) == 0) objCpu.valFlg |= NUM_FLG_ZF; else objCpu.valFlg &= ~NUM_FLG_ZF; \
    if ((res) & 0x8000000000000000ULL) objCpu.valFlg |= NUM_FLG_SF; else objCpu.valFlg &= ~NUM_FLG_SF; \
    if (funPar8((uint8_t)res)) objCpu.valFlg |= NUM_FLG_PF; else objCpu.valFlg &= ~NUM_FLG_PF;

/* set cf, of for 64-bit addition */
#define SET_FLG_ADD64(valA, valB, valRes) \
    if ((valRes) < (valA)) objCpu.valFlg |= NUM_FLG_CF; else objCpu.valFlg &= ~NUM_FLG_CF; \
    if (((valA ^ valRes) & (valB ^ valRes)) >> 63) objCpu.valFlg |= NUM_FLG_OF; else objCpu.valFlg &= ~NUM_FLG_OF;

/* set cf, of for 64-bit subtraction */
#define SET_FLG_SUB64(valA, valB, valRes) \
    if ((valA) < (valB)) objCpu.valFlg |= NUM_FLG_CF; else objCpu.valFlg &= ~NUM_FLG_CF; \
    if (((valA ^ valB) & (valA ^ valRes)) >> 63) objCpu.valFlg |= NUM_FLG_OF; else objCpu.valFlg &= ~NUM_FLG_OF;


/* -------------------------
   stack logic
   ------------------------- */
static inline void funPsh64(uint64_t val) {
    objCpu.arrGpr[4] -= 8; /* rsp */
    funMemW64(objCpu.arrGpr[4], val);
}
static inline uint64_t funPop64(void) {
    uint64_t val = funMemR64(objCpu.arrGpr[4]);
    objCpu.arrGpr[4] += 8; /* rsp */
    return val;
}

/* -------------------------
   condition logic
   ------------------------- */
static int funTstCnd(int numCnd) {
    int flgCf = (objCpu.valFlg & NUM_FLG_CF) >> 0;
    int flgZf = (objCpu.valFlg & NUM_FLG_ZF) >> 6;
    int flgSf = (objCpu.valFlg & NUM_FLG_SF) >> 7;
    int flgOf = (objCpu.valFlg & NUM_FLG_OF) >> 11;
    switch (numCnd & 0xF) {
        case 0x0: return flgOf;           /* o */
        case 0x1: return !flgOf;          /* no */
        case 0x2: return flgCf;           /* c/b/nae */
        case 0x3: return !flgCf;          /* nc/nb/ae */
        case 0x4: return flgZf;           /* z/e */
        case 0x5: return !flgZf;          /* nz/ne */
        case 0x6: return flgCf || flgZf;  /* be/na */
        case 0x7: return !(flgCf || flgZf); /* nbe/a */
        case 0x8: return flgSf;           /* s */
        case 0x9: return !flgSf;          /* ns */
        case 0xA: return (objCpu.valFlg & NUM_FLG_PF) >> 2; /* p/pe */
        case 0xB: return !((objCpu.valFlg & NUM_FLG_PF) >> 2); /* np/po */
        case 0xC: return flgSf != flgOf;  /* l/nge */
        case 0xD: return flgSf == flgOf;  /* nl/ge */
        case 0xE: return (flgSf != flgOf) || flgZf; /* le/ng */
        case 0xF: return !((flgSf != flgOf) || flgZf); /* nle/g */
    }
    return 0;
}

/* -------------------------
   main execution engine
   ------------------------- */
#if defined(__GNUC__)
void funExec(void) {
    /* computed goto table - massively expanded */
    static void *arrJmp[256];
    static int flgIni = 0;
    if (!flgIni) {
        for(int i=0; i<256; i++) arrJmp[i] = &&labErr;

        /* standard alu (fully expanded) */
        arrJmp[0x00] = &&labAdd00; arrJmp[0x01] = &&labAdd01; arrJmp[0x02] = &&labAdd02; arrJmp[0x03] = &&labAdd03;
        arrJmp[0x04] = &&labAdd04; arrJmp[0x05] = &&labAdd05;
        arrJmp[0x08] = &&labOr08;  arrJmp[0x09] = &&labOr09;  arrJmp[0x0A] = &&labOr0A;  arrJmp[0x0B] = &&labOr0B;
        arrJmp[0x0C] = &&labOr0C;  arrJmp[0x0D] = &&labOr0D;
        arrJmp[0x20] = &&labAnd20; arrJmp[0x21] = &&labAnd21; arrJmp[0x22] = &&labAnd22; arrJmp[0x23] = &&labAnd23;
        arrJmp[0x24] = &&labAnd24; arrJmp[0x25] = &&labAnd25;
        arrJmp[0x28] = &&labSub28; arrJmp[0x29] = &&labSub29; arrJmp[0x2A] = &&labSub2A; arrJmp[0x2B] = &&labSub2B;
        arrJmp[0x2C] = &&labSub2C; arrJmp[0x2D] = &&labSub2D;
        arrJmp[0x30] = &&labXor30; arrJmp[0x31] = &&labXor31; arrJmp[0x32] = &&labXor32; arrJmp[0x33] = &&labXor33;
        arrJmp[0x34] = &&labXor34; arrJmp[0x35] = &&labXor35;
        arrJmp[0x38] = &&labCmp38; arrJmp[0x39] = &&labCmp39; arrJmp[0x3A] = &&labCmp3A; arrJmp[0x3B] = &&labCmp3B;
        arrJmp[0x3C] = &&labCmp3C; arrJmp[0x3D] = &&labCmp3D;

        /* inc/dec/push/pop */
        arrJmp[0x50] = &&labPsh50; arrJmp[0x51] = &&labPsh51; arrJmp[0x52] = &&labPsh52; arrJmp[0x53] = &&labPsh53;
        arrJmp[0x54] = &&labPsh54; arrJmp[0x55] = &&labPsh55; arrJmp[0x56] = &&labPsh56; arrJmp[0x57] = &&labPsh57;
        arrJmp[0x58] = &&labPop58; arrJmp[0x59] = &&labPop59; arrJmp[0x5A] = &&labPop5A; arrJmp[0x5B] = &&labPop5B;
        arrJmp[0x5C] = &&labPop5C; arrJmp[0x5D] = &&labPop5D; arrJmp[0x5E] = &&labPop5E; arrJmp[0x5F] = &&labPop5F;
        arrJmp[0x68] = &&labPsh68; arrJmp[0x6A] = &&labPsh6A;

        /* jcc short */
        arrJmp[0x70] = &&labJcc70; arrJmp[0x71] = &&labJcc71; arrJmp[0x72] = &&labJcc72; arrJmp[0x73] = &&labJcc73;
        arrJmp[0x74] = &&labJcc74; arrJmp[0x75] = &&labJcc75; arrJmp[0x76] = &&labJcc76; arrJmp[0x77] = &&labJcc77;
        arrJmp[0x78] = &&labJcc78; arrJmp[0x79] = &&labJcc79; arrJmp[0x7A] = &&labJcc7A; arrJmp[0x7B] = &&labJcc7B;
        arrJmp[0x7C] = &&labJcc7C; arrJmp[0x7D] = &&labJcc7D; arrJmp[0x7E] = &&labJcc7E; arrJmp[0x7F] = &&labJcc7F;

        /* immediate alu group */
        arrJmp[0x80] = &&labAlu80; arrJmp[0x81] = &&labAlu81; arrJmp[0x83] = &&labAlu83;

        /* test / xchg / mov / lea */
        arrJmp[0x84] = &&labTst84; arrJmp[0x85] = &&labTst85;
        arrJmp[0x88] = &&labMov88; arrJmp[0x89] = &&labMov89; arrJmp[0x8A] = &&labMov8A; arrJmp[0x8B] = &&labMov8B;
        arrJmp[0x8D] = &&labLea8D;
        arrJmp[0x8F] = &&labPop8F;

        /* nop / xchg eax (fully unrolled xchg 90-97) */
        arrJmp[0x90] = &&labXch90; arrJmp[0x91] = &&labXch91; arrJmp[0x92] = &&labXch92; arrJmp[0x93] = &&labXch93;
        arrJmp[0x94] = &&labXch94; arrJmp[0x95] = &&labXch95; arrJmp[0x96] = &&labXch96; arrJmp[0x97] = &&labXch97;

        /* movs / stos */
        arrJmp[0xA4] = &&labMovA4; arrJmp[0xA5] = &&labMovA5;
        arrJmp[0xAA] = &&labStoAA; arrJmp[0xAB] = &&labStoAB;

        /* mov imm */
        arrJmp[0xB0] = &&labMovB0; arrJmp[0xB1] = &&labMovB1; arrJmp[0xB2] = &&labMovB2; arrJmp[0xB3] = &&labMovB3;
        arrJmp[0xB4] = &&labMovB4; arrJmp[0xB5] = &&labMovB5; arrJmp[0xB6] = &&labMovB6; arrJmp[0xB7] = &&labMovB7;
        arrJmp[0xB8] = &&labMovB8; arrJmp[0xB9] = &&labMovB9; arrJmp[0xBA] = &&labMovBA; arrJmp[0xBB] = &&labMovBB;
        arrJmp[0xBC] = &&labMovBC; arrJmp[0xBD] = &&labMovBD; arrJmp[0xBE] = &&labMovBE; arrJmp[0xBF] = &&labMovBF;

        /* shifts */
        arrJmp[0xC0] = &&labShfC0; arrJmp[0xC1] = &&labShfC1;
        arrJmp[0xC3] = &&labRetC3;
        arrJmp[0xC6] = &&labMovC6; arrJmp[0xC7] = &&labMovC7;

        /* shift 1 / cl */
        arrJmp[0xD0] = &&labShfD0; arrJmp[0xD1] = &&labShfD1; arrJmp[0xD2] = &&labShfD2; arrJmp[0xD3] = &&labShfD3;

        /* call / jmp */
        arrJmp[0xE8] = &&labCalE8;
        arrJmp[0xE9] = &&labJmpE9;
        arrJmp[0xEB] = &&labJmpEB;

        /* misc groups */
        arrJmp[0xF6] = &&labGrp3F6; arrJmp[0xF7] = &&labGrp3F7;
        arrJmp[0xFE] = &&labGrpFEO; arrJmp[0xFF] = &&labGrpFF;

        /* two byte */
        arrJmp[0x0F] = &&labTwo0F;

        flgIni = 1;
    }

    for (;;) {
        /* reset prefix state */
        objCpu.numOps = 64;
        objCpu.flgRex = 0; objCpu.valRxw = 0; objCpu.valRxr = 0; objCpu.valRxx = 0; objCpu.valRxb = 0;
        objCpu.numRep = 0;

        int flgPre = 1;
        uint8_t numOp = 0;

        while (flgPre) {
            numOp = funFet8();
            switch (numOp) {
                case 0x66: objCpu.numOps = 16; break; /* op override (only affects imm size in 64 bit mode, ignored here for simplicity) */
                case 0xF3: objCpu.numRep = 1; break; /* rep/repe/repz */
                case 0xF2: objCpu.numRep = 2; break; /* repne/repnz */
                default:
                    if ((numOp & 0xF0) == 0x40) {
                        objCpu.flgRex = 1;
                        objCpu.valRxw = (numOp >> 3) & 1; /* w bit */
                        objCpu.valRxr = (numOp >> 2) & 1; /* r bit (reg field) */
                        objCpu.valRxx = (numOp >> 1) & 1; /* x bit (sib index) */
                        objCpu.valRxb = numOp & 1;        /* b bit (r/m or sib base) */
                        if (objCpu.valRxw) objCpu.numOps = 64;
                    } else {
                        flgPre = 0;
                    }
                    break;
            }
        }
        objCpu.valLst = numOp;
        goto *arrJmp[numOp];

    /* ========================================================================
       ALU OPERATIONS - MASSIVELY UNROLLED
       ======================================================================== */
    labAdd00: { /* add r/m8, r8 */
        funDecMr();
        uint8_t src = FUN_GET_R8_L(objCpu.valReg, valRxr);
        uint64_t ea = funCalEa();
        uint8_t dst = funMemR8(ea);
        uint8_t res = dst + src;
        CLR_FLG_ALU();
        /* CF */ if (res < dst) objCpu.valFlg |= NUM_FLG_CF;
        /* OF */ if (((dst ^ res) & (src ^ res)) & 0x80) objCpu.valFlg |= NUM_FLG_OF;
        SET_FLG_SZP8(res);
        funMemW8(ea, res);
        goto endOp;
    }
    labAdd01: { /* add r/m64, r64 (r/m32 if no REX.W) */
        funDecMr();
        uint64_t src = FUN_GET_R64(objCpu.valReg, valRxr);
        if (objCpu.valMod == 3) {
            uint64_t *ptrDst = &objCpu.arrGpr[FUN_IDX_R64(objCpu.valRm, valRxb)];
            uint64_t valOld = *ptrDst; *ptrDst += src;
            CLR_FLG_ALU(); SET_FLG_ADD64(valOld, src, *ptrDst); SET_FLG_SZP64(*ptrDst);
        } else {
            uint64_t ea = funCalEa();
            uint64_t valOld = funMemR64(ea);
            uint64_t valRes = valOld + src;
            CLR_FLG_ALU(); SET_FLG_ADD64(valOld, src, valRes); SET_FLG_SZP64(valRes);
            funMemW64(ea, valRes);
        }
        goto endOp;
    }
    labAdd02: { /* add r8, r/m8 */
        funDecMr();
        uint8_t val = (objCpu.valMod == 3) ? FUN_GET_R8_L(objCpu.valRm, valRxb) : funMemR8(funCalEa());
        uint8_t valOld = FUN_GET_R8_L(objCpu.valReg, valRxr);
        uint8_t valRes = valOld + val;
        FUN_SET_R8_L(objCpu.valReg, valRxr, valRes);
        CLR_FLG_ALU();
        /* CF */ if (valRes < valOld) objCpu.valFlg |= NUM_FLG_CF;
        /* OF */ if (((valOld ^ valRes) & (val ^ valRes)) & 0x80) objCpu.valFlg |= NUM_FLG_OF;
        SET_FLG_SZP8(valRes);
        goto endOp;
    }
    labAdd03: { /* add r64, r/m64 */
        funDecMr();
        uint64_t val = (objCpu.valMod == 3) ? FUN_GET_R64(objCpu.valRm, valRxb) : funMemR64(funCalEa());
        uint64_t *ptrDst = &objCpu.arrGpr[FUN_IDX_R64(objCpu.valReg, valRxr)];
        uint64_t valOld = *ptrDst; *ptrDst += val;
        CLR_FLG_ALU(); SET_FLG_ADD64(valOld, val, *ptrDst); SET_FLG_SZP64(*ptrDst);
        goto endOp;
    }
    labAdd04: { /* add al, imm8 */
        uint8_t imm = funFet8();
        uint8_t valOld = (uint8_t)objCpu.arrGpr[0];
        uint8_t valRes = valOld + imm;
        objCpu.arrGpr[0] = (objCpu.arrGpr[0] & ~0xFFULL) | valRes;
        CLR_FLG_ALU();
        /* CF */ if (valRes < valOld) objCpu.valFlg |= NUM_FLG_CF;
        /* OF */ if (((valOld ^ valRes) & (imm ^ valRes)) & 0x80) objCpu.valFlg |= NUM_FLG_OF;
        SET_FLG_SZP8(valRes);
        goto endOp;
    }
    labAdd05: { /* add rax, imm32 (sign extended) */
        uint64_t imm = (uint64_t)(int64_t)(int32_t)funFet32();
        uint64_t valOld = objCpu.arrGpr[0];
        objCpu.arrGpr[0] += imm;
        CLR_FLG_ALU(); SET_FLG_ADD64(valOld, imm, objCpu.arrGpr[0]); SET_FLG_SZP64(objCpu.arrGpr[0]);
        goto endOp;
    }

    labOr08: { /* or r/m8, r8 */
        funDecMr();
        uint8_t src = FUN_GET_R8_L(objCpu.valReg, valRxr);
        uint64_t ea = funCalEa();
        uint8_t dst = funMemR8(ea);
        uint8_t res = dst | src;
        funMemW8(ea, res);
        CLR_FLG_ALU(); SET_FLG_SZP8(res);
        goto endOp;
    }
    labOr09: { /* or r/m64, r64 */
        funDecMr();
        uint64_t src = FUN_GET_R64(objCpu.valReg, valRxr);
        uint64_t *ptrDst = &objCpu.arrGpr[FUN_IDX_R64(objCpu.valRm, valRxb)];
        uint64_t res;
        if (objCpu.valMod == 3) {
            *ptrDst |= src; res = *ptrDst;
        } else {
            uint64_t ea = funCalEa();
            res = funMemR64(ea) | src;
            funMemW64(ea, res);
        }
        CLR_FLG_ALU(); SET_FLG_SZP64(res);
        goto endOp;
    }
