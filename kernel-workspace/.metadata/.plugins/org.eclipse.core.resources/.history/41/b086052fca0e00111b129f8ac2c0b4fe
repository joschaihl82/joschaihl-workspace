# 3.5 rule: mod prefix, obj/nam/dir postfix
mod_obj := exectrace1.o
mod_nam := exectrace1
mod_dir := /lib/modules/$(shell uname -r)/extra
obj-m := $(mod_obj)

# 3.5 rule: mak prefix, bin/knd/cur/flg postfix
mak_bin := make
mak_knd := /lib/modules/$(shell uname -r)/build
mak_cur := $(shell pwd)
mak_flg := v=1

# 3.5 rule: sym prefix, tgt/chk/lst postfix
# replace 'do_execve' with the function you are actually tracing
sym_tgt := do_execve
sym_chk := /proc/kallsyms
sym_lst := /sys/kernel/debug/kprobes/blacklist

.phony: all clean cln_all load unload debug

all:
	$(mak_bin) -C $(mak_knd) M=$(mak_cur) modules $(mak_flg)

clean:
	$(mak_bin) -C $(mak_knd) M=$(mak_cur) clean

load: all
	sudo mkdir -p $(mod_dir)
	sudo cp $(mod_nam).ko $(mod_dir)
	sudo depmod -a
	sudo modprobe $(mod_nam) || (sudo dmesg | tail -n 20 && exit 1)

unload:
	sudo modprobe -r $(mod_nam)
	sudo rm -f $(mod_dir)/$(mod_nam).ko
	sudo depmod -a

debug:
	@echo "--- checking symbol existence ---"
	@grep -w $(sym_tgt) $(sym_chk) || echo "symbol $(sym_tgt) NOT found!"
	@echo "--- checking kprobe blacklist ---"
	@sudo grep -w $(sym_tgt) $(sym_lst) 2>/dev/null && echo "symbol is BLACKLISTED" || echo "symbol is safe"