/*
 * jlz4.c - lz4-style tool
 * style: freebsd kernel (style(9)) + 3.5 naming rule
 */

#include <sys/types.h>
#include <sys/stat.h>
#include <sys/time.h>
#include <sys/ioctl.h>

#include <err.h>
#include <errno.h>
#include <fcntl.h>
#include <dirent.h>
#include <libgen.h>
#include <limits.h>
#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>
#include <unistd.h>

#define	BLK_SIZE	(1 << 20)
#define	WIN_SIZE	(1 << 16)
#define	MIN_MAT		4
#define	HSH_SIZE	(1 << 16)
#define	HSH_SFT		(32 - 16)

#ifndef PATH_MAX
#define	PATH_MAX	4096
#endif

typedef struct {
	uint64_t tot;
	uint64_t proc;
	struct timeval start;
	const char *curr;
	uint64_t fOrig;
	uint64_t fComp;
	int	 lines;
} prgCtx;

typedef struct {
	FILE	*fp;
	const char *path;
	uint8_t *in;
	uint8_t *out;
	uint32_t cLen;
	uint64_t fLen;
} ioCtx;

static prgCtx gPrg;

/*
 * terminal & string utils
 */

static int
trmWidt(void)
{
	struct winsize ws;

	if (ioctl(STDOUT_FILENO, TIOCGWINSZ, &ws) == 0 && ws.ws_col > 0)
		return ((int)ws.ws_col);
	return (80);
}

static void
strJoin(char *dst, size_t max, const char *dr, const char *fn)
{
	if (dr == NULL || dr[0] == '\0') {
		snprintf(dst, max, "%s", fn);
	} else if (dr[strlen(dr) - 1] == '/') {
		snprintf(dst, max, "%s%s", dr, fn);
	} else {
		snprintf(dst, max, "%s/%s", dr, fn);
	}
}

/*
 * io utils
 */

static int
ioWrit(int fd, const void *buf, size_t n)
{
	const uint8_t *p;
	ssize_t w;

	p = buf;
	while (n > 0) {
		w = write(fd, p, n);
		if (w < 0) {
			if (errno == EINTR)
				continue;
			return (-1);
		}
		n -= w;
		p += w;
	}
	return (0);
}

static size_t
ioRead(FILE *f, uint8_t *buf, size_t n)
{
	size_t got;
	size_t r;

	got = 0;
	while (got < n) {
		r = fread(buf + got, 1, n - got, f);
		if (r == 0)
			break;
		got += r;
	}
	return (got);
}

static int
ioWu32(FILE *f, uint32_t v)
{
	uint8_t b[4];

	b[0] = v & 0xFF;
	b[1] = (v >> 8) & 0xFF;
	b[2] = (v >> 16) & 0xFF;
	b[3] = (v >> 24) & 0xFF;
	return (fwrite(b, 1, 4, f) == 4 ? 0 : -1);
}

static int
ioWu64(FILE *f, uint64_t v)
{
	uint8_t b[8];
	int i;

	for (i = 0; i < 8; ++i)
		b[i] = (v >> (8 * i)) & 0xFF;
	return (fwrite(b, 1, 8, f) == 8 ? 0 : -1);
}

static int
ioRu32(FILE *f, uint32_t *v)
{
	uint8_t b[4];

	if (fread(b, 1, 4, f) != 4)
		return (-1);
	*v = b[0] | (b[1] << 8) | (b[2] << 16) | (b[3] << 24);
	return (0);
}

static int
ioRu64(FILE *f, uint64_t *v)
{
	uint8_t b[8];
	int i;

	if (fread(b, 1, 8, f) != 8)
		return (-1);
	*v = 0;
	for (i = 0; i < 8; ++i)
		*v |= ((uint64_t)b[i]) << (8 * i);
	return (0);
}

/*
 * formatting
 */

static void
fmtByte(uint64_t v, char *b, size_t n)
{
	const char *u[] = {"B", "KB", "MB", "GB"};
	double d;
	int i;

	d = (double)v;
	i = 0;
	while (d >= 1024.0 && i < 3) {
		d /= 1024.0;
		i++;
	}
	snprintf(b, n, "%.2f %s", d, u[i]);
}

static void
fmtTime(double s, char *b, size_t n)
{
	int t;

	if (s < 0)
		s = 0;
	t = (int)(s + 0.5);
	snprintf(b, n, "%02d:%02d:%02d", t / 3600, (t % 3600) / 60, t % 60);
}

/*
 * progress bar
 */

static void
prgLine(int clr)
{
	if (clr && gPrg.lines > 0)
		printf("\033[%dA", gPrg.lines);
	gPrg.lines = 0;
}

static void
prgCalc(double *pct, double *eta, double *spd)
{
	struct timeval now;
	double el;

	gettimeofday(&now, NULL);
	el = (now.tv_sec - gPrg.start.tv_sec) +
	    (now.tv_usec - gPrg.start.tv_usec) / 1e6;
	*pct = gPrg.tot ? (double)gPrg.proc * 100.0 / gPrg.tot : 0;
	*eta = (gPrg.proc > 0 && gPrg.tot > gPrg.proc) ?
	    el * (gPrg.tot - gPrg.proc) / gPrg.proc : 0;
	*spd = (gPrg.proc > 0 && el > 0) ? gPrg.proc / el : 0;
}

static void
prgDraw(double pct, int w)
{
	int fil;
	int i;

	fil = (int)((pct / 100.0) * w + 0.5);
	if (fil > w)
		fil = w;
	printf("\033[K%6.2f%% [", pct);
	for (i = 0; i < fil; ++i)
		putchar('=');
	for (i = fil; i < w; ++i)
		putchar(' ');
	printf("]\n");
	gPrg.lines++;
}

static void
prgUpd(uint64_t p, uint64_t t)
{
	char s1[32], s3[32];
	double pct, eta, spd;

	gPrg.proc = p;
	gPrg.tot = t;
	prgLine(1);
	prgCalc(&pct, &eta, &spd);
	fmtByte((uint64_t)spd, s1, 32);
	fmtTime(eta, s3, 32);

	if (gPrg.curr)
		printf("\033[KFile: %s\n", gPrg.curr);
	else
		printf("\033[K\n");
	gPrg.lines++;
	printf("\033[KETA: %s | Spd: %s/s\n", s3, s1);
	gPrg.lines++;
	prgDraw(pct, trmWidt() - 40);
	fflush(stdout);
}

/*
 * compression core
 */

static inline uint32_t
lz4Hash(const uint8_t *p)
{
	uint32_t v;

	memcpy(&v, p, 4);
	return ((v * 2654435761u) >> HSH_SFT) & (HSH_SIZE - 1);
}

static void
lz4Lit(uint8_t **op, const uint8_t *anc, size_t len)
{
	size_t rem;

	rem = len >= 15 ? len - 15 : 0;
	if (len >= 15) {
		while (rem >= 255) {
			*(*op)++ = 255;
			rem -= 255;
		}
		*(*op)++ = (uint8_t)rem;
	}
	memcpy(*op, anc, len);
	*op += len;
}

static void
lz4Mat(uint8_t **op, size_t off, size_t len)
{
	uint16_t o;
	size_t l;
	size_t rem;

	o = (uint16_t)off;
	*(*op)++ = (uint8_t)(o & 0xFF);
	*(*op)++ = (uint8_t)((o >> 8) & 0xFF);
	l = len - MIN_MAT;
	if (l >= 15) {
		rem = l - 15;
		while (rem >= 255) {
			*(*op)++ = 255;
			rem -= 255;
		}
		*(*op)++ = (uint8_t)rem;
	}
}

static size_t
lz4Comp(const uint8_t *in, size_t n, uint8_t *out, size_t cap)
{
	const uint8_t *ip, *end, *anc, *p1, *p2;
	uint32_t *ht;
	uint8_t *op;
	uint32_t h, ref, cSz;
	size_t mLen, lLen;

	if (cap < 12)
		return (0);
	op = out;
	memcpy(op, "LZ4B", 4);
	op += 4;
	memcpy(op, &n, 4);
	op += 8;

	ht = calloc(HSH_SIZE, sizeof(uint32_t));
	if (ht == NULL)
		return (0);
	memset(ht, 0xFF, HSH_SIZE * sizeof(uint32_t));

	ip = in;
	end = in + n;
	anc = ip;

	while (ip + MIN_MAT <= end) {
		h = lz4Hash(ip);
		ref = ht[h];
		ht[h] = (uint32_t)(ip - in);
		if (ref == 0xFFFFFFFFu || (ip - (in + ref)) > WIN_SIZE ||
		    memcmp(in + ref, ip, 4) != 0) {
			ip++;
			continue;
		}
		p1 = ip;
		p2 = in + ref;
		while (p1 < end && *p1 == *p2) {
			p1++;
			p2++;
		}
		mLen = p1 - ip;
		lLen = ip - anc;
		*op++ = (lLen >= 15 ? 15 : lLen) << 4 |
		    (mLen - 4 >= 15 ? 15 : mLen - 4);
		lz4Lit(&op, anc, lLen);
		lz4Mat(&op, ip - (in + ref), mLen);
		ip += mLen;
		anc = ip;
	}

	lLen = end - anc;
	*op++ = (lLen >= 15 ? 15 : lLen) << 4;
	lz4Lit(&op, anc, lLen);

	cSz = (uint32_t)(op - out - 12);
	memcpy(out + 8, &cSz, 4);
	free(ht);
	return (op - out);
}

/*
 * decompression core
 */

static size_t
lz4Dec(const uint8_t *in, size_t n, uint8_t *out, size_t cap)
{
	const uint8_t *ip, *end;
	uint32_t org, cSz;
	size_t opos, lLen, mLen, ref;
	uint8_t s, tok;
	uint16_t off;
	int i;

	if (n < 12 || memcmp(in, "LZ4B", 4) != 0)
		return (0);
	memcpy(&org, in + 4, 4);
	memcpy(&cSz, in + 8, 4);
	if (cSz + 12 != n)
		return (0);

	ip = in + 12;
	end = in + n;
	opos = 0;

	while (ip < end) {
		tok = *ip++;
		lLen = tok >> 4;
		if (lLen == 15) {
			do {
				s = *ip++;
				lLen += s;
			} while (s == 255);
		}
		if (opos + lLen > cap)
			return (0);
		memcpy(out + opos, ip, lLen);
		ip += lLen;
		opos += lLen;
		if (ip >= end)
			break;

		off = ip[0] | (ip[1] << 8);
		ip += 2;
		mLen = (tok & 0xF) + 4;
		if (mLen - 4 == 15) {
			do {
				s = *ip++;
				mLen += s;
			} while (s == 255);
		}
		ref = opos - off;
		if (off == 0 || off > opos || opos + mLen > cap)
			return (0);
		for (i = 0; i < mLen; ++i)
			out[opos + i] = out[ref + i];
		opos += mLen;
	}
	return (opos == org ? opos : 0);
}

/*
 * file processing helpers
 */

static int
dirMk(const char *p)
{
	struct stat st;
	char tmp[PATH_MAX];
	char *sl;

	strncpy(tmp, p, sizeof(tmp) - 1);
	sl = strrchr(tmp, '/');
	if (sl == NULL || sl == tmp)
		return (0);
	*sl = 0;
	if (stat(tmp, &st) == 0 && S_ISDIR(st.st_mode))
		return (0);
	dirMk(tmp);
	return (mkdir(tmp, 0755) == 0 || errno == EEXIST ? 0 : -1);
}

static int
arcWrit(FILE *arc, const char *nm, uint64_t sz)
{
	uint32_t nl;

	nl = strlen(nm);
	if (ioWu32(arc, nl))
		return (-1);
	if (fwrite(nm, 1, nl, arc) != nl)
		return (-1);
	if (ioWu64(arc, sz))
		return (-1);
	return (0);
}

static int
blkProc(ioCtx *c, FILE *out, int isComp)
{
	size_t res;
	uint32_t bSz;

	if (isComp)
		res = lz4Comp(c->in, c->cLen, c->out, BLK_SIZE * 2);
	else
		res = lz4Dec(c->in, c->cLen, c->out, BLK_SIZE * 2);

	if (res == 0)
		return (-1);

	if (isComp) {
		bSz = (uint32_t)res;
		if (ioWu32(out, bSz))
			return (-1);
		if (fwrite(c->out, 1, res, out) != res)
			return (-1);
		gPrg.fComp += 4 + res;
	} else {
		if (ioWrit(fileno(out), c->out, res))
			return (-1);
	}
	return (0);
}

static int
filComp(ioCtx *c, FILE *arc)
{
	size_t r;
	long szPos, cur;

	gPrg.curr = c->path;
	gPrg.fComp = 0;
	szPos = ftell(arc);
	if (ioWu32(arc, 0))
		return (-1);

	while ((r = ioRead(c->fp, c->in, BLK_SIZE)) > 0) {
		c->cLen = r;
		if (blkProc(c, arc, 1) != 0)
			return (-1);
		gPrg.proc += r;
		prgUpd(gPrg.proc, gPrg.tot);
	}

	cur = ftell(arc);
	fseek(arc, szPos, SEEK_SET);
	ioWu32(arc, (uint32_t)gPrg.fComp);
	fseek(arc, cur, SEEK_SET);
	return (0);
}

static int
filDec(FILE *arc, const char *out, uint32_t cSz)
{
	ioCtx c;
	FILE *fo;
	uint32_t rem;
	uint32_t bSz;
	int fd;

	c.in = malloc(BLK_SIZE * 2);
	c.out = malloc(BLK_SIZE * 2);
	c.fp = NULL;
	fd = open(out, O_WRONLY | O_CREAT | O_TRUNC, 0644);
	fo = (fd >= 0) ? fdopen(fd, "wb") : NULL;
	rem = cSz;

	while (rem > 0) {
		if (ioRu32(arc, &bSz))
			break;
		rem -= 4;
		c.cLen = bSz;
		ioRead(arc, c.in, bSz);
		rem -= bSz;
		blkProc(&c, fo, 0);
		gPrg.proc += 4 + bSz;
		prgUpd(gPrg.proc, gPrg.tot);
	}
	free(c.in);
	free(c.out);
	if (fo)
		fclose(fo);
	return (0);
}

/*
 * directory traversal
 */

static int
recSize(const char *p, uint64_t *sz)
{
	struct stat st;
	struct dirent *e;
	DIR *d;
	char sub[PATH_MAX];

	if (lstat(p, &st))
		return (-1);
	if (S_ISREG(st.st_mode)) {
		*sz += st.st_size;
		return (0);
	}
	if (!S_ISDIR(st.st_mode))
		return (0);

	d = opendir(p);
	if (d == NULL)
		return (-1);
	while ((e = readdir(d))) {
		if (e->d_name[0] == '.')
			continue;
		strJoin(sub, PATH_MAX, p, e->d_name);
		recSize(sub, sz);
	}
	closedir(d);
	return (0);
}

static int
recComp(const char *in, const char *rt, FILE *arc)
{
	struct stat st;
	struct dirent *e;
	ioCtx c;
	DIR *d;
	char sub[PATH_MAX];
	const char *rel;

	if (lstat(in, &st))
		return (-1);
	if (S_ISDIR(st.st_mode)) {
		d = opendir(in);
		if (d == NULL)
			return (-1);
		while ((e = readdir(d))) {
			if (e->d_name[0] == '.')
				continue;
			strJoin(sub, PATH_MAX, in, e->d_name);
			recComp(sub, rt, arc);
		}
		closedir(d);
		return (0);
	}
	if (!S_ISREG(st.st_mode))
		return (0);

	rel = in + strlen(rt);
	if (*rel == '/')
		rel++;
	if (arcWrit(arc, rel, st.st_size))
		return (-1);

	c.path = rel;
	c.fp = fopen(in, "rb");
	c.in = malloc(BLK_SIZE);
	c.out = malloc(BLK_SIZE * 2);
	filComp(&c, arc);
	free(c.in);
	free(c.out);
	fclose(c.fp);
	return (0);
}

/*
 * main actions
 */

static void
actList(const char *fn)
{
	FILE *f;
	uint64_t oSz;
	uint32_t nl, cSz;
	char nm[PATH_MAX];
	char s1[32], s2[32];

	f = fopen(fn, "rb");
	if (f == NULL)
		err(1, "open");
	while (1) {
		if (ioRu32(f, &nl))
			break;
		if (fread(nm, 1, nl, f) != nl)
			break;
		nm[nl] = 0;
		ioRu64(f, &oSz);
		ioRu32(f, &cSz);
		fmtByte(oSz, s1, 32);
		fmtByte(cSz, s2, 32);
		printf("%s %s %s\n", nm, s1, s2);
		fseek(f, cSz, SEEK_CUR);
	}
	fclose(f);
}

static void
actComp(const char *in, const char *out)
{
	FILE *arc;
	char outFn[PATH_MAX];
	char rt[PATH_MAX];
	char *dir;

	if (out == NULL)
		snprintf(outFn, sizeof(outFn), "%s.lz4", in);
	else
		strncpy(outFn, out, sizeof(outFn));

	arc = fopen(outFn, "wb");
	if (arc == NULL)
		err(1, "create");

	strncpy(rt, in, sizeof(rt));
	if (recSize(in, &gPrg.tot))
		err(1, "scan");

	dir = dirname(rt);
	recComp(in, dir, arc);
	fclose(arc);
}

static void
actDec(const char *in, const char *out)
{
	FILE *f;
	struct stat st;
	uint64_t oSz;
	uint32_t nl, cSz;
	char nm[PATH_MAX];
	char dst[PATH_MAX];

	f = fopen(in, "rb");
	if (f == NULL)
		err(1, "open");

	stat(in, &st);
	gPrg.tot = st.st_size;

	while (1) {
		if (ioRu32(f, &nl))
			break;
		fread(nm, 1, nl, f);
		nm[nl] = 0;
		ioRu64(f, &oSz);
		ioRu32(f, &cSz);

		if (out != NULL)
			strJoin(dst, PATH_MAX, out, nm);
		else
			strncpy(dst, nm, PATH_MAX);

		dirMk(dst);
		filDec(f, dst, cSz);
	}
	fclose(f);
}

int
main(int ac, char **av)
{
	if (ac < 3) {
		fprintf(stderr, "use: %s -c|-d|-l <in> [out]\n", av[0]);
		return (1);
	}
	gettimeofday(&gPrg.start, NULL);

	if (strcmp(av[1], "-l") == 0)
		actList(av[2]);
	else if (strcmp(av[1], "-c") == 0)
		actComp(av[2], ac > 3 ? av[3] : NULL);
	else if (strcmp(av[1], "-d") == 0)
		actDec(av[2], ac > 3 ? av[3] : NULL);
	else
		return (1);

	return (0);
}
