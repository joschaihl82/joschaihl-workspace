class ChatWindow : public QWidget {
    Q_OBJECT
public:
    ChatWindow(const QString &jid, XmppController *xmpp, Logger *logger, QWidget *parent = nullptr)
        : QWidget(parent), m_jid(jid), m_xmpp(xmpp), m_logger(logger)
    {
        setWindowTitle(QString("Chat - %1").arg(jid));
        auto *layout = new QVBoxLayout(this);
        m_history = new QPlainTextEdit(this);
        m_history->setReadOnly(true);
        m_input = new QLineEdit(this);
        auto *btnLayout = new QHBoxLayout();
        m_sendBtn = new QPushButton("Send", this);
        m_closeBtn = new QPushButton("Close", this);
        btnLayout->addWidget(m_sendBtn);
        btnLayout->addWidget(m_closeBtn);
        layout->addWidget(m_history);
        layout->addWidget(m_input);
        layout->addLayout(btnLayout);
        connect(m_sendBtn, &QPushButton::clicked, this, &ChatWindow::onSend);
        connect(m_closeBtn, &QPushButton::clicked, this, &ChatWindow::close);
        connect(m_input, &QLineEdit::returnPressed, this, &ChatWindow::onSend);
        if (m_xmpp) connect(m_xmpp, &XmppController::messageReceived, this, &ChatWindow::onIncoming);
    }
    void appendLocal(const QString &text) {
        m_history->appendPlainText(QString("[%1] Me: %2").arg(nowString(), text));
    }
    void appendRemote(const QString &from, const QString &text) {
        m_history->appendPlainText(QString("[%1] %2: %3").arg(nowString(), from, text));
    }
private slots:
    void onSend() {
        QString text = m_input->text().trimmed();
        if (text.isEmpty()) return;
        if (m_xmpp) m_xmpp->sendMessage(m_jid, text);
        appendLocal(text);
        m_input->clear();
    }
    void onIncoming(const QString &from, const QString &body) {
        if (from == m_jid) appendRemote(from, body);
    }
private:
    QString m_jid;
    XmppController *m_xmpp;
    Logger *m_logger;
    QPlainTextEdit *m_history;
    QLineEdit *m_input;
    QPushButton *m_sendBtn;
    QPushButton *m_closeBtn;
};

class SettingsDialog : public QDialog {
    Q_OBJECT
public:
    SettingsDialog(SettingsManager *settings, AudioEngine *audio, QWidget *parent = nullptr)
        : QDialog(parent), m_settings(settings), m_audio(audio)
    {
        setWindowTitle("Settings");
        auto *layout = new QVBoxLayout(this);
        auto *tabs = new QTabWidget(this);

        // General tab
        auto *general = new QWidget(this);
        auto *gLayout = new QFormLayout(general);
        m_autoStart = new QCheckBox("Auto-start on login", this);
        m_autoConnect = new QCheckBox("Auto-connect on startup", this);
        gLayout->addRow(m_autoStart);
        gLayout->addRow(m_autoConnect);
        tabs->addTab(general, "General");

        // Audio tab
        auto *audioTab = new QWidget(this);
        auto *aLayout = new QFormLayout(audioTab);
        m_inputDevice = new QComboBox(this);
        m_outputDevice = new QComboBox(this);
        for (const QString &d : m_audio->availableInputDevices()) m_inputDevice->addItem(d);
        for (const QString &d : m_audio->availableOutputDevices()) m_outputDevice->addItem(d);
        m_agcEnable = new QCheckBox("Enable AGC", this);
        m_agcTarget = new QSpinBox(this);
        m_agcTarget->setRange(100, 10000);
        m_agcTarget->setValue(1000);
        m_agcAttack = new QSlider(Qt::Horizontal, this);
        m_agcAttack->setRange(1, 100);
        m_agcAttack->setValue(2);
        m_agcRelease = new QSlider(Qt::Horizontal, this);
        m_agcRelease->setRange(1, 100);
        m_agcRelease->setValue(10);
        aLayout->addRow("Input device:", m_inputDevice);
        aLayout->addRow("Output device:", m_outputDevice);
        aLayout->addRow(m_agcEnable);
        aLayout->addRow("AGC target RMS:", m_agcTarget);
        aLayout->addRow("AGC attack:", m_agcAttack);
        aLayout->addRow("AGC release:", m_agcRelease);
        tabs->addTab(audioTab, "Audio");

        // Advanced tab (diagnostics)
        auto *adv = new QWidget(this);
        auto *advLayout = new QVBoxLayout(adv);
        m_diag = new QPlainTextEdit(this);
        m_diag->setReadOnly(true);
        advLayout->addWidget(m_diag);
        tabs->addTab(adv, "Diagnostics");

        layout->addWidget(tabs);
        auto *btnLayout = new QHBoxLayout();
        auto *ok = new QPushButton("OK", this);
        auto *cancel = new QPushButton("Cancel", this);
        btnLayout->addWidget(ok);
        btnLayout->addWidget(cancel);
        layout->addLayout(btnLayout);
        connect(ok, &QPushButton::clicked, this, &SettingsDialog::onOk);
        connect(cancel, &QPushButton::clicked, this, &SettingsDialog::reject);

        // Load settings
        load();
    }
    void load() {
        m_autoStart->setChecked(m_settings->value("autoStart", false).toBool());
        m_autoConnect->setChecked(m_settings->value("autoConnect", false).toBool());
        QString inDev = m_settings->value("inputDevice", "").toString();
        QString outDev = m_settings->value("outputDevice", "").toString();
        int idx = m_inputDevice->findText(inDev);
        if (idx >= 0) m_inputDevice->setCurrentIndex(idx);
        idx = m_outputDevice->findText(outDev);
        if (idx >= 0) m_outputDevice->setCurrentIndex(idx);
        m_agcEnable->setChecked(m_settings->value("agcEnabled", true).toBool());
        m_agcTarget->setValue(m_settings->value("agcTarget", 1000).toInt());
        m_agcAttack->setValue(m_settings->value("agcAttack", 2).toInt());
        m_agcRelease->setValue(m_settings->value("agcRelease", 10).toInt());
    }
private slots:
    void onOk() {
        m_settings->setValue("autoStart", m_autoStart->isChecked());
        m_settings->setValue("autoConnect", m_autoConnect->isChecked());
        m_settings->setValue("inputDevice", m_inputDevice->currentText());
        m_settings->setValue("outputDevice", m_outputDevice->currentText());
        m_settings->setValue("agcEnabled", m_agcEnable->isChecked());
        m_settings->setValue("agcTarget", m_agcTarget->value());
        m_settings->setValue("agcAttack", m_agcAttack->value());
        m_settings->setValue("agcRelease", m_agcRelease->value());
        m_settings->sync();
        accept();
    }
private:
    SettingsManager *m_settings;
    AudioEngine *m_audio;
    QCheckBox *m_autoStart;
    QCheckBox *m_autoConnect;
    QComboBox *m_inputDevice;
    QComboBox *m_outputDevice;
    QCheckBox *m_agcEnable;
    QSpinBox *m_agcTarget;
    QSlider *m_agcAttack;
    QSlider *m_agcRelease;
    QPlainTextEdit *m_diag;
};

