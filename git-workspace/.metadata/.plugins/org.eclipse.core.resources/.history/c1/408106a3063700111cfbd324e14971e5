cmake_minimum_required(VERSION 3.16)
project(gitpush LANGUAGES CXX)

set(CMAKE_CXX_STANDARD 17)
find_package(Qt6 REQUIRED COMPONENTS Core Network)
find_package(PkgConfig REQUIRED)
pkg_check_modules(LIBGIT2 REQUIRED libgit2)

add_executable(gitpush gitpush1.cpp)
target_include_directories(gitpush PRIVATE ${LIBGIT2_INCLUDE_DIRS})
target_link_libraries(gitpush PRIVATE Qt6::Core Qt6::Network ${LIBGIT2_LIBRARIES})
target_compile_definitions(gitpush PRIVATE ${LIBGIT2_CFLAGS_OTHER})
