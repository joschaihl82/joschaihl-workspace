/* ===== Instruction matching ===== */

static int match_insn(const char *mnemonic, struct insn **out)
{
    for (size_t i = 0; i < sizeof(insn_table)/sizeof(insn_table[0]); ++i) {
        if (strcmp(mnemonic, insn_table[i].mnemonic) == 0) {
            *out = &insn_table[i];
            return 0;
        }
    }
    return -1;
}

