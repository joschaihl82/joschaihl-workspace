/**
 * simple_debugger.c
 *
 * Ein einfacher Debugger für Linux, der einen Breakpoint in einer ELF/DWARF-Executable
 * basierend auf Dateiname und Zeilennummer setzen kann.
 *
 * Kompilierung:
 * gcc -o simple_debugger simple_debugger.c -ldw -lelf
 *
 * Verwendung:
 * ./simple_debugger <pfad_zum_programm> <quelldatei.c> <zeilennummer>
 *
 * Beispiel:
 * 1. Testprogramm erstellen (test.c):
 * #include <stdio.h>
 * void foo() { printf("In foo()\n"); } // Breakpoint hier in Zeile 2
 * int main() { printf("Start\n"); foo(); printf("Ende\n"); return 0; }
 *
 * 2. Testprogramm mit Debug-Infos kompilieren:
 * gcc -g -o test test.c
 *
 * 3. Debugger starten:
 * ./simple_debugger ./test test.c 2
 */
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <fcntl.h>
#include <sys/ptrace.h>
#include <sys/wait.h>
#include <sys/user.h> // Für struct user_regs_struct
#include <elfutils/libdw.h>
#include <dwarf.h>

/**
 * @brief Findet die virtuelle Speicheradresse für eine gegebene Quelldatei und Zeilennummer
 * durch das Parsen der DWARF-Debugging-Informationen.
 *
 * @param prog_name Der Pfad zur ausführbaren ELF-Datei.
 * @param file_name Der Name der Quelldatei, in der der Breakpoint gesetzt werden soll.
 * @param line_no Die Zeilennummer für den Breakpoint.
 * @return Die ermittelte virtuelle Speicheradresse oder 0 bei einem Fehler.
 */
Dwarf_Addr get_address_from_line(const char* prog_name, const char* file_name, int line_no) {
    // Öffne die ausführbare Datei zum Lesen.
    int fd = open(prog_name, O_RDONLY);
    if (fd < 0) {
        perror("open");
        return 0;
    }

    // Initialisiere die DWARF-Bibliothek für die geöffnete Datei.
    Dwarf* dbg = dwarf_begin(fd, DWARF_C_READ);
    if (!dbg) {
        fprintf(stderr, "dwarf_begin() fehlgeschlagen. Ist die Datei eine ELF-Datei?\n");
        close(fd);
        return 0;
    }

    Dwarf_Addr result_addr = 0;
    Dwarf_Off cu_off = 0, next_cu_off;
    Dwarf_Die* cu_die = NULL;

    // Iteriere durch alle Compilation Units (CUs) in der DWARF-Info.
    // Eine CU entspricht normalerweise einer kompilierten .c-Datei.
    while (dwarf_nextcu(dbg, cu_off, &next_cu_off, NULL, NULL, NULL, NULL) == 0) {
        // Hole das DIE (Debugging Information Entry) für die aktuelle CU.
        cu_die = dwarf_offtodie(dbg, cu_off, NULL);
        if (!cu_die) {
            cu_off = next_cu_off;
            continue;
        }

        // Hole den Namen der Quelldatei, die zu dieser CU gehört.
        // dwarf_getsrcfiles gibt eine Liste zurück, wir nehmen das erste Element.
        const char *cu_file_name = dwarf_getsrcfiles(cu_die, NULL, NULL)[0];

        // Vergleiche, ob es die gesuchte Datei ist.
        if (strstr(cu_file_name, file_name)) {
            Dwarf_Line* lines;
            int nlines;

            // Hole die Zeilennummerntabelle für diese CU.
            if (dwarf_getsrclines(cu_die, &lines, &nlines) == 0) {
                // Iteriere durch alle Zeilen in der Tabelle.
                for (int i = 0; i < nlines; ++i) {
                    int current_line;
                    dwarf_lineno(lines[i], &current_line);

                    // Wenn die Zeilennummer übereinstimmt, haben wir unseren Treffer.
                    if (current_line == line_no) {
                        dwarf_lineaddr(lines[i], &result_addr); // Adresse extrahieren.
                        dwarf_srclines_dealloc(dbg, lines, nlines);
                        goto found; // Springe aus allen Schleifen, da wir fertig sind.
                    }
                }
                dwarf_srclines_dealloc(dbg, lines, nlines);
            }
        }
        cu_off = next_cu_off;
    }

found:
    // Räume die DWARF-Ressourcen auf und schließe die Datei.
    dwarf_end(dbg);
    close(fd);
    return result_addr;
}

/**
 * @brief Führt die Haupt-Debugger-Logik aus: Setzt den Breakpoint und wartet darauf,
 * dass er getroffen wird.
 *
 * @param child_pid Die Prozess-ID des zu debuggenden Kindprozesses.
 * @param addr Die Speicheradresse, an der der Breakpoint gesetzt werden soll.
 */
void run_debugger(pid_t child_pid, Dwarf_Addr addr) {
    int wait_status;
    struct user_regs_struct regs;

    printf("Debugger wartet auf den Start des Kindprozesses (PID: %d)...\n", child_pid);

    // Warte, bis der Kindprozess nach dem exec() anhält.
    wait(&wait_status);

    // 1. Lese die ursprüngliche Anweisung an der Zieladresse. Wir brauchen sie,
    //    um den Breakpoint später wieder zu entfernen.
    long original_instruction = ptrace(PTRACE_PEEKDATA, child_pid, addr, NULL);
    printf("Ursprüngliche Anweisung an Adresse 0x%llx: 0x%lx\n", addr, original_instruction);

    // 2. Setze den Breakpoint. Dies geschieht durch Überschreiben des ersten Bytes
    //    der Anweisung mit dem Opcode 0xCC (INT 3 Interrupt).
    long trap_instruction = (original_instruction & ~0xFF) | 0xCC;
    ptrace(PTRACE_POKEDATA, child_pid, addr, trap_instruction);
    printf("Breakpoint bei 0x%llx gesetzt. Setze Programm fort...\n", addr);

    // 3. Setze die Ausführung des Kindprozesses fort.
    ptrace(PTRACE_CONT, child_pid, NULL, NULL);

    // 4. Warte erneut. Dieses Mal warten wir darauf, dass der Prozess am Breakpoint anhält.
    wait(&wait_status);

    // 5. Überprüfe, ob der Prozess wegen unseres Breakpoints (SIGTRAP) angehalten wurde.
    if (WIFSTOPPED(wait_status) && WSTOPSIG(wait_status) == SIGTRAP) {
        printf("\n✅ Breakpoint bei 0x%llx erreicht!\n", addr);

        // Hole die aktuellen Registerwerte des Kindes.
        ptrace(PTRACE_GETREGS, child_pid, NULL, &regs);
        // Der Instruction Pointer (RIP) zeigt jetzt auf die Adresse NACH dem 0xCC-Byte.
        printf("   Instruction Pointer (RIP) steht bei 0x%llx\n", regs.rip);

        // 6. Stelle die ursprüngliche Anweisung wieder her.
        ptrace(PTRACE_POKEDATA, child_pid, addr, original_instruction);

        // 7. Setze den Instruction Pointer um ein Byte zurück, damit er auf den Anfang
        //    der wiederhergestellten Anweisung zeigt.
        regs.rip -= 1;
        ptrace(PTRACE_SETREGS, child_pid, NULL, &regs);

        printf("   Programm angehalten. Ein echter Debugger würde hier eine Befehlsschleife starten.\n");
    } else {
        printf("\nProzess wurde aus einem anderen Grund gestoppt.\n");
    }

    // Beende den Kindprozess, um keine Zombies zu hinterlassen.
    printf("Beende Kindprozess...\n");
    kill(child_pid, SIGKILL);
}

int main(int argc, char* argv[]) {
    if (argc < 4) {
        fprintf(stderr, "Verwendung: %s <programm> <datei.c> <zeilennummer>\n", argv[0]);
        return 1;
    }

    const char* prog_name = argv[1];
    const char* file_name = argv[2];
    int line_no = atoi(argv[3]);

    // Schritt A: Finde die Speicheradresse für die angegebene Zeile.
    Dwarf_Addr addr = get_address_from_line(prog_name, file_name, line_no);
    if (addr == 0) {
        fprintf(stderr, "Fehler: Adresse für %s:%d konnte nicht gefunden werden.\n", file_name, line_no);
        fprintf(stderr, "Stelle sicher, dass das Programm mit 'gcc -g' kompiliert wurde und die Datei/Zeile existiert.\n");
        return 1;
    }

    printf("Adresse für %s:%d ist 0x%llx\n", file_name, line_no, addr);

    // Schritt B: Starte das Zielprogramm unter der Kontrolle von ptrace.
    pid_t child_pid = fork();
    if (child_pid == 0) {
        // Dies ist der Kindprozess (das Ziel).
        // Erlaubt dem Elternprozess, diesen Prozess zu verfolgen.
        ptrace(PTRACE_TRACEME, 0, NULL, NULL);
        // Lade und starte das Zielprogramm.
        execl(prog_name, prog_name, NULL);
        perror("execl"); // execl kehrt nur bei einem Fehler zurück.
        exit(1);

    } else if (child_pid > 0) {
        // Dies ist der Elternprozess (der Debugger).
        run_debugger(child_pid, addr);

    } else {
        perror("fork");
        return 1;
    }

    return 0;
}
