/* Minimaler XMM-Typ (lo/hi 64-bit lanes) */
typedef struct { uint64_t lo; uint64_t hi; } XMM;

/* Minimaler CPU-Typ (erweiterbar) */
typedef struct {
    uint64_t gpr[16];    /* RAX..R15 */
    uint64_t rflags;
    uint64_t rip;
    XMM xmm[16];
    int op_size; /* 16/32/64 */
    int addr_size; /* 32/64 */
    int has_rex;
    int rex_w, rex_r, rex_x, rex_b;
    int modrm_mod, modrm_reg, modrm_rm;
    uint8_t last_opcode;
} X64CPU;

static X64CPU cpu;

