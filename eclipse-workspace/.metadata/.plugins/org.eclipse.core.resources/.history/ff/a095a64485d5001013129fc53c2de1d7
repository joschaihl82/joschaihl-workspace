/* -------------------------
   Error handling
   ------------------------- */

void error(char *fmt, ...) {
  va_list ap; va_start(ap, fmt); vfprintf(stderr, fmt, ap); fprintf(stderr, "\n"); exit(1);
}

void verror_at(char *loc, char *fmt, va_list ap) {
  char *line = loc;
  while (user_input < line && line[-1] != '\n') line--;
  char *end = loc;
  while (*end != '\n' && *end != '\0') end++;
  int line_num = 1;
  for (char *p = user_input; p < line; p++) if (*p == '\n') line_num++;
  int indent = fprintf(stderr, "%s:%d: ", filename ? filename : "<input>", line_num);
  fprintf(stderr, "%.*s\n", (int)(end - line), line);
  int pos = (int)(loc - line) + indent;
  fprintf(stderr, "%*s^ ", pos, "");
  vfprintf(stderr, fmt, ap);
  fprintf(stderr, "\n");
  exit(1);
}

void error_at(char *loc, char *fmt, ...) { va_list ap; va_start(ap, fmt); verror_at(loc, fmt, ap); }
void error_tok(Token *tok, char *fmt, ...) { va_list ap; va_start(ap, fmt); verror_at(tok->str, fmt, ap); }

/* -------------------------
   Tokenizer helpers
   ------------------------- */

bool start_with(char *s, char *prefix) { return strncmp(s, prefix, strlen(prefix)) == 0; }
bool is_alpha(char c) { return ('a' <= c && c <= 'z') || ('A' <= c && c <= 'Z') || (c == '_'); }
bool is_alphanum(char c) { return is_alpha(c) || ('0' <= c && c <= '9'); }

Token *new_token(TokenKind kind, Token *cur, char *str, int len) {
  Token *tok = calloc(1, sizeof(Token));
  tok->kind = kind; tok->str = str; tok->len = len; cur->next = tok; return tok;
}

char get_escape_char(char c) {
  switch (c) {
  case 'a': return '\a'; case 'b': return '\b'; case 't': return '\t';
  case 'n': return '\n'; case 'v': return '\v'; case 'f': return '\f';
  case 'r': return '\r'; case 'e': return 27; case '0': return 0;
  default: return c;
  }
}

/* -------------------------
   Dynamic string literal reader
   ------------------------- */

Token *read_string_literal(Token *cur, char *start) {
  char *p = start + 1;
  size_t cap = 256;
  char *buf = malloc(cap);
  if (!buf) error_at(start, "out of memory");
  size_t len = 0;
  for (;;) {
    if (*p == '\0') { free(buf); error_at(start, "unclosed string literal"); }
    if (*p == '"') { p++; break; }
    if (*p == '\\') {
      p++;
      if (*p == '\0') { free(buf); error_at(start, "unclosed string literal"); }
      char esc = get_escape_char(*p);
      if (len + 1 >= cap) { cap *= 2; buf = realloc(buf, cap); if (!buf) error_at(start, "out of memory"); }
      buf[len++] = esc; p++; continue;
    }
    if (len + 1 >= cap) { cap *= 2; buf = realloc(buf, cap); if (!buf) error_at(start, "out of memory"); }
    buf[len++] = *p++;
  }
  if (len + 1 >= cap) { cap = len + 1; buf = realloc(buf, cap); if (!buf) error_at(start, "out of memory"); }
  buf[len] = '\0';
  Token *tok = new_token(TK_STR, cur, start, (int)(p - start));
  tok->contents = buf; tok->cont_len = (int)(len + 1);
  return tok;
}

/* -------------------------
   Preprocessor (simple)
   ------------------------- */

typedef struct Macro { char *name; char *value; struct Macro *next; } Macro;
typedef struct IncGuard { char *path; struct IncGuard *next; } IncGuard;
static Macro *macros = NULL;
static IncGuard *inc_guard = NULL;

static void define_macro(const char *name, const char *value) {
  Macro **p = &macros;
  while (*p) { if (strcmp((*p)->name, name) == 0) { free((*p)->value); (*p)->value = strdup(value ? value : ""); return; } p = &(*p)->next; }
  Macro *m = calloc(1, sizeof(Macro)); m->name = strdup(name); m->value = strdup(value ? value : ""); m->next = macros; macros = m;
}
static void undef_macro(const char *name) {
  Macro **p = &macros;
  while (*p) { if (strcmp((*p)->name, name) == 0) { Macro *t = *p; *p = t->next; free(t->name); free(t->value); free(t); return; } p = &(*p)->next; }
}
static const char *lookup_macro(const char *name) { for (Macro *m = macros; m; m = m->next) if (strcmp(m->name, name) == 0) return m->value; return NULL; }

static bool inc_guard_push(const char *path) {
  for (IncGuard *g = inc_guard; g; g = g->next) if (strcmp(g->path, path) == 0) return false;
  IncGuard *g = calloc(1, sizeof(IncGuard)); g->path = strdup(path); g->next = inc_guard; inc_guard = g; return true;
}
static void inc_guard_pop(void) { if (!inc_guard) return; IncGuard *g = inc_guard; inc_guard = g->next; free(g->path); free(g); }

static char *trim(char *s) {
  while (*s && isspace((unsigned char)*s)) s++;
  if (*s == 0) return s;
  char *end = s + strlen(s) - 1;
  while (end > s && isspace((unsigned char)*end)) *end-- = '\0';
  return s;
}

static char *expand_macros_in_line(const char *line) {
  size_t cap = strlen(line) + 1;
  char *out = malloc(cap); if (!out) return NULL; out[0] = '\0';
  const char *p = line;
  while (*p) {
    if (isalpha((unsigned char)*p) || *p == '_') {
      const char *start = p;
      while (isalnum((unsigned char)*p) || *p == '_') p++;
      size_t len = p - start;
      char *ident = strndup(start, (int)len);
      const char *val = lookup_macro(ident);
      if (val) { size_t need = strlen(out) + strlen(val) + 1; if (need > cap) { cap = need * 2; out = realloc(out, cap); } strcat(out, val); }
      else { size_t need = strlen(out) + len + 1; if (need > cap) { cap = need * 2; out = realloc(out, cap); } strncat(out, start, (int)len); }
      free(ident);
    } else {
      size_t need = strlen(out) + 2; if (need > cap) { cap = need * 2; out = realloc(out, cap); } strncat(out, p, 1); p++;
    }
  }
  return out;
}

static char *read_file_local(const char *path) {
  FILE *fp = fopen(path, "rb");
  if (!fp) return NULL;
  if (fseek(fp, 0, SEEK_END) != 0) { fclose(fp); return NULL; }
  long sz = ftell(fp); if (sz < 0) { fclose(fp); return NULL; }
  rewind(fp);
  char *buf = malloc((size_t)sz + 1);
  if (!buf) { fclose(fp); return NULL; }
  if (fread(buf, 1, (size_t)sz, fp) != (size_t)sz) { fclose(fp); free(buf); return NULL; }
  buf[sz] = '\0'; fclose(fp); return buf;
}

static char *dir_of_path(const char *path) {
  char *dup = strdup(path);
  char *slash = strrchr(dup, '/');
  if (!slash) { free(dup); return strdup("."); }
  *slash = '\0'; char *res = strdup(dup); free(dup); return res;
}

static char *preprocess_buffer(const char *buf, const char *curdir);

static char *preprocess_file(const char *path) {
  char *buf = read_file_local(path);
  if (!buf) return NULL;
  char *curdir = dir_of_path(path);
  char *res = preprocess_buffer(buf, curdir);
  free(buf); free(curdir); return res;
}

static char *preprocess_buffer(const char *buf, const char *curdir) {
  size_t cap = strlen(buf) + 1;
  char *out = malloc(cap); if (!out) return NULL; out[0] = '\0';
  int cond_stack[256]; int cond_top = 0; cond_stack[cond_top++] = 1;
  const char *p = buf;
  while (*p) {
    const char *line_start = p;
    while (*p && *p != '\n') p++;
    size_t line_len = p - line_start;
    char *line = strndup(line_start, (int)line_len);
    if (*p == '\n') p++;
    char *t = trim(line);
    if (*t == '#' && cond_stack[cond_top - 1]) {
      t++;
      while (*t && isspace((unsigned char)*t)) t++;
      if (strncmp(t, "include", 7) == 0 && isspace((unsigned char)t[7])) {
        t += 7; while (*t && isspace((unsigned char)*t)) t++;
        if (*t == '"') {
          t++; char *endq = strchr(t, '"');
          if (endq) {
            char *incname = strndup(t, (int)(endq - t));
            char incpath[4096];
            if (curdir && curdir[0]) snprintf(incpath, sizeof(incpath), "%s/%s", curdir, incname);
            else snprintf(incpath, sizeof(incpath), "%s", incname);
            free(incname);
            if (inc_guard_push(incpath)) {
              char *incbuf = preprocess_file(incpath);
              if (incbuf) { size_t need = strlen(out) + strlen(incbuf) + 1; if (need > cap) { cap = need * 2; out = realloc(out, cap); } strcat(out, incbuf); free(incbuf); }
              inc_guard_pop();
            }
          }
        }
      } else if (strncmp(t, "define", 6) == 0 && isspace((unsigned char)t[6])) {
        t += 6; while (*t && isspace((unsigned char)*t)) t++;
        char *name_start = t; while (*t && (isalnum((unsigned char)*t) || *t == '_')) t++;
        char *name = strndup(name_start, (int)(t - name_start));
        while (*t && isspace((unsigned char)*t)) t++;
        char *replacement = strdup(t);
        define_macro(name, replacement);
        free(name); free(replacement);
      } else if (strncmp(t, "undef", 5) == 0 && isspace((unsigned char)t[5])) {
        t += 5; while (*t && isspace((unsigned char)*t)) t++;
        char *name_start = t; while (*t && (isalnum((unsigned char)*t) || *t == '_')) t++;
        char *name = strndup(name_start, (int)(t - name_start));
        undef_macro(name); free(name);
      } else if (strncmp(t, "ifdef", 5) == 0 && isspace((unsigned char)t[5])) {
        t += 5; while (*t && isspace((unsigned char)*t)) t++;
        char *name_start = t; while (*t && (isalnum((unsigned char)*t) || *t == '_')) t++;
        char *name = strndup(name_start, (int)(t - name_start));
        const char *val = lookup_macro(name); free(name);
        cond_stack[cond_top++] = (val != NULL) && cond_stack[cond_top - 2];
      } else if (strncmp(t, "ifndef", 6) == 0 && isspace((unsigned char)t[6])) {
        t += 6; while (*t && isspace((unsigned char)*t)) t++;
        char *name_start = t; while (*t && (isalnum((unsigned char)*t) || *t == '_')) t++;
        char *name = strndup(name_start, (int)(t - name_start));
        const char *val = lookup_macro(name); free(name);
        cond_stack[cond_top++] = (val == NULL) && cond_stack[cond_top - 2];
      } else if (strncmp(t, "if", 2) == 0 && isspace((unsigned char)t[2])) {
        t += 2; while (*t && isspace((unsigned char)*t)) t++;
        int v = atoi(t); cond_stack[cond_top++] = (v != 0) && cond_stack[cond_top - 2];
      } else if (strncmp(t, "else", 4) == 0) {
        if (cond_top > 1) { int prev = cond_stack[cond_top - 1]; int parent = cond_stack[cond_top - 2]; cond_stack[cond_top - 1] = parent && !prev; }
      } else if (strncmp(t, "elif", 4) == 0 && isspace((unsigned char)t[4])) {
        if (cond_top > 1) {
          int parent = cond_stack[cond_top - 2];
          if (!parent) cond_stack[cond_top - 1] = 0;
          else {
            if (cond_stack[cond_top - 1]) cond_stack[cond_top - 1] = 0;
            else { t += 4; while (*t && isspace((unsigned char)*t)) t++; int v = atoi(t); cond_stack[cond_top - 1] = (v != 0); }
          }
        }
      } else if (strncmp(t, "endif", 5) == 0) { if (cond_top > 1) cond_top--; }
    } else {
      if (cond_stack[cond_top - 1]) {
        char *expanded = expand_macros_in_line(line);
        if (expanded) { size_t need = strlen(out) + strlen(expanded) + 2; if (need > cap) { cap = need * 2; out = realloc(out, cap); } strcat(out, expanded); strcat(out, "\n"); free(expanded); }
      }
    }
    free(line);
  }
  return out;
}

/* -------------------------
   Tokenizer
   ------------------------- */

char *read_reserved_list[] = { "return","if","else","while","for","int","char","struct","sizeof","typedef", NULL };
char *multi_ops[] = { "==","!=","<=",">=","->", NULL };

char *read_reserved(char *p) {
  for (int i = 0; read_reserved_list[i]; i++) {
    int len = (int)strlen(read_reserved_list[i]);
    if (start_with(p, read_reserved_list[i]) && !is_alphanum(p[len])) return read_reserved_list[i];
  }
  for (int i = 0; multi_ops[i]; i++) if (start_with(p, multi_ops[i])) return multi_ops[i];
  return NULL;
}

Token *tokenize() {
  char *p = user_input;
  Token head = {}; Token *cur = &head;
  while (*p) {
    if (isspace((unsigned char)*p)) { p++; continue; }
    if (start_with(p, "//")) { p += 2; while (*p && *p != '\n') p++; continue; }
    if (start_with(p, "/*")) { char *start = strstr(p + 2, "*/"); if (!start) error_at(p, "unclosed block comment"); p = start + 2; continue; }
    if (*p == '"') { cur = read_string_literal(cur, p); p += cur->len; continue; }
    char *kw = read_reserved(p);
    if (kw) { int len = (int)strlen(kw); cur = new_token(TK_RESERVED, cur, p, len); p += len; continue; }
    if (is_alpha(*p)) { char *name = p; while (is_alphanum(*p)) p++; cur = new_token(TK_IDENT, cur, name, (int)(p - name)); continue; }
    if (ispunct((unsigned char)*p)) { cur = new_token(TK_RESERVED, cur, p++, 1); continue; }
    if (isdigit((unsigned char)*p)) { cur = new_token(TK_NUM, cur, p, 0); char *prev = p; cur->val = (int)strtol(p, &p, 10); cur->len = (int)(p - prev); continue; }
    error_at(p, "Could not tokenize the string.");
  }
  new_token(TK_EOF, cur, p, 0);
  return head.next;
}

/* -------------------------
   Types and helpers
   ------------------------- */

Type *new_type(TypeKind kind, int size, int align) { Type *t = calloc(1, sizeof(Type)); t->kind = kind; t->size = size; t->align = align; return t; }
Type *pointer_to(Type *base) { Type *t = new_type(TYPE_PTR, 8, 8); t->base = base; return t; }
Type *array_of(Type *base, int len) { Type *t = new_type(TYPE_ARRAY, base->size * len, base->align); t->base = base; t->array_len = len; return t; }
bool is_integer(Type *type) { return type->kind == TYPE_CHAR || type->kind == TYPE_INT; }
int align_to(int n, int align) { return (n + align - 1) & ~(align - 1); }

/* -------------------------
   AST helpers and scopes
   ------------------------- */

Node *new_node(NodeKind kind, Token *tok) { Node *n = calloc(1, sizeof(Node)); n->kind = kind; n->tok = tok; return n; }
Node *new_unary(NodeKind kind, Node *expr, Token *tok) { Node *n = new_node(kind, tok); n->lhs = expr; return n; }
Node *new_binary(NodeKind kind, Node *lhs, Node *rhs, Token *tok) { Node *n = new_node(kind, tok); n->lhs = lhs; n->rhs = rhs; return n; }
Node *new_num(int val, Token *tok) { Node *n = new_node(ND_NUM, tok); n->val = val; return n; }

VarScope *push_scope(char *name) { VarScope *sc = calloc(1, sizeof(VarScope)); sc->name = name; sc->next = var_scope; var_scope = sc; return sc; }
VarList *new_var_list(Var *var) { VarList *vl = calloc(1, sizeof(VarList)); vl->var = var; return vl; }
Var *new_var(char *name, Type *type, bool is_local) { Var *v = calloc(1, sizeof(Var)); v->name = name; v->type = type; v->is_local = is_local; return v; }
Var *new_local_var(char *name, Type *type) { Var *v = new_var(name, type, true); push_scope(name)->var = v; VarList *vl = new_var_list(v); vl->next = locals; locals = vl; return v; }
Var *new_global_var(char *name, Type *type) { Var *v = new_var(name, type, false); push_scope(name)->var = v; VarList *vl = new_var_list(v); vl->next = globals; globals = vl; return v; }
Node *new_var_node(Var *var, Token *tok) { Node *n = new_node(ND_VAR, tok); n->var = var; return n; }

VarScope *find_var(Token *tok) { for (VarScope *sc = var_scope; sc; sc = sc->next) if (strlen(sc->name) == (size_t)tok->len && !strncmp(tok->str, sc->name, tok->len)) return sc; return NULL; }
TagScope *find_tag(Token *tok) { for (TagScope *sc = tag_scope; sc; sc = sc->next) if (strlen(sc->name) == (size_t)tok->len && !strncmp(tok->str, sc->name, tok->len)) return sc; return NULL; }
Type *find_typedef(Token *tok) { if (tok->kind == TK_IDENT) { VarScope *sc = find_var(tok); if (sc) return sc->type_def; } return NULL; }

