/* ===== Instruction Encoding (Helper functions remain the same) ===== */

static void emit_rex(int w, int r, int x, int b)
{
    unsigned char rex = 0x40;
    if (w) rex |= 0x08;
    if (r) rex |= (r >> 3);
    if (x) rex |= (x >> 3) << 1;
    if (b) rex |= (b >> 3);

    if (rex != 0x40) {
        emit_byte(rex);
    }
}

static void emit_modrm(int mod, int reg, int rm)
{
    emit_byte((unsigned char)((mod << 6) | ((reg & 0x7) << 3) | (rm & 0x7)));
}

// movq %reg, %reg (R-R form)
static void encode_mov_rr64(int dst, int src)
{
    emit_rex(1, src, 0, dst);
    emit_byte(0x89);
    emit_modrm(3, src, dst);
}

// movq $imm, %reg (I-R form)
static void encode_mov_r64_imm32(int reg, struct operand *op)
{
    // C7 /0 id - MOV r/m64, imm32
    emit_rex(1, 0, 0, reg);
    emit_byte(0xC7);
    emit_modrm(3, 0, reg);

    if (op->symbol) {
        long current_pos = segment == 1 ? text_len : data_len;

        emit_u32(0);

        emit_reloc(segment, current_pos, op->symbol, R_X86_64_PC32, 0);
    } else {
        emit_u32((unsigned)op->offset);
    }
}

// addq %reg, %reg
static void encode_add_rr64(int dst_rm, int src_reg)
{
    emit_rex(1, src_reg, 0, dst_rm);
    emit_byte(0x01);
    emit_modrm(3, src_reg, dst_rm);
}

// subq %reg, %reg
static void encode_sub_rr64(int dst_rm, int src_reg)
{
    emit_rex(1, src_reg, 0, dst_rm);
    emit_byte(0x29);
    emit_modrm(3, src_reg, dst_rm);
}

// jmp target
static void encode_jmp(struct operand *op)
{
    if (op->symbol) {
        /* Symbol jump: JMP rel32 (0xE9) with R_X86_64_PC32 relocation */
        long current_pos = text_len;

        emit_byte(0xE9);
        emit_u32(0);

        emit_reloc(1, current_pos + 1, op->symbol, R_X86_64_PC32, -4);
    } else {
        /* Immediate jump (short: 0xEB disp8) */
        emit_byte(0xEB);
        long disp = op->offset - (text_bytes + 1);
        emit_byte((unsigned char)(disp & 0xFF));
    }
}


/* ===== Encoder Wrappers (for Instruction Table) ===== */

static void encode_movq_reg_reg_wrapper(struct operand *operands) {
    // AT&T order: src=operands[0], dst=operands[1]
    encode_mov_rr64(operands[1].reg, operands[0].reg);
}

static void encode_movq_imm_reg_wrapper(struct operand *operands) {
    // AT&T order: imm_op=operands[0], reg=operands[1]
    encode_mov_r64_imm32(operands[1].reg, &operands[0]);
}

static void encode_addq_reg_reg_wrapper(struct operand *operands) {
    // AT&T order: src_reg=operands[0], dst_rm=operands[1]
    encode_add_rr64(operands[1].reg, operands[0].reg);
}

static void encode_subq_reg_reg_wrapper(struct operand *operands) {
    // AT&T order: src_reg=operands[0], dst_rm=operands[1]
    encode_sub_rr64(operands[1].reg, operands[0].reg);
}

static void encode_jmp_wrapper(struct operand *operands) {
    // Only one operand (target)
    encode_jmp(&operands[0]);
}

/* ===== Instruction Table ===== */

struct insn_match insn_table[] = {
    // Mnemonic | Num Ops | Op1 Kind | Op2 Kind | Encoder
    // movq $imm, %reg
    {"movq", 2, {O_IMM, O_REG, 0, 0}, encode_movq_imm_reg_wrapper},
    // movq %reg, %reg
    {"movq", 2, {O_REG, O_REG, 0, 0}, encode_movq_reg_reg_wrapper},
    // addq %reg, %reg
    {"addq", 2, {O_REG, O_REG, 0, 0}, encode_addq_reg_reg_wrapper},
    // subq %reg, %reg
    {"subq", 2, {O_REG, O_REG, 0, 0}, encode_subq_reg_reg_wrapper},
    // jmp target ($label or $offset)
    {"jmp", 1, {O_IMM, 0, 0, 0}, encode_jmp_wrapper},
    // Sentinel
    {NULL, 0, {0}, NULL}
};


/* ===== Instruction Parser (Uses Table) ===== */

static int parse_instruction(void)
{
    char *mnemonic = name_token->data;
    nr_operands = 0;

    // Parse operands
    if (next_token() != T_EOF) {
        do {
            if (nr_operands >= MAX_OPERANDS) { error("too many operands"); return -1; }
            // The first operand token is already loaded here if it was a label:mnemonic line
            if (parse_operand(&operands[nr_operands++]) != 0) return -1;
        } while (token_kind == T_COMMA && next_token() != T_EOF);
    }

    // Table-driven encoding lookup
    for (struct insn_match *m = insn_table; m->mnemonic; ++m) {
        if (strcmp(mnemonic, m->mnemonic) == 0) {
            // Match 1: Number of operands
            if (nr_operands != m->nr_operands) continue;

            // Match 2: Operand types (kinds)
            int match = 1;
            for (int i = 0; i < nr_operands; ++i) {
                // Check if the actual operand kind is one of the allowed flags for this entry
                if (!(operands[i].kind & m->operand_flags[i])) {
                    match = 0;
                    break;
                }
            }

            if (match) {
                // Found a match, encode!
                m->encoder(operands);
                return 0;
            }
        }
    }

    error("unsupported instruction form or mnemonic '%s'", mnemonic);
    return -1;
}

