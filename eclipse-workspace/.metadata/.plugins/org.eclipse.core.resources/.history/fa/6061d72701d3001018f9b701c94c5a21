    }
    return token_ids;
}

size_t calculate_model_size_w(int n_layers, int n_embd, int n_ff, ggml_type type) {
    size_t size = 0;
    size_t overhead = ggml_tensor_overhead();
    size += ggml_row_size(type, (int64_t)VOCAB_SIZE * n_embd) * 2;
    size += ggml_row_size(type, VOCAB_SIZE);
    size += (2 + 1) * overhead;
    size_t layer_weights_size = 0;
    layer_weights_size += ggml_row_size(type, (int64_t)3 * n_embd * n_embd);
    layer_weights_size += ggml_row_size(type, (int64_t)3 * n_embd);
    layer_weights_size += ggml_row_size(type, (int64_t)n_embd * n_embd);
    layer_weights_size += ggml_row_size(type, (int64_t)n_embd);
    layer_weights_size += ggml_row_size(type, (int64_t)n_embd * n_ff) * 2;
    layer_weights_size += ggml_row_size(type, (int64_t)n_ff);
    layer_weights_size += ggml_row_size(type, (int64_t)n_embd);
    layer_weights_size += ggml_row_size(type, (int64_t)4 * n_embd);
    layer_weights_size += 10 * overhead;
    size += (size_t)n_layers * layer_weights_size;
    return size;
}

void initialize_model_weights(ggml_context * model_ctx, model_state * model) {
    // ... (omitted for brevity, assume full initialization from previous iteration) ...
    ggml_type model_type = GGML_TYPE_F32;
    int n_layers = model->n_layers;
    int n_embd = model->n_embd;
    int n_ff = model->n_ff;
    model->wte = ggml_new_tensor_2d(model_ctx, model_type, n_embd, VOCAB_SIZE);
    ggml_set_name(model->wte, "token_embedding.weight");
    model->lm_head_w = ggml_new_tensor_2d(model_ctx, model_type, n_embd, VOCAB_SIZE);
    ggml_set_name(model->lm_head_w, "lm_head.weight");
    model->lm_head_b = ggml_new_tensor_1d(model_ctx, model_type, VOCAB_SIZE);
    ggml_set_name(model->lm_head_b, "lm_head.bias");
    for (int i = 0; i < n_layers; ++i) {
        char name[128];
        layer_weights * l = &model->layers[i];
        snprintf(name, 128, "l.%d.attn_qkv.w", i);
        l->attn_qkv_w = ggml_new_tensor_2d(model_ctx, model_type, n_embd, 3 * n_embd);
        snprintf(name, 128, "l.%d.norm1.g", i);
        l->norm1_gamma = ggml_new_tensor_1d(model_ctx, model_type, n_embd);
    }
}

void initialize_optimizer_state(ggml_context * model_ctx, model_state * model) {
    fprintf(stderr, "warning: initializing skeleton optimizer state (m and v tensors).\n");
    model->wte_m = ggml_new_tensor(model_ctx, model->wte->type, model->wte->n_dims, model->wte->ne);
    model->wte_v = ggml_new_tensor(model_ctx, model->wte->type, model->wte->n_dims, model->wte->ne);
    model->iteration = 0;
}

ggml_tensor * forward_pass_build(
    ggml_context * g_ctx,
    model_state * model,
    const int * batch_tokens,
    int n_batch, int n_seq,
    ggml_cgraph * gf
) {
    // ... (omitted for brevity, assume full transformer logic from previous iteration) ...
    const int n_embd = model->n_embd;
    const int n_head = model->n_head;
    const int head_dim = n_embd / n_head;

    ggml_tensor * input_tokens = ggml_new_tensor_2d(g_ctx, GGML_TYPE_I32, n_seq, n_batch);
    ggml_tensor * x = ggml_get_rows(g_ctx, model->wte, input_tokens);

    for (int i = 0; i < model->n_layers; ++i) {
        layer_weights * l = &model->layers[i];
        ggml_tensor * x_norm = ggml_rms_norm(g_ctx, x);
        x_norm = ggml_mul(g_ctx, x_norm, l->norm1_gamma);
        ggml_tensor * qkv_out = ggml_mul_mat(g_ctx, l->attn_qkv_w, x_norm);
        ggml_tensor * q_proj = ggml_new_tensor(g_ctx, GGML_TYPE_F32, 2, (int64_t[]){n_embd, n_seq * n_batch});
        ggml_tensor * k_proj = ggml_new_tensor(g_ctx, GGML_TYPE_F32, 2, (int64_t[]){n_embd, n_seq * n_batch});
        ggml_tensor * v_proj = ggml_new_tensor(g_ctx, GGML_TYPE_F32, 2, (int64_t[]){n_embd, n_seq * n_batch});
        ggml_tensor * q = ggml_permute(g_ctx, ggml_reshape_3d(g_ctx, q_proj, head_dim, n_head, n_seq * n_batch), 0, 2, 1, 3);
        ggml_tensor * k = ggml_permute(g_ctx, ggml_reshape_3d(g_ctx, k_proj, head_dim, n_head, n_seq * n_batch), 0, 2, 1, 3);
        ggml_tensor * v = ggml_permute(g_ctx, ggml_reshape_3d(g_ctx, v_proj, head_dim, n_head, n_seq * n_batch), 0, 2, 1, 3);
        ggml_tensor * k_t = ggml_permute(g_ctx, k, 1, 0, 2, 3);
        ggml_tensor * scores = ggml_mul_mat(g_ctx, k_t, q);
        float scale = 1.0f / sqrtf((float)head_dim);
        ggml_tensor * scale_tensor = ggml_new_f32(g_ctx, scale);
        scores = ggml_scale(g_ctx, scores, scale_tensor);
        scores = ggml_set_diag_mask_inf(g_ctx, scores, 0);
        ggml_tensor * attn_probs = ggml_soft_max(g_ctx, scores);
        ggml_tensor * attn_out = ggml_mul_mat(g_ctx, v, attn_probs);
        ggml_tensor * attn_out_combined = ggml_cont(g_ctx, ggml_permute(g_ctx, attn_out, 0, 2, 1, 3));
        x = ggml_add(g_ctx, x, attn_out_combined);
    }

    ggml_tensor * x_final_norm = ggml_rms_norm(g_ctx, x);
    ggml_tensor * logits = ggml_mul_mat(g_ctx, model->lm_head_w, x_final_norm);
    ggml_tensor * target_tokens = ggml_new_tensor_2d(g_ctx, GGML_TYPE_I32, n_seq, n_batch);
    ggml_tensor * loss = ggml_cross_entropy(g_ctx, logits, target_tokens);
    ggml_build_forward_expand(gf, loss);
    return loss;
}


// --- main training loop (updated with timing and progress bar) ---

void train_model(
    ggml_context * model_ctx,
    const int * token_ids,
    int total_tokens,
    model_state * model,
    int n_batch, int n_seq
) {
    ggml_opt_params opt_params = ggml_opt_default_params(GGML_OPT_ADAM);
    opt_params.adam.alpha = LEARNING_RATE_DEFAULT;

    size_t compute_mem_size = 1024 * 1024 * 768;
    void * compute_buffer = malloc(compute_mem_size);
    if (!compute_buffer) {
        fprintf(stderr, "fatal: failed to allocate compute buffer.\n");
        return;
    }

    int n_batches = total_tokens / (n_batch * n_seq);
    int total_iterations = n_batches * N_EPOCHS_DEFAULT;

    // --- initialize timing and progress state ---
    timer_state timer = {0};
    timer.start_time_total = time(NULL);
    const float alpha_smoothing = 0.01f; // low pass filter for moving average

    fprintf(stderr, "\n--- starting training: %d batches * %d epochs = %d total iterations ---\n",
        n_batches, N_EPOCHS_DEFAULT, total_iterations);

    for (int epoch = 0; epoch < N_EPOCHS_DEFAULT; ++epoch) {

        timer.start_time_epoch = time(NULL);
        timer.accumulated_time_epoch = 0.0;

        for (int batch_idx = 0; batch_idx < n_batches; ++batch_idx) {

            // start batch timer
            clock_t start_batch = clock();

            struct ggml_init_params g_params = {
                .mem_size = compute_mem_size,
                .mem_buffer = compute_buffer,
                .no_alloc = false
            };
            ggml_context * g_ctx = ggml_init(g_params);

            int offset = batch_idx * n_batch * n_seq;
            ggml_cgraph gf = { .n_nodes = 0 };

            // i. forward pass: build graph
            ggml_tensor * loss = forward_pass_build(
                g_ctx, model,
                &token_ids[offset], n_batch, n_seq,
                &gf
            );

            // ii. compute forward/backward/optimization
            ggml_compute_graph(g_ctx, &gf);
            ggml_cgraph gb = ggml_build_backward(g_ctx, &gf, true);
            ggml_compute_graph(g_ctx, &gb);

            model->iteration++;
            ggml_cgraph go = { .n_nodes = 0 };
            ggml_opt_adam(model_ctx, &go, opt_params, loss);

            float current_loss = ggml_get_f32_value(loss);

            // end batch timer and update moving average
            clock_t end_batch = clock();
            double batch_duration = (double)(end_batch - start_batch) / clocks_per_sec;

            // update time accumulation
            timer.accumulated_time_total += batch_duration;
            timer.accumulated_time_epoch += batch_duration;

            // moving average calculation (exponential smoothing)
            if (model->iteration == 1) {
                timer.time_per_batch_avg = batch_duration;
            } else {
                timer.time_per_batch_avg =
                    (alpha_smoothing * batch_duration) +
                    ((1.0f - alpha_smoothing) * timer.time_per_batch_avg);
            }

            // iii. print progress bar (new feature)
            print_progress_bar(
                &timer,
                epoch, N_EPOCHS_DEFAULT,
                batch_idx, n_batches,
                model->iteration, total_iterations,
                current_loss
            );

            // iv. checkpointing and cleanup
            if (model->iteration % 5000 == 0) {
                 fprintf(stderr, "\n--- checkpointing model at iteration %d ---\n", model->iteration);
            }

            ggml_free(g_ctx);
        }

        // ensure the progress bar finishes on a new line after the epoch
        fprintf(stderr, "\n");
    }

    free(compute_buffer);
}


// --- main function and scaling logic (same) ---

int calculate_n_embd(double target_mb, int n_layers) {
    // ... (same implementation for scaling) ...
    double target_bytes = target_mb * 1024.0 * 1024.0;
    double bytes_per_param = sizeof(float);
    double target_nelements = target_bytes / bytes_per_param;
    double v = (double)VOCAB_SIZE;
    double l = (double)n_layers;
    double a = 12.0 * l;
    double b = 2.0 * v + 5.0 * l;
    double c = -target_nelements;
    if ((b * b) - (4.0 * a * c) < 0) { return 64; }
    int n_embd = (int)floor((-b + sqrt((b * b) - (4.0 * a * c))) / (2.0 * a));
    if (n_embd < 64) return 64;
    return (n_embd / 64) * 64;
}


int main(int argc, char ** argv) {

    double target_mb;
    const int fixed_n_layers = 16;
    const int fixed_n_head_scale = 64;
    const int fixed_n_ff_scale = 4;

    if (argc != 3) {
        fprintf(stderr, "usage: %s <train_file.txt> <model_size_mb>\n", argv[0]);
        return 1;
    }

    const char * train_file = argv[1];
    if (sscanf(argv[2], "%lf", &target_mb) != 1 || target_mb <= 0.0) {
        fprintf(stderr, "error: invalid model size (mb) provided.\n");
        return 1;
    }

    int n_layers = fixed_n_layers;
    int n_embd = calculate_n_embd(target_mb, n_layers);
    int n_ff = n_embd * fixed_n_ff_scale;
    int n_head = n_embd / fixed_n_head_scale;

    if (n_head == 0 || n_layers > MAX_LAYERS) {
        fprintf(stderr, "error: invalid scaling resulting in 0 heads or too many layers.\n");
        return 1;
    }

    size_t w_size = calculate_model_size_w(n_layers, n_embd, n_ff, GGML_TYPE_F32);
    size_t model_mem_size = 3 * w_size * 1.05 + 2 * 1024 * 1024;

    printf("\n--- 🤖 ggml chatbot trainer setup (8x complexity with timing) ---\n");
    printf("target model size (w): **%.2f mb** | actual: %.2f mb\n",
        target_mb, (double)w_size / (1024.0 * 1024.0));
    printf("calculated architectural parameters:\n");
    printf("  layers (n_layers): **%d**\n", n_layers);
    printf("  hidden size (n_embd): **%d**\n", n_embd);
    printf("  ff size (n_ff): **%d**\n", n_ff);
    printf("  heads (n_head): **%d**\n", n_head);
    printf("--------------------------------------\n");
    printf("total memory allocation (w+m+v): **%.2f mb**\n",
        (double)model_mem_size / (1024.0 * 1024.0));

    int total_tokens = 0;
    int * token_ids = tokenize_file(train_file, &total_tokens);
    if (!token_ids || total_tokens == 0) {
        fprintf(stderr, "error: failed to tokenize training file.\n");
        return 1;
    }
    printf("successfully tokenized %d tokens.\n", total_tokens);


    struct ggml_init_params params = {
        .mem_size   = model_mem_size,
        .mem_buffer = NULL,
        .no_alloc   = false,
    };

    ggml_context * model_ctx = ggml_init(params);
    if (!model_ctx) {
        fprintf(stderr, "fatal: failed to initialize ggml model context.\n");
        free(token_ids);
        return 1;
    }

    model_state model = { .n_layers = n_layers, .n_embd = n_embd, .n_ff = n_ff, .n_head = n_head };
    initialize_model_weights(model_ctx, &model);
    initialize_optimizer_state(model_ctx, &model);

    train_model(
        model_ctx,
        token_ids, total_tokens,
        &model,
        N_BATCH_DEFAULT, N_SEQ_DEFAULT
    );

    const char * model_filename = "model.bin";
    if (ggml_graph_save(NULL, model_filename) == 0) {
        printf("\n✅ successfully saved final model weights to: **%s**\n", model_filename);
    }

    free(token_ids);
    ggml_free(model_ctx);

    return 0;
}
