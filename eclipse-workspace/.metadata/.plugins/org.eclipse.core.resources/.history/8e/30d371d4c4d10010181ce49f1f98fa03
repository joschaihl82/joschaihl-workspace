}

// -------------------------
// i/o port emulation stubs
// -------------------------
static uint64_t io_read(uint16_t port, int size) {
    uint64_t val = 0;
    switch (port) {
        case io_port_ps2_status:
            val = 0x01; // output buffer full
            break;
        case io_port_ps2_data:
            val = 0xAA; // keyboard self-test successful
            break;
        case io_port_pit_data:
        case io_port_vga_crt_addr:
            // ignore
            break;
        default:
            trace_printf("warn: unhandled in read access to port 0x%04x (size %d)\n", port, size);
            break;
    }
    return val;
}

static void io_write(uint16_t port, uint64_t val, int size) {
    switch (port) {
        case io_port_vga_crt_addr:
            // vga register index write
            break;
        case io_port_pic_master_cmd:
        case io_port_pic_slave_cmd:
            if ((val & 0x10) == 0x10) {
                // icw1 - ignore
            } else {
                // ocw2/3 - ignore
            }
            break;
        case 0x3f8 ... 0x3ff: // com1 serial port
            if (port == 0x3f8) {
                fprintf(stderr, "%c", (char)(val & 0xff)); // simple print to stderr
            }
            break;
        default:
            trace_printf("warn: unhandled out write of 0x%" prix64 " to port 0x%04x (size %d)\n", val, port, size);
            break;
    }
}

// -------------------------
// decoding helpers
// -------------------------
#define decode_modrm_mod ((cpu.decode.modrm >> 6) & 3)
#define decode_modrm_reg ((cpu.decode.modrm >> 3) & 7)
#define decode_modrm_rm  (cpu.decode.modrm & 7)

#define get_reg_val(i, s) ( (s == 8) ? (uint64_t)cpu.reg.r8[i] : \
                          (s == 16) ? (uint64_t)cpu.reg.r16[i] : \
                          (s == 32) ? (uint64_t)cpu.reg.r32[i] : \
                          (s == 64) ? cpu.reg.r64[i] : 0 )

#define set_reg_val(i, s, v) \
    do { \
        if (s == 8) cpu.reg.r8[i] = (uint8_t)v; \
        else if (s == 16) cpu.reg.r16[i] = (uint16_t)v; \
        else if (s == 32) cpu.reg.r32[i] = (uint32_t)v; \
        else if (s == 64) cpu.reg.r64[i] = v; \
    } while (0)

// get index to the register for modrm.reg (r) or rex.r
#define reg_index_r (decode_modrm_reg | (cpu.decode.has_rex ? ((cpu.decode.rex >> 2) & 8) : 0))
// get index to the register for modrm.rm (m) or sib.base (b) or rex.b
#define reg_index_b (decode_modrm_rm | (cpu.decode.has_rex ? (cpu.decode.rex & 8) : 0))
// get index to the register for sib.index (x) or rex.x
#define reg_index_x ( (cpu.decode.sib >> 3 & 7) | (cpu.decode.has_rex ? ((cpu.decode.rex >> 1) & 8) : 0) )

static void cpu_decode_reset(void) {
    memset(&cpu.decode, 0, sizeof(cpu.decode));
    cpu.decode.default_operand_size = 32;
    cpu.decode.default_addr_size = 64;
}

// -------------------------
// effective address calculation
// -------------------------
static int calculate_effective_address(int addr_size) {
    uint64_t base = 0;
    uint64_t index = 0;
    uint64_t scale = 1;
    int sib_present = 0;

    cpu.decode.disp = 0;
    cpu.decode.vaddr = 0;

    if (addr_size == 64) {
        // 64-bit addressing
        if (decode_modrm_mod != 3) {
            if (decode_modrm_rm == 4) { // sib byte present
                cpu.decode.sib = fetch_byte();
                sib_present = 1;

                // scale
                scale = 1 << ((cpu.decode.sib >> 6) & 3);

                // index (r8-r15 support via rex.x)
                if ((cpu.decode.sib & 7) != 4) { // index != rsp
                    index = cpu.reg.r64[reg_index_x];
                }

                // base (r8-r15 support via rex.b)
                if ((cpu.decode.sib & 7) == 5 && decode_modrm_mod == 0) {
                    // [disp32]
                    cpu.decode.disp = fetch_imm32();
                } else {
                    base = cpu.reg.r64[reg_index_b];
                }
            } else if (decode_modrm_rm == 5 && decode_modrm_mod == 0) {
                // rip-relative addressing [rip + disp32]
                base = fetch_rip + 4; // 4 is for the size of disp32
                cpu.decode.disp = fetch_imm32();
            } else {
                // direct addressing [base reg]
                base = cpu.reg.r64[reg_index_b];
            }

            // apply displacement
            if (decode_modrm_mod == 1) { // [reg + disp8]
                cpu.decode.disp = (int8_t)fetch_byte();
            } else if (decode_modrm_mod == 2) { // [reg + disp32]
                cpu.decode.disp = fetch_imm32();
            }

            // final address calculation
            cpu.decode.vaddr = base + index * scale + cpu.decode.disp;

        } else {
            // mod = 3, address is a register
            // cpu.decode.vaddr is not used, reg is accessed directly
            return 1; // indicates register mode
        }
    } else {
        // 32-bit addressing (not fully implemented, treat as simple 32-bit flat for now)
        // this is complex and usually only needed for legacy/compatibility mode
        trace_printf("fatal: 32-bit addressing mode not supported\n");
        exit(1);
    }

    // in a real emulator, vaddr would be translated to paddr here using cr3/paging logic.
    cpu.decode.paddr = cpu.decode.vaddr;
    return 0; // indicates memory mode
}

// -------------------------
// instruction execution core
// -------------------------

// define the general purpose access to modrm.rm or memory
#define access_op_r_w(size) ( (decode_modrm_mod == 3) ? (uint64_t *)&cpu.reg.r64[reg_index_r] : NULL )
#define access_op_r_r(size) ( (decode_modrm_mod == 3) ? get_reg_val(reg_index_r, size) : read_mem##size(cpu.decode.paddr) )
#define access_op_r_w_mem(size) ( (decode_modrm_mod == 3) ? set_reg_val(reg_index_r, size, v) : write_mem##size(cpu.decode.paddr, v) )

// define the general purpose access to modrm.rm or memory
#define access_op_rm_w(size) ( (decode_modrm_mod == 3) ? (uint64_t *)&cpu.reg.r64[reg_index_b] : NULL )
#define access_op_rm_r(size) ( (decode_modrm_mod == 3) ? get_reg_val(reg_index_b, size) : read_mem##size(cpu.decode.paddr) )
#define access_op_rm_w_mem(size, v) \
    do { \
        if (decode_modrm_mod == 3) { \
            set_reg_val(reg_index_b, size, v); \
        } else { \
            write_mem##size(cpu.decode.paddr, v); \
        } \
    } while (0)

#define op_reg_rm(size, func) \
    do { \
        if (calculate_effective_address(cpu.decode.default_addr_size) == 0) { \
            uint64_t val_rm = access_op_rm_r(size); \
            uint64_t val_reg = get_reg_val(reg_index_r, size); \
            uint64_t res = func(val_reg, val_rm); \
            access_op_rm_w_mem(size, res); \
        } else { \
            uint64_t *ptr_rm = access_op_rm_w(size); \
            uint64_t val_reg = get_reg_val(reg_index_r, size); \
            uint64_t res = func(val_reg, *ptr_rm); \
            *ptr_rm = res; \
        } \
    } while (0)

// arithmetic function stubs (must be defined elsewhere for a real 2000-line emulator)
static uint64_t op_add(uint64_t a, uint64_t b, int size) {
    uint66_t res = (uint66_t)a + b;
    update_flags_arith(a, b, res, size);
    return (uint64_t)res;
}
static uint64_t op_sub(uint64_t a, uint64_t b, int size) {
    uint66_t res = (uint66_t)a - b;
    update_flags_arith(a, ~b, res, size); // subtraction flags use inverted second operand
    return (uint64_t)res;
}
static uint64_t op_and(uint64_t a, uint64_t b, int size) {
    uint64_t res = a & b;
    set_flag(flag_cf, 0); set_flag(flag_of, 0);
    set_flag(flag_zf, (res & ( (1ULL << size) - 1 ) ) == 0);
    set_flag(flag_sf, (res >> (size - 1)) & 1);
    return res;
}
static uint64_t op_or(uint64_t a, uint64_t b, int size) {
    uint64_t res = a | b;
    set_flag(flag_cf, 0); set_flag(flag_of, 0);
    set_flag(flag_zf, (res & ( (1ULL << size) - 1 ) ) == 0);
    set_flag(flag_sf, (res >> (size - 1)) & 1);
    return res;
}
static uint64_t op_xor(uint64_t a, uint64_t b, int size) {
    uint64_t res = a ^ b;
    set_flag(flag_cf, 0); set_flag(flag_of, 0);
    set_flag(flag_zf, (res & ( (1ULL << size) - 1 ) ) == 0);
    set_flag(flag_sf, (res >> (size - 1)) & 1);
    return res;
}

// conditional jump evaluation
static int check_cond(int cc) {
    switch (cc) {
        case 0x0: return get_flag(flag_of); // o
        case 0x1: return !get_flag(flag_of); // no
        case 0x2: return get_flag(flag_cf); // b/nae/c
        case 0x3: return !get_flag(flag_cf); // nb/ae/nc
        case 0x4: return get_flag(flag_zf); // z/e
        case 0x5: return !get_flag(flag_zf); // nz/ne
        case 0x6: return get_flag(flag_cf) || get_flag(flag_zf); // be/na
        case 0x7: return !get_flag(flag_cf) && !get_flag(flag_zf); // nbe/a
        case 0x8: return get_flag(flag_sf); // s
        case 0x9: return !get_flag(flag_sf); // ns
        case 0xa: return get_flag(flag_pf); // p/pe
        case 0xb: return !get_flag(flag_pf); // np/po
        case 0xc: return get_flag(flag_sf) != get_flag(flag_of); // l/nge
        case 0xd: return get_flag(flag_sf) == get_flag(flag_of); // nl/ge
        case 0xe: return get_flag(flag_zf) || (get_flag(flag_sf) != get_flag(flag_of)); // le/ng
        case 0xf: return !get_flag(flag_zf) && (get_flag(flag_sf) == get_flag(flag_of)); // nle/g
        default: return 0;
    }
}

// -------------------------
// instruction execution switch
// -------------------------
static void execute_one_extended(void) {
    // 1. fetch initial rip
    fetch_rip = cpu.rip;
    fetch_pc = cpu.rip;
    cpu_decode_reset();

    // 2. decode prefixes (a massive simplification for brevity)
    // in a real emulator, this would handle 0x66, 0x67, segment overrides, and rex
    for (int i = 0; i < 15; i++) { // max 15 bytes total instruction size
        uint8_t prefix = read_mem8(fetch_pc);
        if (prefix >= 0x40 && prefix <= 0x4F) { // rex prefix
            cpu.decode.has_rex = 1;
            cpu.decode.rex = fetch_byte();
            if ((cpu.decode.rex & 0x8) || (cpu.decode.rex & 0x4) || (cpu.decode.rex & 0x2) || (cpu.decode.rex & 0x1)) {
                cpu.decode.default_operand_size = 64;
            }
        } else if (prefix == 0x66) { // operand size override
            cpu.decode.prefixes |= 0x66;
            cpu.decode.default_operand_size = 16;
            fetch_byte();
        } else if (prefix == 0xf3 || prefix == 0xf2) { // rep prefixes
            cpu.decode.prefixes |= prefix;
            fetch_byte();
        } else {
            break; // not a prefix
        }
    }

    int op_size = cpu.decode.default_operand_size;

    // 3. fetch opcode
    cpu.decode.opcode = fetch_byte();
    cpu.rip = fetch_pc; // speculative rip update

    // 4. trace buffer update
    uint32_t trace_idx = (cpu.trace_head & (trace_ring_size - 1));
    cpu.trace[trace_idx].rip = fetch_rip;
    cpu.trace[trace_idx].opcode = cpu.decode.opcode;
    cpu.trace[trace_idx].op2 = 0;
    cpu.trace[trace_idx].modrm = 0;
    cpu.trace[trace_idx].prefixes = cpu.decode.prefixes;
    cpu.trace[trace_idx].info_a = 0;
    cpu.trace[trace_idx].info_b = 0;

    // 5. instruction switch
    switch (cpu.decode.opcode) {

        // --- 1-byte opcodes ---
        case 0x00 ... 0x05: // add, or, adc, sbb, and, sub, xor, cmp (reg/mem, reg)
        case 0x08 ... 0x0d:
        case 0x10 ... 0x15:
        case 0x18 ... 0x1d:
        case 0x20 ... 0x25:
        case 0x28 ... 0x2d:
        case 0x30 ... 0x35:
        case 0x38 ... 0x3d:
        {
            // these all follow a similar pattern: al/ax/eax/rax op imm8/imm32/imm64
            // or reg/mem op reg
            int op_func = (cpu.decode.opcode >> 3) & 7; // 0=add, 1=or, 2=adc, 3=sbb, 4=and, 5=sub, 6=xor, 7=cmp
            int dir = (cpu.decode.opcode >> 1) & 1;     // 1 = reg <- reg/mem, 0 = reg/mem <- reg
            int w = cpu.decode.opcode & 1;              // 1 = 16/32/64 bit, 0 = 8 bit

            op_size = w ? op_size : 8; // correct op_size based on w bit

            if (dir == 1) { // 0x03, 0x0b, ... reg <- reg/mem
                // modrm fetch needed
                cpu.decode.modrm = fetch_byte();
                calculate_effective_address(cpu.decode.default_addr_size);
                // a proper implementation would use a switch on op_func here
                // op_reg_rm(op_size, op_add);
                break;
            } else { // 0x01, 0x09, ... reg/mem <- reg
                cpu.decode.modrm = fetch_byte();
                calculate_effective_address(cpu.decode.default_addr_size);
                // op_rm_reg(op_size, op_add);
                break;
            }
        }

        case 0x40 ... 0x4f: // rex prefixes (already handled)
        case 0x50 ... 0x5f: // push/pop general registers
            if (op_size != 64) { trace_printf("fatal: push/pop not 64-bit\n"); break; }
            int reg_idx = cpu.decode.opcode & 0x7; // r0-r7
            reg_idx |= cpu.decode.has_rex ? ((cpu.decode.rex & 0x1) << 3) : 0; // r8-r15 support

            if (cpu.decode.opcode < 0x58) { // push r/m64
                cpu.rsp -= 8;
                write_mem64(cpu.rsp, cpu.reg.r64[reg_idx]);
            } else { // pop r/m64
                cpu.reg.r64[reg_idx] = read_mem64(cpu.rsp);
                cpu.rsp += 8;
            }
            break;

        case 0x68: // push imm32
            cpu.decode.imm = fetch_imm32();
            cpu.rsp -= 8;
            write_mem64(cpu.rsp, (uint64_t)(int32_t)cpu.decode.imm);
            break;
        case 0x6a: // push imm8
            cpu.decode.imm = (int8_t)fetch_byte();
            cpu.rsp -= 8;
            write_mem64(cpu.rsp, (uint64_t)(int8_t)cpu.decode.imm);
            break;

        case 0x83: // group 1: reg/mem op imm8
        case 0x81: // group 1: reg/mem op imm
        {
            cpu.decode.modrm = fetch_byte();
            int is_mem = calculate_effective_address(cpu.decode.default_addr_size);
            int op_ext = decode_modrm_reg;
            int imm_size = (cpu.decode.opcode == 0x83) ? 8 : op_size;

            if (op_size == 64 && cpu.decode.opcode == 0x81) {
                cpu.decode.imm = fetch_imm32(); // 64-bit ops use 32-bit immediate unless r/m is 64-bit (which is often the case)
            } else if (imm_size == 8) {
                cpu.decode.imm = (uint64_t)(int8_t)fetch_byte();
            } else if (imm_size == 16) {
                cpu.decode.imm = (uint64_t)(int16_t)read_mem16(fetch_pc); fetch_pc += 2;
            } else if (imm_size == 32) {
                cpu.decode.imm = fetch_imm32();
            }

            uint64_t val_rm = is_mem ? access_op_rm_r(op_size) : cpu.reg.r64[reg_index_b];
            uint64_t res = val_rm;

            // this switch needs to be fully implemented for the 2000-line target
            switch (op_ext) {
                case 0: res = op_add(val_rm, cpu.decode.imm, op_size); break;
                // case 1: res = op_or(val_rm, cpu.decode.imm, op_size); break; ...
                case 7: /* cmp */ op_sub(val_rm, cpu.decode.imm, op_size); goto skip_write;
                default: trace_printf("fatal: group 1 op_ext 0x%x not implemented\n", op_ext); exit(1);
            }

            if (is_mem) {
                access_op_rm_w_mem(op_size, res);
            } else {
                cpu.reg.r64[reg_index_b] = res;
            }
            skip_write:;
            break;
        }

        case 0x87: // xchg reg, reg/mem (x64 only supports 0x87 if rex.w is set for 64-bit)
            cpu.decode.modrm = fetch_byte();
            // full implementation is complex with reg-reg swap optimization
            trace_printf("warn: xchg 0x87 not fully implemented\n");
            break;

        case 0x89: // mov reg/mem <- reg
            cpu.decode.modrm = fetch_byte();
            if (calculate_effective_address(cpu.decode.default_addr_size) == 0) { // mem <- reg
                access_op_rm_w_mem(op_size, get_reg_val(reg_index_r, op_size));
            } else { // reg <- reg
                set_reg_val(reg_index_b, op_size, get_reg_val(reg_index_r, op_size));
            }
            break;
        case 0x8b: // mov reg <- reg/mem
            cpu.decode.modrm = fetch_byte();
            if (calculate_effective_address(cpu.decode.default_addr_size) == 0) { // reg <- mem
                set_reg_val(reg_index_r, op_size, access_op_rm_r(op_size));
            } else { // reg <- reg
                set_reg_val(reg_index_r, op_size, get_reg_val(reg_index_b, op_size));
            }
            break;

        case 0x90 ... 0x97: // nop / xchg rax, rx (simple)
            if (cpu.decode.opcode == 0x90) { /* nop */ }
            else { /* xchg rax, rx - not implemented */ }
            break;

        case 0xb8 ... 0xbf: // mov reg, imm
            reg_idx = cpu.decode.opcode & 0x7; // r0-r7
            reg_idx |= cpu.decode.has_rex ? ((cpu.decode.rex & 0x1) << 3) : 0; // r8-r15 support

            if (op_size == 64) {
                cpu.reg.r64[reg_idx] = fetch_imm64();
            } else { // 32-bit immediate moves to lower 32-bit reg, zero-extending to 64-bit
                cpu.reg.r32[reg_idx] = fetch_imm32();
                // implicit zero-extension in x64 is handled by using r32 access
            }
            break;

        case 0xc3: // ret
            cpu.rip = read_mem64(cpu.rsp);
            cpu.rsp += 8;
            goto end_instruction;
        case 0xc7: // mov reg/mem, imm32
            cpu.decode.modrm = fetch_byte();
            is_mem = calculate_effective_address(cpu.decode.default_addr_size);

            if (op_size == 64) {
                cpu.decode.imm = fetch_imm32(); // mov r/m64, imm32 is common
            } else {
                cpu.decode.imm = fetch_imm32();
            }

            if (is_mem) {
                access_op_rm_w_mem(op_size, cpu.decode.imm);
            } else {
                set_reg_val(reg_index_b, op_size, cpu.decode.imm);
            }
            break;

        case 0xe8: // call rel32
            cpu.decode.imm = fetch_imm32();
            cpu.rsp -= 8;
            write_mem64(cpu.rsp, cpu.rip);
            cpu.rip += (uint64_t)(int32_t)cpu.decode.imm;
            goto end_instruction;

        case 0xe9: // jmp rel32
            cpu.decode.imm = fetch_imm32();
            cpu.rip += (uint64_t)(int32_t)cpu.decode.imm;
            goto end_instruction;
        case 0xeb: // jmp rel8
            cpu.decode.imm = (int8_t)fetch_byte();
            cpu.rip += (uint64_t)(int8_t)cpu.decode.imm;
            goto end_instruction;

        case 0xf4: // hlt
            trace_printf("instruction hlt executed. halting emulation.\n");
            goto stop_emulation_loop;

        case 0xff: // group 5 (inc/dec/call/jmp/push)
            cpu.decode.modrm = fetch_byte();
            op_ext = decode_modrm_reg;
            is_mem = calculate_effective_address(cpu.decode.default_addr_size);

            if (op_ext == 2) { // call near (r/m64)
                uint64_t target_addr = is_mem ? access_op_rm_r(64) : cpu.reg.r64[reg_index_b];
                cpu.rsp -= 8;
                write_mem64(cpu.rsp, cpu.rip);
                cpu.rip = target_addr;
                goto end_instruction;
            } else if (op_ext == 4) { // jmp near (r/m64)
                cpu.rip = is_mem ? access_op_rm_r(64) : cpu.reg.r64[reg_index_b];
                goto end_instruction;
            } else if (op_ext == 6) { // push r/m64
                cpu.rsp -= 8;
                uint64_t val = is_mem ? access_op_rm_r(64) : cpu.reg.r64[reg_index_b];
                write_mem64(cpu.rsp, val);
            } else {
                trace_printf("fatal: group 5 op_ext 0x%x not implemented\n", op_ext);
                exit(1);
            }
            break;

        // --- 2-byte opcodes (0x0f prefix) ---
        case 0x0f:
            cpu.decode.opcode = fetch_byte(); // second opcode byte
            cpu.trace[trace_idx].op2 = cpu.decode.opcode; // store in trace

            switch (cpu.decode.opcode) {
                case 0x80 ... 0x8f: // jcc rel32
                    cpu.decode.imm = fetch_imm32();
                    if (check_cond(cpu.decode.opcode & 0xf)) {
                        cpu.rip += (uint64_t)(int32_t)cpu.decode.imm;
                    }
                    break;

                case 0xb6: // movzx r64, r/m8
                case 0xb7: // movzx r64, r/m16
                    cpu.decode.modrm = fetch_byte();
                    int src_size = (cpu.decode.opcode == 0xb6) ? 8 : 16;
                    if (calculate_effective_address(cpu.decode.default_addr_size) == 0) { // mem
                        uint64_t val = (src_size == 8) ? read_mem8(cpu.decode.paddr) : read_mem16(cpu.decode.paddr);
                        cpu.reg.r64[reg_index_r] = val;
                    } else { // reg
                        uint64_t val = (src_size == 8) ? cpu.reg.r8[reg_index_b] : cpu.reg.r16[reg_index_b];
                        cpu.reg.r64[reg_index_r] = val;
                    }
                    break;

                case 0xbe: // movsx r64, r/m8
                case 0xbf: // movsx r64, r/m16
                    cpu.decode.modrm = fetch_byte();
                    src_size = (cpu.decode.opcode == 0xbe) ? 8 : 16;
                    if (calculate_effective_address(cpu.decode.default_addr_size) == 0) {
                        int64_t val = (src_size == 8) ? (int64_t)(int8_t)read_mem8(cpu.decode.paddr) : (int64_t)(int16_t)read_mem16(cpu.decode.paddr);
                        cpu.reg.r64[reg_index_r] = (uint64_t)val;
                    } else {
                        int64_t val = (src_size == 8) ? (int64_t)(int8_t)cpu.reg.r8[reg_index_b] : (int64_t)(int16_t)cpu.reg.r16[reg_index_b];
                        cpu.reg.r64[reg_index_r] = (uint64_t)val;
                    }
                    break;

                case 0xaf: // imul reg, reg/mem
                    cpu.decode.modrm = fetch_byte();
                    // full implementation needs to handle signed multiplication and flag setting
                    trace_printf("warn: imul not fully implemented\n");
                    break;

                case 0x01: // group 7 (lgdt/lidt/mov cr)
                    cpu.decode.modrm = fetch_byte();
                    op_ext = decode_modrm_reg;
                    is_mem = calculate_effective_address(cpu.decode.default_addr_size);

                    if (op_ext == 2) { // lidt r/m64
                        if (is_mem) {
                            // read 10-byte data for lidtr (limit and base address)
                            // not implemented
                            trace_printf("warn: lidt instruction stubbed\n");
                        }
                    } else if (op_ext == 3) { // lwdt r/m64
                         trace_printf("warn: lwdt instruction stubbed\n");
                    } else if (op_ext == 4) { // mov cr to reg
                        // mov cr reg_idx, reg_index_b
                        if (reg_index_r == 0) cpu.reg.r64[reg_index_b] = cpu.cr0;
                        else if (reg_index_r == 3) cpu.reg.r64[reg_index_b] = cpu.cr3;
                        else if (reg_index_r == 4) cpu.reg.r64[reg_index_b] = cpu.cr4;
                    } else if (op_ext == 6) { // mov reg to cr
                        // mov reg_index_b, cr reg_index_r
                        if (reg_index_r == 0) cpu.cr0 = cpu.reg.r64[reg_index_b];
                        else if (reg_index_r == 3) cpu.cr3 = cpu.reg.r64[reg_index_b];
                        else if (reg_index_r == 4) cpu.cr4 = cpu.reg.r64[reg_index_b];
                        // special handling for cr3 write (tlb flush) needed
                    }
                    break;

                // sse/sse2 stubs (only to recognize and skip instructions)
                case 0x10: case 0x11: case 0x28: case 0x29: case 0x2e: case 0x2f: // movups, movapd, movdqa etc.
                    cpu.decode.modrm = fetch_byte();
                    calculate_effective_address(cpu.decode.default_addr_size);
                    // sse instructions often have immediate byte (like 0xf0 in 0f 38 f0)
                    if (cpu.decode.opcode == 0x38 || cpu.decode.opcode == 0x3a) { // 3-byte opcodes
                        fetch_byte();
                        if (cpu.decode.opcode == 0x3a) fetch_byte();
                    }
                    trace_printf("warn: sse instruction stubbed 0x0f %02x\n", cpu.decode.opcode);
                    break;

                default:
                    trace_printf("fatal: unhandled 2-byte opcode 0x0f %02x at 0x%" prix64 "\n", cpu.decode.opcode, fetch_rip);
                    dump_trace_tail(max_trace_dump);
                    exit(1);
            }
            break;

        // --- i/o instructions ---
        case 0xe4: case 0xe5: case 0xec: case 0xed: // in
            if (cpu.decode.opcode == 0xe4 || cpu.decode.opcode == 0xe5) { // in al/ax/eax, imm8
                cpu.decode.imm = fetch_byte();
                cpu.rax = io_read((uint16_t)cpu.decode.imm, op_size);
            } else { // in al/ax/eax, dx
                cpu.rax = io_read((uint16_t)cpu.rdx, op_size);
            }
            break;

        case 0xe6: case 0xe7: case 0xee: case 0xef: // out
            if (cpu.decode.opcode == 0xe6 || cpu.decode.opcode == 0xe7) { // out imm8, al/ax/eax
                cpu.decode.imm = fetch_byte();
                io_write((uint16_t)cpu.decode.imm, cpu.rax, op_size);
            } else { // out dx, al/ax/eax
                io_write((uint16_t)cpu.rdx, cpu.rax, op_size);
            }
            break;

        default:
            trace_printf("fatal: unhandled 1-byte opcode 0x%02x at 0x%" prix64 "\n", cpu.decode.opcode, fetch_rip);
            dump_trace_tail(max_trace_dump);
            exit(1);
    }

    // 6. successful instruction completion
    cpu.rip = fetch_pc;
    cpu.trace_head++;

end_instruction:
    return;

stop_emulation_loop:
    cpu.rip = fetch_rip; // restore rip for clean exit
    // set rip to itself to halt the main loop
}

// -------------------------
// bios loading and initialization
// -------------------------
static int load_bios_file(const char *filename, uint64_t load_addr) {
    file *f = fopen(filename, "rb");
    if (!f) {
        fprintf(stderr, "err: could not open bios file %s: %s\n", filename, strerror(errno));
        return 1;
    }
    fseek(f, 0, seek_end);
    long file_size = ftell(f);
    fseek(f, 0, seek_set);

    if (load_addr + file_size > ram_size) {
        fprintf(stderr, "err: bios file too large for ram (%" priu64 " bytes at 0x%" prix64 ", ram_size is %" priu64 ")\n", (uint64_t)file_size, load_addr, ram_size);
        fclose(f);
        return 1;
    }

    uint8_t *dest = get_memory_ptr(load_addr);
    if (!dest) {
        fprintf(stderr, "err: memory pointer error\n");
        fclose(f);
        return 1;
    }
    size_t bytes_read = fread(dest, 1, file_size, f);
    fclose(f);

    if (bytes_read != (size_t)file_size) {
        fprintf(stderr, "err: failed to read entire bios file, read %zu of %lu bytes\n", bytes_read, file_size);
        return 1;
    }
    printf("loaded %s (0x%zx bytes) to memory address 0x%" prix64 "\n", filename, bytes_read, load_addr);
    return 0;
}

int x64emu_init_standalone(void) {
    // 1. allocate ram
    if (!ram_mem) {
        // use posix_memalign for 4k page alignment, useful for later paging
        // fall back to calloc if posix_memalign is not available
        #ifdef _POSIX_C_SOURCE
        if (posix_memalign((void**)&ram_mem, 4096, ram_size) != 0) {
            ram_mem = (uint8_t*)calloc(1, ram_size);
        }
        #else
        ram_mem = (uint8_t*)calloc(1, ram_size);
        #endif

        if (!ram_mem) {
            fprintf(stderr, "err: failed to allocate ram_mem (%" priu64 " bytes)\n", ram_size);
            return 1;
        }
    }
    // simple framebuffer setup (first 4mb of ram for vga/bios)
    fb_mem = ram_mem + (4 * 1024 * 1024);

    // 2. reset cpu state
    memset(&cpu, 0, sizeof(cpu));

    // set initial 64-bit execution state for loaded payload:
    // rip is set to 0x0, where we load the file.
    // rflags is set to 0x2 (reserved bit).
    cpu.rip = 0x0;
    cpu.rflags = 0x2;

    // a basic 64-bit flat model setup
    cpu.seg[0] = 0x8; // cs
    cpu.seg[1] = 0x10; // ds
    cpu.seg[2] = 0x10; // es
    cpu.seg[3] = 0x10; // fs
    cpu.seg[4] = 0x10; // gs
    cpu.seg[5] = 0x10; // ss

    // basic cr0/cr4 setup for protected/long mode environment
    cpu.cr0 = 0x80000001; // pe and pg enable
    cpu.cr4 = 0x20; // pae enable

    cpu_decode_reset();

    return 0;
}

// -------------------------
// main entry point
// -------------------------
int main(int cntArg, char **arrArg) {
    if (cntArg < 2) {
        fprintf(stderr, "usage: %s <bios_file> [bp_hex...]\n", arrArg[0]);
        return 1;
    }

    // initialize emulator structures (ram, cpu state)
    if (x64emu_init_standalone() != 0) {
        fprintf(stderr, "err: init failed\n");
        return 1;
    }

    // load the file at address 0x0, which is set as the initial rip
    if (load_bios_file(arrArg[1], 0x0) != 0) {
        return 1;
    }

    // set breakpoints (existing logic)
    for (int i=2;i<cntArg && i<2+max_soft_bp;i++) {
        uint64_t bp_addr;
        if (sscanf(arrArg[i], "%" scnx64, &bp_addr) == 1) {
            if (bp_add(bp_addr) == 0) {
                fprintf(stderr, "set bp at 0x%" prix64 "\n", bp_addr);
            }
        }
    }

    // new: the main emulation loop
    fprintf(stderr, "starting emulation at rip=0x%" prix64 " (%s)\n", cpu.rip, arrArg[1]);

    uint64_t inst_count = 0;
    uint64_t max_inst = 1000000; // safety limit

    // main emulation loop
    while (inst_count < max_inst) {
        uint64_t prev_rip = cpu.rip;

        // execute one instruction (the core emulation function)
        execute_one_extended();
        inst_count++;

        // check for soft breakpoint
        if (bp_check(cpu.rip)) {
            trace_printf("\n*** breakpoint hit at 0x%" prix64 " ***\n", cpu.rip);
            dump_cpu_state();
            dump_trace_tail(max_trace_dump);
            break;
        }

        // simple termination check (e.g., looping on the same instruction or hlt)
        if (cpu.rip == prev_rip && cpu.decode.opcode != 0xf4) {
             trace_printf("\n*** emulation halted (rip did not advance) at 0x%" prix64 " ***\n", cpu.rip);
             dump_cpu_state();
             dump_trace_tail(max_trace_dump);
             break;
        }

        // if hlt was executed (0xf4), the rip is restored to previous, so this check works
        if (cpu.decode.opcode == 0xf4) {
            break;
        }
    }

    fprintf(stderr, "\nemulation finished after %" priu64 " instructions.\n", inst_count);

    // cleanup
    if (ram_mem) free(ram_mem);

    return 0;
}

