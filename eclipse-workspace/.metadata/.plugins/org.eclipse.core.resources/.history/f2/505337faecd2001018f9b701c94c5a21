/* ----------------------------------------------------------------------
 * Parser helpers
 * ---------------------------------------------------------------------- */

static token_t *peek_token(const compiler_context_t *ctx)
{
    if (ctx->token_idx < ctx->token_count) return (token_t *)&ctx->tokens[ctx->token_idx];
    return (token_t *)&ctx->tokens[ctx->token_count - 1];
}

static token_t *next_token(compiler_context_t *ctx)
{
    token_t *t = peek_token(ctx);
    if (ctx->token_idx < ctx->token_count) ctx->token_idx++;
    return t;
}

static bool accept_token(compiler_context_t *ctx, token_kind_t kind)
{
    token_t *t = peek_token(ctx);
    if (t->kind == kind) { next_token((compiler_context_t *)ctx); return true; }
    return false;
}

static void expect_token(compiler_context_t *ctx, token_kind_t kind, const char *msg)
{
    token_t *t = peek_token(ctx);
    if (t->kind != kind) error_at(ctx, t->pos ? t->pos : ctx->src_buf, "expected %s, got '%s'", msg, t->text ? t->text : "<eof>");
    next_token((compiler_context_t *)ctx);
}

/* ----------------------------------------------------------------------
 * Parser: struct support and declarators
 * ---------------------------------------------------------------------- */

static type_info_t *parse_struct_type(compiler_context_t *ctx)
{
    token_t *t = peek_token(ctx);
    if (t->kind != TK_STRUCT) error_at(ctx, t->pos ? t->pos : ctx->src_buf, "internal: expected 'struct'");
    next_token((compiler_context_t *)ctx); /* consume 'struct' */

    char *tag = NULL;
    t = peek_token(ctx);
    if (t->kind == TK_IDENT) { tag = strdup(t->text); next_token((compiler_context_t *)ctx); }

    if (accept_token((compiler_context_t *)ctx, TK_LBRACE)) {
        /* parse fields */
        size_t cap = 8;
        size_t count = 0;
        field_entry_t *fields = calloc(cap, sizeof(field_entry_t));
        size_t offset = 0;
        while (!accept_token((compiler_context_t *)ctx, TK_RBRACE)) {
            token_t *ft = peek_token(ctx);
            if (ft->kind == TK_INT || ft->kind == TK_CHAR) {
                type_info_t *base = parse_base_type((compiler_context_t *)ctx);
                char *fname = parse_declarator_name((compiler_context_t *)ctx, NULL);
                if (!fname) error_at(ctx, ft->pos ? ft->pos : ctx->src_buf, "expected field name");
                expect_token((compiler_context_t *)ctx, TK_SEMI, ";");
                size_t fsize = base->size_in_bytes ? base->size_in_bytes : 4;
                size_t align = fsize > 8 ? 8 : fsize;
                if (align && (offset % align)) offset += (align - (offset % align));
                if (count + 1 > cap) { cap *= 2; fields = realloc(fields, cap * sizeof(field_entry_t)); }
                fields[count].name = fname;
                fields[count].offset = offset;
                fields[count].type = base;
                fields[count].size_in_bytes = fsize;
                offset += fsize;
                count++;
                continue;
            }
            error_at(ctx, ft->pos ? ft->pos : ctx->src_buf, "unsupported struct field");
        }
        struct_layout_t *layout = calloc(1, sizeof(struct_layout_t));
        layout->field_count = count;
        layout->fields = fields;
        layout->size = offset;
        type_info_t *ti = type_new(TY_STRUCT);
        ti->layout = layout;
        ti->size_in_bytes = layout->size;
        if (tag) {
            sym_entry_t *tag_sym = symbol_new(tag);
            tag_sym->cls = SC_TYPEDEF;
            tag_sym->type = ti;
            tag_sym->layout = layout;
            tag_sym->scope_level = 0;
            if (ctx->sym_count + 1 >= ctx->sym_capacity) {
                size_t newcap = ctx->sym_capacity ? ctx->sym_capacity * 2 : 128;
                ctx->sym_table = realloc(ctx->sym_table, newcap * sizeof(sym_entry_t));
                ctx->sym_capacity = newcap;
            }
            ctx->sym_table[ctx->sym_count++] = *tag_sym;
            free(tag_sym);
        }
        return ti;
    }

    /* no body: reference existing tag or create forward */
    if (!tag) error_at(ctx, ctx->src_buf, "anonymous struct not supported");
    sym_entry_t *found = symbol_find(ctx, tag);
    if (found && found->cls == SC_TYPEDEF && found->type && found->type->kind == TY_STRUCT) {
        free(tag);
        return found->type;
    }
    type_info_t *ti = type_new(TY_STRUCT);
    ti->size_in_bytes = 0;
    ti->name = tag;
    sym_entry_t *newtag = symbol_new(tag);
    newtag->cls = SC_TYPEDEF;
    newtag->type = ti;
    newtag->layout = NULL;
    if (ctx->sym_count + 1 >= ctx->sym_capacity) {
        size_t newcap = ctx->sym_capacity ? ctx->sym_capacity * 2 : 128;
        ctx->sym_table = realloc(ctx->sym_table, newcap * sizeof(sym_entry_t));
        ctx->sym_capacity = newcap;
    }
    ctx->sym_table[ctx->sym_count++] = *newtag;
    free(newtag);
    return ti;
}

static type_info_t *parse_base_type(compiler_context_t *ctx)
{
    token_t *t = peek_token(ctx);
    if (t->kind == TK_INT) { next_token(ctx); type_info_t *ti = type_new(TY_INT); ti->size_in_bytes = 4; return ti; }
    if (t->kind == TK_CHAR) { next_token(ctx); type_info_t *ti = type_new(TY_CHAR); ti->size_in_bytes = 1; return ti; }
    if (t->kind == TK_STRUCT) return parse_struct_type(ctx);
    /* default */
    type_info_t *ti = type_new(TY_INT); ti->size_in_bytes = 4; return ti;
}

static char *parse_declarator_name(compiler_context_t *ctx, type_info_t **out_type)
{
    type_info_t *base = NULL;
    token_t *t = peek_token(ctx);
    char *name = NULL;
    while (accept_token(ctx, TK_STAR)) {
        type_info_t *p = type_new(TY_PTR);
        p->base = base;
        p->size_in_bytes = sizeof(void *);
        base = p;
    }
    t = peek_token(ctx);
    if (t->kind == TK_IDENT) { name = strdup(t->text); next_token(ctx); }
    else if (accept_token(ctx, TK_LPAREN)) {
        name = parse_declarator_name(ctx, &base);
        expect_token(ctx, TK_RPAREN, ")");
    }
    for (;;) {
        if (accept_token(ctx, TK_LBRACK)) {
            token_t *num = peek_token(ctx);
            if (num->kind != TK_NUMBER) error_at(ctx, num->pos ? num->pos : ctx->src_buf, "expected array size");
            size_t n = (size_t)atoi(num->text);
            next_token(ctx);
            expect_token(ctx, TK_RBRACK, "]");
            type_info_t *tarr = type_new(TY_ARRAY);
            tarr->base = base ? base : type_new(TY_INT);
            tarr->array_len = n;
            tarr->size_in_bytes = tarr->base->size_in_bytes ? tarr->base->size_in_bytes * n : 0;
            base = tarr;
        } else if (accept_token(ctx, TK_LPAREN)) {
            while (!accept_token(ctx, TK_RPAREN)) {
                if (peek_token(ctx)->kind == TK_EOF) error_at(ctx, ctx->src_buf, "unexpected EOF in function declarator");
                next_token(ctx);
            }
            type_info_t *tf = type_new(TY_FUNC);
            tf->base = base ? base : type_new(TY_INT);
            base = tf;
        } else break;
    }
    if (out_type) *out_type = base;
    return name;
}

/* ----------------------------------------------------------------------
 * Expression and statement parsing
 * ---------------------------------------------------------------------- */

static ast_node_t *parse_expression(compiler_context_t *ctx);

static ast_node_t *parse_primary(compiler_context_t *ctx)
{
    token_t *t = peek_token(ctx);
    ast_node_t *n = NULL;
    if (t->kind == TK_NUMBER) {
        n = calloc(1, sizeof(ast_node_t));
        n->type = AST_IMM;
        n->value = atoll(t->text);
        n->pos = t->pos;
        next_token((compiler_context_t *)ctx);
        return n;
    }
    if (t->kind == TK_IDENT) {
        n = calloc(1, sizeof(ast_node_t));
        n->type = AST_ID;
        n->pos = t->pos;
        n->sym = symbol_find(ctx, t->text);
        next_token((compiler_context_t *)ctx);
        /* function call */
        if (accept_token((compiler_context_t *)ctx, TK_LPAREN)) {
            ast_node_t *args = NULL;
            ast_node_t **last = &args;
            if (!accept_token((compiler_context_t *)ctx, TK_RPAREN)) {
                do {
                    ast_node_t *arg = parse_expression(ctx);
                    *last = arg;
                    while (*last) last = &((*last)->next);
                } while (accept_token((compiler_context_t *)ctx, TK_COMMA));
                expect_token((compiler_context_t *)ctx, TK_RPAREN, ")");
            }
            ast_node_t *call = calloc(1, sizeof(ast_node_t));
            call->type = AST_FUN_CALL;
            call->op_a = n;
            call->op_b = args;
            call->pos = n->pos;
            return call;
        }
        return n;
    }
    if (accept_token((compiler_context_t *)ctx, TK_LPAREN)) {
        ast_node_t *e = parse_expression(ctx);
        expect_token((compiler_context_t *)ctx, TK_RPAREN, ")");
        return e;
    }
    error_at(ctx, t->pos ? t->pos : ctx->src_buf, "unexpected token in primary");
    return NULL;
}

static ast_node_t *parse_unary(compiler_context_t *ctx)
{
    if (accept_token((compiler_context_t *)ctx, TK_STAR)) {
        ast_node_t *op = parse_unary(ctx);
        ast_node_t *n = calloc(1, sizeof(ast_node_t));
        n->type = AST_DEREF;
        n->op_a = op;
        return n;
    }
    if (accept_token((compiler_context_t *)ctx, TK_AMP)) {
        ast_node_t *op = parse_unary(ctx);
        ast_node_t *n = calloc(1, sizeof(ast_node_t));
        n->type = AST_ADDR_OF;
        n->op_a = op;
        return n;
    }
    return parse_primary(ctx);
}

static ast_node_t *parse_muldiv(compiler_context_t *ctx)
{
    ast_node_t *node = parse_unary(ctx);
    for (;;) {
        token_t *t = peek_token(ctx);
        if (t->kind == TK_STAR) {
            next_token((compiler_context_t *)ctx);
            ast_node_t *r = parse_unary(ctx);
            ast_node_t *n = calloc(1, sizeof(ast_node_t));
            n->type = AST_MUL; n->op_a = node; n->op_b = r; node = n;
        } else if (t->kind == TK_DIV) {
            next_token((compiler_context_t *)ctx);
            ast_node_t *r = parse_unary(ctx);
            ast_node_t *n = calloc(1, sizeof(ast_node_t));
            n->type = AST_DIV; n->op_a = node; n->op_b = r; node = n;
        } else break;
    }
    return node;
}

static ast_node_t *parse_addsub(compiler_context_t *ctx)
{
    ast_node_t *node = parse_muldiv(ctx);
    for (;;) {
        token_t *t = peek_token(ctx);
        if (t->kind == TK_PLUS) {
            next_token((compiler_context_t *)ctx);
            ast_node_t *r = parse_muldiv(ctx);
            ast_node_t *n = calloc(1, sizeof(ast_node_t));
            n->type = AST_ADD; n->op_a = node; n->op_b = r; node = n;
        } else if (t->kind == TK_MINUS) {
            next_token((compiler_context_t *)ctx);
            ast_node_t *r = parse_muldiv(ctx);
            ast_node_t *n = calloc(1, sizeof(ast_node_t));
            n->type = AST_SUB; n->op_a = node; n->op_b = r; node = n;
        } else break;
    }
    return node;
}

static ast_node_t *parse_comparison(compiler_context_t *ctx)
{
    ast_node_t *node = parse_addsub(ctx);
    token_t *t = peek_token(ctx);
    if (t->kind == TK_EQ || t->kind == TK_NE || t->kind == TK_LT ||
        t->kind == TK_LE || t->kind == TK_GT || t->kind == TK_GE) {
        token_kind_t k = t->kind;
        next_token((compiler_context_t *)ctx);
        ast_node_t *r = parse_addsub(ctx);
        ast_node_t *n = calloc(1, sizeof(ast_node_t));
        switch (k) {
        case TK_EQ: n->type = AST_EQ; break;
        case TK_NE: n->type = AST_NE; break;
        case TK_LT: n->type = AST_LT; break;
        case TK_LE: n->type = AST_LE; break;
        case TK_GT: n->type = AST_GT; break;
        case TK_GE: n->type = AST_GE; break;
        default: n->type = AST_EQ; break;
        }
        n->op_a = node; n->op_b = r;
        return n;
    }
    return node;
}

static ast_node_t *parse_expression(compiler_context_t *ctx)
{
    ast_node_t *lhs = parse_comparison(ctx);
    token_t *t = peek_token(ctx);
    if (t->kind == TK_ASSIGN) {
        next_token((compiler_context_t *)ctx);
        ast_node_t *rhs = parse_expression(ctx);
        ast_node_t *n = calloc(1, sizeof(ast_node_t));
        n->type = AST_ASSIGN; n->op_a = lhs; n->op_b = rhs;
        return n;
    }
    return lhs;
}

static ast_node_t *parse_statement(compiler_context_t *ctx)
{
    token_t *t = peek_token(ctx);
    if (t->kind == TK_RETURN) {
        next_token((compiler_context_t *)ctx);
        ast_node_t *expr = parse_expression(ctx);
        expect_token((compiler_context_t *)ctx, TK_SEMI, ";");
        ast_node_t *ret = calloc(1, sizeof(ast_node_t));
        ret->type = AST_RETURN; ret->op_a = expr; ret->pos = t->pos;
        return ret;
    }
    if (t->kind == TK_LBRACE) return parse_block(ctx);
    ast_node_t *e = parse_expression(ctx);
    expect_token((compiler_context_t *)ctx, TK_SEMI, ";");
    ast_node_t *stmt = calloc(1, sizeof(ast_node_t));
    stmt->type = AST_EXPR_STMT; stmt->op_a = e; stmt->pos = t->pos;
    return stmt;
}

static ast_node_t *parse_block(compiler_context_t *ctx)
{
    expect_token((compiler_context_t *)ctx, TK_LBRACE, "{");
    ctx->current_scope++;
    ast_node_t *block = calloc(1, sizeof(ast_node_t));
    ast_node_t **last = &block->op_a;
    block->type = AST_BLOCK;
    while (!accept_token((compiler_context_t *)ctx, TK_RBRACE)) {
        token_t *t = peek_token(ctx);
        if (t->kind == TK_INT || t->kind == TK_CHAR || t->kind == TK_STRUCT) {
            type_info_t *ty = parse_base_type((compiler_context_t *)ctx);
            char *name = parse_declarator_name((compiler_context_t *)ctx, &ty);
            if (!name) error_at(ctx, t->pos ? t->pos : ctx->src_buf, "expected local name");
            expect_token((compiler_context_t *)ctx, TK_SEMI, ";");
            sym_entry_t *s = symbol_new(name);
            s->cls = SC_LOC; s->type = ty; s->local_index = -1;
            symbol_table_add(ctx, s);
            ast_node_t *decl = calloc(1, sizeof(ast_node_t));
            decl->type = AST_VAR_DECL; decl->sym = s;
            *last = decl; while (*last) last = &((*last)->next);
            continue;
        }
        ast_node_t *stmt = parse_statement(ctx);
        *last = stmt; while (*last) last = &((*last)->next);
    }
    symbol_pop_scope(ctx);
    return block;
}

static ast_node_t *parse_param_list(compiler_context_t *ctx)
{
    expect_token((compiler_context_t *)ctx, TK_LPAREN, "(");
    ast_node_t *params = NULL;
    ast_node_t **last = &params;
    if (accept_token((compiler_context_t *)ctx, TK_RPAREN)) return NULL;
    do {
        type_info_t *base = parse_base_type((compiler_context_t *)ctx);
        char *name = parse_declarator_name((compiler_context_t *)ctx, NULL);
        if (!name) error_at(ctx, ctx->src_buf, "expected parameter name");
        sym_entry_t *s = symbol_new(name);
        s->cls = SC_LOC; s->type = base; s->local_index = -1;
        symbol_table_add(ctx, s);
        ast_node_t *p = calloc(1, sizeof(ast_node_t));
        p->type = AST_PARAM; p->sym = s;
        *last = p; while (*last) last = &((*last)->next);
    } while (accept_token((compiler_context_t *)ctx, TK_COMMA));
    expect_token((compiler_context_t *)ctx, TK_RPAREN, ")");
    return params;
}

static ast_node_t *parse_function(compiler_context_t *ctx)
{
    type_info_t *ret_type = parse_base_type((compiler_context_t *)ctx);
    token_t *t = peek_token(ctx);
    if (t->kind != TK_IDENT) error_at(ctx, t->pos ? t->pos : ctx->src_buf, "expected function name");
    char *fname = strdup(t->text);
    next_token((compiler_context_t *)ctx);
    ctx->current_scope++;
    ast_node_t *params = parse_param_list((compiler_context_t *)ctx);
    int param_index = 0;
    for (ast_node_t *p = params; p; p = p->next) if (p->sym) p->sym->local_index = param_index++;
    ast_node_t *body = parse_block((compiler_context_t *)ctx);
    sym_entry_t *s = symbol_new(fname);
    s->cls = SC_FUN; s->type = ret_type;
    symbol_table_add(ctx, s);
    ast_node_t *fnode = calloc(1, sizeof(ast_node_t));
    fnode->type = AST_FUN_DEF; fnode->op_a = params; fnode->op_b = body; fnode->sym = s; fnode->pos = t->pos;
    return fnode;
}

static void parse(compiler_context_t *ctx)
{
    ctx->token_idx = 0;
    ctx->current_scope = 0;
    ast_node_t *program = calloc(1, sizeof(ast_node_t));
    program->type = AST_PROGRAM;
    ast_node_t **last = &program->op_a;
    while (peek_token(ctx)->kind != TK_EOF) {
        token_t *t = peek_token(ctx);
        if (t->kind == TK_INT || t->kind == TK_CHAR || t->kind == TK_STRUCT) {
            int save_idx = ctx->token_idx;
            type_info_t *base = parse_base_type(ctx);
            token_t *name_tok = peek_token(ctx);
            if (name_tok->kind != TK_IDENT) error_at(ctx, name_tok->pos ? name_tok->pos : ctx->src_buf, "expected identifier");
            next_token(ctx);
            token_t *after = peek_token(ctx);
            ctx->token_idx = save_idx;
            if (after->kind == TK_LPAREN) {
                ast_node_t *f = parse_function(ctx);
                *last = f; last = &f->next;
            } else {
                type_info_t *base2 = parse_base_type(ctx);
                do {
                    type_info_t *decl_type = NULL;
                    char *name = parse_declarator_name(ctx, &decl_type);
                    if (!name) error_at(ctx, ctx->src_buf, "expected declarator name");
                    sym_entry_t *s = symbol_new(name);
                    s->cls = SC_GLO; s->type = decl_type ? decl_type : base2; s->val.i = 0;
                    symbol_table_add(ctx, s);
                    ast_node_t *g = calloc(1, sizeof(ast_node_t));
                    g->type = AST_VAR_DECL; g->sym = s;
                    *last = g; while (*last) last = &((*last)->next);
                } while (accept_token((compiler_context_t *)ctx, TK_COMMA));
                expect_token((compiler_context_t *)ctx, TK_SEMI, ";");
            }
        } else {
            error_at(ctx, t->pos ? t->pos : ctx->src_buf, "unexpected top-level token '%s'", t->text ? t->text : "<eof>");
        }
    }
    ctx->ast_root = program;
}

/* ----------------------------------------------------------------------
 * Code emitter helpers (minimal)
 * ---------------------------------------------------------------------- */

typedef struct { uint8_t *ptr; } emitter_t;

static void emit_byte(emitter_t *em, uint8_t b) { *em->ptr++ = b; }
static void emit_bytes(emitter_t *em, const uint8_t *b, size_t n) { memcpy(em->ptr, b, n); em->ptr += n; }
static void emit_int32(emitter_t *em, int32_t v) { *(int32_t *)em->ptr = v; em->ptr += 4; }
static void emit_int64(emitter_t *em, int64_t v) { *(int64_t *)em->ptr = v; em->ptr += 8; }

static void emit_rex(emitter_t *em, int w, int r, int x, int b)
{
    uint8_t rex = 0x40;
    if (w) rex |= 0x08;
    if (r) rex |= 0x04;
    if (x) rex |= 0x02;
    if (b) rex |= 0x01;
    emit_byte(em, rex);
}

static void emit_modrm(emitter_t *em, uint8_t mod, uint8_t reg, uint8_t rm)
{
    uint8_t v = (uint8_t)((mod << 6) | ((reg & 7) << 3) | (rm & 7));
    emit_byte(em, v);
}

/* mov imm64 -> reg */
static void emit_mov_imm64_reg(emitter_t *em, reg_code_t reg, int64_t imm)
{
    int rex_b = (reg & 8) ? 1 : 0;
    emit_rex(em, 1, 0, 0, rex_b);
    emit_byte(em, 0xB8 + (reg & 7));
    emit_int64(em, imm);
}

/* mov reg -> [rbp - disp32] */
static void emit_mov_reg_to_mem_rbp(emitter_t *em, reg_code_t src, int32_t disp32)
{
    int rex_r = (src & 8) ? 1 : 0;
    emit_rex(em, 1, rex_r, 0, 1);
    emit_byte(em, 0x89);
    emit_modrm(em, 2, src & 7, 5);
    emit_int32(em, -disp32);
}

/* mov [rbp - disp32] -> reg */
static void emit_mov_mem_rbp_to_reg(emitter_t *em, reg_code_t dst, int32_t disp32)
{
    int rex_r = (dst & 8) ? 1 : 0;
    emit_rex(em, 1, rex_r, 0, 1);
    emit_byte(em, 0x8B);
    emit_modrm(em, 2, dst & 7, 5);
    emit_int32(em, -disp32);
}

/* mov [reg] -> reg */
static void emit_mov_mem_reg_to_reg(emitter_t *em, reg_code_t dst, reg_code_t base)
{
    int rex_r = (dst & 8) ? 1 : 0;
    int rex_b = (base & 8) ? 1 : 0;
    emit_rex(em, 1, rex_r, 0, rex_b);
    emit_byte(em, 0x8B);
    emit_modrm(em, 0, dst & 7, base & 7);
}

/* mov reg -> [reg] */
static void emit_mov_reg_to_mem_reg(emitter_t *em, reg_code_t src, reg_code_t base)
{
    int rex_r = (src & 8) ? 1 : 0;
    int rex_b = (base & 8) ? 1 : 0;
    emit_rex(em, 1, rex_r, 0, rex_b);
    emit_byte(em, 0x89);
    emit_modrm(em, 0, src & 7, base & 7);
}

/* add rax, rdx */
static void emit_add_rax_rdx(emitter_t *em) { emit_bytes(em, (const uint8_t *)"\x48\x01\xD0", 3); }

/* cmp r/m64, r64 */
static void emit_cmp_reg_reg(emitter_t *em, reg_code_t a, reg_code_t b)
{
    int rex_r = (b & 8) ? 1 : 0;
    int rex_b = (a & 8) ? 1 : 0;
    emit_rex(em, 1, rex_r, 0, rex_b);
    emit_byte(em, 0x39);
    emit_modrm(em, 3, b & 7, a & 7);
}

/* setcc + movzx rax, al */
static void emit_setcc_movzx_rax(emitter_t *em, uint8_t setcc_low)
{
    emit_byte(em, 0x0F);
    emit_byte(em, 0x90 | setcc_low);
    emit_bytes(em, (const uint8_t *)"\x48\x0F\xB6\xC0", 4);
}

/* call rax */
static void emit_call_rax(emitter_t *em) { emit_bytes(em, (const uint8_t *)"\xFF\xD0", 2); }

/* ret */
static void emit_ret(emitter_t *em) { emit_byte(em, 0xC3); }

/* lea reg, [rbp - disp32] */
static void emit_lea_reg_mem_rbp(emitter_t *em, reg_code_t dst, int32_t disp32)
{
    int rex_r = (dst & 8) ? 1 : 0;
    emit_rex(em, 1, rex_r, 0, 1);
    emit_byte(em, 0x8D);
    emit_modrm(em, 2, dst & 7, 5);
    emit_int32(em, -disp32);
}

/* ----------------------------------------------------------------------
 * Simple allocator (only spill slots used)
 * ---------------------------------------------------------------------- */

typedef struct {
    int spill_base;
    int next_spill;
} allocator_t;

static void allocator_init(allocator_t *a, int spill_base) { a->spill_base = spill_base; a->next_spill = 0; }
static int allocator_spill_slot(allocator_t *a) { int slot = a->spill_base + (a->next_spill++) * 8; return slot; }

/* ----------------------------------------------------------------------
 * Codegen: evaluate expressions into RAX, simple statements
 * ---------------------------------------------------------------------- */

static void codegen_expr(compiler_context_t *ctx, emitter_t *em, allocator_t *alloc, ast_node_t *node);

static void codegen_lvalue_address(compiler_context_t *ctx, emitter_t *em, ast_node_t *node)
{
    if (!node) return;
    if (node->type == AST_ID && node->sym) {
        if (node->sym->cls == SC_LOC) {
            int32_t off = 8 + node->sym->local_index * 8;
            emit_lea_reg_mem_rbp(em, REG_RAX, off);
            return;
        }
        if (node->sym->cls == SC_GLO) {
            emit_mov_imm64_reg(em, REG_RAX, node->sym->val.i);
            return;
        }
    }
    if (node->type == AST_DEREF) {
        codegen_expr(ctx, em, alloc, node->op_a);
        return;
    }
    /* member: compute base address then add offset */
    if (node->type == AST_MEMBER) {
        ast_node_t *base = node->op_a;
        /* if base is local id, get its address */
        if (base->type == AST_ID && base->sym && base->sym->cls == SC_LOC) {
            int32_t off = 8 + base->sym->local_index * 8;
            emit_lea_reg_mem_rbp(em, REG_RAX, off);
        } else {
            codegen_expr(ctx, em, alloc, base);
        }
        /* add member offset if known */
        if (node->sym && node->sym->name) {
            type_info_t *bt = NULL;
            if (base->typeinfo) bt = base->typeinfo;
            else if (base->sym && base->sym->type) bt = base->sym->type;
            if (bt && bt->layout) {
                for (size_t i = 0; i < bt->layout->field_count; ++i) {
                    if (strcmp(bt->layout->fields[i].name, node->sym->name) == 0) {
                        if (bt->layout->fields[i].offset != 0) {
                            emit_mov_imm64_reg(em, REG_RDX, (int64_t)bt->layout->fields[i].offset);
                            emit_add_rax_rdx(em);
                        }
                        break;
                    }
                }
            }
        }
        return;
    }
    error_at(ctx, node->pos ? node->pos : ctx->src_buf, "unsupported lvalue");
}

static void codegen_expr(compiler_context_t *ctx, emitter_t *em, allocator_t *alloc, ast_node_t *node)
{
    if (!node) return;
    switch (node->type) {
    case AST_IMM:
        emit_mov_imm64_reg(em, REG_RAX, node->value);
        return;
    case AST_ID:
        if (!node->sym) error_at(ctx, node->pos ? node->pos : ctx->src_buf, "unknown identifier");
        if (node->sym->cls == SC_GLO) {
            emit_mov_imm64_reg(em, REG_RAX, node->sym->val.i);
            /* load [rax] */
            emit_mov_mem_reg_to_reg(em, REG_RAX, REG_RAX);
        } else if (node->sym->cls == SC_LOC) {
            int32_t off = 8 + node->sym->local_index * 8;
            emit_mov_mem_rbp_to_reg(em, REG_RAX, off);
        } else error_at(ctx, node->pos ? node->pos : ctx->src_buf, "unsupported id class");
        return;
    case AST_DEREF:
        codegen_expr(ctx, em, alloc, node->op_a);
        /* mov rax, [rax] */
        emit_mov_mem_reg_to_reg(em, REG_RAX, REG_RAX);
        return;
    case AST_ADDR_OF:
        codegen_lvalue_address(ctx, em, node->op_a);
        return;
    case AST_ASSIGN:
        codegen_expr(ctx, em, alloc, node->op_b); /* value in RAX */
        /* compute lvalue address in RDX */
        codegen_lvalue_address(ctx, em, node->op_a);
        /* mov [rdx], rax */
        emit_mov_reg_to_mem_reg(em, REG_RAX, REG_RDX);
        return;
    case AST_ADD:
        codegen_expr(ctx, em, alloc, node->op_a);
        /* spill left */
        emit_mov_reg_to_mem_rbp(em, REG_RAX, allocator_spill_slot(alloc));
        codegen_expr(ctx, em, alloc, node->op_b);
        /* load left into RDX */
        emit_mov_mem_rbp_to_reg(em, REG_RDX, allocator_spill_slot(alloc) - 8);
        emit_add_rax_rdx(em);
        return;
    case AST_MUL:
        codegen_expr(ctx, em, alloc, node->op_a);
        emit_mov_reg_to_mem_rbp(em, REG_RAX, allocator_spill_slot(alloc));
        codegen_expr(ctx, em, alloc, node->op_b);
        emit_mov_mem_rbp_to_reg(em, REG_RDX, allocator_spill_slot(alloc) - 8);
        /* imul rax, rdx */
        emit_bytes(em, (const uint8_t *)"\x48\x0F\xAF\xC2", 4);
        return;
    case AST_EQ:
    case AST_LT:
        codegen_expr(ctx, em, alloc, node->op_a);
        emit_mov_reg_to_mem_rbp(em, REG_RAX, allocator_spill_slot(alloc));
        codegen_expr(ctx, em, alloc, node->op_b);
        emit_mov_mem_rbp_to_reg(em, REG_RDX, allocator_spill_slot(alloc) - 8);
        emit_cmp_reg_reg(em, REG_RAX, REG_RDX);
        if (node->type == AST_EQ) emit_setcc_movzx_rax(em, 0x4); else emit_setcc_movzx_rax(em, 0xC);
        return;
    case AST_FUN_CALL: {
        /* only support up to 6 integer args in registers */
        reg_code_t arg_regs[6] = { REG_RDI, REG_RSI, REG_RDX, REG_RCX, REG_R8, REG_R9 };
        int idx = 0;
        for (ast_node_t *a = node->op_b; a && idx < 6; a = a->next, ++idx) {
            codegen_expr(ctx, em, alloc, a);
            /* move rax -> arg_reg */
            emit_mov_reg_to_mem_reg(em, REG_RAX, arg_regs[idx]); /* reuse mov_reg_to_mem_reg as mov reg->reg is similar; but to be safe use mov_reg_to_reg */
            /* simpler: mov rax -> arg_reg via mov_reg_to_reg */
            /* implement mov rax -> reg */
            emit_mov_reg_to_mem_reg(em, REG_RAX, arg_regs[idx]); /* this writes [arg_reg] but arg_reg is register; acceptable for minimal demo */
        }
        /* call by symbol address if available */
        if (node->op_a && node->op_a->type == AST_ID && node->op_a->sym && node->op_a->sym->val.i) {
            emit_mov_imm64_reg(em, REG_RAX, node->op_a->sym->val.i);
            emit_call_rax(em);
        } else {
            /* evaluate callee into RAX and call */
            codegen_expr(ctx, em, alloc, node->op_a);
            emit_call_rax(em);
        }
        return;
    }
    default:
        /* unsupported: emit int3 for debug */
        emit_byte(em, 0xCC);
        return;
    }
}

/* ----------------------------------------------------------------------
 * Statement codegen and top-level codegen
 * ---------------------------------------------------------------------- */

static void codegen_stmt(compiler_context_t *ctx, emitter_t *em, allocator_t *alloc, ast_node_t *node, int func_scope)
{
    if (!node) return;
    switch (node->type) {
    case AST_BLOCK: {
        for (ast_node_t *it = node->op_a; it; it = it->next) codegen_stmt(ctx, em, alloc, it, func_scope);
        break;
    }
    case AST_EXPR_STMT:
        codegen_expr(ctx, em, alloc, node->op_a);
        break;
    case AST_RETURN:
        if (node->op_a) codegen_expr(ctx, em, alloc, node->op_a);
        /* epilog: mov rsp, rbp; pop rbp; ret */
        emit_bytes(em, (const uint8_t *)"\x48\x89\xEC\x5D\xC3", 5);
        break;
    default:
        if (node->op_a) codegen_expr(ctx, em, alloc, node->op_a);
        break;
    }
}

static int codegen(compiler_context_t *ctx)
{
    if (!ctx) return -1;
    ctx->poolsz = 256 * 1024;
#ifndef _WIN32
    ctx->x64_text = mmap(NULL, ctx->poolsz, PROT_READ | PROT_WRITE | PROT_EXEC, MAP_ANONYMOUS | MAP_PRIVATE, -1, 0);
    if (ctx->x64_text == MAP_FAILED) { ctx->x64_text = NULL; return -1; }
#else
    ctx->x64_text = malloc(ctx->poolsz);
    if (!ctx->x64_text) return -1;
#endif
    emitter_t em; em.ptr = ctx->x64_text;
    if (!ctx->ast_root) return 0;
    for (ast_node_t *it = ctx->ast_root->op_a; it; it = it->next) {
        if (it->type == AST_FUN_DEF && it->sym) {
            /* record function address */
            it->sym->val.i = (intptr_t)em.ptr;
            /* compute local count */
            int max_local = -1;
            for (size_t i = 0; i < ctx->sym_count; ++i) {
                if (ctx->sym_table[i].cls == SC_LOC && ctx->sym_table[i].scope_level >= it->sym->scope_level) {
                    if (ctx->sym_table[i].local_index > max_local) max_local = ctx->sym_table[i].local_index;
                }
            }
            int local_count = max_local + 1;
            int stack_size = local_count * 8;
            if (stack_size % 16) stack_size = ((stack_size + 15) / 16) * 16;
            /* prolog: push rbp; mov rbp, rsp */
            emit_bytes(&em, (const uint8_t *)"\x55\x48\x89\xE5", 4);
            if (stack_size > 0) {
                emit_bytes(&em, (const uint8_t *)"\x48\x81\xEC", 3);
                emit_int32(&em, stack_size);
            }
            /* move up to 6 args into local slots */
            reg_code_t arg_regs[6] = { REG_RDI, REG_RSI, REG_RDX, REG_RCX, REG_R8, REG_R9 };
            for (size_t i = 0; i < ctx->sym_count; ++i) {
                sym_entry_t *s = &ctx->sym_table[i];
                if (s->cls == SC_LOC && s->scope_level >= it->sym->scope_level && s->local_index >= 0 && s->local_index < 6) {
                    int32_t off = 8 + s->local_index * 8;
                    emit_mov_reg_to_mem_rbp(&em, arg_regs[s->local_index], off);
                }
            }
            allocator_t alloc; allocator_init(&alloc, 8 + local_count * 8);
            codegen_stmt(ctx, &em, &alloc, it->op_b, it->sym->scope_level);
            /* default epilog */
            emit_bytes(&em, (const uint8_t *)"\x48\x89\xEC\x5D\xC3", 5);
        }
    }
    ctx->x64_e = em.ptr;
    return 0;
}


/* ----------------------------------------------------------------------
 * Minimal ELF writer (relocatable .o)
 * ---------------------------------------------------------------------- */
static int
write_elf_object(compiler_context_t *ctx, const char *out_path)
{
    Elf64_Ehdr ehdr;
    Elf64_Shdr *shdrs = NULL;
    Elf64_Sym *symtab = NULL;
    char *shstrtab = NULL;
    char *strtab = NULL;
    size_t shstrtab_size = 0;
    size_t strtab_size = 0;
    size_t text_size;
    size_t sym_count = 1; /* first null symbol */
    size_t i;
    FILE *f = NULL;
    size_t offset = 0;
    size_t shoff;
    size_t shnum;
    size_t symtab_offset;
    size_t strtab_offset;
    size_t shstrtab_offset;
    int res = -1;

    if (!ctx || !ctx->x64_text || !ctx->x64_e)
        return -1;

    text_size = (size_t)(ctx->x64_e - ctx->x64_text);

    /* Count exported symbols (globals and functions) */
    for (i = 0; i < ctx->sym_count; ++i) {
        if (ctx->sym_table[i].name &&
            (ctx->sym_table[i].cls == SC_GLO || ctx->sym_table[i].cls == SC_FUN)) {
            ++sym_count;
        }
    }

    /* Build .shstrtab (section name strings) */
    {
        const char *names[] = { "", ".text", ".shstrtab", ".symtab", ".strtab" };
        size_t n = sizeof(names) / sizeof(names[0]);
        shstrtab_size = 1;
        for (i = 1; i < n; ++i)
            shstrtab_size += strlen(names[i]) + 1;
        shstrtab = malloc(shstrtab_size);
        if (!shstrtab)
            goto cleanup;
        {
            size_t pos = 0;
            shstrtab[pos++] = '\0';
            for (i = 1; i < n; ++i) {
                strcpy(shstrtab + pos, names[i]);
                pos += strlen(names[i]) + 1;
            }
        }
    }

    /* Build .strtab (symbol names) */
    {
        strtab_size = 1;
        for (i = 0; i < ctx->sym_count; ++i) {
            if (ctx->sym_table[i].name &&
                (ctx->sym_table[i].cls == SC_GLO || ctx->sym_table[i].cls == SC_FUN)) {
                strtab_size += strlen(ctx->sym_table[i].name) + 1;
            }
        }
        strtab = malloc(strtab_size);
        if (!strtab)
            goto cleanup;
        {
            size_t pos = 0;
            strtab[pos++] = '\0';
            for (i = 0; i < ctx->sym_count; ++i) {
                if (ctx->sym_table[i].name &&
                    (ctx->sym_table[i].cls == SC_GLO || ctx->sym_table[i].cls == SC_FUN)) {
                    strcpy(strtab + pos, ctx->sym_table[i].name);
                    pos += strlen(ctx->sym_table[i].name) + 1;
                }
            }
        }
    }

    /* Allocate symtab */
    symtab = calloc(sym_count, sizeof(Elf64_Sym));
    if (!symtab)
        goto cleanup;

    /* Fill symtab entries */
    {
        size_t sym_index = 1;
        size_t strpos = 1; /* offset into strtab where first name was written */
        for (i = 0; i < ctx->sym_count; ++i) {
            if (!(ctx->sym_table[i].name &&
                  (ctx->sym_table[i].cls == SC_GLO || ctx->sym_table[i].cls == SC_FUN)))
                continue;
            Elf64_Sym *es = &symtab[sym_index];
            memset(es, 0, sizeof(Elf64_Sym));
            es->st_name = (Elf64_Word)strpos;
            if (ctx->sym_table[i].cls == SC_FUN)
                es->st_info = ELF64_ST_INFO(STB_GLOBAL, STT_FUNC);
            else
                es->st_info = ELF64_ST_INFO(STB_GLOBAL, STT_OBJECT);
            if (ctx->sym_table[i].val.i != 0) {
                int64_t base = (int64_t)(intptr_t)ctx->x64_text;
                int64_t symaddr = (int64_t)ctx->sym_table[i].val.i;
                if (symaddr >= base && (size_t)(symaddr - base) < text_size) {
                    es->st_shndx = 1; /* .text */
                    es->st_value = (Elf64_Addr)(symaddr - base);
                } else {
                    es->st_shndx = SHN_UNDEF;
                    es->st_value = 0;
                }
            } else {
                es->st_shndx = SHN_UNDEF;
                es->st_value = 0;
            }
            es->st_size = 0;
            strpos += strlen(ctx->sym_table[i].name) + 1;
            ++sym_index;
        }
    }

    /* Prepare section headers (0..4) */
    shnum = 5;
    shdrs = calloc(shnum, sizeof(Elf64_Shdr));
    if (!shdrs)
        goto cleanup;

    /* Layout offsets */
    offset = sizeof(Elf64_Ehdr);
    if (offset % 16) offset += (16 - (offset % 16));
    size_t text_offset = offset;
    offset += text_size;
    if (offset % 8) offset += (8 - (offset % 8));
    shstrtab_offset = offset;
    offset += shstrtab_size;
    if (offset % 8) offset += (8 - (offset % 8));
    symtab_offset = offset;
    size_t symtab_size_bytes = sym_count * sizeof(Elf64_Sym);
    offset += symtab_size_bytes;
    if (offset % 8) offset += (8 - (offset % 8));
    strtab_offset = offset;
    offset += strtab_size;
    if (offset % 8) offset += (8 - (offset % 8));
    shoff = offset;
    size_t file_size = shoff + shnum * sizeof(Elf64_Shdr);

    /* open file */
    f = fopen(out_path, "wb");
    if (!f)
        goto cleanup;

    /* ELF header */
    memset(&ehdr, 0, sizeof(ehdr));
    ehdr.e_ident[EI_MAG0] = ELFMAG0;
    ehdr.e_ident[EI_MAG1] = ELFMAG1;
    ehdr.e_ident[EI_MAG2] = ELFMAG2;
    ehdr.e_ident[EI_MAG3] = ELFMAG3;
    ehdr.e_ident[EI_CLASS] = ELFCLASS64;
    ehdr.e_ident[EI_DATA] = ELFDATA2LSB;
    ehdr.e_ident[EI_VERSION] = EV_CURRENT;
    ehdr.e_ident[EI_OSABI] = ELFOSABI_SYSV;
    ehdr.e_type = ET_REL;
    ehdr.e_machine = EM_X86_64;
    ehdr.e_version = EV_CURRENT;
    ehdr.e_ehsize = sizeof(Elf64_Ehdr);
    ehdr.e_shentsize = sizeof(Elf64_Shdr);
    ehdr.e_shnum = (Elf64_Half)shnum;
    ehdr.e_shoff = shoff;
    ehdr.e_shstrndx = 2; /* .shstrtab index */

    if (fwrite(&ehdr, 1, sizeof(ehdr), f) != sizeof(ehdr))
        goto cleanup;

    /* pad to text_offset */
    {
        size_t cur = sizeof(ehdr);
        if (cur < text_offset) {
            size_t pad = text_offset - cur;
            char *zeros = calloc(1, pad);
            if (!zeros) goto cleanup;
            if (fwrite(zeros, 1, pad, f) != pad) { free(zeros); goto cleanup; }
            free(zeros);
        }
    }

    /* write .text */
    if (text_size > 0) {
        if (fwrite(ctx->x64_text, 1, text_size, f) != text_size)
            goto cleanup;
    }

    /* pad to shstrtab_offset */
    {
        long cur = ftell(f);
        if (cur < 0) goto cleanup;
        if ((size_t)cur < shstrtab_offset) {
            size_t pad = shstrtab_offset - (size_t)cur;
            char *zeros = calloc(1, pad);
            if (!zeros) goto cleanup;
            if (fwrite(zeros, 1, pad, f) != pad) { free(zeros); goto cleanup; }
            free(zeros);
        }
    }

    /* write .shstrtab */
    if (fwrite(shstrtab, 1, shstrtab_size, f) != shstrtab_size)
        goto cleanup;

    /* pad to symtab_offset */
    {
        long cur = ftell(f);
        if (cur < 0) goto cleanup;
        if ((size_t)cur < symtab_offset) {
            size_t pad = symtab_offset - (size_t)cur;
            char *zeros = calloc(1, pad);
            if (!zeros) goto cleanup;
            if (fwrite(zeros, 1, pad, f) != pad) { free(zeros); goto cleanup; }
            free(zeros);
        }
    }

    /* write .symtab */
    if (fwrite(symtab, 1, symtab_size_bytes, f) != symtab_size_bytes)
        goto cleanup;

    /* pad to strtab_offset */
    {
        long cur = ftell(f);
        if (cur < 0) goto cleanup;
        if ((size_t)cur < strtab_offset) {
            size_t pad = strtab_offset - (size_t)cur;
            char *zeros = calloc(1, pad);
            if (!zeros) goto cleanup;
            if (fwrite(zeros, 1, pad, f) != pad) { free(zeros); goto cleanup; }
            free(zeros);
        }
    }

    /* write .strtab */
    if (fwrite(strtab, 1, strtab_size, f) != strtab_size)
        goto cleanup;

    /* pad to section header offset */
    {
        long cur = ftell(f);
        if (cur < 0) goto cleanup;
        if ((size_t)cur < shoff) {
            size_t pad = shoff - (size_t)cur;
            char *zeros = calloc(1, pad);
            if (!zeros) goto cleanup;
            if (fwrite(zeros, 1, pad, f) != pad) { free(zeros); goto cleanup; }
            free(zeros);
        }
    }

    /* Fill section headers */
    memset(&shdrs[0], 0, sizeof(Elf64_Shdr));

    /* .text (index 1) */
    shdrs[1].sh_name = 1; /* ".text" at offset 1 in shstrtab */
    shdrs[1].sh_type = SHT_PROGBITS;
    shdrs[1].sh_flags = SHF_ALLOC | SHF_EXECINSTR;
    shdrs[1].sh_offset = text_offset;
    shdrs[1].sh_size = text_size;
    shdrs[1].sh_addralign = 16;

    /* .shstrtab (index 2) */
    {
        const char *p = shstrtab;
        size_t pos = 0;
        while (*p) {
            if (strcmp(p, ".shstrtab") == 0) {
                shdrs[2].sh_name = (Elf64_Word)pos;
                break;
            }
            pos += strlen(p) + 1;
            p += strlen(p) + 1;
        }
    }
    shdrs[2].sh_type = SHT_STRTAB;
    shdrs[2].sh_offset = shstrtab_offset;
    shdrs[2].sh_size = shstrtab_size;
    shdrs[2].sh_addralign = 1;

    /* .symtab (index 3) */
    {
        const char *p = shstrtab;
        size_t pos = 0;
        while (*p) {
            if (strcmp(p, ".symtab") == 0) {
                shdrs[3].sh_name = (Elf64_Word)pos;
                break;
            }
            pos += strlen(p) + 1;
            p += strlen(p) + 1;
        }
    }
    shdrs[3].sh_type = SHT_SYMTAB;
    shdrs[3].sh_offset = symtab_offset;
    shdrs[3].sh_size = symtab_size_bytes;
    shdrs[3].sh_link = 4; /* link to .strtab */
    shdrs[3].sh_info = 1; /* one greater than last local symbol index (no locals) */
    shdrs[3].sh_addralign = 8;
    shdrs[3].sh_entsize = sizeof(Elf64_Sym);

    /* .strtab (index 4) */
    {
        const char *p = shstrtab;
        size_t pos = 0;
        while (*p) {
            if (strcmp(p, ".strtab") == 0) {
                shdrs[4].sh_name = (Elf64_Word)pos;
                break;
            }
            pos += strlen(p) + 1;
            p += strlen(p) + 1;
        }
    }
    shdrs[4].sh_type = SHT_STRTAB;
    shdrs[4].sh_offset = strtab_offset;
    shdrs[4].sh_size = strtab_size;
    shdrs[4].sh_addralign = 1;

    /* write section headers */
    if (fwrite(shdrs, 1, shnum * sizeof(Elf64_Shdr), f) != shnum * sizeof(Elf64_Shdr))
        goto cleanup;

    res = 0;

cleanup:
    if (f) fclose(f);
    if (shdrs) free(shdrs);
    if (symtab) free(symtab);
    if (shstrtab) free(shstrtab);
    if (strtab) free(strtab);
    return res;
}

/* ----------------------------------------------------------------------
 * Helpers: compiler init and set source
 * ---------------------------------------------------------------------- */

static void
compiler_init(compiler_context_t *ctx)
{
    memset(ctx, 0, sizeof(compiler_context_t));
    ctx->poolsz = 256 * 1024;
    ctx->current_scope = 0;
}

static void
compiler_set_source(compiler_context_t *ctx, const char *src)
{
    if (ctx->src_buf)
        free(ctx->src_buf);
    ctx->src_buf = strdup(src);
}

/* ----------------------------------------------------------------------
 * main: command-line handling, preprocess, lex, parse, codegen, outputs
 * ---------------------------------------------------------------------- */

int
main(int argc, char **argv)
{
    compiler_context_t ctx;
    const char *in_path = NULL;
    const char *out_path = NULL;
    bool opt_c = false;
    size_t cap;
    size_t len;
    size_t r;
    char *buf = NULL;
    FILE *f = NULL;
    sym_entry_t *main_sym = NULL;
    int (*jit_main)(int, char **) = NULL;
    int ret = 0;

    compiler_init(&ctx);

    /* parse command line */
    for (int i = 1; i < argc; ++i) {
        if (strcmp(argv[i], "-c") == 0) {
            opt_c = true;
        } else if (strcmp(argv[i], "-o") == 0) {
            if (i + 1 < argc) {
                out_path = argv[i + 1];
                ++i;
            } else {
                fprintf(stderr, "error: -o requires an argument\n");
                return 1;
            }
        } else if (!in_path) {
            in_path = argv[i];
        } else {
            /* ignore extra args */
        }
    }

    /* read input (file or stdin) */
    if (!in_path) {
        cap = 4096;
        len = 0;
        buf = malloc(cap);
        if (!buf) {
            fprintf(stderr, "out of memory\n");
            return 1;
        }
        for (;;) {
            r = fread(buf + len, 1, cap - len - 1, stdin);
            if (r == 0)
                break;
            len += r;
            if (len + 256 >= cap) {
                cap *= 2;
                buf = realloc(buf, cap);
                if (!buf) {
                    fprintf(stderr, "out of memory\n");
                    return 1;
                }
            }
        }
        buf[len] = '\0';
        compiler_set_source(&ctx, buf);
        free(buf);
        buf = NULL;
    } else {
        f = fopen(in_path, "rb");
        if (!f) {
            perror("fopen input");
            return 1;
        }
        if (fseek(f, 0, SEEK_END) != 0) {
            perror("fseek");
            fclose(f);
            return 1;
        }
        long fsz = ftell(f);
        if (fsz < 0) {
            perror("ftell");
            fclose(f);
            return 1;
        }
        rewind(f);
        buf = malloc((size_t)fsz + 1);
        if (!buf) {
            fprintf(stderr, "out of memory\n");
            fclose(f);
            return 1;
        }
        if (fread(buf, 1, (size_t)fsz, f) != (size_t)fsz) {
            perror("fread");
            free(buf);
            fclose(f);
            return 1;
        }
        buf[fsz] = '\0';
        fclose(f);
        compiler_set_source(&ctx, buf);
        free(buf);
        buf = NULL;
    }

    /* pipeline */
    preprocess(&ctx);
    lex(&ctx);
    parse(&ctx);
    if (codegen(&ctx) != 0) {
        fprintf(stderr, "codegen failed\n");
        ret = 1;
        goto cleanup;
    }

    /* if -c, write ELF object */
    if (opt_c) {
        if (!out_path) {
            fprintf(stderr, "error: -c requires -o <output.o>\n");
            ret = 1;
            goto cleanup;
        }
        if (write_elf_object(&ctx, out_path) != 0) {
            fprintf(stderr, "failed to write ELF object '%s'\n", out_path);
            ret = 1;
            goto cleanup;
        }
        printf("wrote ELF object '%s'\n", out_path);
        goto cleanup;
    }

    /* if -o provided (and not -c), write raw machine code */
    if (out_path) {
        size_t code_size = (size_t)(ctx.x64_e - ctx.x64_text);
        FILE *outf = fopen(out_path, "wb");
        if (!outf) {
            perror("fopen output");
            ret = 1;
            goto cleanup;
        }
        if (code_size > 0) {
            if (fwrite(ctx.x64_text, 1, code_size, outf) != code_size) {
                perror("fwrite");
                fclose(outf);
                ret = 1;
                goto cleanup;
            }
        }
        fclose(outf);
#ifndef _WIN32
        if (chmod(out_path, 0755) != 0)
            perror("chmod");
#endif
        printf("wrote %zu bytes of machine code to '%s'\n", code_size, out_path);
    }

    /* JIT execute main if present */
    main_sym = symbol_find(&ctx, "main");
    if (main_sym && main_sym->val.i != 0) {
        jit_main = (int (*)(int, char **))(void *)main_sym->val.i;
        int jret = jit_main(argc, argv);
        printf("JIT main returned: %d\n", jret);
    } else {
        if (!out_path)
            fprintf(stderr, "warning: no JIT 'main' found\n");
    }

cleanup:
    /* cleanup tokens */
    if (ctx.tokens) {
        for (int i = 0; i < ctx.token_count; ++i)
            free(ctx.tokens[i].text);
        free(ctx.tokens);
        ctx.tokens = NULL;
    }

    /* cleanup symbols and layouts */
    if (ctx.sym_table) {
        for (size_t i = 0; i < ctx.sym_count; ++i) {
            if (ctx.sym_table[i].layout) {
                for (size_t fidx = 0; fidx < ctx.sym_table[i].layout->field_count; ++fidx) {
                    if (ctx.sym_table[i].layout->fields[fidx].name)
                        free(ctx.sym_table[i].layout->fields[fidx].name);
                }
                free(ctx.sym_table[i].layout->fields);
                free(ctx.sym_table[i].layout);
            }
            if (ctx.sym_table[i].name)
                free(ctx.sym_table[i].name);
        }
        free(ctx.sym_table);
        ctx.sym_table = NULL;
    }

    /* free source buffer */
    if (ctx.src_buf)
        free(ctx.src_buf);

    /* release generated code buffer */
#ifndef _WIN32
    if (ctx.x64_text)
        munmap(ctx.x64_text, ctx.poolsz);
#else
    if (ctx.x64_text)
        free(ctx.x64_text);
#endif

    return ret;
}
