#define SYNC_DIR_DEFAULT "/home/%s/google_drive"
#define TOKEN_FILE_DEFAULT "/home/%s/.config/DriveSync/token.txt"
#define DRIVE_FILES_URL "https://www.googleapis.com/drive/v3/files"
#define PAGE_SIZE "1000"

typedef struct {
    char *memory;
    size_t size;
} MemoryStruct;

typedef struct {
    char *id;
    json_t *meta; // borrowed reference
} IdMeta;

typedef struct {
    IdMeta *items;
    size_t count;
    size_t cap;
} IdIndex;

typedef struct {
    char *relpath;
    int is_dir;
    off_t size;
    time_t mtime;
} LocalEntry;

typedef struct {
    LocalEntry *items;
    size_t count;
    size_t cap;
} LocalIndex;

typedef struct {
    json_t *queue; // array of json objects (copies)
    size_t total_bytes;
} DownloadQueue;

static IdIndex idIndex = {NULL,0,0};
static LocalIndex localIndex = {NULL,0,0};
static pthread_mutex_t idIndexLock = PTHREAD_MUTEX_INITIALIZER;
static pthread_mutex_t tokenLock = PTHREAD_MUTEX_INITIALIZER;
static char access_token[4096] = {0};
static char sync_path[PATH_MAX];

static void *xmalloc(size_t s) {
    void *p = malloc(s);
    if (!p) { perror("malloc"); exit(1); }
    return p;
}

static size_t write_callback(void *contents, size_t size, size_t nmemb, void *userp) {
    size_t realsize = size * nmemb;
    MemoryStruct *mem = (MemoryStruct*)userp;
    mem->memory = realloc(mem->memory, mem->size + realsize + 1);
    if (!mem->memory) return 0;
    memcpy(&(mem->memory[mem->size]), contents, realsize);
    mem->size += realsize;
    mem->memory[mem->size] = 0;
    return realsize;
}

static int ensure_dir_for_file(const char *path) {
    char *dup = strdup(path);
    char *dir = dirname(dup);
    struct stat st;
    if (stat(dir, &st) == 0) {
        free(dup);
        return 0;
    }
    // recursively create
    char tmp[PATH_MAX];
    char *p;
    snprintf(tmp, sizeof(tmp), "%s", dir);
    for (p = tmp + 1; *p; p++) {
        if (*p == '/') {
            *p = 0;
            mkdir(tmp, 0755);
            *p = '/';
        }
    }
    mkdir(tmp, 0755);
    free(dup);
    return 0;
}

static int load_token_from_file(const char *path, char *out, size_t outlen) {
    FILE *f = fopen(path, "r");
    if (!f) return -1;
    if (!fgets(out, outlen, f)) { fclose(f); return -1; }
    // strip newline
    size_t L = strlen(out);
    if (L && (out[L-1] == '\n' || out[L-1] == '\r')) out[L-1] = 0;
    fclose(f);
    return 0;
}

static void idindex_add(const char *id, json_t *meta) {
    pthread_mutex_lock(&idIndexLock);
    if (idIndex.count == idIndex.cap) {
        size_t ncap = idIndex.cap ? idIndex.cap * 2 : 256;
        idIndex.items = realloc(idIndex.items, ncap * sizeof(IdMeta));
        idIndex.cap = ncap;
    }
    idIndex.items[idIndex.count].id = strdup(id);
    idIndex.items[idIndex.count].meta = meta;
    idIndex.count++;
    pthread_mutex_unlock(&idIndexLock);
}

static json_t *idindex_find(const char *id) {
    json_t *res = NULL;
    pthread_mutex_lock(&idIndexLock);
    for (size_t i=0;i<idIndex.count;i++) {
        if (strcmp(idIndex.items[i].id, id) == 0) { res = idIndex.items[i].meta; break; }
    }
    pthread_mutex_unlock(&idIndexLock);
    return res;
}

static void free_idindex() {
    pthread_mutex_lock(&idIndexLock);
    for (size_t i=0;i<idIndex.count;i++) free(idIndex.items[i].id);
    free(idIndex.items);
    idIndex.items = NULL;
    idIndex.count = idIndex.cap = 0;
    pthread_mutex_unlock(&idIndexLock);
}

static void localindex_add(const char *rel, int is_dir, off_t size, time_t mtime) {
    if (localIndex.count == localIndex.cap) {
        size_t ncap = localIndex.cap ? localIndex.cap * 2 : 256;
        localIndex.items = realloc(localIndex.items, ncap * sizeof(LocalEntry));
        localIndex.cap = ncap;
    }
    localIndex.items[localIndex.count].relpath = strdup(rel);
    localIndex.items[localIndex.count].is_dir = is_dir;
    localIndex.items[localIndex.count].size = size;
    localIndex.items[localIndex.count].mtime = mtime;
    localIndex.count++;
}

static void free_localindex() {
    for (size_t i=0;i<localIndex.count;i++) free(localIndex.items[i].relpath);
    free(localIndex.items);
    localIndex.items = NULL;
    localIndex.count = localIndex.cap = 0;
}

static void scan_local_state() {
    printf("[status] Scanning local state: %s\n", sync_path);
    free_localindex();
    // simple stack-based DFS
    char base[PATH_MAX];
    snprintf(base, sizeof(base), "%s", sync_path);
    // recursive function
    struct stack_item { char path[PATH_MAX]; };
    struct stack_item *stack = NULL;
    size_t sc = 0, sc_cap = 0;
    // push base
    if (sc == sc_cap) { sc_cap = sc_cap ? sc_cap*2 : 64; stack = realloc(stack, sc_cap * sizeof(*stack)); }
    strncpy(stack[sc++].path, base, PATH_MAX);
    while (sc) {
        struct stack_item it = stack[--sc];
        DIR *d = opendir(it.path);
        if (!d) continue;
        struct dirent *ent;
        while ((ent = readdir(d)) != NULL) {
            if (strcmp(ent->d_name, ".") == 0 || strcmp(ent->d_name, "..") == 0) continue;
            char full[PATH_MAX];
            snprintf(full, sizeof(full), "%s/%s", it.path, ent->d_name);
            struct stat st;
            if (lstat(full, &st) != 0) continue;
            char rel[PATH_MAX];
            if (strncmp(full, sync_path, strlen(sync_path)) == 0) {
                const char *p = full + strlen(sync_path) + 1;
                if (*p == 0) strcpy(rel, ".");
                else strncpy(rel, p, PATH_MAX);
            } else {
                strncpy(rel, ent->d_name, PATH_MAX);
            }
            if (S_ISDIR(st.st_mode)) {
                localindex_add(rel, 1, 0, st.st_mtime);
                // push
                if (sc == sc_cap) { sc_cap *= 2; stack = realloc(stack, sc_cap * sizeof(*stack)); }
                strncpy(stack[sc++].path, full, PATH_MAX);
            } else if (S_ISREG(st.st_mode)) {
                localindex_add(rel, 0, st.st_size, st.st_mtime);
            }
        }
        closedir(d);
    }
    free(stack);
    printf("[status] Local scan complete (%zu entries)\n", localIndex.count);
}

static char *build_full_path_for_id(const char *id) {
    if (!id || !*id) return NULL;
    // iterative parent walk, detect cycles
    size_t parts_cap = 16;
    char **parts = malloc(parts_cap * sizeof(char*));
    size_t parts_count = 0;
    // visited set: simple array
    char **visited = NULL; size_t vcount=0, vcap=0;
    char curid[256]; strncpy(curid, id, sizeof(curid));
    while (curid[0]) {
        // cycle check
        int cyc = 0;
        for (size_t i=0;i<vcount;i++) if (strcmp(visited[i], curid) == 0) { cyc = 1; break; }
        if (cyc) { fprintf(stderr, "[warn] cycle in parents for id %s\n", curid); break; }
        if (vcount == vcap) { vcap = vcap? vcap*2:64; visited = realloc(visited, vcap * sizeof(char*)); }
        visited[vcount++] = strdup(curid);
        json_t *meta = idindex_find(curid);
        if (!meta) break;
        json_t *jname = json_object_get(meta, "name");
        if (jname && json_is_string(jname)) {
            const char *nm = json_string_value(jname);
            if (parts_count == parts_cap) { parts_cap *= 2; parts = realloc(parts, parts_cap * sizeof(char*)); }
            parts[parts_count++] = strdup(nm);
        }
        json_t *parents = json_object_get(meta, "parents");
        if (!parents || !json_is_array(parents) || json_array_size(parents) == 0) break;
        json_t *p0 = json_array_get(parents, 0);
        if (!p0 || !json_is_string(p0)) break;
        const char *next = json_string_value(p0);
        if (!next || !*next) break;
        strncpy(curid, next, sizeof(curid));
    }
    // join parts with '/'
    if (parts_count == 0) { // fallback to id
        char *res = strdup(id);
        for (size_t i=0;i<vcount;i++) free(visited[i]);
        free(visited);
        return res;
    }
    size_t len = 0;
    for (size_t i=0;i<parts_count;i++) len += strlen(parts[i]) + 1;
    char *res = malloc(len + 1);
    res[0] = 0;
    for (size_t i=0;i<parts_count;i++) {
        if (i) strcat(res, "/");
        strcat(res, parts[parts_count - 1 - i]);
    }
    for (size_t i=0;i<parts_count;i++) free(parts[i]);
    free(parts);
    for (size_t i=0;i<vcount;i++) free(visited[i]);
    free(visited);
    return res;
}

static size_t file_write_cb(void *ptr, size_t size, size_t nmemb, void *stream) {
    FILE *f = (FILE*)stream;
    return fwrite(ptr, size, nmemb, f);
}

static int download_file_with_curl(const char *id, const char *outpath) {
    CURL *curl = curl_easy_init();
    if (!curl) return -1;
    char url[512];
    snprintf(url, sizeof(url), "%s/%s?alt=media", DRIVE_FILES_URL, id);
    FILE *f = fopen(outpath, "wb");
    if (!f) { curl_easy_cleanup(curl); return -1; }
    struct curl_slist *headers = NULL;
    char auth[8192];
    pthread_mutex_lock(&tokenLock);
    snprintf(auth, sizeof(auth), "Authorization: Bearer %s", access_token);
    pthread_mutex_unlock(&tokenLock);
    headers = curl_slist_append(headers, auth);
    curl_easy_setopt(curl, CURLOPT_URL, url);
    curl_easy_setopt(curl, CURLOPT_HTTPHEADER, headers);
    curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, file_write_cb);
    curl_easy_setopt(curl, CURLOPT_WRITEDATA, f);
    curl_easy_setopt(curl, CURLOPT_USERAGENT, "DriveSync-C");
    CURLcode res = curl_easy_perform(curl);
    fclose(f);
    curl_slist_free_all(headers);
    curl_easy_cleanup(curl);
    if (res != CURLE_OK) {
        fprintf(stderr, "[error] curl failed: %s\n", curl_easy_strerror(res));
        return -1;
    }
    return 0;
}

static void *metadata_fetcher_thread(void *arg) {
    (void)arg;
    CURL *curl = curl_easy_init();
    if (!curl) return NULL;
    char pageToken[512] = {0};
    int page = 0;
    while (1) {
        MemoryStruct chunk = {0};
        char url[1024];
        if (pageToken[0]) {
            snprintf(url, sizeof(url), "%s?pageSize=%s&fields=nextPageToken,files(id,name,mimeType,parents,size,modifiedTime,md5Checksum)&pageToken=%s",
                     DRIVE_FILES_URL, PAGE_SIZE, pageToken);
        } else {
            snprintf(url, sizeof(url), "%s?pageSize=%s&fields=nextPageToken,files(id,name,mimeType,parents,size,modifiedTime,md5Checksum)",
                     DRIVE_FILES_URL, PAGE_SIZE);
        }
        struct curl_slist *headers = NULL;
        char auth[8192];
        pthread_mutex_lock(&tokenLock);
        snprintf(auth, sizeof(auth), "Authorization: Bearer %s", access_token);
        pthread_mutex_unlock(&tokenLock);
        headers = curl_slist_append(headers, auth);
        curl_easy_setopt(curl, CURLOPT_URL, url);
        curl_easy_setopt(curl, CURLOPT_HTTPHEADER, headers);
        curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, write_callback);
        curl_easy_setopt(curl, CURLOPT_WRITEDATA, (void*)&chunk);
        curl_easy_setopt(curl, CURLOPT_USERAGENT, "DriveSync-C");
        CURLcode res = curl_easy_perform(curl);
        curl_slist_free_all(headers);
        if (res != CURLE_OK) {
            fprintf(stderr, "[error] metadata fetch failed: %s\n", curl_easy_strerror(res));
            free(chunk.memory);
            break;
        }
        if (!chunk.memory) break;
        json_error_t jerr;
        json_t *root = json_loads(chunk.memory, 0, &jerr);
        free(chunk.memory);
        if (!root || !json_is_object(root)) {
            fprintf(stderr, "[error] invalid JSON from metadata\n");
            if (root) json_decref(root);
            break;
        }
        json_t *files = json_object_get(root, "files");
        if (files && json_is_array(files)) {
            size_t n = json_array_size(files);
            for (size_t i=0;i<n;i++) {
                json_t *f = json_array_get(files, i);
                if (!json_is_object(f)) continue;
                json_t *jid = json_object_get(f, "id");
                if (!jid || !json_is_string(jid)) continue;
                const char *id = json_string_value(jid);
                // store a *reference* to the object by increasing refcount
                json_incref(f);
                idindex_add(id, f);
            }
        }
        json_t *npt = json_object_get(root, "nextPageToken");
        if (npt && json_is_string(npt) && strlen(json_string_value(npt))>0) {
            strncpy(pageToken, json_string_value(npt), sizeof(pageToken)-1);
            json_decref(root);
            page++;
            continue;
        } else {
            json_decref(root);
            break;
        }
    }
    curl_easy_cleanup(curl);
    printf("[status] Metadata fetch complete (%zu objects)\n", idIndex.count);
    return NULL;
}

static void reconcile_and_sync() {
    printf("[status] Reconciling local and remote\n");
    // Build remotePathIndex: compositeKey = fullpath::id
    // For simplicity, we will iterate idIndex and build a map of path->list of metas
    typedef struct RItem { char *path; json_t *meta; struct RItem *next; } RItem;
    RItem *rmap = NULL;
    for (size_t i=0;i<idIndex.count;i++) {
        const char *id = idIndex.items[i].id;
        json_t *meta = idIndex.items[i].meta;
        char *full = build_full_path_for_id(id);
        if (!full) {
            json_t *jname = json_object_get(meta, "name");
            if (jname && json_is_string(jname)) full = strdup(json_string_value(jname));
            else full = strdup(id);
        }
        // insert into rmap
        RItem *it = malloc(sizeof(RItem));
        it->path = full;
        it->meta = meta;
        it->next = rmap;
        rmap = it;
    }
    // Build set of all paths (from local and remote)
    // For simplicity, we will iterate remote map and localIndex and decide downloads
    DownloadQueue dq = { json_array(), 0 };
    // remote-only or remote newer -> queue download
    for (RItem *it = rmap; it; it = it->next) {
        const char *path = it->path;
        // find local entry
        int found_local = 0;
        LocalEntry *lentry = NULL;
        for (size_t j=0;j<localIndex.count;j++) {
            if (strcmp(localIndex.items[j].relpath, path) == 0) { found_local = 1; lentry = &localIndex.items[j]; break; }
        }
        json_t *meta = it->meta;
        const char *mime = NULL;
        json_t *jmime = json_object_get(meta, "mimeType");
        if (jmime && json_is_string(jmime)) mime = json_string_value(jmime);
        if (mime && strcmp(mime, "application/vnd.google-apps.folder") == 0) {
            // ensure local folder exists
            char localdir[PATH_MAX];
            snprintf(localdir, sizeof(localdir), "%s/%s", sync_path, path);
            struct stat st;
            if (stat(localdir, &st) != 0) {
                printf("[status] Creating local folder: %s\n", localdir);
                mkdir(localdir, 0755);
            }
            continue;
        }
        if (!found_local) {
            // queue download
            json_t *copy = json_deep_copy(meta);
            json_array_append(dq.queue, copy);
            json_t *jsize = json_object_get(copy, "size");
            if (jsize && json_is_string(jsize)) dq.total_bytes += atoll(json_string_value(jsize));
            else if (jsize && json_is_integer(jsize)) dq.total_bytes += (long)json_integer_value(jsize);
            printf("[status] Queueing download: %s\n", path);
        } else {
            // compare mtimes if available
            json_t *rmtime_j = json_object_get(meta, "modifiedTime");
            time_t rmtime = 0;
            if (rmtime_j && json_is_string(rmtime_j)) {
                struct tm tm; memset(&tm,0,sizeof(tm));
                strptime(json_string_value(rmtime_j), "%Y-%m-%dT%H:%M:%S", &tm);
                rmtime = mktime(&tm);
            }
            if (lentry && !lentry->is_dir && rmtime > (lentry->mtime + 2)) {
                json_t *copy = json_deep_copy(meta);
                json_array_append(dq.queue, copy);
                json_t *jsize = json_object_get(copy, "size");
                if (jsize && json_is_string(jsize)) dq.total_bytes += atoll(json_string_value(jsize));
                else if (jsize && json_is_integer(jsize)) dq.total_bytes += (long)json_integer_value(jsize);
                printf("[status] Remote newer, queueing download: %s\n", path);
            }
        }
    }
    // perform downloads serially
    size_t qn = json_array_size(dq.queue);
    if (qn == 0) {
        printf("[status] No downloads required\n");
    } else {
        printf("[status] Starting downloads (%zu files, ~%zu bytes)\n", qn, dq.total_bytes);
        for (size_t i=0;i<qn;i++) {
            json_t *meta = json_array_get(dq.queue, i);
            const char *id = json_string_value(json_object_get(meta, "id"));
            const char *name = json_string_value(json_object_get(meta, "name"));
            char *fullpath = build_full_path_for_id(id);
            if (!fullpath) {
                // fallback to name
                fullpath = strdup(name ? name : id);
            }
            char outtmp[PATH_MAX];
            char outfinal[PATH_MAX];
            snprintf(outtmp, sizeof(outtmp), "%s/%s.part", sync_path, fullpath);
            snprintf(outfinal, sizeof(outfinal), "%s/%s", sync_path, fullpath);
            ensure_dir_for_file(outtmp);
            printf("[status] Downloading %s -> %s\n", fullpath, outfinal);
            int rc = download_file_with_curl(id, outtmp);
            if (rc == 0) {
                // rename
                rename(outtmp, outfinal);
                printf("[status] Downloaded: %s\n", outfinal);
            } else {
                fprintf(stderr, "[error] Failed to download id=%s\n", id);
                unlink(outtmp);
            }
            free(fullpath);
        }
    }
    // cleanup
    size_t rcount = 0;
    for (RItem *it = rmap; it; ) {
        RItem *n = it->next;
        free(it->path);
        free(it);
        it = n;
        rcount++;
    }
    json_decref(dq.queue);
    printf("[status] Reconcile complete\n");
}

int main(int argc, char **argv) {
    // determine user home
    const char *user = getenv("USER");
    if (!user) user = "user";
    snprintf(sync_path, sizeof(sync_path), SYNC_DIR_DEFAULT, user);
    char token_file[PATH_MAX];
    snprintf(token_file, sizeof(token_file), TOKEN_FILE_DEFAULT, user);
    // ensure config dir exists
    char cfgdir[PATH_MAX];
    snprintf(cfgdir, sizeof(cfgdir), "/home/%s/.config/DriveSync", user);
    mkdir(cfgdir, 0755);
    // load token
    if (load_token_from_file(token_file, access_token, sizeof(access_token)) != 0) {
        fprintf(stderr, "No access token found in %s\n", token_file);
        fprintf(stderr, "Please place a valid OAuth2 access token in that file.\n");
        return 1;
    }
    printf("[status] Using token length %zu\n", strlen(access_token));
    // ensure sync dir exists
    struct stat st;
    if (stat(sync_path, &st) != 0) mkdir(sync_path, 0755);
    // init curl
    curl_global_init(CURL_GLOBAL_DEFAULT);
    // start metadata fetcher thread
    pthread_t meta_thread;
    if (pthread_create(&meta_thread, NULL, metadata_fetcher_thread, NULL) != 0) {
        perror("pthread_create");
        return 1;
    }
    pthread_join(meta_thread, NULL);
    // scan local
    scan_local_state();
    // reconcile and sync
    reconcile_and_sync();
    // cleanup
    free_idindex();
    free_localindex();
    curl_global_cleanup();
    printf("[status] Done\n");
    return 0;
}
