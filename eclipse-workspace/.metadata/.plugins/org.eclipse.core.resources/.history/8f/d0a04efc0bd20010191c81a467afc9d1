### Fix applied — robust PE/EFI loader in `jitemu.c`

I updated `jitemu.c` so the loader no longer fails on malformed or nonstandard Optional Header values (like `magic = 0x0200`) and on wildly incorrect `NumberOfSections`. The new loader:

- **Validates** `SizeOfOptionalHeader` and `NumberOfSections` and caps them when they look corrupted.
- **Detects** an unknown OptionalHeader magic and **falls back** to a heuristic section-table discovery:
  - Scans a reasonable window after the PE header for plausible section headers (checks `PointerToRawData` and `SizeOfRawData` against file size).
  - Picks `.text` or the first executable section as the entry candidate if the OptionalHeader doesn't provide a valid entry.
- **Prints detailed diagnostics** at every step (values, offsets, why a fallback was used).
- Keeps the existing `SystemTable` / `ConOut->OutputString` wiring and trampoline logic.
- Still warns about the security risk of executing arbitrary `.efi` images.

Save this file as `jitemu.c`, rebuild, and run it on your `bootx64.efi`. The loader will print detailed messages explaining what it did and why.

```c
/*
 jitemu.c
 Robust EFI loader with verbose diagnostics and fallback for nonstandard PE headers.
 - Handles malformed OptionalHeader magic (e.g., 0x0200) by scanning for section table heuristically.
 - Caps suspicious NumberOfSections and SizeOfOptionalHeader values.
 - Builds minimal SystemTable/ConOut and calls entry via trampoline.
 WARNING: executes loaded .efi in-process. Run only trusted images.
*/

#define _GNU_SOURCE
#include <stdio.h>
#include <stdlib.h>
#include <stdint.h>
#include <string.h>
#include <unistd.h>
#include <sys/mman.h>
#include <inttypes.h>
#include <errno.h>

#pragma pack(push,1)
typedef struct {
    uint16_t e_magic;    /* "MZ" */
    uint16_t e_cblp;
    uint16_t e_cp;
    uint16_t e_crlc;
    uint16_t e_cparhdr;
    uint16_t e_minalloc;
    uint16_t e_maxalloc;
    uint16_t e_ss;
    uint16_t e_sp;
    uint16_t e_csum;
    uint16_t e_ip;
    uint16_t e_cs;
    uint16_t e_lfarlc;
    uint16_t e_ovno;
    uint16_t e_res[4];
    uint16_t e_oemid;
    uint16_t e_oeminfo;
    uint16_t e_res2[10];
    uint32_t e_lfanew;   /* offset to PE header */
} IMAGE_DOS_HEADER;

typedef struct {
    uint32_t Signature; /* "PE\0\0" */
    uint16_t Machine;
    uint16_t NumberOfSections;
    uint32_t TimeDateStamp;
    uint32_t PointerToSymbolTable;
    uint32_t NumberOfSymbols;
    uint16_t SizeOfOptionalHeader;
    uint16_t Characteristics;
} IMAGE_FILE_HEADER;

typedef struct {
    uint16_t Magic; /* 0x10b or 0x20b */
    uint8_t  MajorLinkerVersion;
    uint8_t  MinorLinkerVersion;
    uint32_t SizeOfCode;
    uint32_t SizeOfInitializedData;
    uint32_t SizeOfUninitializedData;
    uint32_t AddressOfEntryPoint;
    uint32_t BaseOfCode;
    /* rest omitted */
} IMAGE_OPTIONAL_HEADER32;

typedef struct {
    uint8_t  Name[8];
    union {
        uint32_t PhysicalAddress;
        uint32_t VirtualSize;
    } Misc;
    uint32_t VirtualAddress;
    uint32_t SizeOfRawData;
    uint32_t PointerToRawData;
    uint32_t PointerToRelocations;
    uint32_t PointerToLinenumbers;
    uint16_t NumberOfRelocations;
    uint16_t NumberOfLinenumbers;
    uint32_t Characteristics;
} IMAGE_SECTION_HEADER;
#pragma pack(pop)

/* ---------- helpers ---------- */

static uint8_t* read_file(const char* path, size_t* out_size) {
    if (!path || !out_size) return NULL;
    FILE* f = fopen(path, "rb");
    if (!f) {
        fprintf(stderr, "[error] fopen('%s') failed: %s\n", path, strerror(errno));
        return NULL;
    }
    if (fseek(f, 0, SEEK_END) != 0) {
        fprintf(stderr, "[error] fseek end failed: %s\n", strerror(errno));
        fclose(f); return NULL;
    }
    long sz = ftell(f);
    if (sz < 0) {
        fprintf(stderr, "[error] ftell failed: %s\n", strerror(errno));
        fclose(f); return NULL;
    }
    rewind(f);
    uint8_t* buf = malloc((size_t)sz);
    if (!buf) { fprintf(stderr, "[error] malloc(%ld) failed\n", sz); fclose(f); return NULL; }
    size_t got = fread(buf, 1, (size_t)sz, f);
    if (got != (size_t)sz) {
        fprintf(stderr, "[error] fread expected %ld bytes, got %zu\n", sz, got);
        free(buf); fclose(f); return NULL;
    }
    fclose(f);
    *out_size = (size_t)sz;
    fprintf(stderr, "[info] read '%s' size=%zu bytes\n", path, *out_size);
    return buf;
}

static void* alloc_executable(size_t size) {
    long ps = sysconf(_SC_PAGE_SIZE);
    if (ps <= 0) ps = 4096;
    size_t page = (size_t)ps;
    size = (size + page - 1) & ~(page - 1);
    void* p = mmap(NULL, size, PROT_READ | PROT_WRITE | PROT_EXEC, MAP_PRIVATE | MAP_ANONYMOUS, -1, 0);
    if (p == MAP_FAILED) {
        fprintf(stderr, "[error] mmap exec size=%zu failed: %s\n", size, strerror(errno));
        return NULL;
    }
    return p;
}
static void free_executable(void* p, size_t size) {
    if (!p || p == MAP_FAILED) return;
    long ps = sysconf(_SC_PAGE_SIZE);
    if (ps <= 0) ps = 4096;
    size_t page = (size_t)ps;
    size = (size + page - 1) & ~(page - 1);
    munmap(p, size);
}

/* Heuristic: validate and cap suspicious header values */
static uint16_t cap_num_sections(uint16_t nsec, size_t file_size) {
    if (nsec == 0) return 0;
    if (nsec > 1024) {
        fprintf(stderr, "[warn] NumberOfSections suspiciously large (%u), capping to 256\n", nsec);
        return 256;
    }
    /* also ensure it is not larger than file_size/sizeof(section) */
    size_t max_possible = file_size / sizeof(IMAGE_SECTION_HEADER);
    if (nsec > max_possible) {
        uint16_t cap = (uint16_t)(max_possible > 0 ? max_possible : 0);
        fprintf(stderr, "[warn] NumberOfSections (%u) > file/section_size (%zu), capping to %u\n", nsec, max_possible, cap);
        return cap;
    }
    return nsec;
}

/* Try to discover a plausible section table when OptionalHeader is unknown or corrupted.
   We scan a limited window after the IMAGE_FILE_HEADER for entries that look like section headers:
   - Name: 8 bytes (printable ASCII or dot)
   - PointerToRawData + SizeOfRawData <= file_size
   - VirtualAddress reasonable (< 0x1000000)
   We return a dynamically allocated array of IMAGE_SECTION_HEADER (caller must free) and set out_count.
*/
static IMAGE_SECTION_HEADER* discover_section_table(uint8_t* base, size_t base_off, size_t file_size, int* out_count) {
    const size_t scan_limit = 0x400; /* scan up to 1KB after file header */
    size_t start = base_off;
    size_t end = base_off + (scan_limit > file_size - base_off ? file_size - base_off : scan_limit);
    int max_sections = 256;
    IMAGE_SECTION_HEADER* found = calloc(max_sections, sizeof(IMAGE_SECTION_HEADER));
    if (!found) return NULL;
    int found_count = 0;

    for (size_t off = start; off + sizeof(IMAGE_SECTION_HEADER) <= end; off += 1) {
        IMAGE_SECTION_HEADER* cand = (IMAGE_SECTION_HEADER*)(base + off);
        /* quick sanity checks */
        uint32_t ptr = cand->PointerToRawData;
        uint32_t rawsz = cand->SizeOfRawData;
        uint32_t vaddr = cand->VirtualAddress;
        uint32_t vsize = cand->Misc.VirtualSize;

        /* Pointer and size must be within file */
        if ((size_t)ptr + rawsz > file_size) continue;
        /* Virtual address should be reasonable (not huge) */
        if (vaddr > 0x10000000u) continue;
        /* Name should be printable ASCII or dot/underscore */
        int printable = 1;
        for (int i = 0; i < 8; ++i) {
            unsigned char c = cand->Name[i];
            if (c == 0) break;
            if ((c < 0x20 || c > 0x7E) && c != '.' && c != '_' && c != '$') { printable = 0; break; }
        }
        if (!printable) continue;

        /* Looks plausible; copy it */
        if (found_count < max_sections) {
            memcpy(&found[found_count], cand, sizeof(IMAGE_SECTION_HEADER));
            found_count++;
        } else break;
    }

    if (found_count == 0) {
        free(found);
        *out_count = 0;
        return NULL;
    }
    *out_count = found_count;
    fprintf(stderr, "[info] discovered %d plausible section headers by heuristic scan\n", found_count);
    return found;
}

/* ---------- robust PE loader with fallback ---------- */

static void* load_pe_to_executable_verbose(const char* path,
                                          void (**entry_ptr)(void),
                                          size_t* out_alloc_size,
                                          uint64_t* out_entry_rva)
{
    size_t fsz = 0;
    uint8_t* file = read_file(path, &fsz);
    if (!file) {
        fprintf(stderr, "[fail] cannot open or read file '%s'\n", path);
        return NULL;
    }

    if (fsz < sizeof(IMAGE_DOS_HEADER)) {
        fprintf(stderr, "[fail] file too small for IMAGE_DOS_HEADER: size=%zu, need=%zu\n", fsz, sizeof(IMAGE_DOS_HEADER));
        free(file); return NULL;
    }

    IMAGE_DOS_HEADER* dos = (IMAGE_DOS_HEADER*)file;
    fprintf(stderr, "[info] DOS header e_magic=0x%04x e_lfanew=0x%08x\n", dos->e_magic, dos->e_lfanew);

    if (dos->e_magic != 0x5A4D) {
        fprintf(stderr, "[fail] invalid DOS signature: 0x%04x (expected 0x5A4D 'MZ')\n", dos->e_magic);
        free(file); return NULL;
    }

    if ((size_t)dos->e_lfanew + 4 + sizeof(IMAGE_FILE_HEADER) > fsz) {
        fprintf(stderr, "[fail] e_lfanew (0x%08x) points beyond file size %zu\n", dos->e_lfanew, fsz);
        free(file); return NULL;
    }

    uint8_t* pe_ptr = file + dos->e_lfanew;
    uint32_t pe_sig = *(uint32_t*)pe_ptr;
    fprintf(stderr, "[info] PE signature at offset 0x%08x = 0x%08x\n", dos->e_lfanew, pe_sig);

    if (pe_sig != 0x00004550) {
        fprintf(stderr, "[fail] invalid PE signature: 0x%08x (expected 0x00004550 'PE\\0\\0')\n", pe_sig);
        free(file); return NULL;
    }

    IMAGE_FILE_HEADER* fh = (IMAGE_FILE_HEADER*)(pe_ptr + 4);
    fprintf(stderr, "[info] IMAGE_FILE_HEADER: Machine=0x%04x NumberOfSections=%u SizeOfOptionalHeader=%u Characteristics=0x%04x\n",
            fh->Machine, fh->NumberOfSections, fh->SizeOfOptionalHeader, fh->Characteristics);

    uint16_t nsec_raw = fh->NumberOfSections;
    uint16_t nsec = cap_num_sections(nsec_raw, fsz);
    uint16_t opt_size_raw = fh->SizeOfOptionalHeader;
    size_t opt_size = (size_t)opt_size_raw;

    uint8_t* opt_hdr = pe_ptr + 4 + sizeof(IMAGE_FILE_HEADER);
    if ((size_t)(opt_hdr - file) + opt_size > fsz) {
        fprintf(stderr, "[warn] optional header size (%u) seems to exceed file bounds; capping to available bytes\n", opt_size_raw);
        opt_size = (size_t)(fsz - (size_t)(opt_hdr - file));
    }

    if (opt_size == 0) {
        fprintf(stderr, "[warn] optional header size is zero; will attempt section discovery\n");
    }

    uint16_t magic = 0;
    if (opt_size >= 2) magic = *(uint16_t*)opt_hdr;
    fprintf(stderr, "[info] OptionalHeader magic=0x%04x (opt_size=%zu)\n", magic, opt_size);

    uint64_t entry_rva = 0;
    int recognized_optional = 0;
    if (magic == 0x10b || magic == 0x20b) {
        recognized_optional = 1;
        if ((size_t)opt_size >= 20) {
            entry_rva = *(uint32_t*)(opt_hdr + 16); /* AddressOfEntryPoint */
            fprintf(stderr, "[info] AddressOfEntryPoint (RVA) = 0x%08" PRIx64 "\n", entry_rva);
        } else {
            fprintf(stderr, "[warn] optional header too small to contain AddressOfEntryPoint\n");
            recognized_optional = 0;
        }
    } else {
        fprintf(stderr, "[warn] unknown OptionalHeader magic: 0x%04x (not PE32/PE32+). Will attempt section-table fallback\n", magic);
        /* dump a small hex sample for debugging */
        size_t dump_n = opt_size < 64 ? opt_size : 64;
        fprintf(stderr, "[debug] optional header first %zu bytes:\n", dump_n);
        for (size_t i = 0; i < dump_n; ++i) {
            if ((i & 15) == 0) fprintf(stderr, "  %04zx: ", i);
            fprintf(stderr, "%02x ", opt_hdr[i]);
            if ((i & 15) == 15) fprintf(stderr, "\n");
        }
        if (dump_n & 15) fprintf(stderr, "\n");
    }

    uint8_t* sec_table = opt_hdr + opt_size;
    /* If nsec was capped earlier, use that; but if opt_size was weird, we may need to discover */
    int used_discovered = 0;
    IMAGE_SECTION_HEADER* sections = NULL;
    int sections_count = 0;

    if ((size_t)(sec_table - file) + (size_t)nsec * sizeof(IMAGE_SECTION_HEADER) <= fsz && nsec > 0) {
        /* Looks plausible: read sections directly */
        sections_count = nsec;
        sections = malloc(sizeof(IMAGE_SECTION_HEADER) * sections_count);
        if (!sections) { fprintf(stderr, "[fail] malloc sections failed\n"); free(file); return NULL; }
        memcpy(sections, sec_table, sizeof(IMAGE_SECTION_HEADER) * sections_count);
        fprintf(stderr, "[info] read %d section headers from file (using SizeOfOptionalHeader=%zu)\n", sections_count, opt_size);
    } else {
        /* Fallback: try to discover plausible section headers by scanning */
        int discovered = 0;
        sections = discover_section_table(file, (size_t)(pe_ptr + 4 + sizeof(IMAGE_FILE_HEADER) - file), fsz, &discovered);
        if (sections && discovered > 0) {
            sections_count = discovered;
            used_discovered = 1;
            fprintf(stderr, "[info] using %d discovered section headers\n", sections_count);
        } else {
            /* As last resort, treat whole file as single blob at exec+0 */
            fprintf(stderr, "[warn] could not read or discover section headers; will map entire file and set entry RVA=0\n");
            sections_count = 0;
        }
    }

    /* Inspect sections and choose candidate entry if optional header not recognized */
    uint64_t max_va = 0;
    uint64_t candidate_entry = 0;
    int found_text = 0;
    const uint32_t IMAGE_SCN_MEM_EXECUTE = 0x20000000u;

    if (sections_count > 0) {
        for (int i = 0; i < sections_count; ++i) {
            IMAGE_SECTION_HEADER* sh = &sections[i];
            char name[9]; memcpy(name, sh->Name, 8); name[8] = 0;
            fprintf(stderr, "  [%02d] Name='%.8s' VirtualAddress=0x%08x VirtualSize=0x%08x SizeOfRawData=0x%08x PointerToRawData=0x%08x Characteristics=0x%08x\n",
                    i, name, sh->VirtualAddress, sh->Misc.VirtualSize, sh->SizeOfRawData, sh->PointerToRawData, sh->Characteristics);
            uint64_t va_end = (uint64_t)sh->VirtualAddress + (uint64_t)sh->Misc.VirtualSize;
            if (va_end > max_va) max_va = va_end;

            /* Heuristics for entry */
            if (!recognized_optional) {
                if (!found_text && strcmp(name, ".text") == 0) {
                    candidate_entry = sh->VirtualAddress;
                    found_text = 1;
                    fprintf(stderr, "[info] found .text section, candidate entry RVA = 0x%08" PRIx64 "\n", candidate_entry);
                } else if ((sh->Characteristics & IMAGE_SCN_MEM_EXECUTE) && candidate_entry == 0) {
                    candidate_entry = sh->VirtualAddress;
                    fprintf(stderr, "[info] found executable section '%.8s', candidate entry RVA = 0x%08" PRIx64 "\n", name, candidate_entry);
                }
            }
        }
    } else {
        /* No sections: map whole file */
        max_va = fsz;
    }

    if (!recognized_optional) {
        if (candidate_entry != 0) {
            entry_rva = candidate_entry;
            fprintf(stderr, "[info] using candidate entry RVA from section table: 0x%08" PRIx64 "\n", entry_rva);
        } else {
            entry_rva = 0;
            fprintf(stderr, "[warn] no candidate entry found; using entry RVA = 0 (exec+0)\n");
        }
    }

    if (max_va == 0) max_va = fsz;
    size_t alloc_size = (size_t)((max_va + 0xFFF) & ~0xFFFULL);
    if (alloc_size < fsz) alloc_size = ((fsz + 0xFFF) & ~0xFFFULL);
    if (alloc_size < 0x1000) alloc_size = 0x1000;
    fprintf(stderr, "[info] allocating exec buffer size=%zu (max_va=0x%zx file_size=%zu)\n", alloc_size, (size_t)max_va, fsz);

    void* exec = alloc_executable(alloc_size);
    if (!exec) {
        fprintf(stderr, "[fail] alloc_executable(%zu) failed\n", alloc_size);
        free(sections); free(file); return NULL;
    }
    memset(exec, 0, alloc_size);

    /* Copy sections if present; otherwise copy whole file at exec+0 */
    if (sections_count > 0) {
        for (int i = 0; i < sections_count; ++i) {
            IMAGE_SECTION_HEADER* sh = &sections[i];
            uint32_t vaddr = sh->VirtualAddress;
            uint32_t rawsz = sh->SizeOfRawData;
            uint32_t rawptr = sh->PointerToRawData;
            uint32_t vsize = sh->Misc.VirtualSize;
            char name[9]; memcpy(name, sh->Name, 8); name[8] = 0;

            if ((size_t)rawptr + rawsz > fsz) {
                fprintf(stderr, "[fail] section '%.8s' raw out of file bounds (recheck): rawptr=0x%08x rawsz=0x%08x file_size=%zu\n",
                        name, rawptr, rawsz, fsz);
                free_executable(exec, alloc_size); free(sections); free(file); return NULL;
            }
            if ((size_t)vaddr + rawsz > alloc_size) {
                fprintf(stderr, "[fail] section '%.8s' would overflow exec buffer: vaddr=0x%08x rawsz=0x%08x alloc_size=%zu\n",
                        name, vaddr, rawsz, alloc_size);
                free_executable(exec, alloc_size); free(sections); free(file); return NULL;
            }

            memcpy((uint8_t*)exec + vaddr, file + rawptr, rawsz);
            if (vsize > rawsz) {
                if ((size_t)vaddr + vsize > alloc_size) {
                    fprintf(stderr, "[fail] zero-fill for section '%.8s' would overflow exec buffer: vaddr=0x%08x vsize=0x%08x alloc_size=%zu\n",
                            name, vaddr, vsize, alloc_size);
                    free_executable(exec, alloc_size); free(sections); free(file); return NULL;
                }
                memset((uint8_t*)exec + vaddr + rawsz, 0, vsize - rawsz);
            }
            fprintf(stderr, "[info] copied section '%.8s' -> exec+0x%08x (raw=0x%08x vsize=0x%08x)\n", name, vaddr, rawsz, vsize);
        }
    } else {
        if (fsz > alloc_size) {
            fprintf(stderr, "[fail] file size %zu larger than alloc_size %zu\n", fsz, alloc_size);
            free_executable(exec, alloc_size); free(sections); free(file); return NULL;
        }
        memcpy(exec, file, fsz);
        fprintf(stderr, "[info] no section table present; copied entire file into exec buffer (size=%zu)\n", fsz);
    }

    void* entry = (uint8_t*)exec + (size_t)entry_rva;
    fprintf(stderr, "[info] final entry RVA=0x%08" PRIx64 " -> exec@%p\n", entry_rva, entry);

    *entry_ptr = (void(*)(void*))entry;
    if (out_alloc_size) *out_alloc_size = alloc_size;
    if (out_entry_rva) *out_entry_rva = entry_rva;

    free(sections);
    free(file);
    return exec;
}

/* ---------- minimal ConOut OutputString and helpers ---------- */

static uint64_t host_OutputString(void* This, const uint16_t* str) {
    (void)This;
    if (!str) return 1;
    char buf[2048];
    size_t bi = 0;
    for (const uint16_t* p = str; *p != 0; ++p) {
        uint16_t ch = *p;
        if (ch < 0x80) {
            if (bi + 1 >= sizeof(buf)) break;
            buf[bi++] = (char)ch;
        } else {
            if (bi + 1 >= sizeof(buf)) break;
            buf[bi++] = '?';
        }
    }
    if (bi > 0) {
        fwrite(buf, 1, bi, stdout);
        fflush(stdout);
    }
    return 0; /* EFI_SUCCESS */
}

static void host_service_stub(void) {
    fprintf(stderr, "[host_stub] called by EFI image\n");
    fflush(stderr);
}

/* Build fake SystemTable/BootServices/ConOut with multiple offsets populated */
static int build_fake_system_table(void** out_st, void** out_bs, void** out_conout) {
    if (!out_st || !out_bs || !out_conout) return -1;
    size_t st_size = 0x200;
    size_t bs_size = 0x200;
    size_t conout_size = 0x100;

    uint8_t* st = calloc(1, st_size);
    uint8_t* bs = calloc(1, bs_size);
    uint8_t* conout = calloc(1, conout_size);
    if (!st || !bs || !conout) { free(st); free(bs); free(conout); return -1; }

    uint64_t bs_ptr = (uint64_t)(uintptr_t)bs;
    memcpy(st + 0x30, &bs_ptr, sizeof(bs_ptr)); /* observed offset */

    uint64_t conout_ptr = (uint64_t)(uintptr_t)conout;
    memcpy(st + 0x18, &conout_ptr, sizeof(conout_ptr));
    memcpy(st + 0x20, &conout_ptr, sizeof(conout_ptr));
    memcpy(st + 0x28, &conout_ptr, sizeof(conout_ptr));
    memcpy(st + 0x40, &conout_ptr, sizeof(conout_ptr));
    memcpy(st + 0x48, &conout_ptr, sizeof(conout_ptr));

    uint64_t stub_ptr = (uint64_t)(uintptr_t)host_service_stub;
    memcpy(bs + 0x00, &stub_ptr, sizeof(stub_ptr));

    uint64_t outstr_ptr = (uint64_t)(uintptr_t)host_OutputString;
    memcpy(conout + 0x00, &outstr_ptr, sizeof(outstr_ptr));

    *out_st = st;
    *out_bs = bs;
    *out_conout = conout;
    return 0;
}

/* Build trampoline: set RDI=image_handle, RDX=system_table, RSI=system_table, then call entry */
static void* build_trampoline(void (*entry)(void), void* image_handle, void* system_table) {
    uint8_t* tramp = alloc_executable(4096);
    if (!tramp) return NULL;
    uint8_t* cp = tramp;

    /* mov rdi, imm64 */
    *cp++ = 0x48; *cp++ = 0xBF;
    uint64_t ih = (uint64_t)(uintptr_t)image_handle;
    memcpy(cp, &ih, 8); cp += 8;

    /* mov rdx, imm64 */
    *cp++ = 0x48; *cp++ = 0xBA;
    uint64_t stp = (uint64_t)(uintptr_t)system_table;
    memcpy(cp, &stp, 8); cp += 8;

    /* mov rsi, imm64 */
    *cp++ = 0x48; *cp++ = 0xBE;
    memcpy(cp, &stp, 8); cp += 8;

    /* call rel32 */
    *cp++ = 0xE8;
    int64_t rel = (int64_t)((uint8_t*)entry - (cp + 4));
    int32_t rel32 = (int32_t)rel;
    memcpy(cp, &rel32, 4); cp += 4;

    /* ret */
    *cp++ = 0xC3;

    return tramp;
}

/* ---------- main ---------- */

int main(int argc, char** argv) {
    if (argc != 2) {
        fprintf(stderr, "Usage: %s <bootx64.efi>\n", argv[0]);
        return 1;
    }
    const char* path = argv[1];

    void (*entry_fn)(void) = NULL;
    size_t exec_size = 0;
    uint64_t entry_rva = 0;
    void* exec_buf = load_pe_to_executable_verbose(path, &entry_fn, &exec_size, &entry_rva);
    if (!exec_buf || !entry_fn) {
        fprintf(stderr, "[fatal] Failed to load EFI image '%s'. See messages above for details.\n", path);
        return 2;
    }
    fprintf(stderr, "[ok] loaded image exec@%p size=%zu entry_rva=0x%08" PRIx64 "\n", exec_buf, exec_size, entry_rva);

    void* st_buf = NULL;
    void* bs_buf = NULL;
    void* conout_buf = NULL;
    if (build_fake_system_table(&st_buf, &bs_buf, &conout_buf) != 0) {
        fprintf(stderr, "[fatal] Failed to build fake SystemTable/BootServices/ConOut\n");
        free_executable(exec_buf, exec_size);
        return 3;
    }
    fprintf(stderr, "[info] SystemTable=%p BootServices=%p ConOut=%p\n", st_buf, bs_buf, conout_buf);

    void* image_handle = exec_buf;
    void* tramp = build_trampoline(entry_fn, image_handle, st_buf);
    if (!tramp) {
        fprintf(stderr, "[fatal] Failed to build trampoline\n");
        free(st_buf); free(bs_buf); free(conout_buf);
        free_executable(exec_buf, exec_size);
        return 4;
    }

    fprintf(stderr, "[info] invoking entry via trampoline %p\n", tramp);
    typedef void (*TrampFn)(void);
    TrampFn tf = (TrampFn)tramp;

    tf();

    fprintf(stderr, "[info] returned from EFI image entry\n");

    free_executable(tramp, 4096);
    free(st_buf);
    free(bs_buf);
    free(conout_buf);
    free_executable(exec_buf, exec_size);

    return 0;
}
