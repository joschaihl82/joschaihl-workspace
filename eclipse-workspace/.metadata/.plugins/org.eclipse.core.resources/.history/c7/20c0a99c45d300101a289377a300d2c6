static QString nowString() {
    return QDateTime::currentDateTime().toString(Qt::ISODate);
}

static QString appDataPath() {
    return QStandardPaths::writableLocation(QStandardPaths::AppDataLocation);
}

static void ensureDirExists(const QString &path) {
    QDir d(path);
    if (!d.exists()) d.mkpath(".");
}

// -----------------------------------------------------------------------------
// Logger - logs to file and UI sink
// -----------------------------------------------------------------------------
class Logger : public QObject {
    Q_OBJECT
public:
    explicit Logger(QObject *parent = nullptr) : QObject(parent) {
        ensureDirExists(appDataPath());
        QString logFile = appDataPath() + "/xmpp_voip.log";
        m_file.setFileName(logFile);
        m_file.open(QIODevice::Append | QIODevice::Text);
    }
    ~Logger() override {
        if (m_file.isOpen()) m_file.close();
    }
    void log(const QString &msg) {
        QString line = QString("[%1] %2").arg(nowString(), msg);
        emit newLog(line);
        if (m_file.isOpen()) {
            QTextStream ts(&m_file);
            ts << line << "\n";
            ts.flush();
        }
        qDebug().noquote() << line;
    }
signals:
    void newLog(const QString &line);
private:
    QFile m_file;
};

