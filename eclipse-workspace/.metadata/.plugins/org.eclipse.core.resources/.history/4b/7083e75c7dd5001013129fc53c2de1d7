// --- vi. lexer implementation ---

token *new_token(token_kind kind, token *cur, char *str, int len) {
    token *tok = calloc(1, sizeof(token));
    tok->kind = kind;
    tok->str = str;
    tok->len = len;
    tok->file_pos = str;
    cur->next = tok;
    return tok;
}

int is_ident_char(char c) { return isalnum((unsigned char)c) || c == '_'; }

int consume(char *op) {
    if (current_token->kind != tk_reserved || current_token->len != (int)strlen(op) || strncmp(current_token->str, op, current_token->len) != 0) return 0;
    current_token = current_token->next;
    return 1;
}

int consume_keyword(char *kw) {
    if (current_token->kind != tk_keyword || current_token->len != (int)strlen(kw) || strncmp(current_token->str, kw, current_token->len) != 0) return 0;
    current_token = current_token->next;
    return 1;
}

token *expect_ident() {
    if (current_token->kind != tk_ident) error_tok(current_token, "expected identifier");
    token *t = current_token;
    current_token = current_token->next;
    return t;
}

void expect(char *op) {
    if (!consume(op)) error_tok(current_token, "expected '%s'", op);
}

long expect_number() {
    if (current_token->kind != tk_num) error_tok(current_token, "expected number");
    long val = current_token->val;
    current_token = current_token->next;
    return val;
}

token *peek() { return current_token; }

int is_type_token(token *tok) {
    if (tok->kind == tk_keyword) {
        return strncmp(tok->str, "int", tok->len) == 0 ||
               strncmp(tok->str, "char", tok->len) == 0 ||
               strncmp(tok->str, "long", tok->len) == 0 ||
               strncmp(tok->str, "unsigned", tok->len) == 0 ||
               strncmp(tok->str, "static", tok->len) == 0 ||
               strncmp(tok->str, "extern", tok->len) == 0 ||
               strncmp(tok->str, "struct", tok->len) == 0;
    }
    return 0;
}

token *tokenize(char *p) {
    // [omitted implementation of tokenize for brevity, but assume it exists]
    // should correctly handle multi-character operators, keywords, identifiers, numbers, and string literals.
    token *head = calloc(1, sizeof(token));
    token *cur = head;
    // ... tokenization logic ...

    // minimal stub to allow parsing to continue
    while (*p) {
        if (isspace((unsigned char)*p)) { p++; continue; }
        if (p[0] == '/' && p[1] == '/') { while (*p && *p != '\n') p++; continue; }
        if (p[0] == '/' && p[1] == '*') { char *q = strstr(p + 2, "*/"); if (!q) error_at(p, "unterminated block comment"); p = q + 2; continue; }
        if (*p == '"') {
            char *q = p + 1; while (*q && *q != '"') { if (*q == '\\') q++; q++; }
            if (*q) { cur = new_token(tk_string, cur, p, q - p + 1); p = q + 1; continue; }
        }
        if (strncmp(p, "==", 2) == 0 || strncmp(p, "!=", 2) == 0 || strncmp(p, "<=", 2) == 0 || strncmp(p, ">=", 2) == 0 || strncmp(p, "<<=", 3) == 0 || strncmp(p, ">>=", 3) == 0 || strncmp(p, "+=", 2) == 0 || strncmp(p, "-=", 2) == 0 || strncmp(p, "*=", 2) == 0 || strncmp(p, "/=", 2) == 0 || strncmp(p, "%=", 2) == 0 || strncmp(p, "&=", 2) == 0 || strncmp(p, "|=", 2) == 0 || strncmp(p, "^=", 2) == 0 || strncmp(p, "&&", 2) == 0 || strncmp(p, "||", 2) == 0 || strncmp(p, "->", 2) == 0 || strncmp(p, "<<", 2) == 0 || strncmp(p, ">>", 2) == 0) {
            int len = (p[2] == '=') ? 3 : 2; cur = new_token(tk_reserved, cur, p, len); p += len; continue;
        }
        if (strchr("+-*/%()=;{},&<>!~[]?:.", *p)) { cur = new_token(tk_reserved, cur, p++, 1); continue; }
        for (int i = 0; keywords[i].name; i++) {
            if (strncmp(p, keywords[i].name, keywords[i].len) == 0 && !is_ident_char(p[keywords[i].len])) { cur = new_token(tk_keyword, cur, p, keywords[i].len); p += keywords[i].len; goto next_char; }
        }
        if (isalpha((unsigned char)*p) || *p == '_') {
            char *q = p++; while (is_ident_char(*p)) p++; cur = new_token(tk_ident, cur, q, p - q); continue;
        }
        if (isdigit((unsigned char)*p)) { char *q = p; cur = new_token(tk_num, cur, p, 0); cur->val = strtol(p, &p, 0); cur->len = p - q; continue; }
        error_at(p, "invalid token");
        next_char:;
    }

    new_token(tk_eof, cur, p, 0);
    return head->next;
}

// --- vii. ast node constructors ---

node *new_node(node_kind kind, node *lhs, node *rhs) {
    node *n = calloc(1, sizeof(node));
    n->kind = kind;
    n->lhs = lhs;
    n->rhs = rhs;
    add_type(n);
    return n;
}

node *new_num_node(long val) {
    node *n = calloc(1, sizeof(node));
    n->kind = nd_num;
    n->val = val;
    add_type(n);
    return n;
}

node *new_lvar_node(lvar *var) {
    node *n = calloc(1, sizeof(node));
    n->kind = nd_lvar;
    n->var = var;
    add_type(n);
    return n;
}

// --- viii. parser implementation (recursive descent) ---

node *lvar_addr(token *tok, ty *type, int is_static) {
    // for non-local variables, check global/extern vars
    if (!current_func) {
        error_tok(tok, "variable used outside function context");
        return NULL; // unreachable
    }

    lvar *var = find_lvar(tok, type, is_static);
    return new_lvar_node(var);
}

// member_access = ("." | "->") ident
node *member_access(node *n) {
    while (consume(".") || consume("->")) {
        node *mem = calloc(1, sizeof(node));
        mem->kind = nd_member;

        // if "->", implicitly dereference
        if (mem->kind == nd_member && peek()->str[0] == '-') {
            n = new_node(nd_deref, n, NULL);
        }

        if (n->type->kind != ty_ptr && n->type->kind != ty_struct) {
            error_tok(current_token, "cannot access member on non-struct/non-pointer type");
        }

        ty *type = (n->type->kind == ty_ptr) ? n->type->base : n->type;
        token *tok = expect_ident();

        mem->mem = get_struct_member(type, tok);
        if (!mem->mem) error_tok(tok, "no such member in struct");

        mem->lhs = n;
        n = mem;
        add_type(n);
    }
    return n;
}

// primary = "(" expr ")" | "sizeof" unary | ident ("(" (assign ("," assign)*)? ")")? | num | string
node *primary() {
    if (consume("(")) {
        node *n = expr();
        expect(")");
        return n;
    }

    if (consume_keyword("sizeof")) {
        node *un = unary();
        add_type(un);
        return new_num_node(un->type->size);
    }

    if (current_token->kind == tk_ident) {
        token *tok = current_token;
        current_token = current_token->next;

        if (consume("(")) { // function call
            node *n = calloc(1, sizeof(node));
            n->kind = nd_funcall;
            n->name = strndup(tok->str, tok->len);

            node head = {};
            node *cur = &head;
            while (!consume(")")) {
                if (cur != &head) expect(",");
                cur->next = assign();
                cur = cur->next;
            }
            n->rhs = head.next;
            add_type(n);
            return n;
        }

        // variable lookup
        for (lvar *l = current_func->locals; l; l = l->next) {
            if (l->len == tok->len && strncmp(l->name, tok->str, l->len) == 0) return new_lvar_node(l);
        }

        // global var / extern func lookup (minimal support)
        gvar *g = find_global_var(tok);
        if (g) {
            lvar *l = calloc(1, sizeof(lvar)); // create a mock lvar for global
            l->name = g->name;
            l->len = (int)strlen(g->name);
            l->is_static = 1; // treat global as static for addr emission
            l->gname = g->name;
            l->type = new_type_ptr(ty_int_def()); // minimal type info for now

            node *n = new_lvar_node(l);
            n->kind = nd_deref; // implicitly dereference global address
            return n;
        }

        error_tok(tok, "undeclared identifier: %s", strndup(tok->str, tok->len));
    }

    if (current_token->kind == tk_num) {
        return new_num_node(expect_number());
    }

    if (current_token->kind == tk_string) {
        token *tok = current_token;
        current_token = current_token->next;

        // create a global variable entry for the string literal
        gvar *g = calloc(1, sizeof(gvar));
        g->name = malloc(32);
        snprintf(g->name, 32, ".str%d", string_label_count++);
        g->size = tok->len; // includes quotes and null terminator in the string literal representation

        sinit *init = calloc(1, sizeof(sinit));
        init->kind = init_string;
        init->str_content = strndup(tok->str + 1, tok->len - 2); // remove quotes
        g->initializer = init;

        g->next = global_vars;
        global_vars = g;

        // return a node that evaluates to the address of the global string
        lvar *l = calloc(1, sizeof(lvar));
        l->name = g->name;
        l->len = (int)strlen(g->name);
        l->is_static = 1;
        l->gname = g->name;
        l->type = new_type_array(ty_char_def(), tok->len - 1); // array type

        return new_lvar_node(l); // array decays to pointer
    }

    error_tok(current_token, "expected expression");
    return NULL;
}

// postfix = primary ("[" expr "]" | "++" | "--" | member_access)*
node *postfix() {
    node *n = primary();
    for (;;) {
        if (consume("[")) {
            node *idx = expr();
            expect("]");
            // a[i] is equivalent to *(a + i)
            node *add = new_node(nd_add, n, idx);
            n = new_node(nd_deref, add, NULL);
        } else if (peek()->kind == tk_reserved && (peek()->str[0] == '.' || (peek()->len == 2 && peek()->str[0] == '-' && peek()->str[1] == '>'))) {
            n = member_access(n);
        } else {
            return n;
        }
    }
}

// unary = ("+" | "-" | "*" | "&" | "!" | "~")? postfix
node *unary() {
    // ... (omitted: same as previous implementation)
    if (consume("+")) return unary();
    if (consume("-")) return new_node(nd_sub, new_num_node(0), unary());
    if (consume("*")) return new_node(nd_deref, unary(), NULL);
    if (consume("&")) return new_node(nd_addr, unary(), NULL);
    if (consume("!")) return new_node(nd_not, unary(), NULL);
    if (consume("~")) return new_node(nd_bitnot, unary(), NULL);
    return postfix();
}

// ... (omitted: mul, add, shift, relational, equality, and, exclusive_or, inclusive_or) ...
node *mul() { node *n = unary(); for (;;) { if (consume("*")) n = new_node(nd_mul, n, unary()); else if (consume("/")) n = new_node(nd_div, n, unary()); else if (consume("%")) n = new_node(nd_mod, n, unary()); else return n; } }
node *add() { node *n = mul(); for (;;) { if (consume("+")) n = new_node(nd_add, n, mul()); else if (consume("-")) n = new_node(nd_sub, n, mul()); else return n; } }
node *shift() { node *n = add(); for (;;) { if (consume("<<")) n = new_node(nd_shl, n, add()); else if (consume(">>")) n = new_node(nd_shr, n, add()); else return n; } }
node *relational() { node *n = shift(); for (;;) { if (consume("<")) n = new_node(nd_lt, n, shift()); else if (consume("<=")) n = new_node(nd_le, n, shift()); else if (consume(">")) n = new_node(nd_lt, shift(), n); else if (consume(">=")) n = new_node(nd_le, shift(), n); else return n; } }
node *equality() { node *n = relational(); for (;;) { if (consume("==")) n = new_node(nd_eq, n, relational()); else if (consume("!=")) n = new_node(nd_ne, n, relational()); else return n; } }
node *and() { node *n = equality(); for (;;) { if (consume("&")) n = new_node(nd_band, n, equality()); else return n; } }
node *exclusive_or() { node *n = and(); for (;;) { if (consume("^")) n = new_node(nd_bxor, n, and()); else return n; } }
node *inclusive_or() { node *n = exclusive_or(); for (;;) { if (consume("|")) n = new_node(nd_bor, n, exclusive_or()); else return n; } }

node *logical_and() { node *n = inclusive_or(); for (;;) { if (consume("&&")) n = new_node(nd_logical_and, n, inclusive_or()); else return n; } }
node *logical_or() { node *n = logical_and(); for (;;) { if (consume("||")) n = new_node(nd_logical_or, n, logical_and()); else return n; } }

node *conditional() {
    node *n = logical_or();
    if (!consume("?")) return n;
    node *rhs = expr();
    expect(":");
    node *els = conditional();
    n->kind = nd_cond;
    n->rhs = rhs;
    n->els = els;
    add_type(n);
    return n;
}

node *assign() {
    node *n = conditional();

    if (consume("=")) return new_node(nd_assign, n, assign());
    if (consume("+=")) return new_node(nd_add_assign, n, assign());
    if (consume("-=")) return new_node(nd_sub_assign, n, assign());
    if (consume("*=")) return new_node(nd_mul_assign, n, assign());
    if (consume("/=")) return new_node(nd_div_assign, n, assign());
    if (consume("%=")) return new_node(nd_mod_assign, n, assign());
    if (consume("<<=")) return new_node(nd_shl_assign, n, assign());
    if (consume(">>=")) return new_node(nd_shr_assign, n, assign());
    if (consume("&=")) return new_node(nd_band_assign, n, assign());
    if (consume("|=")) return new_node(nd_bor_assign, n, assign());
    if (consume("^=")) return new_node(nd_bxor_assign, n, assign());

    return n;
}

node *expr() { return assign(); }


// --- ix. struct definition and initializer parsing ---

// parses struct members and calculates total size/alignment
ty *parse_struct_specifier() {
    token *tag = NULL;
    if (peek()->kind == tk_ident) {
        tag = expect_ident();
    }

    ty *type = NULL;

    if (consume("{")) { // full definition
        type = new_type_struct();
        if (tag) { // save anonymous/named tag
            struct_tag *st = calloc(1, sizeof(struct_tag));
            st->name = strndup(tag->str, tag->len);
            st->len = tag->len;
            st->type = type;
            st->next = struct_tags;
            struct_tags = st;
        }

        int offset = 0;
        int max_align = 1;
        member head = {};
        member *cur = &head;

        while (!consume("}")) {
            int is_unsigned = 0, is_static = 0, is_extern = 0;
            ty *base = parse_type_specifier(&is_unsigned, &is_static, &is_extern);

            do {
                token *ident_tok = NULL;
                ty *mem_type = parse_declarator(base, &ident_tok);
                if (!ident_tok) error_tok(current_token, "expected member name");

                offset = align_to(offset, mem_type->align);

                member *m = calloc(1, sizeof(member));
                m->name = strndup(ident_tok->str, ident_tok->len);
                m->len = ident_tok->len;
                m->type = mem_type;
                m->offset = offset;

                cur->next = m;
                cur = cur->next;

                offset += mem_type->size;
                if (mem_type->align > max_align) max_align = mem_type->align;

            } while (consume(","));

            expect(";");
        }

        type->members = head.next;
        type->align = max_align;
        type->size = align_to(offset, max_align);

    } else if (tag) { // forward declaration or existing definition lookup
        type = find_struct_tag(tag);
        if (!type) error_tok(tag, "unknown struct tag '%s'", strndup(tag->str, tag->len));
    } else {
        error_tok(current_token, "expected '{' or a struct tag");
    }

    return type;
}


sinit *parse_initializer_recursive(ty *type, int *offset_ptr) {
    sinit head = {};
    sinit *cur = &head;

    if (type->kind == ty_array) {
        size_t index = 0;
        if (consume("{")) { // array initialization list
            while (!consume("}")) {
                if (index > 0) consume(",");
                if (index >= type->array_len && type->array_len > 0) error_tok(current_token, "too many elements in array initializer");

                cur->next = parse_initializer_recursive(type->base, NULL);
                cur = cur->next;
                cur->offset = (*offset_ptr) + (index * type->base->size);

                index++;
            }
        } else {
            // single element initializer (e.g., char a[4] = "abc"; is handled in declaration)
            if (type->base->kind == ty_char && peek()->kind == tk_string) {
                // array of char initialized by string literal: handled in declaration
                return NULL;
            }

            cur->next = parse_initializer_recursive(type->base, NULL);
            cur = cur->next;
            cur->offset = (*offset_ptr);

            // ensure offset_ptr is incremented if we only take one element and it's for a fixed array.
            // this is messy for a simple compiler. assume only list initializers for non-char arrays.
            if (type->array_len > 1) error_tok(current_token, "expected array initializer list { ... }");
        }
        // implicit zero-initialization for remaining elements is done by emit_data_initializer

    } else if (type->kind == ty_struct) {
        member *m = type->members;
        if (!consume("{")) error_tok(current_token, "expected struct initializer list { ... }");

        while (!consume("}")) {
            if (m) {
                if (m != type->members) expect(",");

                cur->next = parse_initializer_recursive(m->type, NULL);
                cur = cur->next;
                cur->offset = (*offset_ptr) + m->offset;

                m = m->next;
            } else {
                error_tok(current_token, "too many members in struct initializer");
            }
        }

        // implicit zero-initialization for remaining members is done by emit_data_initializer

    } else { // scalar initializer
        node *rhs = conditional(); // use conditional to capture constant expression
        if (rhs->kind != nd_num && rhs->kind != nd_lvar) error_tok(current_token, "expected constant expression for initializer");

        sinit *init = calloc(1, sizeof(sinit));
        init->type = type;
        init->size = type->size;

        if (rhs->kind == nd_num) {
            init->kind = init_int;
            init->val = rhs->val;
        } else if (rhs->kind == nd_lvar && (rhs->var->type->kind == ty_array || rhs->var->type->kind == ty_func)) {
            // pointer to array/function
            init->kind = init_ptr;
            init->str_label = strdup(rhs->var->gname); // assuming global/static var for address
        } else {
            // simple scalar expression for now (constant folding needed for full support)
            error_tok(current_token, "non-constant initializer value");
        }

        cur->next = init;
        cur = cur->next;
    }

    return head.next;
}

sinit *parse_initializer(ty *type) {
    if (type->kind == ty_array && type->base->kind == ty_char && peek()->kind == tk_string) {
        token *tok = current_token;
        current_token = current_token->next;

        sinit *init = calloc(1, sizeof(sinit));
        init->kind = init_string;
        init->type = type;
        init->size = type->size;
        init->str_content = strndup(tok->str + 1, tok->len - 2); // remove quotes

        // if array size is inferred, calculate it (e.g., char a[] = "abc";)
        if (type->array_len == 0) {
            type->array_len = tok->len - 1; // len - 1 is for string content + null terminator
            type->size = type->array_len * type->base->size;
        }
        return init;
    }

    // start recursion at offset 0
    int start_offset = 0;
    return parse_initializer_recursive(type, &start_offset);
}


ty *parse_type_specifier(int *is_unsigned_ptr, int *is_static_ptr, int *is_extern_ptr) {
    ty *base = NULL;
    while (is_type_token(current_token)) {
        if (consume_keyword("int")) base = ty_int_def();
        else if (consume_keyword("char")) base = ty_char_def();
        else if (consume_keyword("long")) base = ty_long_def();
        else if (consume_keyword("unsigned")) *is_unsigned_ptr = 1;
        else if (consume_keyword("static")) *is_static_ptr = 1;
        else if (consume_keyword("extern")) *is_extern_ptr = 1;
        else if (consume_keyword("struct")) base = parse_struct_specifier();
        else break;
    }
    if (!base) base = ty_int_def();
    return base;
}

// parses declarator, returns final type, sets ident_tok_ptr to the identifier token
ty *parse_declarator(ty *base, token **ident_tok_ptr) {
    while (consume("*")) {
        base = new_type_ptr(base);
    }

    token *ident_tok = NULL;
    if (peek()->kind == tk_ident) {
        ident_tok = expect_ident();
    }

    // array declarators
    while (consume("[")) {
        size_t len = 0;
        if (current_token->kind == tk_num) {
            len = expect_number();
        } else {
            // incomplete array size: use 0 for global/static declaration
        }
        expect("]");
        base = new_type_array(base, len);
    }

    if (ident_tok_ptr) *ident_tok_ptr = ident_tok;
    return base;
}

// declaration = typespec declarator ("=" initializer)? ("," declarator ("=" initializer)?)* ";"
node *declaration(int is_global) {
    int is_unsigned = 0;
    int is_static = 0;
    int is_extern = 0;
    ty *base = parse_type_specifier(&is_unsigned, &is_static, &is_extern);

    node head = {};
    node *cur = &head;

    do {
        token *ident_tok = NULL;
        ty *type = parse_declarator(base, &ident_tok);
        if (!ident_tok) error_tok(current_token, "expected identifier in declaration");

        sinit *initializer = NULL;
        if (consume("=")) {
            initializer = parse_initializer(type);
        }

        if (is_global || is_static) {
            // global/static declaration
            gvar *g = calloc(1, sizeof(gvar));
            if (is_static) {
                g->name = malloc(32);
                snprintf(g->name, 32, ".gstatic%d", static_var_count++);
                // ensure local static mapping exists
                if (current_func) {
                    lvar *l = find_lvar(ident_tok, type, 1);
                    l->gname = g->name;
                }
            } else {
                g->name = strndup(ident_tok->str, ident_tok->len);
            }
            g->size = type->size;
            g->initializer = initializer;
            g->is_extern = is_extern;

            g->next = global_vars;
            global_vars = g;

        } else {
            // local declaration
            lvar *var = find_lvar(ident_tok, type, is_static);

            if (initializer) {
                node *n = calloc(1, sizeof(node));
                n->kind = nd_local_init;
                n->var = var;
                n->init_list = initializer;
                cur->next = n;
                cur = cur->next;
            }
            // non-initialized local arrays/structs will be zeroed in codegen
        }

    } while (consume(","));

    expect(";");
    return head.next;
}

node *stmt() {
    // ... (omitted: if, while, for, return, break, continue, block logic)
    if (consume_keyword("return")) {
        node *n = new_node(nd_return, expr(), NULL);
        expect(";");
        return n;
    }
    if (consume_keyword("if")) {
        node *n = calloc(1, sizeof(node)); n->kind = nd_if; expect("("); n->lhs = expr(); expect(")"); n->rhs = stmt(); if (consume_keyword("else")) { n->els = stmt(); } return n;
    }
    if (consume_keyword("while")) {
        node *n = calloc(1, sizeof(node)); n->kind = nd_while; expect("("); n->lhs = expr(); expect(")");
        continue_break_labels cbl = { .continue_label = label_count++, .break_label = label_count++, .next = loop_or_switch_labels }; loop_or_switch_labels = &cbl;
        node *body = stmt(); loop_or_switch_labels = cbl.next; n->rhs = body; return n;
    }
    if (consume_keyword("for")) {
        node *n = calloc(1, sizeof(node)); n->kind = nd_for; expect("(");
        if (is_type_token(peek())) { n->lhs = declaration(0); } else if (!consume(";")) { n->lhs = expr(); expect(";"); }
        if (!consume(";")) { n->rhs = expr(); expect(";"); }
        if (!consume(")")) { n->els = expr(); expect(")"); }
        continue_break_labels cbl = { .continue_label = label_count++, .break_label = label_count++, .next = loop_or_switch_labels }; loop_or_switch_labels = &cbl;
        node *body = stmt(); loop_or_switch_labels = cbl.next; n->next = body; return n;
    }
    if (consume_keyword("break")) { node *n = calloc(1, sizeof(node)); n->kind = nd_break; expect(";"); return n; }
    if (consume_keyword("continue")) { node *n = calloc(1, sizeof(node)); n->kind = nd_continue; expect(";"); return n; }

    if (consume("{")) {
        node head = {};
        node *cur = &head;
        while (!consume("}")) {
            if (is_type_token(peek())) { // local variable declaration
                cur->next = declaration(0);
                while (cur->next) cur = cur->next;
            } else {
                cur->next = stmt();
                cur = cur->next;
            }
        }
        node *n = calloc(1, sizeof(node));
        n->kind = nd_block;
        n->rhs = head.next;
        return n;
    }

    node *n = expr();
    expect(";");
    node *expr_stmt = calloc(1, sizeof(node));
    expr_stmt->kind = nd_expr_stmt;
    expr_stmt->lhs = n;
    return expr_stmt;
}

node *block() {
    // ... (omitted: block logic, essentially just wraps stmt* with '{' '}')
    node head = {};
    node *cur = &head;
    while (!consume("}")) {
        if (is_type_token(peek())) { // local variable declaration
            cur->next = declaration(0);
            while (cur->next) cur = cur->next;
        } else {
            cur->next = stmt();
            cur = cur->next;
        }
    }
    node *n = calloc(1, sizeof(node));
    n->kind = nd_block;
    n->rhs = head.next;
    return n;
}

node *param_declaration(int is_func_def) {
    int is_unsigned = 0;
    int is_static = 0;
    int is_extern = 0;
    ty *base = parse_type_specifier(&is_unsigned, &is_static, &is_extern);

    token *ident_tok = NULL;
    ty *type = parse_declarator(base, &ident_tok);

    if (!ident_tok) error_tok(current_token, "expected parameter name");

    lvar *var = find_lvar(ident_tok, type, 0);
    current_func->num_params++;
    return new_lvar_node(var);
}

void parse_fundef_or_global() {
    int is_unsigned = 0;
    int is_static = 0;
    int is_extern = 0;
    ty *base = parse_type_specifier(&is_unsigned, &is_static, &is_extern);

    token *ident_tok = NULL;
    ty *type = parse_declarator(base, &ident_tok);

    // check if it's a function declaration (lookahead for '(')
    if (peek()->kind == tk_reserved && strncmp(peek()->str, "(", 1) == 0) {
        // it's a function
        expect("(");

        function *f = calloc(1, sizeof(function));
        f->name = strndup(ident_tok->str, ident_tok->len);
        f->is_static = is_static;
        f->next = program_head;
        program_head = f;
        current_func = f;

        // parameters
        while (!consume(")")) {
            if (f->num_params > 0) expect(",");
            param_declaration(1);
        }

        if (consume("{")) { // function definition
            f->body = block();
            f->stack_size = align_to(f->stack_size, 16);
            current_func = NULL; // reset current function
        } else { // function declaration
            expect(";");
            // should not have locals, reset stack/locals
            f->locals = NULL;
            f->stack_size = 0;
        }
    } else {
        // not a function: it must be a global declaration
        current_token = ident_tok; // put the identifier back
        declaration(1); // parse as global variable declaration
        current_func = NULL;
    }
}

// --- x. code generation implementation (x86-64) ---

char *arg_reg[] = {"rdi", "rsi", "rdx", "rcx", "r8", "r9"};

void emit_addr(node *n) {
    if (n->kind == nd_lvar) {
        if (n->var->is_static) {
            printf("  lea rax, %s[rip]\n", n->var->gname);
        } else {
            printf("  lea rax, [rbp-%d]\n", n->var->offset);
        }
        printf("  push rax\n");
        return;
    }
    if (n->kind == nd_deref) {
        emit_expr(n->lhs);
        return;
    }
    if (n->kind == nd_member) {
        emit_addr(n->lhs);
        printf("  pop rax\n");
        printf("  add rax, %d\n", n->mem->offset);
        printf("  push rax\n");
        return;
    }
    error_tok(current_token, "lvalue required");
}

void emit_load(ty *type) {
    printf("  pop rax\n");
    if (type->kind == ty_array || type->kind == ty_struct) return;

    if (type->size == 1) {
        printf("  movsx rax, byte ptr [rax]\n");
    } else if (type->size == 4) {
        printf("  movsxd rax, dword ptr [rax]\n");
    } else {
        printf("  mov rax, [rax]\n");
    }
    printf("  push rax\n");
}

void emit_store(ty *type) {
    printf("  pop rdi\n");
    printf("  pop rax\n");

    if (type->kind == ty_struct || type->kind == ty_array) {
        // copy structure/array by 8-byte chunks (not fully abi compliant but simple)
        int size = type->size;
        int count = size / 8;
        if (size % 8 != 0) count++;

        printf("  mov rsi, rax\n"); // source address (from rax)
        printf("  mov rdi, rdi\n"); // destination address
        printf("  mov rcx, %d\n", count);
        printf("  rep movsq\n"); // copy 8-byte chunks
        printf("  push rax\n"); // push a value back (address of dest, though not strictly needed)
        return;
    }

    if (type->size == 1) {
        printf("  mov [rdi], al\n");
    } else if (type->size == 4) {
        printf("  mov [rdi], eax\n");
    } else {
        printf("  mov [rdi], rax\n");
    }
    printf("  push rax\n");
}

void emit_expr(node *n) {
    switch (n->kind) {
        // ... (omitted: nd_num, nd_lvar, nd_assign, nd_addr, nd_deref, nd_member, nd_funcall)
        case nd_num: printf("  push %ld\n", n->val); return;
        case nd_lvar: emit_addr(n); emit_load(n->type); return;
        case nd_assign: emit_addr(n->lhs); emit_expr(n->rhs); emit_store(n->lhs->type); return;
        case nd_addr: emit_addr(n->lhs); return;
        case nd_deref: emit_expr(n->lhs); emit_load(n->type); return;
        case nd_member: emit_addr(n); emit_load(n->type); return;
        case nd_funcall:
            // arg setup
            int num_args = 0; for (node *arg = n->rhs; arg; arg = arg->next) { emit_expr(arg); num_args++; }
            for (int i = num_args - 1; i >= 0; i--) { printf("  pop %s\n", arg_reg[i]); }
            printf("  mov rax, 0\n"); printf("  call %s\n", n->name);
            printf("  push rax\n"); return;

        // standard binary operators (including pointer arithmetic fix)
        case nd_add: case nd_sub: case nd_mul: case nd_div: case nd_mod:
        case nd_shl: case nd_shr: case nd_band: case nd_bor: case nd_bxor:
        case nd_eq: case nd_ne: case nd_lt: case nd_le:
        {
            emit_expr(n->lhs);
            emit_expr(n->rhs);
            printf("  pop rdi\n"); // rdi = rhs value
            printf("  pop rax\n"); // rax = lhs value

            ty *lhs_type = n->lhs->type;
            ty *rhs_type = n->rhs->type;

            int scale = 1;
            int lhs_is_ptr = (lhs_type->kind == ty_ptr || lhs_type->kind == ty_array);
            int rhs_is_ptr = (rhs_type->kind == ty_ptr || rhs_type->kind == ty_array);

            if (lhs_is_ptr) scale = lhs_type->base->size;
            else if (rhs_is_ptr) scale = rhs_type->base->size;

            switch (n->kind) {
                case nd_add:
                    if (lhs_is_ptr) printf("  imul rdi, %d\n", scale);
                    printf("  add rax, rdi\n");
                    break;
                case nd_sub:
                    if (lhs_is_ptr && !rhs_is_ptr) {
                        printf("  imul rdi, %d\n", scale);
                        printf("  sub rax, rdi\n");
                    } else if (lhs_is_ptr && rhs_is_ptr) {
                        printf("  sub rax, rdi\n");
                        printf("  cqo\n");
                        printf("  mov rdi, %d\n", scale);
                        printf("  idiv rdi\n");
                    } else {
                        printf("  sub rax, rdi\n");
                    }
                    break;
                case nd_mul: printf("  imul rax, rdi\n"); break;
                case nd_div: printf("  cqo\n"); printf("  idiv rdi\n"); break;
                case nd_mod: printf("  cqo\n"); printf("  idiv rdi\n"); printf("  mov rax, rdx\n"); break;
                case nd_shl: printf("  mov rcx, rdi\n"); printf("  shl rax, cl\n"); break;
                case nd_shr: printf("  mov rcx, rdi\n"); printf("  shr rax, cl\n"); break;
                case nd_band: printf("  and rax, rdi\n"); break;
                case nd_bor: printf("  or rax, rdi\n"); break;
                case nd_bxor: printf("  xor rax, rdi\n"); break;
                case nd_eq: printf("  cmp rax, rdi\n"); printf("  sete al\n"); printf("  movzx rax, al\n"); break;
                case nd_ne: printf("  cmp rax, rdi\n"); printf("  setne al\n"); printf("  movzx rax, al\n"); break;
                case nd_lt: printf("  cmp rax, rdi\n"); printf("  setl al\n"); printf("  movzx rax, al\n"); break;
                case nd_le: printf("  cmp rax, rdi\n"); printf("  setle al\n"); printf("  movzx rax, al\n"); break;
                default: break;
            }
            printf("  push rax\n");
            return;
        }
        case nd_logical_and: case nd_logical_or: // short-circuit logic (omitted: complex for this snippet)
        case nd_not: // logical NOT (omitted)
        case nd_bitnot: // bitwise NOT (omitted)
        case nd_cond: // ternary operator (omitted)
        default: error_tok(current_token, "unsupported expression type in emit_expr");
    }
}

void emit_local_initializer(sinit *init, ty *type, int offset) {
    if (init->kind == init_array || init->kind == init_struct) {
        for (sinit *child = init->children; child; child = child->next) {
            emit_local_initializer(child, child->type, offset);
        }
    } else if (init->kind == init_int) {
        printf("  mov rax, %ld\n", init->val);
        printf("  mov [rbp-%d], rax\n", offset - init->offset); // adjust offset
    } else {
        // for now, ignore complex local initializers (like pointers, structs/arrays) for simplicity
        // a real compiler would use helper functions to copy data from the data section.
        printf("  ; skipping complex local initializer at offset %d\n", offset - init->offset);
    }
}

void emit_stmt(node *n) {
    if (!n) return;

    switch (n->kind) {
        // ... (omitted: nd_return, nd_expr_stmt, nd_block, nd_if, nd_while, nd_for, nd_break, nd_continue)
        case nd_return: emit_expr(n->lhs); printf("  pop rax\n"); printf("  jmp .l.return.%s\n", current_func->name); return;
        case nd_expr_stmt: emit_expr(n->lhs); printf("  pop rax\n"); return;
        case nd_block: for (node *cur = n->rhs; cur; cur = cur->next) { emit_stmt(cur); } return;
        case nd_if: // ... (omitted: if logic)
        case nd_while: // ... (omitted: while logic)
        case nd_for: // ... (omitted: for logic)
        case nd_break: // ... (omitted: break logic)
        case nd_continue: // ... (omitted: continue logic)

        case nd_local_init:
            // for simple initialization lists, emit a sequence of mov instructions
            emit_local_initializer(n->init_list, n->var->type, n->var->offset);
            return;

        default: error_tok(current_token, "unsupported statement type in emit_stmt");
    }
}

void emit_data_initializer(sinit *init, ty *type) {
    if (init->kind == init_string) {
        printf("  .asciz \"%s\"\n", init->str_content);
        return;
    }

    if (init->kind == init_int) {
        if (type->size == 1) printf("  .byte %ld\n", init->val);
        else if (type->size == 4) printf("  .long %ld\n", init->val);
        else printf("  .quad %ld\n", init->val);
        return;
    }

    if (init->kind == init_ptr) {
        printf("  .quad %s\n", init->str_label);
        return;
    }

    // recursive initializer for struct/array
    int current_offset = 0;
    sinit *cur = init->children;

    while (current_offset < type->size) {
        if (cur && cur->offset == current_offset) {
            // emit data for the current item
            emit_data_initializer(cur, cur->type);
            current_offset += cur->size;
            cur = cur->next;
        } else {
            // emit zero padding for uninitialized parts or alignment padding
            int zero_size = type->size - current_offset;
            if (cur) zero_size = cur->offset - current_offset;

            if (zero_size > 0) {
                printf("  .zero %d\n", zero_size);
                current_offset += zero_size;
            }
        }
    }
}


void codegen_program(function *funcs) {
    printf("  .intel_syntax noprefix\n");

    // 1. emit global data
    printf("  .data\n");
    for (gvar *g = global_vars; g; g = g->next) {
        if (g->is_extern) continue;

        if (g->initializer) {
            printf("  .globl %s\n", g->name);
            printf("%s:\n", g->name);
            // recursive initializer emission
            emit_data_initializer(g->initializer, NULL); // null type is a placeholder, only used for simple types
        } else {
            // uninitialized data goes into .bss
            printf("  .bss\n");
            printf("  .globl %s\n", g->name);
            printf("%s:\n", g->name);
            printf("  .zero %d\n", g->size);
            printf("  .data\n"); // switch back to data for next initialized var
        }
    }

    // 2. function definitions (.text)
    printf("  .text\n");
    for (function *f = funcs; f; f = f->next) {
        current_func = f;

        if (f->body) { // only emit definitions, not declarations
            if (!f->is_static) { printf("  .globl %s\n", f->name); }
            printf("%s:\n", f->name);

            // prologue
            printf("  push rbp\n");
            printf("  mov rbp, rsp\n");
            printf("  sub rsp, %d\n", f->stack_size);

            // parameter setup
            lvar *p = f->locals;
            for (int i = 0; i < f->num_params; i++) {
                printf("  mov [rbp-%d], %s\n", p->offset, arg_reg[i]);
                p = p->next;
            }

            // code body
            emit_stmt(f->body);

            // epilogue label
            printf(".l.return.%s:\n", f->name);
            printf("  mov rsp, rbp\m");
            printf("  pop rbp\n");
            printf("  ret\n");
        }
    }
}

