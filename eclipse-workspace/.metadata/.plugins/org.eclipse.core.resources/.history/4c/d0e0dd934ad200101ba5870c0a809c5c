// cc.c
// Minimal single-file C compiler: lexer, parser (subset), codegen (x86-64), ELF object writer, linker invocation.
// Produces relocatable object out.o and links with system linker to create dynamically linked executable out.
//
// Limitations:
// - Supports a small subset of C: integer literals, string literals, local variables, simple arithmetic,
//   function definitions with integer return, function calls, return statements.
// - No full type system, no structs, no enums, limited error checking.
// - Emits simple x86-64 machine code for expressions and function prologue/epilogue.
// - Emits relocations for external function calls and global addresses, writes out.o, then runs `gcc out.o -o out`.
//
// Use: gcc cc.c -o cc
//       ./cc test.c
//
// Example test.c:
//   int puts(const char*);
//   int main() {
//     puts("hello");
//     return 0;
//   }

#define _GNU_SOURCE
#include <ctype.h>
#include <stdbool.h>
#include <stdint.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

/* ---------------------------
   Tokenizer
   --------------------------- */
typedef enum {
    TK_RESERVED,
    TK_TYPE,
    TK_ID,
    TK_NUM,
    TK_CHAR,
    TK_STRING,
    TK_EOF,
} token_kind;

typedef struct token token;
struct token {
    token_kind kind;
    token *next;
    char *str;
    int len;
    int val;
};

char *p; // input pointer
token *cur_tok;

bool is_alpha(char c){
    return c == '_' || ('a' <= c && c <= 'z') || ('A' <= c && c <= 'Z');
}
bool is_alnum(char c){
    return is_alpha(c) || isdigit(c);
}

token *tokenize(char *code){
    p = code;
    token *head = calloc(1, sizeof(token));
    token *cur = head;

    char *types[] = {"void","_Bool","char","short","int","long","unsigned","signed","const","volatile","static","extern"};
    int num_types = sizeof(types)/sizeof(*types);

    char *keywords[] = {"return","if","else","while","for","break","continue","sizeof","typedef","struct","union","enum","include"};
    int num_keywords = sizeof(keywords)/sizeof(*keywords);

    char *puncts[] = {
        "+=", "-=", "*=", "/=", "%=", "||", "&&", "==", "!=", "<=", ">=", "<<", ">>", "++", "--", "->",
        "#", "=", "?", ":", "|", "^", "&", "<", ">", "+", "-", "*", "/", "%", "!", ".", ",", ";", "(", ")", "{", "}", "[", "]"
    };
    int num_puncts = sizeof(puncts)/sizeof(*puncts);

    while(*p){
        if(isspace(*p)){ p++; continue; }
        if(*p == '#'){ while(*p && *p != '\n') p++; continue; }
        if(memcmp(p, "//", 2) == 0){ p+=2; while(*p && *p != '\n') p++; continue; }
        if(memcmp(p, "/*", 2) == 0){ p+=2; while(*p && memcmp(p,"*/",2)) p++; if(*p) p+=2; continue; }

        if(*p == '\''){
            token *t = calloc(1, sizeof(token));
            t->kind = TK_CHAR;
            t->str = p;
            t->len = 1;
            p++;
            while(*p && *p != '\''){ if(*p == '\\') p+=2; else p++; t->len++; }
            if(*p == '\''){ p++; t->len++; }
            cur->next = t; cur = t;
            continue;
        }
        if(*p == '\"'){
            token *t = calloc(1, sizeof(token));
            t->kind = TK_STRING;
            t->str = p;
            t->len = 1;
            p++;
            while(*p && *p != '\"'){ if(*p == '\\') { p+=2; t->len+=2; } else { p++; t->len++; } }
            if(*p == '\"'){ p++; t->len++; }
            cur->next = t; cur = t;
            continue;
        }

        bool matched = false;
        for(int i=0;i<num_types;i++){
            char *s = types[i];
            int L = strlen(s);
            if(memcmp(p, s, L) == 0 && !is_alnum(p[L])){
                token *t = calloc(1, sizeof(token));
                t->kind = TK_TYPE;
                t->str = p;
                t->len = L;
                cur->next = t; cur = t;
                p += L;
                matched = true; break;
            }
        }
        if(matched) continue;
        for(int i=0;i<num_keywords;i++){
            char *s = keywords[i];
            int L = strlen(s);
            if(memcmp(p, s, L) == 0 && !is_alnum(p[L])){
                token *t = calloc(1, sizeof(token));
                t->kind = TK_RESERVED;
                t->str = p;
                t->len = L;
                cur->next = t; cur = t;
                p += L;
                matched = true; break;
            }
        }
        if(matched) continue;
        for(int i=0;i<num_puncts;i++){
            char *s = puncts[i];
            int L = strlen(s);
            if(memcmp(p, s, L) == 0){
                token *t = calloc(1, sizeof(token));
                t->kind = TK_RESERVED;
                t->str = p;
                t->len = L;
                cur->next = t; cur = t;
                p += L;
                matched = true; break;
            }
        }
        if(matched) continue;

        if(isdigit(*p)){
            token *t = calloc(1, sizeof(token));
            t->kind = TK_NUM;
            t->str = p;
            t->len = 0;
            t->val = 0;
            while(isdigit(*p)){ t->val = t->val*10 + (*p - '0'); p++; t->len++; }
            cur->next = t; cur = t;
            continue;
        }
        if(is_alpha(*p)){
            token *t = calloc(1, sizeof(token));
            t->kind = TK_ID;
            t->str = p;
            t->len = 0;
            while(is_alnum(*p)){ p++; t->len++; }
            cur->next = t; cur = t;
            continue;
        }
        fprintf(stderr, "invalid token at: %c\n", *p);
        exit(1);
    }
    token *t = calloc(1, sizeof(token));
    t->kind = TK_EOF;
    cur->next = t;
    return head->next;
}

/* ---------------------------
   AST and symbol structures
   --------------------------- */
typedef enum {
    ND_FUNC_DEF,
    ND_GLOBAL_DEF,
    ND_BLOCK,
    ND_IF,
    ND_WHILE,
    ND_FOR,
    ND_RET,
    ND_COMMA,
    ND_ASSIGN,
    ND_COND,
    ND_LOG_OR,
    ND_LOG_AND,
    ND_BIT_OR,
    ND_BIT_XOR,
    ND_BIT_AND,
    ND_EQ,
    ND_NEQ,
    ND_LT,
    ND_LEQ,
    ND_LSHIFT,
    ND_RSHIFT,
    ND_ADD,
    ND_SUB,
    ND_MUL,
    ND_DIV,
    ND_MOD,
    ND_NEG,
    ND_LOG_NOT,
    ND_ADR,
    ND_DEREF,
    ND_CAST,
    ND_GLOBAL,
    ND_LOCAL,
    ND_NUM,
    ND_STRING,
    ND_FUNC_CALL,
    ND_DOT,
    ND_ARROW,
} node_kind;

typedef enum {
    NOHEAD, VOID, BOOL, CHAR, SHORT, INT, LONG, PTR, ARRAY, FUNC, STRUCT, ENUM
} type_kind;

typedef enum {
    SY_VAR, SY_ENUM, SY_TYPE, SY_TAG
} symb_kind;

typedef struct type type;
typedef struct symb symb;
typedef struct node node;
typedef struct block block;

struct type {
    type_kind kind;
    type *ptr_to;
    symb *head;
    int size;
    int align;
    char *name;
    int len;
};

struct symb {
    symb_kind kind;
    symb *next;
    type *ty;
