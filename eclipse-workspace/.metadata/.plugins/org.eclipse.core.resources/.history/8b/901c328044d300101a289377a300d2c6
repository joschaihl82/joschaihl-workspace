cmake_minimum_required(VERSION 3.16)
project(xmpp_voip_scaffold LANGUAGES CXX)

# Project settings
set(CMAKE_CXX_STANDARD 17)
set(CMAKE_CXX_STANDARD_REQUIRED ON)
set(CMAKE_POSITION_INDEPENDENT_CODE ON)

# Optionally allow building in Release by default
if(NOT CMAKE_BUILD_TYPE)
  set(CMAKE_BUILD_TYPE Release CACHE STRING "Build type" FORCE)
endif()

# Find Qt6 components
find_package(Qt6 COMPONENTS Widgets Network Multimedia REQUIRED)

# Find pkg-config and QXmpp via pkg-config
find_package(PkgConfig REQUIRED)
pkg_check_modules(QXMPP REQUIRED IMPORTED_TARGET qxmpp)

# Include directories for QXmpp (pkg-config provides IMPORTED_TARGET)
# If your QXmpp installation does not provide a pkg-config file, set QXMPP_INCLUDE_DIRS and QXMPP_LIBRARIES manually.
if(NOT TARGET PkgConfig::PkgConfig)
  # nothing, PkgConfig is used only for pkg_check_modules
endif()

# Source
set(SRC
    xmpp.cpp
)

# Create executable
add_executable(${PROJECT_NAME} ${SRC})

# Include directories
target_include_directories(${PROJECT_NAME}
  PRIVATE
    ${Qt6Widgets_INCLUDE_DIRS}
    ${Qt6Network_INCLUDE_DIRS}
    ${Qt6Multimedia_INCLUDE_DIRS}
    ${QXMPP_INCLUDE_DIRS}
)

# Link libraries
target_link_libraries(${PROJECT_NAME}
  PRIVATE
    Qt6::Widgets
    Qt6::Network
    Qt6::Multimedia
    PkgConfig::QXMPP
    asound
)

# Compiler warnings and definitions
if(MSVC)
  target_compile_options(${PROJECT_NAME} PRIVATE /W4 /permissive-)
else()
  target_compile_options(${PROJECT_NAME} PRIVATE -Wall -Wextra -Wpedantic -Wno-unused-parameter)
  # Enable position independent code and link time optimization if supported
  include(CheckCXXCompilerFlag)
  check_cxx_compiler_flag("-flto" COMPILER_SUPPORTS_LTO)
  if(COMPILER_SUPPORTS_LTO)
    target_compile_options(${PROJECT_NAME} PRIVATE -flto)
    target_link_options(${PROJECT_NAME} PRIVATE -flto)
  endif()
endif()

# RPATH handling for runtime libraries (useful during development)
set_target_properties(${PROJECT_NAME} PROPERTIES
  BUILD_RPATH "$ORIGIN/../lib"
  INSTALL_RPATH "$ORIGIN/../lib"
)

# Install rules
install(TARGETS ${PROJECT_NAME}
  RUNTIME DESTINATION bin
)

# Helpful CMake messages
message(STATUS "Project: ${PROJECT_NAME}")
message(STATUS "C++ standard: ${CMAKE_CXX_STANDARD}")
message(STATUS "Qt6 Widgets: ${Qt6Widgets_FOUND}")
message(STATUS "QXmpp pkg-config: ${QXMPP_FOUND}")

# Notes for maintainers (printed at configure time)
message(STATUS "If pkg-config cannot find qxmpp, set QXMPP_INCLUDE_DIRS and QXMPP_LIBRARIES manually or install qxmpp dev package.")
