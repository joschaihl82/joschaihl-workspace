// selfcc.c
// Enhanced tutorial-style C compiler (subset) that can translate itself
// Supports: int, pointers, local variables, function definitions, params,
// return, if/while/for, expressions, assignments, function calls, string literals.
// Emits x86-64 assembly (Intel syntax).

#include <ctype.h>
#include <stdarg.h>
#include <stdbool.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

//
// Tokenizer
//

typedef enum {
  TK_RESERVED, // Keywords or punctuators
  TK_IDENT,    // Identifier
  TK_NUM,      // Integer literal
  TK_STR,      // String literal
  TK_EOF,      // End-of-file markers
} TokenKind;

typedef struct Token Token;
struct Token {
  TokenKind kind;
  Token *next;
  int val;        // If kind == TK_NUM
  char *str;      // Token string (for identifiers we point into input)
  int len;        // Token length
  char *loc;      // original location in input (for error_at)
};

char *user_input;
Token *token;

void error(char *fmt, ...) {
  va_list ap;
  va_start(ap, fmt);
  vfprintf(stderr, fmt, ap);
  fprintf(stderr, "\n");
  exit(1);
}

void error_at(char *loc, char *fmt, ...) {
  va_list ap;
  va_start(ap, fmt);
  int pos = loc - user_input;
  fprintf(stderr, "%s\n", user_input);
  fprintf(stderr, "%*s", pos, "");
  fprintf(stderr, "^ ");
  vfprintf(stderr, fmt, ap);
  fprintf(stderr, "\n");
  exit(1);
}

bool startswith(char *p, char *q) {
  return memcmp(p, q, strlen(q)) == 0;
}

Token *new_token(TokenKind kind, Token *cur, char *str, int len, char *loc) {
  Token *tok = calloc(1, sizeof(Token));
  tok->kind = kind;
  tok->str = str;
  tok->len = len;
  tok->loc = loc;
  cur->next = tok;
  return tok;
}

bool is_ident1(char c) { return isalpha(c) || c == '_'; }
bool is_ident2(char c) { return isalnum(c) || c == '_'; }

Token *tokenize() {
  char *p = user_input;
  Token head;
  head.next = NULL;
  Token *cur = &head;

  while (*p) {
    if (isspace(*p)) { p++; continue; }

    // comments
    if (startswith(p, "//")) {
      p += 2;
      while (*p && *p != '\n') p++;
      continue;
    }
    if (startswith(p, "/*")) {
      char *q = strstr(p + 2, "*/");
      if (!q) error_at(p, "unclosed comment");
      p = q + 2;
      continue;
    }

    // string literal
    if (*p == '"') {
      char *start = p;
      p++;
      char *buf = calloc(1, 1);
      size_t cap = 0, len = 0;
      while (*p && *p != '"') {
        if (*p == '\\') {
          p++;
          char esc = *p;
          char out = esc;
          if (esc == 'n') out = '\n';
          else if (esc == 't') out = '\t';
          else if (esc == 'r') out = '\r';
          else if (esc == '\\') out = '\\';
          else if (esc == '"') out = '"';
          else out = esc;
          if (len + 1 >= cap) { cap = cap ? cap * 2 : 8; buf = realloc(buf, cap); }
          buf[len++] = out;
          p++;
        } else {
          if (len + 1 >= cap) { cap = cap ? cap * 2 : 8; buf = realloc(buf, cap); }
          buf[len++] = *p++;
        }
      }
      if (*p != '"') error_at(start, "unclosed string literal");
      p++; // skip closing "
      buf = realloc(buf, len + 1);
      buf[len] = '\0';
      Token *tok = new_token(TK_STR, cur, NULL, 0, start);
      tok->str = buf;
      tok->len = len;
      cur = tok;
      continue;
    }

    // multi-letter punctuator
    if (startswith(p, "==") || startswith(p, "!=") ||
        startswith(p, "<=") || startswith(p, ">=") ||
        startswith(p, "->") || startswith(p, "&&") ||
        startswith(p, "||") || startswith(p, "<<") ||
        startswith(p, ">>")) {
      cur = new_token(TK_RESERVED, cur, p, 2, p);
      p += 2;
      continue;
    }

    // single-letter punctuator
    if (strchr("+-*/()<>;=,{}[]&!~?:.%", *p)) {
      cur = new_token(TK_RESERVED, cur, p, 1, p);
      p++;
      continue;
    }

    // number
    if (isdigit(*p)) {
      char *q = p;
      int val = strtol(p, &p, 10);
      cur = new_token(TK_NUM, cur, q, p - q, q);
      cur->val = val;
      continue;
    }

    // identifier or keyword
    if (is_ident1(*p)) {
      char *q = p++;
      while (is_ident2(*p)) p++;
      int len = p - q;
      TokenKind kind = TK_IDENT;
      // keywords: int, return, if, else, while, for, sizeof
      if (len == 3 && memcmp(q, "int", 3) == 0) kind = TK_RESERVED;
      else if (len == 6 && memcmp(q, "return", 6) == 0) kind = TK_RESERVED;
      else if (len == 2 && memcmp(q, "if", 2) == 0) kind = TK_RESERVED;
      else if (len == 4 && memcmp(q, "else", 4) == 0) kind = TK_RESERVED;
      else if (len == 5 && memcmp(q, "while", 5) == 0) kind = TK_RESERVED;
      else if (len == 3 && memcmp(q, "for", 3) == 0) kind = TK_RESERVED;
      else if (len == 6 && memcmp(q, "sizeof", 6) == 0) kind = TK_RESERVED;
      cur = new_token(kind, cur, q, len, q);
      continue;
    }

    error_at(p, "invalid token");
  }

  new_token(TK_EOF, cur, p, 0, p);
  return head.next;
}

//
// Types
//

typedef enum {
  TY_INT,
  TY_PTR,
} TypeKind;

typedef struct Type Type;
struct Type {
  TypeKind kind;
  Type *base; // for pointer
  int size;
};

Type *ty_int;
Type *int_type() {
  if (!ty_int) {
    ty_int = calloc(1, sizeof(Type));
    ty_int->kind = TY_INT;
    ty_int->size = 4;
  }
  return ty_int;
}
Type *pointer_to(Type *base) {
  Type *t = calloc(1, sizeof(Type));
  t->kind = TY_PTR;
  t->base = base;
  t->size = 8;
  return t;
}

//
// AST
//

typedef enum {
  ND_ADD, ND_SUB, ND_MUL, ND_DIV,
  ND_EQ, ND_NE, ND_LT, ND_LE,
  ND_ASSIGN, ND_VAR, ND_NUM, ND_RETURN,
  ND_IF, ND_WHILE, ND_FOR, ND_BLOCK,
  ND_FUNCALL, ND_ADDR, ND_DEREF, ND_SIZEOF,
  ND_EXPR_STMT, ND_NULL,
} NodeKind;

typedef struct Node Node;
struct Node {
  NodeKind kind;
  Node *lhs;
  Node *rhs;
  Node *cond;
  Node *then;
  Node *els;
  Node *init;
  Node *inc;
  Node **stmts;
  int stmts_len;
  int val;
  char *name; // for var or func
  Type *ty;
  int offset; // for local variable
  Node **args;
  int args_len;
  char *str; // for string literal
};

Node *new_node(NodeKind kind) {
  Node *n = calloc(1, sizeof(Node));
  n->kind = kind;
  return n;
}
Node *new_binary(NodeKind kind, Node *lhs, Node *rhs) {
  Node *n = new_node(kind);
  n->lhs = lhs;
  n->rhs = rhs;
  return n;
}
Node *new_num(int val) {
  Node *n = new_node(ND_NUM);
  n->val = val;
  n->ty = int_type();
  return n;
}
Node *new_var_node(char *name) {
  Node *n = new_node(ND_VAR);
  n->name = strdup(name);
  n->ty = int_type();
  return n;
}
Node *new_strlit(char *s) {
  Node *n = new_node(ND_NULL);
  n->kind = ND_NULL;
  n->str = s;
  return n;
}

//
// Symbol table
//

typedef struct Var Var;
struct Var {
  Var *next;
  char *name;
  int offset;
  Type *ty;
  bool is_param;
};

Var *locals;

Var *find_var_by_name(char *name) {
  for (Var *v = locals; v; v = v->next) {
    if (strcmp(v->name, name) == 0) return v;
  }
  return NULL;
}

Var *push_var(char *name, Type *ty, bool is_param) {
  Var *v = calloc(1, sizeof(Var));
  v->name = strdup(name);
  v->ty = ty;
  v->is_param = is_param;
  v->next = locals;
  locals = v;
  return v;
}

//
// Function symbol
//

typedef struct Function Function;
struct Function {
  Function *next;
  char *name;
  Node *body;
  int stack_size;
  int params_count;
  char **params;
};

Function *functions;

//
// Parser
//

// forward
Node *program();
Node *declaration();
Node *stmt();
Node *expr();
Node *assign();
Node *equality();
Node *relational();
Node *add();
Node *mul();
Node *unary();
Node *postfix();
Node *primary();
Node *compound_stmt();

bool consume(char *op) {
  if (token->kind != TK_RESERVED || strlen(op) != token->len ||
      memcmp(token->str, op, token->len))
    return false;
  token = token->next;
  return true;
}

void expect(char *op) {
  if (token->kind != TK_RESERVED || strlen(op) != token->len ||
      memcmp(token->str, op, token->len))
    error_at(token->loc, "expected \"%s\"", op);
  token = token->next;
}

int expect_number() {
  if (token->kind != TK_NUM)
    error_at(token->loc, "expected a number");
  int val = token->val;
  token = token->next;
  return val;
}

char *expect_ident() {
  if (token->kind != TK_IDENT)
    error_at(token->loc, "expected an identifier");
  char *s = strndup(token->str, token->len);
  token = token->next;
  return s;
}

bool at_eof() { return token->kind == TK_EOF; }

bool is_keyword(char *kw) {
  if (token->kind != TK_RESERVED) return false;
  if (strlen(kw) != token->len) return false;
  return memcmp(token->str, kw, token->len) == 0;
}

// program = (function | declaration | stmt)*
Node *program() {
  Node *head = new_node(ND_BLOCK);
  head->stmts = NULL;
  head->stmts_len = 0;

  while (!at_eof()) {
    if (is_keyword("int")) {
      token = token->next; // consume int
      if (token->kind == TK_IDENT) {
        char *name = strndup(token->str, token->len);
        Token *save = token;
        token = token->next;
        if (consume("(")) {
          // parse parameter list (only int identifiers)
          Function *f = calloc(1, sizeof(Function));
          f->name = name;
          f->params_count = 0;
          f->params = NULL;
          while (!consume(")")) {
            if (is_keyword("int")) token = token->next;
            if (token->kind == TK_IDENT) {
              char *pname = strndup(token->str, token->len);
              token = token->next;
              f->params = realloc(f->params, sizeof(char *) * (f->params_count + 1));
              f->params[f->params_count++] = pname;
            }
            if (consume(",")) continue;
          }
          // parse function body
          f->body = compound_stmt();
          f->next = functions;
          functions = f;
          continue;
        } else {
          // declaration: revert token
          token = save;
          Node *d = declaration();
          head->stmts = realloc(head->stmts, sizeof(Node *) * (head->stmts_len + 1));
          head->stmts[head->stmts_len++] = d;
          continue;
        }
      } else {
        error_at(token->loc, "expected identifier after int");
      }
    }
    Node *s = stmt();
    head->stmts = realloc(head->stmts, sizeof(Node *) * (head->stmts_len + 1));
    head->stmts[head->stmts_len++] = s;
  }
  return head;
}

// declaration = ident ("=" expr)? ";"
Node *declaration() {
  char *name = expect_ident();
  Type *ty = int_type();
  // register local variable immediately
  push_var(name, ty, false);
  Node *node = new_node(ND_EXPR_STMT);
  if (consume("=")) {
    Node *rhs = expr();
    Node *lhs = new_var_node(name);
    Node *assign = new_binary(ND_ASSIGN, lhs, rhs);
    node->lhs = assign;
  } else {
    node->lhs = NULL;
  }
  expect(";");
  return node;
}

// compound_stmt = "{" (declaration | stmt)* "}"
Node *compound_stmt() {
  expect("{");
  Node *node = new_node(ND_BLOCK);
  node->stmts = NULL;
  node->stmts_len = 0;
  while (!consume("}")) {
    if (is_keyword("int")) {
      token = token->next;
      Node *d = declaration();
      node->stmts = realloc(node->stmts, sizeof(Node *) * (node->stmts_len + 1));
      node->stmts[node->stmts_len++] = d;
    } else {
      Node *s = stmt();
      node->stmts = realloc(node->stmts, sizeof(Node *) * (node->stmts_len + 1));
      node->stmts[node->stmts_len++] = s;
    }
  }
  return node;
}

// stmt = "return" expr ";" | "if" "(" expr ")" stmt ("else" stmt)? | "while" "(" expr ")" stmt
//      | "for" "(" (expr|declaration|";") ";" expr? ";" expr? ")" stmt
//      | compound_stmt | expr ";"
Node *stmt() {
  if (is_keyword("return")) {
    token = token->next;
    Node *n = new_node(ND_RETURN);
    n->lhs = expr();
    expect(";");
    return n;
  }

  if (is_keyword("if")) {
    token = token->next;
    expect("(");
    Node *cond = expr();
    expect(")");
    Node *then = stmt();
    Node *els = NULL;
    if (is_keyword("else")) {
      token = token->next;
      els = stmt();
    }
    Node *n = new_node(ND_IF);
    n->cond = cond;
    n->then = then;
    n->els = els;
    return n;
  }

  if (is_keyword("while")) {
    token = token->next;
    expect("(");
    Node *cond = expr();
    expect(")");
    Node *body = stmt();
    Node *n = new_node(ND_WHILE);
    n->cond = cond;
    n->then = body;
    return n;
  }

  if (is_keyword("for")) {
    token = token->next;
    expect("(");
    Node *init = NULL;
    if (!consume(";")) {
      if (is_keyword("int")) {
        token = token->next;
        init = declaration();
      } else {
        init = expr();
        expect(";");
      }
    }
    Node *cond = NULL;
    if (!consume(";")) {
      cond = expr();
      expect(";");
    }
    Node *inc = NULL;
    if (!consume(")")) {
      inc = expr();
      expect(")");
    }
    Node *body = stmt();
    Node *n = new_node(ND_FOR);
    n->init = init;
    n->cond = cond;
    n->inc = inc;
    n->then = body;
    return n;
  }

  if (token->kind == TK_RESERVED && token->len == 1 && token->str[0] == '{') {
    return compound_stmt();
  }

  Node *n = expr();
  expect(";");
  Node *es = new_node(ND_EXPR_STMT);
  es->lhs = n;
  return es;
}

// expr = assign
Node *expr() { return assign(); }

// assign = equality ("=" assign)?
Node *assign() {
  Node *node = equality();
  if (consume("=")) {
    Node *rhs = assign();
    node = new_binary(ND_ASSIGN, node, rhs);
  }
  return node;
}

// equality = relational ("==" relational | "!=" relational)*
Node *equality() {
  Node *node = relational();
  for (;;) {
    if (consume("==")) node = new_binary(ND_EQ, node, relational());
    else if (consume("!=")) node = new_binary(ND_NE, node, relational());
    else return node;
  }
}

// relational = add ("<" add | "<=" add | ">" add | ">=" add)*
Node *relational() {
  Node *node = add();
  for (;;) {
    if (consume("<")) node = new_binary(ND_LT, node, add());
    else if (consume("<=")) node = new_binary(ND_LE, node, add());
    else if (consume(">")) node = new_binary(ND_LT, add(), node);
    else if (consume(">=")) node = new_binary(ND_LE, add(), node);
    else return node;
  }
}

// add = mul ("+" mul | "-" mul)*
Node *add() {
  Node *node = mul();
  for (;;) {
    if (consume("+")) node = new_binary(ND_ADD, node, mul());
    else if (consume("-")) node = new_binary(ND_SUB, node, mul());
    else return node;
  }
}

// mul = unary ("*" unary | "/" unary)*
Node *mul() {
  Node *node = unary();
  for (;;) {
    if (consume("*")) node = new_binary(ND_MUL, node, unary());
    else if (consume("/")) node = new_binary(ND_DIV, node, unary());
    else return node;
  }
}

// unary = ("+" | "-" | "*" | "&" | "sizeof") unary | postfix
Node *unary() {
  if (consume("+")) return unary();
  if (consume("-")) return new_binary(ND_SUB, new_num(0), unary());
  if (consume("&")) {
    Node *n = new_node(ND_ADDR);
    n->lhs = unary();
    return n;
  }
  if (consume("*")) {
    Node *n = new_node(ND_DEREF);
    n->lhs = unary();
    return n;
  }
  if (is_keyword("sizeof")) {
    token = token->next;
    Node *n = new_node(ND_SIZEOF);
    n->lhs = unary();
    return n;
  }
  return postfix();
}

// postfix = primary ( "(" args? ")" | "[" expr "]" )*
Node *postfix() {
  Node *node = primary();
  for (;;) {
    if (consume("(")) {
      Node *n = new_node(ND_FUNCALL);
      n->name = node->name; // primary should have set name for identifier
      n->args = NULL;
      n->args_len = 0;
      if (!consume(")")) {
        while (1) {
          Node *a = expr();
          n->args = realloc(n->args, sizeof(Node *) * (n->args_len + 1));
          n->args[n->args_len++] = a;
          if (consume(")")) break;
          expect(",");
        }
      }
      node = n;
      continue;
    }
    if (consume("[")) {
      Node *idx = expr();
      expect("]");
      Node *addn = new_binary(ND_ADD, node, idx);
      Node *deref = new_node(ND_DEREF);
      deref->lhs = addn;
      node = deref;
      continue;
    }
    break;
  }
  return node;
}

// primary = "(" expr ")" | ident | num | string
Node *primary() {
  if (consume("(")) {
    Node *n = expr();
    expect(")");
    return n;
  }

  if (token->kind == TK_IDENT) {
    char *name = strndup(token->str, token->len);
    token = token->next;
    Node *n = new_var_node(name);
    n->name = name;
    return n;
  }

  if (token->kind == TK_NUM) {
    int val = token->val;
    token = token->next;
    return new_num(val);
  }

  if (token->kind == TK_STR) {
    char *s = token->str;
    token = token->next;
    Node *n = new_strlit(s);
    return n;
  }

  error_at(token->loc, "expected an expression");
  return NULL;
}

//
// Semantic: compute offsets for locals and parameters
//

void assign_lvar_offsets(Function *f) {
  // assign offsets for locals (locals list is in reverse order of declaration)
  int offset = 0;
  // first assign offsets for locals that are not params
  for (Var *v = locals; v; v = v->next) {
    if (v->is_param) continue;
    offset += 8; // 8-byte slots
    v->offset = offset;
  }
  // then assign offsets for params (we place them after locals)
  for (Var *v = locals; v; v = v->next) {
    if (!v->is_param) continue;
    offset += 8;
    v->offset = offset;
  }
  f->stack_size = ((offset + 15) / 16) * 16;
}

//
// String literal table
//

typedef struct StrLit StrLit;
struct StrLit {
  StrLit *next;
  char *s;
  int id;
};

StrLit *str_literals;
int str_label_seq = 0;

int add_string_literal(char *s) {
  StrLit *sl = calloc(1, sizeof(StrLit));
  sl->s = strdup(s);
  sl->id = ++str_label_seq;
  sl->next = str_literals;
  str_literals = sl;
  return sl->id;
}

//
// Code generator
//

int label_seq = 0;

void gen_lval(Node *node) {
  if (node->kind == ND_VAR) {
    Var *vv = find_var_by_name(node->name);
    if (!vv) error("undefined variable %s", node->name);
    printf("  lea rax, [rbp-%d]\n", vv->offset);
    printf("  push rax\n");
    return;
  }
  error("not an lvalue");
}

void gen(Node *node) {
  if (!node) return;

  switch (node->kind) {
  case ND_NUM:
    printf("  push %d\n", node->val);
    return;
  case ND_NULL:
    if (node->str) {
      int id = add_string_literal(node->str);
      printf("  lea rax, [rel .LC%d]\n", id);
      printf("  push rax\n");
      return;
    }
    break;
  case ND_VAR: {
    Var *vv = find_var_by_name(node->name);
    if (!vv) error("undefined variable %s", node->name);
    printf("  mov rax, rbp\n");
    printf("  sub rax, %d\n", vv->offset);
    printf("  push rax\n");
    return;
  }
  case ND_ASSIGN: {
    gen_lval(node->lhs);
    gen(node->rhs);
    printf("  pop rdi\n"); // value
    printf("  pop rax\n"); // address
    printf("  mov [rax], rdi\n");
    printf("  push rdi\n");
    return;
  }
  case ND_ADDR:
    gen_lval(node->lhs);
    return;
  case ND_DEREF:
    gen(node->lhs);
    printf("  pop rax\n");
    printf("  mov rax, [rax]\n");
    printf("  push rax\n");
    return;
  case ND_SIZEOF:
    // only support sizeof int and pointer (both treated as int size)
    printf("  push %d\n", int_type()->size);
    return;
  case ND_RETURN:
    gen(node->lhs);
    printf("  pop rax\n");
    printf("  mov rsp, rbp\n");
    printf("  pop rbp\n");
    printf("  ret\n");
    return;
  case ND_IF: {
    int seq = label_seq++;
    gen(node->cond);
    printf("  pop rax\n");
    printf("  cmp rax, 0\n");
    if (node->els) {
      printf("  je .Lelse%d\n", seq);
      gen(node->then);
      printf("  jmp .Lend%d\n", seq);
      printf(".Lelse%d:\n", seq);
      gen(node->els);
      printf(".Lend%d:\n", seq);
    } else {
      printf("  je .Lend%d\n", seq);
      gen(node->then);
      printf(".Lend%d:\n", seq);
    }
    return;
  }
  case ND_WHILE: {
    int seq = label_seq++;
    printf(".Lbegin%d:\n", seq);
    gen(node->cond);
    printf("  pop rax\n");
    printf("  cmp rax, 0\n");
    printf("  je .Lend%d\n", seq);
    gen(node->then);
    printf("  jmp .Lbegin%d\n", seq);
    printf(".Lend%d:\n", seq);
    return;
  }
  case ND_FOR: {
    int seq = label_seq++;
    if (node->init) gen(node->init);
    printf(".Lbegin%d:\n", seq);
    if (node->cond) {
      gen(node->cond);
      printf("  pop rax\n");
      printf("  cmp rax, 0\n");
      printf("  je .Lend%d\n", seq);
    }
    gen(node->then);
    if (node->inc) gen(node->inc);
    printf("  jmp .Lbegin%d\n", seq);
    printf(".Lend%d:\n", seq);
    return;
  }
  case ND_BLOCK: {
    for (int i = 0; i < node->stmts_len; i++) gen(node->stmts[i]);
    return;
  }
  case ND_EXPR_STMT:
    if (node->lhs) gen(node->lhs);
    // discard expression result
    printf("  pop rax\n");
    return;
  case ND_FUNCALL: {
    const char *regs[] = {"rdi", "rsi", "rdx", "rcx", "r8", "r9"};
    // evaluate args left-to-right and push them
    for (int i = 0; i < node->args_len; i++) gen(node->args[i]);
    // move args into registers (reverse order because pushed)
    for (int i = node->args_len - 1, r = 0; i >= 0 && r < 6; i--, r++) {
      printf("  pop %s\n", regs[r]);
    }
    // TODO: support >6 args on stack
    printf("  call %s\n", node->name);
    printf("  push rax\n");
    return;
  }
  case ND_ADD:
  case ND_SUB:
  case ND_MUL:
  case ND_DIV:
  case ND_EQ:
  case ND_NE:
  case ND_LT:
  case ND_LE: {
    gen(node->lhs);
    gen(node->rhs);
    printf("  pop rdi\n");
    printf("  pop rax\n");
    switch (node->kind) {
    case ND_ADD: printf("  add rax, rdi\n"); break;
    case ND_SUB: printf("  sub rax, rdi\n"); break;
    case ND_MUL: printf("  imul rax, rdi\n"); break;
    case ND_DIV: printf("  cqo\n  idiv rdi\n"); break;
    case ND_EQ:  printf("  cmp rax, rdi\n  sete al\n  movzb rax, al\n"); break;
    case ND_NE:  printf("  cmp rax, rdi\n  setne al\n  movzb rax, al\n"); break;
    case ND_LT:  printf("  cmp rax, rdi\n  setl al\n  movzb rax, al\n"); break;
    case ND_LE:  printf("  cmp rax, rdi\n  setle al\n  movzb rax, al\n"); break;
    default: break;
    }
    printf("  push rax\n");
    return;
  }
  default:
    error("codegen: unknown node kind %d", node->kind);
  }
}

//
// Utility: collect locals by scanning AST for declarations and parameters
//

void collect_locals_from_node(Node *node) {
  if (!node) return;
  switch (node->kind) {
  case ND_BLOCK:
    for (int i = 0; i < node->stmts_len; i++) collect_locals_from_node(node->stmts[i]);
    break;
  case ND_EXPR_STMT:
    // declaration nodes were already handled in parser by push_var
    if (node->lhs) collect_locals_from_node(node->lhs);
    break;
  case ND_IF:
    collect_locals_from_node(node->cond);
    collect_locals_from_node(node->then);
    collect_locals_from_node(node->els);
    break;
  case ND_WHILE:
    collect_locals_from_node(node->cond);
    collect_locals_from_node(node->then);
    break;
  case ND_FOR:
    collect_locals_from_node(node->init);
    collect_locals_from_node(node->cond);
    collect_locals_from_node(node->inc);
    collect_locals_from_node(node->then);
    break;
  case ND_RETURN:
    collect_locals_from_node(node->lhs);
    break;
  case ND_ASSIGN:
  case ND_ADD:
  case ND_SUB:
  case ND_MUL:
  case ND_DIV:
  case ND_EQ:
  case ND_NE:
  case ND_LT:
  case ND_LE:
    collect_locals_from_node(node->lhs);
    collect_locals_from_node(node->rhs);
    break;
  case ND_DEREF:
  case ND_ADDR:
  case ND_SIZEOF:
    collect_locals_from_node(node->lhs);
    break;
  case ND_FUNCALL:
    for (int i = 0; i < node->args_len; i++) collect_locals_from_node(node->args[i]);
    break;
  default:
    break;
  }
}

//
// Entry point: parse program and emit assembly
//

int main(int argc, char **argv) {
  if (argc != 2) {
    fprintf(stderr, "Usage: %s 'program'\n", argv[0]);
    return 1;
  }

  user_input = argv[1];
  token = tokenize();

  Node *prog = program();

  // Emit assembly header
  printf(".intel_syntax noprefix\n");

  // Emit functions
  for (Function *f = functions; f; f = f->next) {
    // reset locals list for this function
    locals = NULL;
    // push parameters as locals (in reverse order so first param is last in list)
    for (int i = f->params_count - 1; i >= 0; i--) {
      push_var(f->params[i], int_type(), true);
    }
    // collect locals declared in body (parser already pushed them)
    collect_locals_from_node(f->body);
    // assign offsets
    assign_lvar_offsets(f);

    // function label and prologue
    printf(".global %s\n", f->name);
    printf("%s:\n", f->name);
    printf("  push rbp\n");
    printf("  mov rbp, rsp\n");
    printf("  sub rsp, %d\n", f->stack_size);

    // move parameters from registers to stack slots for first 6 params
    const char *regs[] = {"rdi", "rsi", "rdx", "rcx", "r8", "r9"};
    for (int i = 0; i < f->params_count && i < 6; i++) {
      Var *v = find_var_by_name(f->params[i]);
      if (!v) continue;
      printf("  mov [rbp-%d], %s\n", v->offset, regs[i]);
    }
    // TODO: handle >6 params (on stack)

    // generate function body
    gen(f->body);

    // ensure return if none
    printf("  mov rsp, rbp\n");
    printf("  pop rbp\n");
    printf("  ret\n");
  }

  // If no functions, emit main from top-level block
  if (!functions) {
    // treat top-level as main
    locals = NULL;
    collect_locals_from_node(prog);
    Function tmp;
    tmp.stack_size = 0;
    assign_lvar_offsets(&tmp);
    printf(".global main\n");
    printf("main:\n");
    printf("  push rbp\n");
    printf("  mov rbp, rsp\n");
    printf("  sub rsp, %d\n", tmp.stack_size ? tmp.stack_size : 16);
    gen(prog);
    printf("  pop rax\n");
    printf("  mov rsp, rbp\n");
    printf("  pop rbp\n");
    printf("  ret\n");
  }

  // Emit string literals
  if (str_literals) {
    // print in reverse order so .LC1 is first declared
    // collect into array
    int n = str_label_seq;
    char **arr = calloc(n + 1, sizeof(char *));
    StrLit *s;
    for (s = str_literals; s; s = s->next) {
      arr[s->id] = s->s;
    }
    printf(".section .rodata\n");
    for (int i = 1; i <= n; i++) {
      printf(".LC%d:\n", i);
      // emit as bytes with escape for non-printables
      char *p = arr[i];
      printf("  .string \"");
      for (char *q = p; *q; q++) {
        char c = *q;
        if (c == '\\') printf("\\\\");
        else if (c == '\"') printf("\\\"");
        else if (c == '\n') printf("\\n");
        else if (c == '\t') printf("\\t");
        else if ((unsigned char)c < 32 || (unsigned char)c >= 127) {
          printf("\\x%02x", (unsigned char)c);
        } else {
          putchar(c);
        }
      }
      printf("\"\n");
    }
    free(arr);
  }

  return 0;
}
