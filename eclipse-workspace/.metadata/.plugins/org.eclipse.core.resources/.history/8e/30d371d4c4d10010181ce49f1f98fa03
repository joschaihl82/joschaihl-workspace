static void dump_trace_tail(int count) {
    int n = (count > trace_ring_size) ? trace_ring_size : count;
    uint32_t head = cpu.trace_head;
    for (int i = n; i > 0; --i) {
        uint32_t idx = (head - i) & (trace_ring_size - 1);
        printf("trace[%04" priu32 "]: rip=%016" prix64 " op=%02x op2=%02x modrm=%02x pref=%02x a=%016" prix64 " b=%016" prix64 "\n",
               idx, cpu.trace[idx].rip, cpu.trace[idx].opcode, cpu.trace[idx].op2, cpu.trace[idx].modrm, cpu.trace[idx].prefixes, cpu.trace[idx].info_a, cpu.trace[idx].info_b);
    }
}

static void dump_cpu_state(void) {
    printf("\n--- cpu state ---\n");
    printf("rax: %016" prix64 " rbx: %016" prix64 " rcx: %016" prix64 " rdx: %016" prix64 "\n", cpu.rax, cpu.rbx, cpu.rcx, cpu.rdx);
    printf("rsp: %016" prix64 " rbp: %016" prix64 " rsi: %016" prix64 " rdi: %016" prix64 "\n", cpu.rsp, cpu.rbp, cpu.rsi, cpu.rdi);
    printf("r8 : %016" prix64 " r9 : %016" prix64 " r10: %016" prix64 " r11: %016" prix64 "\n", cpu.r8, cpu.r9, cpu.r10, cpu.r11);
    printf("r12: %016" prix64 " r13: %016" prix64 " r14: %016" prix64 " r15: %016" prix64 "\n", cpu.r12, cpu.r13, cpu.r14, cpu.r15);
    printf("rip: %016" prix64 " rflags: %08" prix64 " (cf:%d zf:%d sf:%d of:%d pf:%d df:%d)\n",
