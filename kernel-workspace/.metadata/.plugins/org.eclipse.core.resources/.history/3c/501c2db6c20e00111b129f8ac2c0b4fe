cmake_minimum_required(VERSION 3.10)
project(exectrace1_module NONE)

# --- Configuration variables (override on the command line)
# Example:
#   cmake -DKERNEL_DIR=/lib/modules/$(uname -r)/build -DMODULE_NAME=exectrace1 -S . -B build
set(KERNEL_DIR "/lib/modules/${CMAKE_SYSTEM_VERSION}/build" CACHE PATH "Path to kernel build directory")
set(MODULE_NAME "exectrace1" CACHE STRING "Kernel module base name (without .ko)")
set(MODULE_SRC "exectrace1.c" CACHE STRING "Module source file")

# Fallback if the above kernel dir doesn't exist
if(NOT EXISTS "${KERNEL_DIR}")
  set(KERNEL_DIR "/lib/modules/${CMAKE_HOST_SYSTEM_VERSION}/build" CACHE PATH "Path to kernel build directory" FORCE)
endif()

# Output directory for built module
set(MODULE_OUTPUT_DIR "${CMAKE_BINARY_DIR}/out" CACHE PATH "Directory to place built .ko")

# Build target: invoke kernel build system
add_custom_target(build
  COMMAND ${CMAKE_COMMAND} -E make_directory "${MODULE_OUTPUT_DIR}"
  COMMAND ${CMAKE_MAKE_PROGRAM} -C "${KERNEL_DIR}" M="${CMAKE_SOURCE_DIR}" modules
  WORKING_DIRECTORY ${CMAKE_SOURCE_DIR}
  COMMENT "Building kernel module ${MODULE_NAME} using kernel build system at ${KERNEL_DIR}"
  VERBATIM
)

# Clean target: invoke kernel clean
add_custom_target(clean
  COMMAND ${CMAKE_MAKE_PROGRAM} -C "${KERNEL_DIR}" M="${CMAKE_SOURCE_DIR}" clean
  COMMAND ${CMAKE_COMMAND} -E rm -rf "${MODULE_OUTPUT_DIR}"
  WORKING_DIRECTORY ${CMAKE_SOURCE_DIR}
  COMMENT "Cleaning kernel module build artifacts"
  VERBATIM
)

# Install target: copy the .ko to MODULE_OUTPUT_DIR
add_custom_target(install
  DEPENDS build
  COMMAND ${CMAKE_COMMAND} -E make_directory "${MODULE_OUTPUT_DIR}"
  COMMAND ${CMAKE_COMMAND} -E copy_if_different
          "${CMAKE_SOURCE_DIR}/${MODULE_NAME}.ko"
          "${MODULE_OUTPUT_DIR}/${MODULE_NAME}.ko"
  COMMENT "Copying ${MODULE_NAME}.ko to ${MODULE_OUTPUT_DIR}"
  VERBATIM
)

# Convenience target to show configuration
add_custom_target(show
  COMMAND ${CMAKE_COMMAND} -E echo "Kernel dir: ${KERNEL_DIR}"
  COMMAND ${CMAKE_COMMAND} -E echo "Module source: ${MODULE_SRC}"
  COMMAND ${CMAKE_COMMAND} -E echo "Built module (after install): ${MODULE_OUTPUT_DIR}/${MODULE_NAME}.ko"
  VERBATIM
)

message(STATUS "CMake configured for kernel module build")
message(STATUS "Override KERNEL_DIR and MODULE_NAME with -DKERNEL_DIR=... -DMODULE_NAME=...")
