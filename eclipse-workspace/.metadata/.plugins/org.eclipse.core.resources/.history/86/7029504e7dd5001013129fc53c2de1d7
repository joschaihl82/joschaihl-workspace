// --- iv. lexer implementation ---

token *new_token(token_kind kind, token *cur, char *str, int len) {
    token *tok = calloc(1, sizeof(token));
    tok->kind = kind;
    tok->str = str;
    tok->len = len;
    tok->file_pos = str;
    cur->next = tok;
    return tok;
}

int is_ident_char(char c) { return isalnum((unsigned char)c) || c == '_'; }

int consume(char *op) {
    if (current_token->kind != tk_reserved || current_token->len != (int)strlen(op) || strncmp(current_token->str, op, current_token->len) != 0) return 0;
    current_token = current_token->next;
    return 1;
}

int consume_keyword(char *kw) {
    if (current_token->kind != tk_keyword || current_token->len != (int)strlen(kw) || strncmp(current_token->str, kw, current_token->len) != 0) return 0;
    current_token = current_token->next;
    return 1;
}

token *expect_ident() {
    if (current_token->kind != tk_ident) error_tok(current_token, "expected identifier");
    token *t = current_token;
    current_token = current_token->next;
    return t;
}

void expect(char *op) {
    if (!consume(op)) error_tok(current_token, "expected '%s'", op);
}

long expect_number() {
    if (current_token->kind != tk_num) error_tok(current_token, "expected number");
    long val = current_token->val;
    current_token = current_token->next;
    return val;
}

token *tokenize(char *p) {
    token *head = calloc(1, sizeof(token));
    token *cur = head;

next_token:
    while (*p) {
        if (isspace((unsigned char)*p)) { p++; continue; }
        if (p[0] == '/' && p[1] == '/') { while (*p && *p != '\n') p++; continue; }
        if (p[0] == '/' && p[1] == '*') { char *q = strstr(p + 2, "*/"); if (!q) error_at(p, "unterminated block comment"); p = q + 2; continue; }

        // string literal
        if (*p == '"') {
            char *q = p + 1;
            while (*q && *q != '"') { if (*q == '\\') q++; q++; }
            if (!*q) error_at(p, "unterminated string literal");
            cur = new_token(tk_reserved, cur, p, q - p + 1);
            p = q + 1;
            goto next_token;
        }

        // multi-character operators
        if (strncmp(p, "==", 2) == 0 || strncmp(p, "!=", 2) == 0 ||
            strncmp(p, "<=", 2) == 0 || strncmp(p, ">=", 2) == 0 ||
            strncmp(p, "<<=", 3) == 0 || strncmp(p, ">>=", 3) == 0 ||
            strncmp(p, "+=", 2) == 0 || strncmp(p, "-=", 2) == 0 ||
            strncmp(p, "*=", 2) == 0 || strncmp(p, "/=", 2) == 0 ||
            strncmp(p, "%=", 2) == 0 ||
            strncmp(p, "&=", 2) == 0 || strncmp(p, "|=", 2) == 0 ||
            strncmp(p, "^=", 2) == 0 ||
            strncmp(p, "&&", 2) == 0 || strncmp(p, "||", 2) == 0 ||
            strncmp(p, "->", 2) == 0 ||
            strncmp(p, "<<", 2) == 0 || strncmp(p, ">>", 2) == 0) {
            int len = 2;
            if (p[2] == '=') len = 3;
            cur = new_token(tk_reserved, cur, p, len);
            p += len;
            goto next_token;
        }

        // single-character operators
        if (strchr("+-*/%()=;{},&<>!~[]?:", *p)) {
            cur = new_token(tk_reserved, cur, p++, 1);
            goto next_token;
        }

        // keywords
        for (int i = 0; keywords[i].name; i++) {
            if ((int)strlen(p) >= keywords[i].len &&
                strncmp(p, keywords[i].name, keywords[i].len) == 0 &&
                !is_ident_char(p[keywords[i].len])) {
                cur = new_token(tk_keyword, cur, p, keywords[i].len);
                p += keywords[i].len;
                goto next_token;
            }
        }

        // identifier
        if (isalpha((unsigned char)*p) || *p == '_') {
            char *q = p++;
            while (is_ident_char(*p)) p++;
            cur = new_token(tk_ident, cur, q, p - q);
            goto next_token;
        }

        // number
        if (isdigit((unsigned char)*p)) {
            char *q = p;
            cur = new_token(tk_num, cur, p, 0);
            cur->val = strtol(p, &p, 0);
            cur->len = p - q;
            goto next_token;
        }

        error_at(p, "invalid token");
    }

    new_token(tk_eof, cur, p, 0);
    return head->next;
}

// --- v. ast node constructors ---

node *new_node(node_kind kind, node *lhs, node *rhs) {
    node *n = calloc(1, sizeof(node));
    n->kind = kind;
    n->lhs = lhs;
    n->rhs = rhs;
    add_type(n);
    return n;
}

node *new_num_node(long val) {
    node *n = calloc(1, sizeof(node));
    n->kind = nd_num;
    n->val = val;
    add_type(n);
    return n;
}

node *new_lvar_node(lvar *var) {
    node *n = calloc(1, sizeof(node));
    n->kind = nd_lvar;
    n->var = var;
    add_type(n);
    return n;
}

// --- vi. parser implementation (recursive descent) ---

// helper for address of variable, handles array decay
node *lvar_addr(token *tok, ty *type, int is_static) {
    lvar *var = find_lvar(tok, type, is_static);
    return new_lvar_node(var);
}

// primary = "(" expr ")" | "sizeof" unary | ident ("(" (assign ("," assign)*)? ")")? | num
node *primary() {
    if (consume("(")) {
        node *n = expr();
        expect(")");
        return n;
    }

    if (consume_keyword("sizeof")) {
        // For simplicity, sizeof returns the size of the following expression/type
        node *un = unary();
        add_type(un);
        return new_num_node(un->type->size);
    }

    if (current_token->kind == tk_ident) {
        token *tok = current_token;
        current_token = current_token->next;

        if (consume("(")) { // function call
            node *n = calloc(1, sizeof(node));
            n->kind = nd_funcall;
            n->name = strndup(tok->str, tok->len);

            node head = {};
            node *cur = &head;
            while (!consume(")")) {
                if (cur != &head) expect(",");
                cur->next = assign();
                cur = cur->next;
            }
            n->rhs = head.next; // arguments
            add_type(n);
            return n;
        }

        // local variable
        error_tok(tok, "variable '%s' used without declaration or initialization", strndup(tok->str, tok->len));
    }

    if (current_token->kind == tk_num) {
        return new_num_node(expect_number());
    }

    // String literal: decay to a pointer to char (stubbed)
    if (current_token->kind == tk_reserved && *current_token->str == '"') {
        error_tok(current_token, "string literal not supported in local context");
    }

    error_tok(current_token, "expected expression");
    return NULL; // unreachable
}

// postfix = primary ("[" expr "]" | "++" | "--")*
node *postfix() {
    node *n = primary();
    while (consume("[")) {
        node *idx = expr();
        expect("]");
        // a[i] is equivalent to *(a + i)
        node *add = new_node(nd_add, n, idx);
        n = new_node(nd_deref, add, NULL);
    }
    return n;
}

// unary = ("+" | "-" | "*" | "&" | "!" | "~")? postfix
node *unary() {
    if (consume("+")) return unary();
    if (consume("-")) return new_node(nd_sub, new_num_node(0), unary());
    if (consume("*")) return new_node(nd_deref, unary(), NULL);
    if (consume("&")) return new_node(nd_addr, unary(), NULL);
    if (consume("!")) return new_node(nd_not, unary(), NULL);
    if (consume("~")) return new_node(nd_bitnot, unary(), NULL);
    return postfix();
}

// mul = unary (("*" | "/" | "%") unary)*
node *mul() {
    node *n = unary();
    for (;;) {
        if (consume("*")) n = new_node(nd_mul, n, unary());
        else if (consume("/")) n = new_node(nd_div, n, unary());
        else if (consume("%")) n = new_node(nd_mod, n, unary());
        else return n;
    }
}

// add = mul (("+" | "-") mul)*
node *add() {
    node *n = mul();
    for (;;) {
        if (consume("+")) n = new_node(nd_add, n, mul());
        else if (consume("-")) n = new_node(nd_sub, n, mul());
        else return n;
    }
}

// shift = add (("<<" | ">>") add)*
node *shift() {
    node *n = add();
    for (;;) {
        if (consume("<<")) n = new_node(nd_shl, n, add());
        else if (consume(">>")) n = new_node(nd_shr, n, add());
        else return n;
    }
}

// relational = shift (("<" | "<=" | ">" | ">=") shift)*
node *relational() {
    node *n = shift();
    for (;;) {
        if (consume("<")) n = new_node(nd_lt, n, shift());
        else if (consume("<=")) n = new_node(nd_le, n, shift());
        else if (consume(">")) n = new_node(nd_lt, shift(), n); // swapped for a > b
        else if (consume(">=")) n = new_node(nd_le, shift(), n); // swapped for a >= b
        else return n;
    }
}

// equality = relational (("==" | "!=") relational)*
node *equality() {
    node *n = relational();
    for (;;) {
        if (consume("==")) n = new_node(nd_eq, n, relational());
        else if (consume("!=")) n = new_node(nd_ne, n, relational());
        else return n;
    }
}

// and = equality ("&" equality)*
node *and() {
    node *n = equality();
    for (;;) {
        if (consume("&")) n = new_node(nd_band, n, equality());
        else return n;
    }
}

// exclusive_or = and ("^" and)*
node *exclusive_or() {
    node *n = and();
    for (;;) {
        if (consume("^")) n = new_node(nd_bxor, n, and());
        else return n;
    }
}

// inclusive_or = exclusive_or ("|" exclusive_or)*
node *inclusive_or() {
    node *n = exclusive_or();
    for (;;) {
        if (consume("|")) n = new_node(nd_bor, n, exclusive_or());
        else return n;
    }
}

// logical_and = inclusive_or ("&&" inclusive_or)*
node *logical_and() {
    node *n = inclusive_or();
    for (;;) {
        if (consume("&&")) n = new_node(nd_logical_and, n, inclusive_or());
        else return n;
    }
}

// logical_or = logical_and ("||" logical_and)*
node *logical_or() {
    node *n = logical_and();
    for (;;) {
        if (consume("||")) n = new_node(nd_logical_or, n, logical_and());
        else return n;
    }
}

// conditional = logical_or ("?" expr ":" conditional)?
node *conditional() {
    node *n = logical_or();
    if (!consume("?")) return n;
    node *rhs = expr(); // then
    expect(":");
    node *els = conditional(); // else
    n->kind = nd_cond;
    n->rhs = rhs;
    n->els = els;
    add_type(n); // re-evaluate type after adding rhs/els
    return n;
}

// assign = conditional (("=" | "+=" | "-=" | "*=" | "/=" | "%=" | "<<=" | ">>=" | "&=" | "|=" | "^=") assign)?
node *assign() {
    node *n = conditional();

    if (consume("=")) return new_node(nd_assign, n, assign());
    if (consume("+=")) return new_node(nd_add_assign, n, assign());
    if (consume("-=")) return new_node(nd_sub_assign, n, assign());
    if (consume("*=")) return new_node(nd_mul_assign, n, assign());
    if (consume("/=")) return new_node(nd_div_assign, n, assign());
    if (consume("%=")) return new_node(nd_mod_assign, n, assign());
    if (consume("<<=")) return new_node(nd_shl_assign, n, assign());
    if (consume(">>=")) return new_node(nd_shr_assign, n, assign());
    if (consume("&=")) return new_node(nd_band_assign, n, assign());
    if (consume("|=")) return new_node(nd_bor_assign, n, assign());
    if (consume("^=")) return new_node(nd_bxor_assign, n, assign());

    return n;
}

// expr = assign
node *expr() {
    return assign();
}

// declaration = typespec declarator ("=" initializer)? ("," declarator ("=" initializer)?)* ";"
node *declaration() {
    int is_unsigned = 0;
    int is_static = 0;
    ty *base = parse_type_specifier(&is_unsigned, &is_static);

    node head = {};
    node *cur = &head;

    do {
        token *tok = current_token;
        ty *type = parse_declarator(base);
        if (tok->kind != tk_ident) error_tok(tok, "expected identifier in declaration");

        current_token = current_token->next;

        lvar *var = find_lvar(tok, type, is_static);
        node *lvar_node = new_lvar_node(var);

        if (consume("=")) {
            // Simple assignment initializer
            node *rhs = assign();
            cur->next = new_node(nd_assign, lvar_node, rhs);
            cur = cur->next;
        } else if (var->type->kind == ty_array && !is_static) {
            // Local arrays need zero initialization if no initializer is given
            node *n = calloc(1, sizeof(node));
            n->kind = nd_array_init_zero;
            n->var = var;
            cur->next = n;
            cur = cur->next;
        }
    } while (consume(","));

    expect(";");
    return head.next;
}

// stmt = "return" expr ";" | "if" "(" expr ")" stmt ("else" stmt)? | "while" "(" expr ")" stmt | "for" "(" (declaration | expr)? ";" expr? ";" expr? ")" stmt | "break" ";" | "continue" ";" | "switch" "(" expr ")" stmt | "case" num ":" stmt | "default" ":" stmt | "{" block | expr ";"
node *stmt() {
    if (consume_keyword("return")) {
        node *n = new_node(nd_return, expr(), NULL);
        expect(";");
        return n;
    }

    if (consume_keyword("if")) {
        node *n = calloc(1, sizeof(node));
        n->kind = nd_if;
        expect("(");
        n->lhs = expr(); // condition
        expect(")");
        n->rhs = stmt(); // then
        if (consume_keyword("else")) {
            n->els = stmt(); // else
        }
        return n;
    }
    if (consume_keyword("while")) {
        node *n = calloc(1, sizeof(node));
        n->kind = nd_while;
        expect("(");
        n->lhs = expr(); // condition
        expect(")");

        continue_break_labels cbl = { .continue_label = label_count++, .break_label = label_count++, .next = loop_or_switch_labels };
        loop_or_switch_labels = &cbl;
        node *body = stmt(); // body
        loop_or_switch_labels = cbl.next; // restore labels
        n->rhs = body;
        return n;
    }
    if (consume_keyword("for")) {
        node *n = calloc(1, sizeof(node));
        n->kind = nd_for;
        expect("(");

        // init
        if (!consume(";")) {
            if (is_type_token(current_token)) {
                n->lhs = declaration(); // allows declaration in init part
            } else {
                n->lhs = expr();
                expect(";");
            }
        }

        // cond
        if (!consume(";")) {
            n->rhs = expr();
            expect(";");
        }

        // inc
        if (!consume(")")) {
            n->els = expr();
            expect(")");
        }

        continue_break_labels cbl = { .continue_label = label_count++, .break_label = label_count++, .next = loop_or_switch_labels };
        loop_or_switch_labels = &cbl;
        node *body = stmt(); // body
        loop_or_switch_labels = cbl.next; // restore labels
        n->next = body; // using n->next for body here as it is a multi-part node
        return n;
    }
    if (consume_keyword("break")) {
        node *n = calloc(1, sizeof(node));
        n->kind = nd_break;
        expect(";");
        return n;
    }
    if (consume_keyword("continue")) {
        node *n = calloc(1, sizeof(node));
        n->kind = nd_continue;
        expect(";");
        return n;
    }

    // block or expression statement
    if (consume("{")) return block();

    node *n = expr();
    expect(";");
    node *expr_stmt = calloc(1, sizeof(node));
    expr_stmt->kind = nd_expr_stmt;
    expr_stmt->lhs = n;
    return expr_stmt;
}

// block = stmt* "}"
node *block() {
    node head = {};
    node *cur = &head;
    while (!consume("}")) {
        cur->next = stmt();
        cur = cur->next;
    }
    node *n = calloc(1, sizeof(node));
    n->kind = nd_block;
    n->rhs = head.next; // statements list
    return n;
}

ty *parse_type_specifier(int *is_unsigned_ptr, int *is_static_ptr) {
    ty *base = NULL;
    int count = 0;
    while (is_type_token(current_token)) {
        if (consume_keyword("int")) base = ty_int_def();
        else if (consume_keyword("char")) base = ty_char_def();
        else if (consume_keyword("long")) base = ty_long_def();
        else if (consume_keyword("unsigned")) *is_unsigned_ptr = 1;
        else if (consume_keyword("static")) *is_static_ptr = 1;
        else if (consume_keyword("struct")) error_tok(current_token, "struct definition not fully implemented"); // minimal placeholder
        count++;
    }
    if (!base) base = ty_int_def(); // default to int
    return base;
}

ty *parse_declarator(ty *base) {
    while (consume("*")) {
        base = new_type_ptr(base);
    }
    return base;
}

node *param_declaration() {
    int is_unsigned = 0;
    int is_static = 0; // parameters cannot be static
    ty *base = parse_type_specifier(&is_unsigned, &is_static);

    ty *type = parse_declarator(base);

    token *tok = expect_ident();

    lvar *var = find_lvar(tok, type, 0);
    current_func->num_params++;
    return new_lvar_node(var);
}


// global struct array declaration parser (specific to keywords[])
void parse_global_struct_array_decl() {
    // This function only handles: struct { char *name; int len; } keywords[] = { ... };

    consume_keyword("struct");
    if (!consume("{")) error_tok(current_token, "expected '{' after struct");
    if (!consume_keyword("char")) error_tok(current_token, "expected 'char'");
    expect("*");
    expect_ident(); // 'name'
    expect(";");
    if (!consume_keyword("int")) error_tok(current_token, "expected 'int'");
    expect_ident(); // 'len'
    expect(";");
    expect("}");

    token *tok = expect_ident(); // 'keywords'

    expect("[");
    expect("]");
    expect("=");
    expect("{");

    sdata *s = calloc(1, sizeof(sdata));
    s->label = strndup(tok->str, tok->len);
    sinit head = {};
    sinit *cur_init = &head;
    size_t array_len = 0;

    while (!consume("}")) {
        if (array_len > 0) consume(",");

        expect("{");

        if (current_token->kind != tk_reserved || *current_token->str != '"') error_tok(current_token, "expected string literal for 'name'");

        char *str_start = current_token->str + 1;
        char *str_end = str_start;
        while (*str_end != '"' && *str_end != '\0') str_end++;
        if (*str_end != '"') error_tok(current_token, "unterminated string literal in initializer");

        size_t str_len = str_end - str_start;
        char *str_content = malloc(str_len + 1);
        memcpy(str_content, str_start, str_len);
        str_content[str_len] = '\0';

        current_token = current_token->next;

        // char* (offset 0, size 8)
        cur_init->next = calloc(1, sizeof(sinit)); cur_init = cur_init->next;
        cur_init->kind = init_ptr;
        cur_init->str_label = str_content;
        cur_init->offset = array_len * 16 + 0;
        cur_init->size = 8;

        expect(",");

        // int (offset 8, size 4)
        if (current_token->kind != tk_num) error_tok(current_token, "expected number for 'len'");
        long val = expect_number();

        cur_init->next = calloc(1, sizeof(sinit)); cur_init = cur_init->next;
        cur_init->kind = init_int;
        cur_init->val = val;
        cur_init->offset = array_len * 16 + 8;
        cur_init->size = 4;

        expect("}");

        array_len++;
    }

    consume(",");

    s->inits = head.next;
    s->size = array_len * 16;

    expect(";");

    s->next = static_data_list;
    static_data_list = s;
}


// function definition
void parse_fundef() {
    int is_unsigned = 0;
    int is_static = 0;
    ty *base = parse_type_specifier(&is_unsigned, &is_static);

    ty *type = parse_declarator(base);

    if (type->kind != ty_ptr) error_tok(current_token, "expected a function definition");

    token *tok = expect_ident();

    function *f = calloc(1, sizeof(function));
    f->name = strndup(tok->str, tok->len);
    f->is_static = is_static;
    f->next = program_head;
    program_head = f;
    current_func = f;

    expect("(");

    // parameters
    while (!consume(")")) {
        if (f->num_params > 0) expect(",");
        param_declaration();
    }

    // body
    expect("{");
    f->body = block();

    // align stack size to 16 bytes for red zone/abi
    f->stack_size = (f->stack_size + 15) & ~15;
}

// --- vii. code generation implementation (x86-64) ---

// register mapping for integer arguments
char *arg_reg[] = {"rdi", "rsi", "rdx", "rcx", "r8", "r9"};

// Push the address of a variable onto the stack.
void emit_addr(node *n) {
    if (n->kind == nd_lvar) {
        if (n->var->is_static) {
            printf("  lea rax, %s[rip]\n", n->var->gname);
        } else {
            printf("  lea rax, [rbp-%d]\n", n->var->offset);
        }
        printf("  push rax\n");
        return;
    }
    if (n->kind == nd_deref) {
        emit_expr(n->lhs);
        return;
    }
    error_tok(current_token, "lvalue required");
}

// Load a value from the stack address into rax.
void emit_load(ty *type) {
    printf("  pop rax\n");
    if (type->kind == ty_array) return; // Arrays decay to pointer, already loaded.

    if (type->size == 1) {
        printf("  movzx rax, byte ptr [rax]\n");
    } else if (type->size == 4) {
        printf("  movsxd rax, dword ptr [rax]\n");
    } else {
        printf("  mov rax, [rax]\n");
    }
    printf("  push rax\n");
}

// Store the value in rax to the stack address (top of stack).
void emit_store(ty *type) {
    printf("  pop rdi\n"); // address
    printf("  pop rax\n"); // value

    if (type->size == 1) {
        printf("  mov [rdi], al\n");
    } else if (type->size == 4) {
        printf("  mov [rdi], eax\n");
    } else {
        printf("  mov [rdi], rax\n");
    }
    printf("  push rax\n");
}

// Emit code for an expression.
void emit_expr(node *n) {
    switch (n->kind) {
        case nd_num:
            printf("  push %ld\n", n->val);
            return;
        case nd_lvar:
            emit_addr(n);
            emit_load(n->type);
            return;
        case nd_assign:
            emit_addr(n->lhs);
            emit_expr(n->rhs);
            emit_store(n->lhs->type);
            return;
        case nd_add_assign: case nd_sub_assign: case nd_mul_assign: case nd_div_assign: case nd_mod_assign:
        case nd_shl_assign: case nd_shr_assign: case nd_band_assign: case nd_bor_assign: case nd_bxor_assign:
        { // compound assignment: x op= y -> x = x op y
            emit_addr(n->lhs);
            printf("  push qword ptr [rsp]\n"); // Duplicate address for store
            node_kind binary_op;
            switch (n->kind) {
                case nd_add_assign: binary_op = nd_add; break;
                case nd_sub_assign: binary_op = nd_sub; break;
                case nd_mul_assign: binary_op = nd_mul; break;
                case nd_div_assign: binary_op = nd_div; break;
                case nd_mod_assign: binary_op = nd_mod; break;
                case nd_shl_assign: binary_op = nd_shl; break;
                case nd_shr_assign: binary_op = nd_shr; break;
                case nd_band_assign: binary_op = nd_band; break;
                case nd_bor_assign: binary_op = nd_bor; break;
                case nd_bxor_assign: binary_op = nd_bxor; break;
                default: binary_op = 0; // Should not happen
            }
            emit_expr(new_node(binary_op, new_node(nd_deref, n->lhs, NULL), n->rhs));
            emit_store(n->lhs->type);
            return;
        }
        case nd_addr:
            emit_addr(n->lhs);
            return;
        case nd_deref:
            emit_expr(n->lhs);
            emit_load(n->type);
            return;
        case nd_funcall:
            // Function call logic (setup args, call, store result)
            // Save argument registers before evaluation
            int num_args = 0;
            for (node *arg = n->rhs; arg; arg = arg->next) {
                emit_expr(arg);
                num_args++;
            }
            // Move args from stack to registers
            for (int i = num_args - 1; i >= 0; i--) {
                printf("  pop %s\n", arg_reg[i]);
            }
            // Align stack pointer for call (rdi/rsi already saved)
            printf("  mov rax, 0\n"); // no floating point args
            printf("  call %s\n", n->name);
            printf("  push rax\n"); // function result
            return;

        // standard binary operators (non-short-circuiting)
        case nd_add: case nd_sub: case nd_mul: case nd_div: case nd_mod:
        case nd_shl: case nd_shr: case nd_band: case nd_bor: case nd_bxor:
        case nd_eq: case nd_ne: case nd_lt: case nd_le:
        {
            emit_expr(n->lhs);
            emit_expr(n->rhs);
            printf("  pop rdi\n");
            printf("  pop rax\n");

            // Pointer arithmetic scaling (only for + and -)
            int scale = 1;
            if ((n->kind == nd_add || n->kind == nd_sub) && (n->lhs->type->kind == ty_ptr || n->lhs->type->kind == ty_array)) {
                scale = n->lhs->type->base->size;
                if (n->kind == nd_add) {
                    printf("  imul rdi, %d\n", scale);
                } else if (n->kind == nd_sub && n->rhs->type->kind != ty_ptr) {
                    printf("  imul rdi, %d\n", scale);
                }
            }

            switch (n->kind) {
                case nd_add: printf("  add rax, rdi\n"); break;
                case nd_sub:
                    if (n->lhs->type->kind == ty_ptr && n->rhs->type->kind == ty_ptr) {
                        printf("  sub rax, rdi\n");
                        printf("  cqo\n");
                        printf("  mov rdi, %d\n", n->lhs->type->base->size);
                        printf("  idiv rdi\n"); // divide by scale factor
                    } else {
                        printf("  sub rax, rdi\n");
                    }
                    break;
                case nd_mul: printf("  imul rax, rdi\n"); break;
                case nd_div:
                    printf("  cqo\n"); printf("  idiv rdi\n"); break;
                case nd_mod:
                    printf("  cqo\n"); printf("  idiv rdi\n"); printf("  mov rax, rdx\n"); break;
                case nd_shl: printf("  mov rcx, rdi\n"); printf("  shl rax, cl\n"); break;
                case nd_shr: printf("  mov rcx, rdi\n"); printf("  shr rax, cl\n"); break;
                case nd_band: printf("  and rax, rdi\n"); break;
                case nd_bor: printf("  or rax, rdi\n"); break;
                case nd_bxor: printf("  xor rax, rdi\n"); break;

                // Comparison nodes: set if equal/not equal
                case nd_eq: printf("  cmp rax, rdi\n"); printf("  sete al\n"); printf("  movzx rax, al\n"); break;
                case nd_ne: printf("  cmp rax, rdi\n"); printf("  setne al\n"); printf("  movzx rax, al\n"); break;
                case nd_lt: printf("  cmp rax, rdi\n"); printf("  setl al\n"); printf("  movzx rax, al\n"); break;
                case nd_le: printf("  cmp rax, rdi\n"); printf("  setle al\n"); printf("  movzx rax, al\n"); break;
                default: break;
            }
            printf("  push rax\n");
            return;
        }
        case nd_not: // logical NOT
            emit_expr(n->lhs);
            printf("  pop rax\n");
            printf("  cmp rax, 0\n");
            printf("  sete al\n");
            printf("  movzx rax, al\n");
            printf("  push rax\n");
            return;
        case nd_bitnot: // bitwise NOT
            emit_expr(n->lhs);
            printf("  pop rax\n");
            printf("  not rax\n");
            printf("  push rax\n");
            return;
        case nd_logical_and: // short-circuiting logical and
        case nd_logical_or:  // short-circuiting logical or
        {
            int l_label = label_count++;
            int e_label = label_count++;

            emit_expr(n->lhs);
            printf("  pop rax\n");
            printf("  cmp rax, 0\n");

            if (n->kind == nd_logical_and) {
                // if lhs is 0, result is 0 (false), jump to end_label
                printf("  je .l%d\n", l_label);
            } else { // nd_logical_or
                // if lhs is non-0, result is 1 (true), jump to end_label
                printf("  jne .l%d\n", e_label);
            }

            // evaluate rhs
            emit_expr(n->rhs);
            printf("  pop rax\n");
            printf("  jmp .l%d\n", e_label);

            printf(".l%d:\n", l_label);
            printf("  mov rax, 0\n"); // result is 0 (for nd_logical_and failure)

            printf(".l%d:\n", e_label);
            // for nd_logical_or success, rax is already 1 from conditional jump:
            // if we jumped here from the beginning, rax holds the non-zero result.
            // if we flowed through, rax holds the result of rhs.
            printf("  push rax\n");
            return;
        }
        case nd_cond:
        {
            int l_label = label_count++;
            int e_label = label_count++;

            emit_expr(n->lhs); // condition
            printf("  pop rax\n");
            printf("  cmp rax, 0\n");
            printf("  je .l%d\n", l_label);

            emit_expr(n->rhs); // then
            printf("  jmp .l%d\n", e_label);

            printf(".l%d:\n", l_label);
            emit_expr(n->els); // else

            printf(".l%d:\n", e_label);
            return;
        }
        default:
            error_tok(current_token, "unsupported expression type in emit_expr");
    }
}

// Emit code for a statement.
void emit_stmt(node *n) {
    if (!n) return;

    switch (n->kind) {
        case nd_return:
            emit_expr(n->lhs);
            printf("  pop rax\n");
            printf("  jmp .l.return.%s\n", current_func->name);
            return;
        case nd_expr_stmt:
            emit_expr(n->lhs);
            printf("  pop rax\n"); // discard result
            return;
        case nd_block:
            for (node *cur = n->rhs; cur; cur = cur->next) {
                emit_stmt(cur);
            }
            return;
        case nd_if:
        {
            int l_label = label_count++;
            int e_label = l_label;

            emit_expr(n->lhs); // condition
            printf("  pop rax\n");
            printf("  cmp rax, 0\n");

            if (n->els) {
                e_label = label_count++;
                printf("  je .l%d\n", l_label);
                emit_stmt(n->rhs); // then
                printf("  jmp .l%d\n", e_label);
                printf(".l%d:\n", l_label);
                emit_stmt(n->els); // else
            } else {
                printf("  je .l%d\n", l_label);
                emit_stmt(n->rhs); // then
            }

            printf(".l%d:\n", e_label);
            return;
        }
        case nd_while:
        {
            int loop_label = label_count++;
            int continue_label = loop_or_switch_labels->continue_label;
            int break_label = loop_or_switch_labels->break_label;

            printf(".l%d:\n", loop_label); // start of loop (condition)
            emit_expr(n->lhs);
            printf("  pop rax\n");
            printf("  cmp rax, 0\n");
            printf("  je .l%d\n", break_label);

            emit_stmt(n->rhs); // body

            printf(".l%d:\n", continue_label); // continue target
            printf("  jmp .l%d\n", loop_label);

            printf(".l%d:\n", break_label); // break target
            return;
        }
        case nd_for:
        {
            int loop_label = label_count++;
            int continue_label = loop_or_switch_labels->continue_label;
            int break_label = loop_or_switch_labels->break_label;

            // init (n->lhs is init statement/declaration)
            emit_stmt(n->lhs);

            printf(".l%d:\n", loop_label); // start of loop (condition)

            // cond (n->rhs is condition expression)
            if (n->rhs) {
                emit_expr(n->rhs);
                printf("  pop rax\n");
                printf("  cmp rax, 0\n");
                printf("  je .l%d\n", break_label);
            }

            // body (n->next is body statement)
            emit_stmt(n->next);

            printf(".l%d:\n", continue_label); // continue target (increment)

            // inc (n->els is increment expression)
            if (n->els) {
                emit_expr(n->els);
                printf("  pop rax\n");
            }

            printf("  jmp .l%d\n", loop_label);

            printf(".l%d:\n", break_label); // break target
            return;
        }
        case nd_break:
            if (!loop_or_switch_labels) error_tok(current_token, "break statement not within loop or switch");
            printf("  jmp .l%d\n", loop_or_switch_labels->break_label);
            return;
        case nd_continue:
            if (!loop_or_switch_labels) error_tok(current_token, "continue statement not within loop or switch");
            printf("  jmp .l%d\n", loop_or_switch_labels->continue_label);
            return;
        case nd_array_init_zero:
            // Zero-out the local array on the stack
            printf("  mov rax, rbp\n");
            printf("  sub rax, %d\n", n->var->offset); // address of array start
            printf("  mov rdi, rax\n");
            printf("  mov rcx, %d\n", n->var->type->size / 8); // 8-byte chunks
            printf("  mov rax, 0\n");
            printf("  rep stosq\n");
            return;
        default:
            error_tok(current_token, "unsupported statement type in emit_stmt");
    }
}

// emit uninitialized global/static locals
void emit_global_statics() {
    if (!global_statics) return;

    printf("  .bss\n");
    for (gvar *g = global_statics; g; g = g->next) {
        printf("  .globl %s\n", g->name);
        printf("%s:\n", g->name);
        printf("  .zero %d\n", g->size);
    }
}

// emit static data (global array initialization, used for keywords[])
void emit_static_data() {
    if (!static_data_list) return;

    // First, emit all strings in .rodata section
    printf("  .section .rodata\n");
    int str_label_count = 0;
    for (sdata *s = static_data_list; s; s = s->next) {
        for (sinit *init = s->inits; init; init = init->next) {
            if (init->kind == init_ptr) {
                char *label = malloc(32);
                snprintf(label, 32, ".str.%d", str_label_count++);
                printf("%s:\n", label);
                printf("  .asciz \"%s\"\n", init->str_label);
                free(init->str_label);
                init->str_label = label;
            }
        }
    }

    // Second, emit the global array in .data section
    printf("  .data\n");
    for (sdata *s = static_data_list; s; s = s->next) {
        printf("  .globl %s\n", s->label);
        printf("%s:\n", s->label);

        // Emit initialized data (16 bytes per struct: 8-byte ptr + 4-byte int + 4-byte padding)
        for (sinit *init = s->inits; init; init = init->next) {
            if (init->kind == init_ptr) {
                // .quad is 8 bytes for pointer
                printf("  .quad %s\n", init->str_label);
            } else if (init->kind == init_int) {
                // .long is 4 bytes for int
                printf("  .long %ld\n", init->val);

                // Add 4 bytes of padding to complete the 16-byte struct
                printf("  .zero 4\n");
            }
        }
    }
}


void codegen_program(function *funcs) {
    printf("  .intel_syntax noprefix\n");

    // 1. emit global data
    emit_global_statics();
    emit_static_data();

    // 2. global function definitions (.text)
    printf("  .text\n");
    for (function *f = funcs; f; f = f->next) {
        current_func = f;

        // function declaration/label
        if (!f->is_static) {
            printf("  .globl %s\n", f->name);
        }
        printf("%s:\n", f->name);

        // prologue
        printf("  push rbp\n");
        printf("  mov rbp, rsp\n");
        // allocate stack space for local variables (aligned to 16)
        printf("  sub rsp, %d\n", f->stack_size);

        // initialize parameters from registers
        lvar *p = f->locals;
        for (int i = 0; i < f->num_params; i++) {
            // parameter variables are the first N locals
            printf("  mov [rbp-%d], %s\n", p->offset, arg_reg[i]);
            p = p->next;
        }

        // code body
        emit_stmt(f->body);

        // epilogue label
        printf(".l.return.%s:\n", f->name);
        printf("  mov rsp, rbp\n");
        printf("  pop rbp\n");
        printf("  ret\n");
    }
}

// --- main driver ---

int main(int argc, char **argv) {
    if (argc < 2) {
        fprintf(stderr, "usage: cc file.c\n");
        return 1;
    }

    // concatenate all input files into one buffer with preprocessing
    char *combined = NULL;
    size_t combined_len = 0;
    for (int i = 1; i < argc; i++) {
        char *buf = read_file_to_buffer(argv[i]);
        if (!buf) {
            fprintf(stderr, "cannot open file: %s\n", argv[i]);
            return 1;
        }
        char *pp = preprocess_includes_and_macros(buf, 0); // uses full pp logic
        free(buf);
        if (!combined) {
            combined = pp;
            combined_len = strlen(combined);
        } else {
            size_t newlen = combined_len + strlen(pp) + 2;
            combined = realloc(combined, newlen);
            memcpy(combined + combined_len, pp, strlen(pp));
            combined_len += strlen(pp);
            combined[combined_len] = '\0';
            free(pp);
        }
    }

    user_input = combined;

    // tokenize
    token *tok = tokenize(user_input);
    current_token = tok;

    // parse all function definitions and global data until eof
    while (current_token->kind != tk_eof) {
        if (current_token->kind == tk_keyword && strncmp(current_token->str, "struct", current_token->len) == 0) {
            parse_global_struct_array_decl();
        } else {
            parse_fundef();
        }
    }

    // code generation
    codegen_program(program_head);

    return 0;
}
