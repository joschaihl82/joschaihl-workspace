cmake_minimum_required(VERSION 3.15)

# Option: TARGET_WINDOWS = ON -> build for Windows (mingw-w64) even when running CMake on Linux
option(TARGET_WINDOWS "Build for Windows (mingw-w64) even on Linux" OFF)

# If user requested TARGET_WINDOWS, try to locate common mingw-w64 cross compilers
if (TARGET_WINDOWS)
  # Prefer 64-bit cross compiler, fall back to 32-bit if nötig
  find_program(MINGW64_GCC x86_64-w64-mingw32-gcc)
  find_program(MINGW32_GCC i686-w64-mingw32-gcc)
  find_program(MINGW64_WINDRES x86_64-w64-mingw32-windres)
  find_program(MINGW32_WINDRES i686-w64-mingw32-windres)

  if (MINGW64_GCC)
    set(CMAKE_C_COMPILER ${MINGW64_GCC} CACHE FILEPATH "mingw-w64 gcc" FORCE)
    if (MINGW64_WINDRES)
      set(CMAKE_RC_COMPILER ${MINGW64_WINDRES} CACHE FILEPATH "mingw-w64 windres" FORCE)
    endif()
    set(CMAKE_SYSTEM_PROCESSOR x86_64)
  elseif (MINGW32_GCC)
    set(CMAKE_C_COMPILER ${MINGW32_GCC} CACHE FILEPATH "mingw-w64 gcc (i686)" FORCE)
    if (MINGW32_WINDRES)
      set(CMAKE_RC_COMPILER ${MINGW32_WINDRES} CACHE FILEPATH "mingw-w64 windres (i686)" FORCE)
    endif()
    set(CMAKE_SYSTEM_PROCESSOR i686)
  else()
    message(WARNING "TARGET_WINDOWS=ON but no mingw-w64 compiler found in PATH. You can set -DCMAKE_C_COMPILER=/path/to/x86_64-w64-mingw32-gcc")
  endif()

  # Tell CMake the target system is Windows (affects e.g. WIN32 variable)
  set(CMAKE_SYSTEM_NAME Windows CACHE STRING "Target system name" FORCE)
endif()

project(MiniNotepad C)
set(CMAKE_C_STANDARD 11)
set(SRC_FILES notepad_clone.c)

# Choose WIN32 executable on Windows targets to suppress console window
if (TARGET_WINDOWS OR CMAKE_SYSTEM_NAME STREQUAL "Windows")
  add_executable(notepad_clone WIN32 ${SRC_FILES})
else()
  add_executable(notepad_clone ${SRC_FILES})
endif()

# Unicode defines for WinAPI code
target_compile_definitions(notepad_clone PRIVATE UNICODE _UNICODE)

# Compiler warnings and mingw-specific flags
if (CMAKE_C_COMPILER_ID STREQUAL "GNU")
  target_compile_options(notepad_clone PRIVATE -Wall -Wextra -Wno-unused-parameter)
  if (TARGET_WINDOWS)
    # -municode helps wWinMain handling on some mingw setups; optional
    target_compile_options(notepad_clone PRIVATE -municode)
  endif()
elseif (MSVC)
  target_compile_options(notepad_clone PRIVATE /W4)
endif()

# Link Windows libraries only when targeting Windows
if (TARGET_WINDOWS OR CMAKE_SYSTEM_NAME STREQUAL "Windows")
  target_link_libraries(notepad_clone PRIVATE user32 gdi32 comdlg32 kernel32)
endif()

# Install target (optional)
install(TARGETS notepad_clone RUNTIME DESTINATION bin)
