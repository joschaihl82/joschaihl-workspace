        mainLayout->addWidget(connGroup);

        // Splitter: left contacts, right chat/calls/log
        auto *split = new QSplitter(Qt::Horizontal, central);

        // Left: contacts and groups
        auto *left = new QWidget(this);
        auto *leftLayout = new QVBoxLayout(left);
        auto *contactsGroup = new QGroupBox("Contacts", left);
        auto *contactsLayout = new QVBoxLayout(contactsGroup);
        m_contactsList = new QListWidget(this);
        contactsLayout->addWidget(m_contactsList);
        auto *contactBtns = new QHBoxLayout();
        m_addContact = new QPushButton("+", this);
        m_removeContact = new QPushButton("-", this);
        m_callContact = new QPushButton("Call", this);
        m_chatContact = new QPushButton("Chat", this);
        contactBtns->addWidget(m_addContact);
        contactBtns->addWidget(m_removeContact);
        contactBtns->addWidget(m_callContact);
        contactBtns->addWidget(m_chatContact);
        contactsLayout->addLayout(contactBtns);
        leftLayout->addWidget(contactsGroup);
        split->addWidget(left);

        // Right: stacked chat/call/log
        auto *right = new QWidget(this);
        auto *rightLayout = new QVBoxLayout(right);
        m_tab = new QTabWidget(this);
        // Chat tab
        m_chatArea = new QWidget(this);
        auto *chatLayout = new QVBoxLayout(m_chatArea);
        m_chatStack = new QStackedWidget(this);
        chatLayout->addWidget(m_chatStack);
        m_tab->addTab(m_chatArea, "Chats");
        // Calls tab
        m_callsArea = new QWidget(this);
        auto *callsLayout = new QVBoxLayout(m_callsArea);
        m_callHistory = new QPlainTextEdit(this);
        m_callHistory->setReadOnly(true);
        callsLayout->addWidget(m_callHistory);
        m_tab->addTab(m_callsArea, "Calls");
        // Log tab
        m_logArea = new QWidget(this);
        auto *logLayout = new QVBoxLayout(m_logArea);
        m_logView = new QPlainTextEdit(this);
        m_logView->setReadOnly(true);
        logLayout->addWidget(m_logView);
        m_tab->addTab(m_logArea, "Activity");
        rightLayout->addWidget(m_tab);
        split->addWidget(right);

        mainLayout->addWidget(split);
        setCentralWidget(central);

        // Status bar
        statusBar()->showMessage("Ready");

        // Tray icon
        setupTray();

        // Connect signals
        connect(m_connectBtn, &QPushButton::clicked, this, &MainWindow::onConnect);
        connect(m_disconnectBtn, &QPushButton::clicked, this, &MainWindow::onDisconnect);
        connect(m_registerBtn, &QPushButton::clicked, this, &MainWindow::onRegister);
        connect(m_settingsBtn, &QPushButton::clicked, this, &MainWindow::onSettings);
        connect(m_addContact, &QPushButton::clicked, this, &MainWindow::onAddContact);
        connect(m_removeContact, &QPushButton::clicked, this, &MainWindow::onRemoveContact);
        connect(m_callContact, &QPushButton::clicked, this, &MainWindow::onCallContact);
        connect(m_chatContact, &QPushButton::clicked, this, &MainWindow::onChatContact);

        // Logger wiring
        connect(m_logger, &Logger::newLog, this, &MainWindow::onNewLog);

        // Xmpp wiring
        connect(m_xmpp, &XmppController::connected, this, &MainWindow::onXmppConnected);
        connect(m_xmpp, &XmppController::disconnected, this, &MainWindow::onXmppDisconnected);
        connect(m_xmpp, &XmppController::rosterUpdated, this, &MainWindow::onRosterUpdated);
        connect(m_xmpp, &XmppController::messageReceived, this, &MainWindow::onMessageReceived);

        // Call wiring
        connect(m_callManager, &CallManager::callStarted, this, &MainWindow::onCallStarted);
        connect(m_callManager, &CallManager::callEnded, this, &MainWindow::onCallEnded);

        // Load persisted settings
        loadSettings();

        // Self-test in mock mode if requested
        if (m_settings.value("mockMode", false).toBool()) {
            enterMockMode();
        }
    }

    ~MainWindow() override {
        if (m_tray) { m_tray->hide(); delete m_tray; m_tray = nullptr; }
    }

private slots:
    void onConnect() {
        QString jid = m_jid->text().trimmed();
        QString pw = m_password->text();
        QString server = m_server->text().trimmed();
        int port = m_port->text().toInt();
        if (jid.isEmpty() || pw.isEmpty()) {
            QMessageBox::warning(this, "Missing", "Please enter JID and password.");
            return;
        }
        m_xmpp->connectToServer(jid, pw, server, port);
        m_logger->log(QString("Connect requested: %1").arg(jid));
        // persist credentials if auto-connect
        if (m_settings.value("autoConnect", false).toBool()) {
            m_settings.setValue("jid", jid);
            m_settings.setValue("password", pw);
            m_settings.setValue("server", server);
            m_settings.sync();
        }
    }
    void onDisconnect() {
        m_xmpp->disconnectFromServer();
    }
    void onRegister() {
        // show registration dialog
        RegistrationWindow dlg(this);
        dlg.exec();
    }
    void onSettings() {
        SettingsDialog dlg(&m_settings, m_audio, this);
        if (dlg.exec() == QDialog::Accepted) {
            // apply settings
            QString inDev = m_settings.value("inputDevice", "").toString();
            QString outDev = m_settings.value("outputDevice", "").toString();
            if (!inDev.isEmpty()) m_audio->setInputDeviceByName(inDev);
            if (!outDev.isEmpty()) m_audio->setOutputDeviceByName(outDev);
            m_audio->setAgcEnabled(m_settings.value("agcEnabled", true).toBool());
            m_audio->setAgcTargetRms(m_settings.value("agcTarget", 1000).toDouble());
            m_audio->setAgcAttack(m_settings.value("agcAttack", 0.02).toDouble());
            m_audio->setAgcRelease(m_settings.value("agcRelease", 0.1).toDouble());
            m_logger->log("Settings applied");
        }
    }
    void onAddContact() {
        bool ok = false;
        QString jid = QInputDialog::getText(this, "Add Contact", "JID:", QLineEdit::Normal, QString(), &ok);
        if (ok && !jid.isEmpty()) {
            m_xmpp->addRosterItem(jid);
            refreshContacts();
        }
    }
    void onRemoveContact() {
        QListWidgetItem *it = m_contactsList->currentItem();
        if (!it) return;
        QString jid = it->text();
        m_xmpp->removeRosterItem(jid);
        refreshContacts();
    }
    void onCallContact() {
        QListWidgetItem *it = m_contactsList->currentItem();
        if (!it) return;
        QString jid = it->text();
        m_callManager->startCall(jid);
    }
    void onChatContact() {
        QListWidgetItem *it = m_contactsList->currentItem();
        if (!it) return;
        QString jid = it->text();
        openChat(jid);
    }
    void onNewLog(const QString &line) {
        m_logView->appendPlainText(line);
    }
    void onXmppConnected() {
        statusBar()->showMessage("Connected");
        m_logger->log("Connected to XMPP server");
        refreshContacts();
        showTrayMessage("Connected", "Connected to XMPP server");
    }
    void onXmppDisconnected() {
        statusBar()->showMessage("Disconnected");
        m_logger->log("Disconnected from XMPP server");
        showTrayMessage("Disconnected", "Disconnected from XMPP server");
    }
    void onRosterUpdated() {
        refreshContacts();
    }
    void onMessageReceived(const QString &from, const QString &body) {
        m_logger->log(QString("Incoming message from %1: %2").arg(from, body));
        if (!m_chatWindows.contains(from)) openChat(from);
        ChatWindow *cw = qobject_cast<ChatWindow *>(m_chatWindows[from]);
        if (cw) cw->appendRemote(from, body);
        showTrayMessage("New message", QString("From %1: %2").arg(from, body));
    }
    void onCallStarted(const QString &jid) {
        m_callHistory->appendPlainText(QString("[%1] Call started: %2").arg(nowString(), jid));
        m_logger->log(QString("Call started with %1").arg(jid));
    }
    void onCallEnded(const QString &jid) {
        m_callHistory->appendPlainText(QString("[%1] Call ended: %2").arg(nowString(), jid));
        m_logger->log(QString("Call ended with %1").arg(jid));
    }

private:
    void refreshContacts() {
        m_contactsList->clear();
        QStringList jids = m_xmpp->rosterJids();
        for (const QString &j : jids) {
            m_contactsList->addItem(j);
        }
    }
    void openChat(const QString &jid) {
        if (m_chatWindows.contains(jid)) {
            QWidget *w = m_chatWindows[jid];
            m_chatStack->setCurrentWidget(w);
            return;
        }
        ChatWindow *cw = new ChatWindow(jid, m_xmpp, m_logger, this);
        m_chatWindows.insert(jid, cw);
        m_chatStack->addWidget(cw);
        m_chatStack->setCurrentWidget(cw);
    }
    void setupTray() {
        if (!QSystemTrayIcon::isSystemTrayAvailable()) return;
        m_tray = new QSystemTrayIcon(this);
        m_tray->setIcon(style()->standardIcon(QStyle::SP_ComputerIcon));
        QMenu *menu = new QMenu(this);
        QAction *showAct = new QAction("Show", this);
        QAction *quitAct = new QAction("Quit", this);
        menu->addAction(showAct);
        menu->addSeparator();
        menu->addAction(quitAct);
        m_tray->setContextMenu(menu);
        connect(showAct, &QAction::triggered, this, &MainWindow::showNormal);
        connect(quitAct, &QAction::triggered, qApp, &QApplication::quit);
        connect(m_tray, &QSystemTrayIcon::activated, this, &MainWindow::onTrayActivated);
        m_tray->show();
    }
    void onTrayActivated(QSystemTrayIcon::ActivationReason r) {
        if (r == QSystemTrayIcon::Trigger) {
            if (
