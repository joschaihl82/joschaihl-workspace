cmake_minimum_required(VERSION 3.16)
project(MiniGTK4Browser C)

# C Standard
set(CMAKE_C_STANDARD 11)
set(CMAKE_C_STANDARD_REQUIRED ON)

# Require pkg-config
find_package(PkgConfig REQUIRED)

# Find GTK4 and WebKitGTK 6
pkg_check_modules(GTK4 REQUIRED gtk4)
pkg_check_modules(WEBKIT REQUIRED webkit2gtk-6.0)

# Source and target
set(SRC browser.c)
add_executable(browser ${SRC})

# Include directories from pkg-config
target_include_directories(browser PRIVATE
  ${GTK4_INCLUDE_DIRS}
  ${WEBKIT_INCLUDE_DIRS}
)

# Compiler flags from pkg-config (e.g. -D, -I, -pthread)
target_compile_options(browser PRIVATE
  ${GTK4_CFLAGS_OTHER}
  ${WEBKIT_CFLAGS_OTHER}
)

# Link libraries from pkg-config
target_link_libraries(browser PRIVATE
  ${GTK4_LIBRARIES}
  ${WEBKIT_LIBRARIES}
)

# Linker flags (if any extra flags are provided by pkg-config)
if(GTK4_LDFLAGS)
  target_link_options(browser PRIVATE ${GTK4_LDFLAGS})
endif()
if(WEBKIT_LDFLAGS)
  target_link_options(browser PRIVATE ${WEBKIT_LDFLAGS})
endif()

# Make sure pkg-config variables are visible for IDEs
set_target_properties(browser PROPERTIES
  INTERFACE_INCLUDE_DIRECTORIES "${GTK4_INCLUDE_DIRS};${WEBKIT_INCLUDE_DIRS}"
)

# Optional: install target
install(TARGETS browser RUNTIME DESTINATION bin)
