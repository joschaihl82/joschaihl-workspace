            return;
        }
        m_controller->connectToServer(jid, pw, server, port);
        statusBar()->showMessage("Connecting...");
        appendLog(QString("Connecting to %1").arg(jid));
    }

    void onDisconnectClicked() {
        m_controller->disconnectFromServer();
        statusBar()->showMessage("Disconnecting...");
        appendLog("Disconnect requested");
    }

    void onRegisterClicked() {
        m_registrationWindow->show();
    }

    void onXmppConnected() {
        statusBar()->showMessage("Connected");
        appendLog("Connected to XMPP server");
        m_userList->refreshRoster();
    }

    void onXmppDisconnected() {
        statusBar()->showMessage("Disconnected");
        appendLog("Disconnected from XMPP server");
    }

    void onRosterUpdated() {
        appendLog("Roster updated");
        m_userList->refreshRoster();
    }

    void onTick() {
        // Periodic UI housekeeping
        // For example, update log label with timestamp
        Q_UNUSED(nowString());
    }

private:
    void appendLog(const QString &text) {
        QString current = m_logText->text();
        QString newText = QString("[%1] %2\n%3").arg(nowString()).arg(text).arg(current);
        m_logText->setText(newText);
    }

    QLineEdit *m_jidEdit;
    QLineEdit *m_passwordEdit;
    QLineEdit *m_serverEdit;
    QLineEdit *m_portEdit;
    QPushButton *m_connectBtn;
