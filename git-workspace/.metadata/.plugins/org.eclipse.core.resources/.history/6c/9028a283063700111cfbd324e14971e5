// ---------- Helper: synchronous POST JSON ----------
static bool postJsonSync(QNetworkAccessManager &mgr, const QUrl &url, const QByteArray &json,
                         const QByteArray &authHeader, int timeoutMs, int &httpStatus, QByteArray &responseBody)
{
    QNetworkRequest req(url);
    req.setHeader(QNetworkRequest::ContentTypeHeader, "application/json");
    if (!authHeader.isEmpty()) req.setRawHeader("Authorization", authHeader);
    QNetworkReply *reply = mgr.post(req, json);
    QEventLoop loop;
    QTimer timer;
    timer.setSingleShot(true);
    QObject::connect(reply, &QNetworkReply::finished, &loop, &QEventLoop::quit);
    QObject::connect(&timer, &QTimer::timeout, &loop, &QEventLoop::quit);
    timer.start(timeoutMs);
    loop.exec();
    if (!timer.isActive()) {
        reply->abort();
        responseBody = reply->readAll();
        httpStatus = 0;
        reply->deleteLater();
        return false;
    }
    responseBody = reply->readAll();
    QVariant status = reply->attribute(QNetworkRequest::HttpStatusCodeAttribute);
    httpStatus = status.isValid() ? status.toInt() : 0;
    reply->deleteLater();
    return (httpStatus >= 200 && httpStatus < 300);
}

// ---------- libgit2 credential callback ----------
struct CredContext {
    QByteArray token;
};

static int credentials_cb(git_cred **out,
                          const char *url,
                          const char *username_from_url,
                          unsigned int allowed_types,
                          void *payload)
{
    Q_UNUSED(url);
    Q_UNUSED(username_from_url);
    CredContext *ctx = static_cast<CredContext*>(payload);

    if (allowed_types & GIT_CREDTYPE_USERPASS_PLAINTEXT) {
        const char *user = "x-access-token";
        const char *pass = ctx->token.constData();
        return git_cred_userpass_plaintext_new(out, user, pass);
    }
    return GIT_PASSTHROUGH;
}

// Forward declaration for CombinedPayload used in callbacks
struct CombinedPayload;

// ---------- Worker (runs in background thread) ----------
class GitPushWorker : public QObject {
    Q_OBJECT
public:
    GitPushWorker(const QString &dirPath,
                  const QString &githubUser,
                  const QString &token,
                  bool isPrivate)
        : m_dirPath(dirPath), m_githubUser(githubUser), m_token(token), m_isPrivate(isPrivate),
          m_lastBytes(0), m_firstProgress(true)
    {
        m_speedTimer.invalidate();
    }

signals:
    void progressUpdated(qint64 transferred, qint64 total, double bytesPerSec);
    void message(const QString &text);
    void finished(int exitCode);

public slots:
    void run() {
        // 1) create repo on GitHub
        emit message(QStringLiteral("Erstelle Repository auf GitHub..."));
        QNetworkAccessManager mgr;
        QUrl url("https://api.github.com/user/repos");
        QJsonObject body;
        body["name"] = QFileInfo(m_dirPath).fileName();
        body["private"] = m_isPrivate;
        body["auto_init"] = false;
        QByteArray json = QJsonDocument(body).toJson();
        QByteArray authHeader = QString("token %1").arg(m_token).toUtf8();

        int httpStatus = 0;
        QByteArray resp;
        if (!postJsonSync(mgr, url, json, authHeader, 30000, httpStatus, resp)) {
            emit message(QStringLiteral("Fehler: Repository-Erstellung fehlgeschlagen: %1").arg(QString::fromUtf8(resp)));
            emit finished(4);
            return;
        }
        emit message(QStringLiteral("Repository erstellt. Initialisiere lokales Repo..."));

        // 2) libgit2 init/open
        git_libgit2_init();
        git_repository *repo = nullptr;
        int error = git_repository_open(&repo, m_dirPath.toUtf8().constData());
        if (error == GIT_ENOTFOUND) {
            error = git_repository_init(&repo, m_dirPath.toUtf8().constData(), 0);
            if (error) {
                emit message(QStringLiteral("Fehler beim Initialisieren des Repositories: %1").arg(error));
                git_libgit2_shutdown();
                emit finished(5);
                return;
            }
        } else if (error) {
            emit message(QStringLiteral("Fehler beim Öffnen des Repositories: %1").arg(error));
            git_libgit2_shutdown();
            emit finished(5);
            return;
        }

        // 3) add files to index
        emit message(QStringLiteral("Füge Dateien zum Index hinzu..."));
        git_index *index = nullptr;
        error = git_repository_index(&index, repo);
        if (error) {
            emit message(QStringLiteral("Fehler beim Zugriff auf Index: %1").arg(error));
            git_repository_free(repo);
            git_libgit2_shutdown();
            emit finished(6);
            return;
        }

        QDirIterator it(m_dirPath, QDir::Files | QDir::NoSymLinks | QDir::NoDotAndDotDot, QDirIterator::Subdirectories);
        while (it.hasNext()) {
            QString filePath = it.next();
            QString rel = QDir(m_dirPath).relativeFilePath(filePath);
            QByteArray relUtf8 = rel.toUtf8();
            error = git_index_add_bypath(index, relUtf8.constData());
            if (error) {
                git_index_free(index);
                emit message(QStringLiteral("Fehler beim Hinzufügen: %1").arg(error));
                git_repository_free(repo);
                git_libgit2_shutdown();
                emit finished(6);
                return;
            }
        }
        error = git_index_write(index);
        git_index_free(index);
        if (error) {
            emit message(QStringLiteral("Fehler beim Schreiben des Index: %1").arg(error));
            git_repository_free(repo);
            git_libgit2_shutdown();
            emit finished(6);
            return;
        }

        // 4) commit if needed
        emit message(QStringLiteral("Erstelle Commit..."));
        git_index *idx2 = nullptr;
        error = git_repository_index(&idx2, repo);
        if (error) {
            emit message(QStringLiteral("Fehler Index: %1").arg(error));
            git_repository_free(repo);
            git_libgit2_shutdown();
            emit finished(7);
            return;
        }
        if (git_index_entrycount(idx2) > 0) {
            git_oid tree_oid;
            error = git_index_write_tree(&tree_oid, idx2);
            if (error) { git_index_free(idx2); emit message(QStringLiteral("Fehler write_tree: %1").arg(error)); git_repository_free(repo); git_libgit2_shutdown(); emit finished(7); return; }
            git_tree *tree = nullptr;
            error = git_tree_lookup(&tree, repo, &tree_oid);
            if (error) { git_index_free(idx2); emit message(QStringLiteral("Fehler tree_lookup: %1").arg(error)); git_repository_free(repo); git_libgit2_shutdown(); emit finished(7); return; }

            git_signature *sig = nullptr;
            error = git_signature_now(&sig, "gitpush", "gitpush@example.com");
            if (error) { git_tree_free(tree); git_index_free(idx2); emit message(QStringLiteral("Fehler signature: %1").arg(error)); git_repository_free(repo); git_libgit2_shutdown(); emit finished(7); return; }

            // parent if exists
            git_reference *head_ref = nullptr;
            git_commit *parent = nullptr;
            if (git_reference_lookup(&head_ref, repo, "HEAD") == 0) {
                git_oid parent_oid;
                if (git_reference_name_to_id(&parent_oid, repo, "HEAD") == 0) {
                    if (git_commit_lookup(&parent, repo, &parent_oid) != 0) parent = nullptr;
                }
            }

            git_oid commit_oid;
            const git_commit *parents[1];
            int parent_count = 0;
            if (parent) { parents[0] = parent; parent_count = 1; }

            error = git_commit_create_v(&commit_oid, repo, "HEAD", sig, sig, nullptr, "Initial commit", tree, parent_count, parent_count ? parents : nullptr);
            git_signature_free(sig);
            if (parent) git_commit_free(parent);
            if (head_ref) git_reference_free(head_ref);
            git_tree_free(tree);
            git_index_free(idx2);

            if (error) {
                emit message(QStringLiteral("Fehler beim Commit: %1").arg(error));
                git_repository_free(repo);
                git_libgit2_shutdown();
                emit finished(8);
                return;
            }
        } else {
            git_index_free(idx2);
            emit message(QStringLiteral("Keine Änderungen zum Committen."));
        }

        // 5) remote create
        emit message(QStringLiteral("Füge Remote origin hinzu..."));
        QString remoteUrl = QString("https://github.com/%1/%2.git").arg(m_githubUser, QFileInfo(m_dirPath).fileName());
        git_remote *existing = nullptr;
        if (git_remote_lookup(&existing, repo, "origin") == 0) {
            git_remote_delete(repo, "origin");
            if (existing) git_remote_free(existing);
        }
        git_remote *remote = nullptr;
        error = git_remote_create(&remote, repo, "origin", remoteUrl.toUtf8().constData());
        if (error) {
            emit message(QStringLiteral("Fehler beim Anlegen des Remote: %1").arg(error));
            git_repository_free(repo);
            git_libgit2_shutdown();
            emit finished(9);
            return;
        }
        git_remote_free(remote);

        // 6) push with progress callback (instantaneous speed)
        emit message(QStringLiteral("Starte Push..."));

        // prepare callbacks
        CredContext credCtx;
        credCtx.token = m_token.toUtf8();

        // Combined payload to pass both cred context and worker pointer
        struct CombinedPayload {
            CredContext *cred;
            GitPushWorker *worker;
        } combined;
        combined.cred = &credCtx;
        combined.worker = this;

        // callbacks
        git_remote_callbacks callbacks = GIT_REMOTE_CALLBACKS_INIT;
        callbacks.credentials = [](git_cred **out, const char *url, const char *username_from_url, unsigned int allowed_types, void *payload)->int {
            CombinedPayload *cp = static_cast<CombinedPayload*>(payload);
            return credentials_cb(out, url, username_from_url, allowed_types, cp->cred);
        };
        callbacks.transfer_progress = [](const git_transfer_progress *stats, void *payload)->int {
            CombinedPayload *cp = static_cast<CombinedPayload*>(payload);
            if (!cp || !cp->worker) return 0;
            qint64 received = (qint64)stats->received_bytes;
            qint64 total = (qint64)stats->total_bytes;
            // Direct call into worker's slot (same thread), compute instantaneous speed there
            QMetaObject::invokeMethod(cp->worker, "onLibgit2Progress", Qt::DirectConnection,
                                      Q_ARG(qint64, received), Q_ARG(qint64, total));
            return 0;
        };

        git_push_options push_opts;
        error = git_push_init_options(&push_opts, GIT_PUSH_OPTIONS_VERSION);
        if (error) {
            emit message(QStringLiteral("Fehler push options: %1").arg(error));
            git_repository_free(repo);
            git_libgit2_shutdown();
            emit finished(10);
            return;
        }
        push_opts.callbacks = callbacks;
        push_opts.callbacks.payload = &combined;

        // refspec: push HEAD to refs/heads/main (try main then master)
        const char *refs_main[] = { "HEAD:refs/heads/main" };
        git_strarray refspecs_main;
        refspecs_main.strings = const_cast<char**>(refs_main);
        refspecs_main.count = 1;

        git_remote *r = nullptr;
        if ((error = git_remote_lookup(&r, repo, "origin")) != 0) {
            emit message(QStringLiteral("Fehler remote lookup: %1").arg(error));
            git_repository_free(repo);
            git_libgit2_shutdown();
            emit finished(11);
            return;
        }

        error = git_remote_push(r, &refspecs_main, &push_opts);
        if (error) {
            // try master
            const char *refs_master[] = { "HEAD:refs/heads/master" };
            git_strarray refspecs_master;
            refspecs_master.strings = const_cast<char**>(refs_master);
            refspecs_master.count = 1;
            error = git_remote_push(r, &refspecs_master, &push_opts);
            if (error) {
                const git_error *e = git_error_last();
                QString errMsg = e ? QString::fromUtf8(e->message) : QStringLiteral("Unknown libgit2 error");
                emit message(QStringLiteral("Push fehlgeschlagen: %1").arg(errMsg));
                git_remote_free(r);
                git_repository_free(repo);
                git_libgit2_shutdown();
                emit finished(12);
                return;
            }
        }

        git_remote_free(r);
        emit message(QStringLiteral("Push erfolgreich abgeschlossen."));
        git_repository_free(repo);
        git_libgit2_shutdown();
        emit finished(0);
    }

    // Slot invoked from libgit2 callback (DirectConnection). Compute instantaneous speed.
public slots:
    void onLibgit2Progress(qint64 received, qint64 total) {
        qint64 nowMs = QDateTime::currentMSecsSinceEpoch();
        if (m_firstProgress) {
            m_lastBytes = received;
            m_lastTimeMs = nowMs;
            m_firstProgress = false;
            emit progressUpdated(received, total, 0.0);
            return;
        }
        qint64 deltaBytes = received - m_lastBytes;
        qint64 deltaMs = nowMs - m_lastTimeMs;
        double bytesPerSec = 0.0;
        if (deltaMs > 0) bytesPerSec = (double)deltaBytes / (deltaMs / 1000.0);
        // protect against negative or zero
        if (bytesPerSec < 0) bytesPerSec = 0.0;
        m_lastBytes = received;
        m_lastTimeMs = nowMs;
        emit progressUpdated(received, total, bytesPerSec);
    }

private:
    QString m_dirPath;
    QString m_githubUser;
    QString m_token;
    bool m_isPrivate;

    // speed calculation state
    qint64 m_lastBytes;
    qint64 m_lastTimeMs;
    bool m_firstProgress;
    QElapsedTimer m_speedTimer;
};

#include "gitpush.moc"

// ---------- Small GUI ----------
class MainWindow : public QWidget {
    Q_OBJECT
public:
    MainWindow(const QString &dirPath, const QString &user, const QString &token, bool isPrivate)
        : m_dirPath(dirPath), m_user(user), m_token(token), m_isPrivate(isPrivate)
    {
        setWindowTitle("gitpush");
        resize(480, 140);
        QVBoxLayout *l = new QVBoxLayout(this);
        m_label = new QLabel("Bereit", this);
        m_progress = new QProgressBar(this);
        m_progress->setRange(0, 100);
        m_speed = new QLabel("", this);
        m_startBtn = new QPushButton("Start", this);
        l->addWidget(m_label);
        l->addWidget(m_progress);
        l->addWidget(m_speed);
        l->addWidget(m_startBtn);
        connect(m_startBtn, &QPushButton::clicked, this, &MainWindow::onStart);
    }

public slots:
    void onStart() {
        m_startBtn->setEnabled(false);
        m_label->setText("Starte...");
        // create worker and thread
        GitPushWorker *worker = new GitPushWorker(m_dirPath, m_user, m_token, m_isPrivate);
        QThread *t = new QThread;
        worker->moveToThread(t);
        connect(t, &QThread::started, worker, &GitPushWorker::run);
        connect(worker, &GitPushWorker::progressUpdated, this, &MainWindow::onProgress);
        connect(worker, &GitPushWorker::message, this, &MainWindow::onMessage);
        connect(worker, &GitPushWorker::finished, this, [this, t, worker](int code){
            if (code == 0) m_label->setText("Fertig");
            else m_label->setText(QStringLiteral("Beendet mit Code %1").arg(code));
            m_startBtn->setEnabled(true);
            t->quit();
            t->wait();
            worker->deleteLater();
            t->deleteLater();
        });
        t->start();
    }

    void onProgress(qint64 transferred, qint64 total, double bytesPerSec) {
        int percent = 0;
        if (total > 0) percent = int((transferred * 100) / total);
        m_progress->setValue(percent);
        QString speedStr;
        if (bytesPerSec > 1024*1024) speedStr = QString::asprintf("%.2f MB/s", bytesPerSec / (1024.0*1024.0));
        else if (bytesPerSec > 1024) speedStr = QString::asprintf("%.2f KB/s", bytesPerSec / 1024.0);
        else speedStr = QString::asprintf("%.0f B/s", bytesPerSec);
        m_speed->setText(QStringLiteral("Upload: %1 / %2 — %3")
                         .arg(QString::number(transferred), QString::number(total), speedStr));
    }

    void onMessage(const QString &txt) {
        m_label->setText(txt);
    }

private:
    QString m_dirPath;
    QString m_user;
    QString m_token;
    bool m_isPrivate;

    QLabel *m_label;
    QProgressBar *m_progress;
    QLabel *m_speed;
    QPushButton *m_startBtn;
};

// ---------- main ----------
int main(int argc, char *argv[])
{
    QApplication app(argc, argv);
    QCoreApplication::setApplicationName("gitpush");

    QCommandLineParser parser;
    parser.setApplicationDescription("gitpush - create GitHub repo and push directory (GUI)");
    parser.addHelpOption();
    parser.addVersionOption();
    parser.addPositionalArgument("directory", "Lokales Verzeichnis, das gepusht werden soll");
    parser.addOption({{"u","user"}, "GitHub Benutzername (erforderlich)", "user"});
    parser.addOption({{"t","token"}, "GitHub Personal Access Token (oder setze GITHUB_TOKEN)", "token"});
    parser.addOption({{"p","private"}, "Repository privat erstellen", ""});
    parser.process(QCoreApplication::arguments());

    const QStringList posArgs = parser.positionalArguments();
    if (posArgs.isEmpty() || !parser.isSet("user")) {
        parser.showHelp(1);
    }

    QString dirPath = posArgs.first();
    QString githubUser = parser.value("user");
    QString token = parser.value("token");
    if (token.isEmpty()) token = qgetenv("GITHUB_TOKEN");
    if (token.isEmpty()) {
        qCritical() << "Kein Token angegeben. Nutze --token oder setze die Umgebungsvariable GITHUB_TOKEN.";
        return 2;
    }

    QFileInfo fi(dirPath);
    if (!fi.exists() || !fi.isDir()) {
        qCritical() << "Verzeichnis existiert nicht:" << dirPath;
        return 3;
    }

    MainWindow w(dirPath, githubUser, token, parser.isSet("private"));
    w.show();
    return app.exec();
}

