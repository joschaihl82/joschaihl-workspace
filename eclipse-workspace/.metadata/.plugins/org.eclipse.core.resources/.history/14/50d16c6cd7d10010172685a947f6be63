/* micro-ops layer (sse removed) */
typedef enum {
    uop_none = 0,
    uop_alu_bin,     /* dst = alu(dst, src) */
    uop_alu_bin_mem, /* mem = alu(mem, src) */
    uop_alu_imm,     /* dst = alu(dst, imm) */
    uop_mov_reg_reg,
    uop_mov_reg_mem_load,
    uop_mov_mem_reg_store,
    uop_push_reg,
    uop_pop_reg,
    uop_push_imm,
    uop_push_mem,
    uop_pop_mem,
    uop_jmp_rel8,
    uop_jmp_rel32,
    uop_call_rel32,
    uop_ret,
    uop_lea,
    uop_break_trap
} uopkind;

typedef enum { opadd, opor, opadc, opsbb, opand, opsub, opxor, opcmp } aluop;

/* micro-op record */
typedef struct {
    uopkind kind;
    aluop   aop;
    int width;      /* 8,16,32,64 where relevant */
    int dst_reg;    /* gpr index */
    int src_reg;    /* gpr index */
    uint64_t imm;
    uint64_t ea;
    uint8_t prefix_bits;
    uint8_t opcode;
    uint8_t op2;    /* for 0f group */
} uop;

/* micro-op executor */
static inline void exec_uop(const uop *u);

