/* ----------------------------------------------------------------------------
   configuration switches
   ---------------------------------------------------------------------------- */
#define USE_INLINE_ASM_FASTMEM 1
#define USE_INLINE_ASM_FETCH 1
#define USE_INLINE_ASM_STACK 1
#define USE_FB_STREAMING 1

/* ----------------------------------------------------------------------------
   basic sizes and globals
   ---------------------------------------------------------------------------- */
#define RAM_SIZE (64ULL * 1024 * 1024) /* 64 mib default */
#define FB_BASE_ADDR (1ULL * 1024 * 1024) /* framebuffer mapped at 1 mib */
#define RFLAGS_CF (1ULL << 0)
#define RFLAGS_PF (1ULL << 2)
#define RFLAGS_AF (1ULL << 4)
#define RFLAGS_ZF (1ULL << 6)
#define RFLAGS_SF (1ULL << 7)
#define RFLAGS_TF (1ULL << 8)
#define RFLAGS_IF (1ULL << 9)
#define RFLAGS_DF (1ULL << 10)
#define RFLAGS_OF (1ULL << 11)

static uint8_t *ram_mem = NULL;
static uint8_t *fb_mem = NULL;

/* minimal xmm type (128-bit) */
typedef struct { uint64_t lo; uint64_t hi; } XMM;

/* minimal cpu type (x64) */
typedef struct {
    uint64_t gpr[16];    /* general purpose registers: rax..r15 */
    uint64_t rflags;     /* flags register */
    uint64_t rip;        /* instruction pointer */
    XMM xmm[16];         /* sse/sse2 registers */
    int op_size;         /* 16/32/64 */
    int addr_size;       /* 32/64 */
    int has_rex;
    int rex_w, rex_r, rex_x, rex_b;
    int modrm_mod, modrm_reg, modrm_rm;
    uint8_t last_opcode;
} X64CPU;

static X64CPU cpu;

