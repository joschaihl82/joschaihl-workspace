// ============================================================================
// jemu.c - x64 emulator (sse/xmm support removed)
// ============================================================================
//
// self-contained minimal x86-64 emulator without sse/xmm support.
// implements a subset of integer x86-64 instructions, 0f-group non-sse
// opcodes (imul, jcc, setcc), modr/m + sib addressing, memory, stack,
// tracing, soft breakpoints, and an sdl framebuffer for visualization.
//
// build:
//   gcc -o2 -std=c11 -wall -wextra -pthread -o jemu jemu.c `sdl2-config --cflags --libs`
//
// run:
//   ./jemu [optional-binary-to-load]
//
// ----------------------------------------------------------------------------

