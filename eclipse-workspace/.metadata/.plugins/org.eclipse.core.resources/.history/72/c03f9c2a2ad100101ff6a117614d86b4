/* -------------------------
   extended execute
   ------------------------- */
void execute_one_extended(void) {
    cpu_decode_reset();
    int decoding = 1;
    uint8_t op = 0;
    while (decoding) {
        uint8_t b = fetch8();
        switch (b) {
            case 0x66: cpu.op_size = 16; continue;
            case 0x67: cpu.addr_size = 32; continue;
            default:
                if ((b & 0xF0) == 0x40) {
                    cpu.has_rex = 1;
                    cpu.rex_w = (b >> 3) & 1; cpu.rex_r = (b >> 2) & 1;
                    cpu.rex_x = (b >> 1) & 1; cpu.rex_b = b & 1;
                    continue;
                }
                op = b; decoding = 0;
                break;
        }
    }

    switch (op) {
        case 0x01: { /* ADD r/m64, r64 */
            decode_modrm();
            uint64_t src = cpu.gpr[(cpu.modrm_reg | (cpu.rex_r<<3))];
            if (cpu.modrm_mod == 3) {
                uint64_t *dstp = &cpu.gpr[(cpu.modrm_rm | (cpu.rex_b<<3))];
                uint64_t res = *dstp + src;
                clear_alu_flags(); update_add_flags_u64(*dstp, src, res, 64);
                *dstp = res; set_flag_zf_sf_pf8(res, 64);
            } else {
                uint64_t addr = compute_ea();
                uint64_t val = mem_read64(addr);
                uint64_t res = val + src;
                mem_write64(addr, res);
                clear_alu_flags(); update_add_flags_u64(val, src, res, 64);
                set_flag_zf_sf_pf8(res, 64);
            }
            break;
        }
        default:
            trace_printf("Unimplemented extended: 0x%02X at rip=0x%016" PRIx64 "\n", op, cpu.rip-1);
            exit(1);
    }
}

/* -------------------------
   framebuffer / sdl
   ------------------------- */
typedef struct {
    SDL_Window *window;
    SDL_Renderer *renderer;
    SDL_Texture *texture;
    int width, height;
    int pitch;
} FBDisplay;
static FBDisplay fbdisp;

int fb_init_display(int width, int height) {
    if (SDL_Init(SDL_INIT_VIDEO | SDL_INIT_TIMER) != 0) return -1;
    fbdisp.width = width; fbdisp.height = height;
    fbdisp.window = SDL_CreateWindow("x64emu", SDL_WINDOWPOS_CENTERED, SDL_WINDOWPOS_CENTERED, width, height, SDL_WINDOW_SHOWN);
    if (!fbdisp.window) return -1;
    fbdisp.renderer = SDL_CreateRenderer(fbdisp.window, -1, SDL_RENDERER_ACCELERATED | SDL_RENDERER_PRESENTVSYNC);
    if (!fbdisp.renderer) return -1;
    fbdisp.texture = SDL_CreateTexture(fbdisp.renderer, SDL_PIXELFORMAT_ARGB8888, SDL_TEXTUREACCESS_STREAMING, width, height);
    if (!fbdisp.texture) return -1;
    fbdisp.pitch = width * 4;
    if (!fb_mem) {
        fb_mem = malloc((size_t)fbdisp.pitch * height);
        if (!fb_mem) return -1;
        memset(fb_mem, 0, (size_t)fbdisp.pitch * height);
    }
    return 0;
}

void fb_present() {
    if (!fbdisp.texture || !fb_mem) return;
    SDL_UpdateTexture(fbdisp.texture, NULL, fb_mem, fbdisp.pitch);
    SDL_RenderClear(fbdisp.renderer);
    SDL_RenderCopy(fbdisp.renderer, fbdisp.texture, NULL, NULL);
    SDL_RenderPresent(fbdisp.renderer);
}
void fb_shutdown() {
    if (fb_mem) { free(fb_mem); fb_mem = NULL; }
    if (fbdisp.texture) SDL_DestroyTexture(fbdisp.texture);
    if (fbdisp.renderer) SDL_DestroyRenderer(fbdisp.renderer);
    if (fbdisp.window) SDL_DestroyWindow(fbdisp.window);
    SDL_Quit();
}

/* -------------------------
   optimized run loop
   ------------------------- */
#if defined(__GNUC__) && defined(__x86_64__)
void run_loop_optimized(void) {
    static void *op_labels[256];
    static int table_init = 0;
    if (!table_init) {
        for (int i=0;i<256;i++) op_labels[i] = &&default_label;
        op_labels[0x01] = &&op_add_rm64_r64;
        op_labels[0x29] = &&op_sub_rm64_r64;
        op_labels[0xFF] = &&op_ff_group;
        op_labels[0x8F] = &&op_pop_rm64;
        op_labels[0x6A] = &&op_push_imm8;
        op_labels[0x68] = &&op_push_imm32;
        op_labels[0x39] = &&op_cmp_rm64_r64;
        op_labels[0x85] = &&op_test_rm64_r64;
        op_labels[0x8D] = &&op_lea_r64_m;
        op_labels[0x0F] = &&op_0F;
        op_labels[0xEB] = &&op_jmp_short;
        op_labels[0xE9] = &&op_jmp_rel;
        op_labels[0xE8] = &&op_call_rel;
        op_labels[0xC3] = &&op_ret;
        table_init = 1;
    }

    for (;;) {
        cpu_decode_reset();
        int decoding = 1;
        uint8_t op = 0;
        while (decoding) {
            uint8_t b = fetch8();
            switch (b) {
                case 0x66: cpu.op_size = 16; continue;
                case 0x67: cpu.addr_size = 32; continue;
                default:
                    if ((b & 0xF0) == 0x40) {
                        cpu.has_rex = 1;
                        cpu.rex_w = (b >> 3) & 1; cpu.rex_r = (b >> 2) & 1;
                        cpu.rex_x = (b >> 1) & 1; cpu.rex_b = b & 1;
                        continue;
                    }
                    op = b; decoding = 0;
                    break;
            }
        }
        goto *op_labels[op];

    op_add_rm64_r64: {
        decode_modrm();
        if (cpu.modrm_mod == 3) {
            handle_add_reg64(cpu.modrm_rm | (cpu.rex_b<<3), cpu.modrm_reg | (cpu.rex_r<<3));
        } else {
            uint64_t src = cpu.gpr[(cpu.modrm_reg | (cpu.rex_r<<3))];
            uint64_t addr = compute_ea();
            uint64_t val = mem_read64(addr);
            uint64_t res = val + src;
            mem_write64(addr, res);
            clear_alu_flags(); update_add_flags_u64(val, src, res, 64);
            set_flag_zf_sf_pf8(res, 64);
        }
        goto dispatch_continue;
    }
    op_sub_rm64_r64: {
        decode_modrm();
        if (cpu.modrm_mod == 3) {
            handle_sub_reg64(cpu.modrm_rm | (cpu.rex_b<<3), cpu.modrm_reg | (cpu.rex_r<<3));
        } else {
            uint64_t src = cpu.gpr[(cpu.modrm_reg | (cpu.rex_r<<3))];
            uint64_t addr = compute_ea();
            uint64_t val = mem_read64(addr);
            uint64_t res = val - src;
            mem_write64(addr, res);
            clear_alu_flags(); update_sub_flags_u64(val, src, res, 64);
            set_flag_zf_sf_pf8(res, 64);
        }
        goto dispatch_continue;
    }
    op_ff_group: {
        decode_modrm();
        int subop = cpu.modrm_reg;
        if (subop == 0) { /* INC */
            if (cpu.modrm_mod == 3) handle_inc_reg64(cpu.modrm_rm | (cpu.rex_b<<3));
            else {
                uint64_t addr = compute_ea();
                uint64_t old = mem_read64(addr);
                uint64_t res = old + 1;
                mem_write64(addr, res);
                clear_alu_flags(); update_add_flags_u64(old, 1, res, 64);
                set_flag_zf_sf_pf8(res, 64);
            }
        } else if (subop == 2) { /* CALL */
            uint64_t dest = (cpu.modrm_mod == 3) ? cpu.gpr[(cpu.modrm_rm | (cpu.rex_b<<3))] : mem_read64(compute_ea());
            push_u64(cpu.rip); cpu.rip = dest;
        } else if (subop == 4) { /* JMP */
            cpu.rip = (cpu.modrm_mod == 3) ? cpu.gpr[(cpu.modrm_rm | (cpu.rex_b<<3))] : mem_read64(compute_ea());
        }
        goto dispatch_continue;
    }
    op_pop_rm64: {
        decode_modrm();
        uint64_t val = pop_u64();
        if (cpu.modrm_mod == 3) cpu.gpr[(cpu.modrm_rm | (cpu.rex_b<<3))] = val;
        else mem_write64(compute_ea(), val);
        goto dispatch_continue;
    }
    op_push_imm8: {
        push_u64((uint64_t)(int64_t)(int8_t)fetch8());
        goto dispatch_continue;
    }
    op_push_imm32: {
        push_u64((uint64_t)(int64_t)(int32_t)fetch32());
        goto dispatch_continue;
    }
    op_cmp_rm64_r64: {
        decode_modrm();
        if (cpu.modrm_mod == 3) {
            handle_cmp_reg64(cpu.modrm_rm | (cpu.rex_b<<3), cpu.modrm_reg | (cpu.rex_r<<3));
        } else {
            uint64_t src = cpu.gpr[(cpu.modrm_reg | (cpu.rex_r<<3))];
            uint64_t lhs = mem_read64(compute_ea());
            uint64_t res = lhs - src;
            clear_alu_flags(); update_sub_flags_u64(lhs, src, res, 64);
            set_flag_zf_sf_pf8(res, 64);
        }
        goto dispatch_continue;
    }
    op_test_rm64_r64: {
        decode_modrm();
        uint64_t src = cpu.gpr[(cpu.modrm_reg | (cpu.rex_r<<3))];
        uint64_t lhs = (cpu.modrm_mod == 3) ? cpu.gpr[(cpu.modrm_rm | (cpu.rex_b<<3))] : mem_read64(compute_ea());
        uint64_t res = lhs & src;
        cpu.rflags &= ~(1ULL | (1ULL<<11)); set_flag_zf_sf_pf8(res, 64);
        goto dispatch_continue;
    }
    op_lea_r64_m: {
        decode_modrm();
        uint64_t val = (cpu.modrm_mod == 3) ? cpu.gpr[(cpu.modrm_rm | (cpu.rex_b<<3))] : compute_ea();
        cpu.gpr[(cpu.modrm_reg | (cpu.rex_r<<3))] = val;
        goto dispatch_continue;
    }
    op_0F: {
        handle_0F_group(fetch8());
        goto dispatch_continue;
    }
    op_jmp_short: {
        cpu.rip += (int64_t)(int8_t)fetch8();
        goto dispatch_continue;
    }
    op_jmp_rel: {
        cpu.rip += (int64_t)(int32_t)fetch32();
        goto dispatch_continue;
    }
    op_call_rel: {
        int32_t s = (int32_t)fetch32();
        push_u64(cpu.rip); cpu.rip += s;
        goto dispatch_continue;
    }
    op_ret: {
        cpu.rip = pop_u64();
        goto dispatch_continue;
    }
    default_label:
        trace_printf("Unimplemented: 0x%02X\n", (unsigned)mem_read8(cpu.rip-1));
        exit(1);

    dispatch_continue:;
    }
}
#else
void run_loop_optimized(void) { for (;;) execute_one_extended(); }
#endif

/* -------------------------
   init helper
   ------------------------- */
int x64emu_init_standalone(void) {
    if (!ram_mem) {
        ram_mem = malloc(RAM_SIZE);
        if (!ram_mem) return -1;
        memset(ram_mem, 0, RAM_SIZE);
    }
    cpu.gpr[4] = RAM_SIZE - 0x1000;
    cpu.rip = 0;
    cpu.rflags = 0;
    return 0;
}

/* -------------------------
   bios loader (new)
   ------------------------- */
int funLoad(const char *strPath) {
    FILE *ptrFile = fopen(strPath, "rb");
    if (!ptrFile) {
        fprintf(stderr, "err: cannot open file: %s\n", strPath);
        return -1;
    }

    fseek(ptrFile, 0, SEEK_END);
    long cntSize = ftell(ptrFile);
    fseek(ptrFile, 0, SEEK_SET);

    if (cntSize > RAM_SIZE) {
        fprintf(stderr, "err: file too big for ram\n");
        fclose(ptrFile);
        return -1;
    }

    /* load at address 0x0000 */
    size_t cntRead = fread(ram_mem, 1, cntSize, ptrFile);
    fclose(ptrFile);

    printf("sys: loaded %ld bytes from %s\n", cntRead, strPath);
    return 0;
}

/* -------------------------
   main entry point
   ------------------------- */
int main(int cntArg, char **arrArg) {
	char *bios_file = "test_bios.bin";

    if (cntArg >= 2) {
    	bios_file = argv[1];
    }

    if (x64emu_init_standalone() != 0) {
        fprintf(stderr, "err: init failed\n");
        return 1;
    }

    if (fb_init_display(640, 480) != 0) {
        fprintf(stderr, "err: fb init failed\n");
        return 1;
    }

    /* load bios */
    if (funLoad(bios_file) != 0) {
        return 1;
    }

    /* start emulation */
    cpu.rip = 0;
    printf("sys: starting emulation...\n");

    run_loop_optimized();

    fb_shutdown();
    return 0;
}
