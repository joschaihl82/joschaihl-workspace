/*
 * as.c — Minimal x86-64 assembler (AT&T syntax) — amalgamated single file
 *
 * Features:
 * - AT&T parsing: %registers, $immediates, disp(base,index,scale)
 * - Labels with forward/backward references via a relocation list
 * - Core instructions: movq/addq/subq/cmpq/andq/orq/xorq/testq/push/pop/call/ret/jmp/jcc/lea/xchg/nop/leave/syscall/...
 * - SSE subset: movaps/movups/addps/subps/mulps/xorps/andps/orps between XMM regs and r/m128
 * - Emits hex dump of .text and .data to stdout
 *
 * Note: This is a teaching scaffold, not a production assembler.
 */

