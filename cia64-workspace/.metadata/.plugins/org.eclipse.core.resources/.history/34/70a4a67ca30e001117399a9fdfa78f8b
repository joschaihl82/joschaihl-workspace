/* ---------------- Printing helpers ---------------- */

static void println(const char *fmt, ...) {
    va_list ap;
    va_start(ap, fmt);
    vprintf(fmt, ap);
    va_end(ap);
    putchar('\n');
}

/* ---------------- Register helpers ----------------
   reg(i) returns "xN" string for integer register index i.
   freg(i) returns "fN" string for floating register index i.
   These return pointers to static buffers; caller should not free.
*/

static char regbuf[32][8];
static char fregbuf[32][8];

static char *reg(int i) {
    if (i < 0) i = 0;
    if (i >= 32) i = i % 32;
    snprintf(regbuf[i], sizeof(regbuf[i]), "x%d", i);
    return regbuf[i];
}

static char *freg(int i) {
    if (i < 0) i = 0;
    if (i >= 32) i = i % 32;
    snprintf(fregbuf[i], sizeof(fregbuf[i]), "f%d", i);
    return fregbuf[i];
}

/* ---------------- Simple temporary register allocator ----------------
   We use a small pool of caller-saved registers for temporaries:
   x5..x7, x28..x31 (t0..t6 in RISC-V naming). We'll allocate and free.
*/

#define TEMP_REG_COUNT 8
static int temp_regs[TEMP_REG_COUNT] = {5, 6, 7, 28, 29, 30, 31, 11}; // 11 used as extra
static bool temp_in_use[TEMP_REG_COUNT];

static int alloc_temp(void) {
    for (int i = 0; i < TEMP_REG_COUNT; i++) {
        if (!temp_in_use[i]) {
            temp_in_use[i] = true;
            return temp_regs[i];
        }
    }
    // fallback: use x12 (caller-saved) if none free
    return 12;
}

static void free_temp(int r) {
    for (int i = 0; i < TEMP_REG_COUNT; i++) {
        if (temp_regs[i] == r) {
            temp_in_use[i] = false;
            return;
        }
    }
    // else ignore
}

/* ---------------- Stack frame helpers ----------------
   We follow the earlier convention:
   - sp is x2
   - s0 is x8 (frame pointer)
   - a0..a7 are x10..x17
   - return value in x10 (a0) for integers, f0 for floats
*/

static const char *SP = "x2";
static const char *FP = "x8";
static const char *RET_INT = "x10";
static const char *RET_FLOAT = "f0";

/* reg_save_area_offset[] is declared in prototypes header; if not, define fallback */
#ifndef reg_save_area_offset
int reg_save_area_offset[8] = { -200, -192, -184, -176, -168, -160, -152, -144 };
#endif

/* argreg[] and fargreg[] are expected by the original code; provide defaults */
#ifndef argreg
char *argreg[] = { "x17", "x16", "x15", "x14", "x13", "x12", "x11", "x10" };
#endif
#ifndef fargreg
int fargreg[] = { 0, 1, 2, 3, 4, 5, 6, 7 };
#endif

/* ---------------- Utility: emit load/store for types ---------------- */

/* Emit load of integer of size bytes from address in base+offset into dest reg */
static void emit_load_int(const char *dest, int bytes, const char *base, int offset) {
    if (bytes == 1) println("  LB %s, -%d(%s)", dest, offset, base);
    else if (bytes == 2) println("  LH %s, -%d(%s)", dest, offset, base);
    else if (bytes == 4) println("  LW %s, -%d(%s)", dest, offset, base);
    else if (bytes == 8) println("  LD %s, -%d(%s)", dest, offset, base);
    else {
        // fallback: load byte-by-byte into dest (little-endian)
        println("  /* load %d bytes into %s (byte loop) */", bytes, dest);
        for (int i = 0; i < bytes; i++) {
            println("  LB %s, -%d(%s)  # byte %d", dest, offset + i, base, i);
            // combine bytes (not implemented fully here)
        }
    }
}

/* Emit store of integer of size bytes from src reg into base+offset */
static void emit_store_int(const char *src, int bytes, const char *base, int offset) {
    if (bytes == 1) println("  SB %s, -%d(%s)", src, offset, base);
    else if (bytes == 2) println("  SH %s, -%d(%s)", src, offset, base);
    else if (bytes == 4) println("  SW %s, -%d(%s)", src, offset, base);
    else if (bytes == 8) println("  SD %s, -%d(%s)", src, offset, base);
    else {
        println("  /* store %d bytes from %s (byte loop) */", bytes, src);
    }
}

/* Emit load/store for floating types */
static void emit_load_float(const char *fdest, int bytes, const char *base, int offset) {
    if (bytes == 4) println("  FLW %s, -%d(%s)", fdest, offset, base);
    else if (bytes == 8) println("  FLD %s, -%d(%s)", fdest, offset, base);
    else println("  /* unsupported float size %d */", bytes);
}

static void emit_store_float(const char *fsrc, int bytes, const char *base, int offset) {
    if (bytes == 4) println("  FSW %s, -%d(%s)", fsrc, offset, base);
    else if (bytes == 8) println("  FSD %s, -%d(%s)", fsrc, offset, base);
    else println("  /* unsupported float size %d */", bytes);
}

/* ---------------- Address generation and memory ops ----------------
   gen_addr: compute address of a variable or deref expression and leave
   the address in a temporary integer register (returned as int).
   For simplicity we return the register index; caller must free it.
*/

/* Forward declarations for gen_expr/gen_stmt used below */
static void gen_expr(Node *node);
static void gen_stmt(Node *node);

static int gen_addr(Node *node) {
    // For variable nodes, compute address as FP-relative or global label.
    if (node->kind == ND_VAR) {
        Var *v = node->var;
        if (!v->is_local) {
            // global: load address of label into temp
            int t = alloc_temp();
            println("  /* address of global %s -> %s */", v->name, reg(t));
            println("  LA %s, %s", reg(t), v->name); // LA pseudo-instruction
            return t;
        } else {
            // local: address = s0 - offset
            int t = alloc_temp();
            println("  ADDI %s, %s, -%d", reg(t), FP, v->offset);
            return t;
        }
    } else if (node->kind == ND_DEREF) {
        // &(*expr) -> address is value of expr
        // generate expr to get pointer in a temp register
        gen_expr(node->lhs);
        // assume result in RET_INT (x10)
        int t = alloc_temp();
        println("  ADDI %s, %s, 0", reg(t), RET_INT);
        return t;
    } else if (node->kind == ND_ADD || node->kind == ND_SUB) {
        // compute address expression: base + offset
        // generate left and right, combine
        gen_expr(node->lhs);
        println("  /* left in %s */", RET_INT);
        int t1 = alloc_temp();
        println("  ADDI %s, %s, 0", reg(t1), RET_INT);
        gen_expr(node->rhs);
        int t2 = alloc_temp();
        println("  ADDI %s, %s, 0", reg(t2), RET_INT);
        // add or sub
        if (node->kind == ND_ADD)
            println("  ADD %s, %s, %s", reg(t1), reg(t1), reg(t2));
        else
            println("  SUB %s, %s, %s", reg(t1), reg(t1), reg(t2));
        free_temp(t2);
        // move result to RET_INT
        println("  ADDI %s, %s, 0", RET_INT, reg(t1));
        free_temp(t1);
        // return a temp holding address
        int t = alloc_temp();
        println("  ADDI %s, %s, 0", reg(t), RET_INT);
        return t;
    } else {
        // fallback: evaluate expression and treat result as address
        gen_expr(node);
        int t = alloc_temp();
        println("  ADDI %s, %s, 0", reg(t), RET_INT);
        return t;
    }
}

/* load: load value at address in RET_INT into RET_INT (for integers)
   or into RET_FLOAT for floats. We assume address is in RET_INT.
*/
static void load(Type *ty) {
    if (!ty) {
        println("  /* load: missing type */");
        return;
    }
    if (ty->kind == TY_FLOAT || ty->kind == TY_DOUBLE) {
        // floating load
        if (ty->size == 4) println("  FLW %s, 0(%s)", RET_FLOAT, RET_INT);
        else println("  FLD %s, 0(%s)", RET_FLOAT, RET_INT);
    } else {
        // integer load
        if (ty->size == 1) println("  LB %s, 0(%s)", RET_INT, RET_INT);
        else if (ty->size == 2) println("  LH %s, 0(%s)", RET_INT, RET_INT);
        else if (ty->size == 4) println("  LW %s, 0(%s)", RET_INT, RET_INT);
        else if (ty->size == 8) println("  LD %s, 0(%s)", RET_INT, RET_INT);
        else println("  /* load: unsupported size %d */", ty->size);
    }
}

/* store: store value from RET_INT or RET_FLOAT into address in addr_reg */
static void store(Type *ty, const char *addr_reg) {
    if (!ty) {
        println("  /* store: missing type */");
        return;
    }
    if (ty->kind == TY_FLOAT || ty->kind == TY_DOUBLE) {
        if (ty->size == 4) println("  FSW %s, 0(%s)", RET_FLOAT, addr_reg);
        else println("  FSD %s, 0(%s)", RET_FLOAT, addr_reg);
    } else {
        if (ty->size == 1) println("  SB %s, 0(%s)", RET_INT, addr_reg);
        else if (ty->size == 2) println("  SH %s, 0(%s)", RET_INT, addr_reg);
        else if (ty->size == 4) println("  SW %s, 0(%s)", RET_INT, addr_reg);
        else if (ty->size == 8) println("  SD %s, 0(%s)", RET_INT, addr_reg);
        else println("  /* store: unsupported size %d */", ty->size);
    }
}

/* cmp_zero: compare RET_INT with zero and set x10 to 1 if non-zero else 0 */
static void cmp_zero(void) {
    // produce boolean in RET_INT (x10)
    int t = alloc_temp();
    println("  ADDI %s, %s, 0", reg(t), RET_INT);
    println("  SLTIU %s, %s, 1", reg(t), reg(t)); // set t = (t < 1) ? 1 : 0 -> this yields 1 if zero
    // invert: we want 1 if non-zero
    println("  XOR %s, %s, 1", reg(t), reg(t)); // t = t ^ 1
    println("  ADDI %s, %s, 0", RET_INT, reg(t));
    free_temp(t);
}

