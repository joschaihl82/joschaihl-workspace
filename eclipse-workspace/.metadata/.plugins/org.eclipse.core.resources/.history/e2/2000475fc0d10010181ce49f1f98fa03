/* INC reg64 optimized handler */
static inline void handle_inc_reg64(int dst_idx) {
	uint64_t dst = cpu.gpr[dst_idx];
	unsigned char of = 0, sf = 0, zf = 0, pf_byte = 0;
	asm volatile (
			"incq %[dst]\n\t"
