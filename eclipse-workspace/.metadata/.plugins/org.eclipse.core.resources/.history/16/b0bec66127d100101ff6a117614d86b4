/* Optimized run loop */
void run_loop_optimized(void) {
    static void *op_labels[256];
    static int table_init = 0;
    if (!table_init) {
        for (int i=0;i<256;i++) op_labels[i] = &&default_label;
        op_labels[0x01] = &&op_add_rm64_r64;
        op_labels[0x29] = &&op_sub_rm64_r64;
        op_labels[0xFF] = &&op_ff_group;
        op_labels[0x8F] = &&op_pop_rm64;
        op_labels[0x6A] = &&op_push_imm8;
        op_labels[0x68] = &&op_push_imm32;
        op_labels[0x39] = &&op_cmp_rm64_r64;
        op_labels[0x85] = &&op_test_rm64_r64;
        op_labels[0x8D] = &&op_lea_r64_m;
        op_labels[0x0F] = &&op_0F;
        op_labels[0xEB] = &&op_jmp_short;
        op_labels[0xE9] = &&op_jmp_rel;
        op_labels[0xE8] = &&op_call_rel;
        op_labels[0xC3] = &&op_ret;
        table_init = 1;
    }

    for (;;) {
        cpu_decode_reset();
        int decoding = 1;
        uint8_t op = 0;
        while (decoding) {
            uint8_t b = fetch8();
            switch (b) {
                case 0x66: cpu.op_size = 16; continue;
                case 0x67: cpu.addr_size = 32; continue;
                default:
                    if ((b & 0xF0) == 0x40) {
                        cpu.has_rex = 1;
                        cpu.rex_w = (b >> 3) & 1; cpu.rex_r = (b >> 2) & 1; cpu.rex_x = (b >> 1) & 1; cpu.rex_b = b & 1;
                        continue;
                    }
                    op = b; decoding = 0;
                    break;
            }
        }

        goto *op_labels[op];

    op_add_rm64_r64: {
        decode_modrm();
        if (cpu.modrm_mod == 3) {
            int dst = cpu.modrm_rm | (cpu.rex_b<<3);
            int src = cpu.modrm_reg | (cpu.rex_r<<3);
            handle_add_reg64(dst, src);
        } else {
            uint64_t src = cpu.gpr[(cpu.modrm_reg | (cpu.rex_r<<3))];
            uint64_t addr = compute_ea();
            uint64_t val = mem_read64(addr);
            uint64_t res = val + src;
            mem_write64(addr, res);
            clear_alu_flags();
            update_add_flags_u64(val, src, res, 64);
            set_flag_zf_sf_pf8(res, 64);
        }
        goto dispatch_continue;
    }

    op_sub_rm64_r64: {
        decode_modrm();
        if (cpu.modrm_mod == 3) {
            int dst = cpu.modrm_rm | (cpu.rex_b<<3);
            int src = cpu.modrm_reg | (cpu.rex_r<<3);
            handle_sub_reg64(dst, src);
        } else {
            uint64_t src = cpu.gpr[(cpu.modrm_reg | (cpu.rex_r<<3))];
            uint64_t addr = compute_ea();
            uint64_t val = mem_read64(addr);
            uint64_t res = val - src;
            mem_write64(addr, res);
            clear_alu_flags();
            update_sub_flags_u64(val, src, res, 64);
            set_flag_zf_sf_pf8(res, 64);
        }
        goto dispatch_continue;
    }

    op_ff_group: {
        decode_modrm();
        int subop = cpu.modrm_reg;
        if (subop == 0) { /* INC r/m64 */
            if (cpu.modrm_mod == 3) {
                int dst = cpu.modrm_rm | (cpu.rex_b<<3);
                handle_inc_reg64(dst);
            } else {
                uint64_t addr = compute_ea();
                uint64_t old = mem_read64(addr);
                asm volatile ("incq %0" : "+r"(old) : : "cc");
                mem_write64(addr, old);
                clear_alu_flags();
                /* approximate flags update */
                set_flag_zf_sf_pf8(old, 64);
            }
        } else if (subop == 2) { /* CALL r/m64 */
            if (cpu.modrm_mod == 3) {
                uint64_t dest = cpu.gpr[(cpu.modrm_rm | (cpu.rex_b<<3))];
                push_u64(cpu.rip);
                cpu.rip = dest;
            } else {
                uint64_t addr = compute_ea();
                uint64_t dest = mem_read64(addr);
                push_u64(cpu.rip);
                cpu.rip = dest;
            }
        } else if (subop == 4) { /* JMP r/m64 */
            if (cpu.modrm_mod == 3) {
                cpu.rip = cpu.gpr[(cpu.modrm_rm | (cpu.rex_b<<3))];
            } else {
                uint64_t addr = compute_ea();
                uint64_t dest = mem_read64(addr);
                cpu.rip = dest;
            }
        } else {
            trace_printf("FF subop %d unimplemented\n", subop);
            exit(1);
        }
        goto dispatch_continue;
    }

    op_pop_rm64: {
        decode_modrm();
        if (cpu.modrm_reg != 0) { trace_printf("8F with reg!=0 unimplemented\n"); exit(1); }
        uint64_t val = pop_u64();
        if (cpu.modrm_mod == 3) {
            cpu.gpr[(cpu.modrm_rm | (cpu.rex_b<<3))] = val;
        } else {
            uint64_t addr = compute_ea();
            mem_write64(addr, val);
        }
        goto dispatch_continue;
    }

    op_push_imm8: {
        int8_t imm = (int8_t)fetch8();
        push_u64((uint64_t)(int64_t)imm);
        goto dispatch_continue;
    }

    op_push_imm32: {
        uint32_t imm = fetch32();
        push_u64((uint64_t)(int64_t)(int32_t)imm);
        goto dispatch_continue;
    }

    op_cmp_rm64_r64: {
        decode_modrm();
        if (cpu.modrm_mod == 3) {
            int lhs = cpu.modrm_rm | (cpu.rex_b<<3);
            int rhs = cpu.modrm_reg | (cpu.rex_r<<3);
            handle_cmp_reg64(lhs, rhs);
        } else {
            uint64_t src = cpu.gpr[(cpu.modrm_reg | (cpu.rex_r<<3))];
            uint64_t addr = compute_ea();
            uint64_t lhs = mem_read64(addr);
            uint64_t res = lhs - src;
            clear_alu_flags();
            update_sub_flags_u64(lhs, src, res, 64);
            set_flag_zf_sf_pf8(res, 64);
        }
        goto dispatch_continue;
    }

    op_test_rm64_r64: {
        decode_modrm();
        uint64_t src = cpu.gpr[(cpu.modrm_reg | (cpu.rex_r<<3))];
        uint64_t lhs;
        if (cpu.modrm_mod == 3) lhs = cpu.gpr[(cpu.modrm_rm | (cpu.rex_b<<3))];
        else { uint64_t addr = compute_ea(); lhs = mem_read64(addr); }
        uint64_t res = lhs & src;
        cpu.rflags &= ~(1ULL | (1ULL<<11));
        set_flag_zf_sf_pf8(res, 64);
        goto dispatch_continue;
    }

    op_lea_r64_m: {
        decode_modrm();
        if (cpu.modrm_mod == 3) {
            uint64_t val = cpu.gpr[(cpu.modrm_rm | (cpu.rex_b<<3))];
            cpu.gpr[(cpu.modrm_reg | (cpu.rex_r<<3))] = val;
        } else {
            uint64_t addr = compute_ea();
            cpu.gpr[(cpu.modrm_reg | (cpu.rex_r<<3))] = addr;
        }
        goto dispatch_continue;
    }

    op_0F: {
        uint8_t op2 = fetch8();
        handle_0F_group(op2);
        goto dispatch_continue;
    }

    op_jmp_short: {
        int8_t d8 = (int8_t)fetch8();
        cpu.rip = cpu.rip + d8;
        goto dispatch_continue;
    }

    op_jmp_rel: {
        uint32_t d32 = fetch32();
        int32_t s = (int32_t)d32;
        cpu.rip = cpu.rip + s;
        goto dispatch_continue;
    }

    op_call_rel: {
        uint32_t d32 = fetch32();
        int32_t s = (int32_t)d32;
        push_u64(cpu.rip);
        cpu.rip = cpu.rip + s;
        goto dispatch_continue;
    }

    op_ret: {
        cpu.rip = pop_u64();
        goto dispatch_continue;
    }

    default_label:
        trace_printf("Unimplemented opcode extended (fallback): 0x%02X at rip=0x%016" PRIx64 "\n", (unsigned)mem_read8(cpu.rip-1), cpu.rip-1);
        exit(1);

    dispatch_continue:
        ; /* continue loop */
    } /* end for(;;) */
}

#else
/* Fallback: call execute_one_extended in a loop */
void run_loop_optimized(void) {
    for (;;) execute_one_extended();
}
#endif

/* -------------------------
   Initialization helper
   ------------------------- */
int x64emu_init_standalone(void) {
    if (!ram_mem) {
        ram_mem = malloc(RAM_SIZE);
        if (!ram_mem) return -1;
        memset(ram_mem, 0, RAM_SIZE);
    }
    cpu.gpr[4] = RAM_SIZE - 0x1000; /* RSP */
    cpu.rip = 0;
    cpu.rflags = 0;
    return 0;
}

