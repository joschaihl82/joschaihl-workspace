    set_flag_bit(2, pf);
    set_flag_bit(6, zf);
    set_flag_bit(7, sf);
    set_flag_bit(11, of);
}

static inline void handle_cmp_reg64(int lhs_idx, int rhs_idx) {
    uint64_t lhs = cpu.gpr[lhs_idx];
    uint64_t rhs = cpu.gpr[rhs_idx];
    unsigned char cf=0, of=0, sf=0, zf=0, pf_byte=0;
    asm volatile (
        "cmpq %[rhs], %[lhs]\n\t"
        "setc %[cf]\n\t"
        "seto %[of]\n\t"
