        m_callBtn = new QPushButton("Call", this);
        m_hangupBtn = new QPushButton("Hangup", this);
        btnLayout->addWidget(m_addBtn);
        btnLayout->addWidget(m_removeBtn);
        btnLayout->addWidget(m_callBtn);
        btnLayout->addWidget(m_hangupBtn);
        gLayout->addLayout(btnLayout);
        layout->addWidget(group);

        connect(m_addBtn, &QPushButton::clicked, this, &UserListWidget::onAddClicked);
        connect(m_removeBtn, &QPushButton::clicked, this, &UserListWidget::onRemoveClicked);
        connect(m_callBtn, &QPushButton::clicked, this, &UserListWidget::onCallClicked);
        connect(m_hangupBtn, &QPushButton::clicked, this, &UserListWidget::onHangupClicked);
    }

    void setController(XmppController *controller) {
        m_controller = controller;
        if (m_controller) {
            connect(m_controller, &XmppController::rosterUpdated, this, &UserListWidget::refreshRoster);
            connect(m_controller, &XmppController::presenceUpdated, this, &UserListWidget::onPresenceUpdated);
        }
    }

    void refreshRoster() {
        if (!m_controller) return;
        m_listWidget->clear();
        QStringList jids = m_controller->rosterJids();
        for (const QString &jid : jids) {
            m_listWidget->addItem(jid);
        }
    }

private slots:
    void onAddClicked() {
        bool ok = false;
        QString jid = QInputDialog::getText(this, "Add Contact", "JID:", QLineEdit::Normal, QString(), &ok);
        if (ok && !jid.isEmpty()) {
            if (m_controller) m_controller->addRosterItem(jid);
            refreshRoster();
        }
    }

    void onRemoveClicked() {
        QListWidgetItem *it = m_listWidget->currentItem();
        if (!it) {
            QMessageBox::warning(this, "No selection", "Please select a contact to remove.");
            return;
        }
        QString jid = it->text();
        if (m_controller) m_controller->removeRosterItem(jid);
        refreshRoster();
    }

    void onCallClicked() {
        QListWidgetItem *it = m_listWidget->currentItem();
        if (!it) {
            QMessageBox::warning(this, "No selection", "Please select a contact to call.");
            return;
        }
        QString jid = it->text();
        if (m_controller) {
            m_controller->placeCall(jid);
            QMessageBox::information(this, "Calling", QString("Calling %1...").arg(jid));
        }
    }

    void onHangupClicked() {
        QListWidgetItem *it = m_listWidget->currentItem();
        if (!it) {
            QMessageBox::warning(this, "No selection", "Please select a contact to hang up.");
            return;
        }
        QString jid = it->text();
        if (m_controller) {
            m_controller->hangupCall(jid);
            QMessageBox::information(this, "Hangup", QString("Hung up %1").arg(jid));
        }
    }

    void onPresenceUpdated(const QString &jid, const QString &status) {
        Q_UNUSED(status);
        // Update UI presence indicator (not implemented in this scaffold)
        Q_UNUSED(jid);
    }

private:
    QListWidget *m_listWidget;
    QPushButton *m_addBtn;
    QPushButton *m_removeBtn;
    QPushButton *m_callBtn;
    QPushButton *m_hangupBtn;
    XmppController *m_controller;
};

