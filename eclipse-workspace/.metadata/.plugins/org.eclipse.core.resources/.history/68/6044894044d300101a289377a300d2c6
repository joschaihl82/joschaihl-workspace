// -----------------------------------------------------------------------------
// ToneGenerator - generates PCM tone patterns (16-bit LE, 8000 Hz mono)
// -----------------------------------------------------------------------------
class ToneGenerator {
public:
    ToneGenerator(int sampleRate = 8000) : m_sampleRate(sampleRate) {}
    QByteArray sineTone(int ms, double freq, double amplitude = 3000.0) {
        int samples = (m_sampleRate * ms) / 1000;
        QByteArray ba;
        ba.resize(samples * 2);
        qint16 *ptr = reinterpret_cast<qint16 *>(ba.data());
        for (int i = 0; i < samples; ++i) {
            double t = static_cast<double>(i) / m_sampleRate;
            double v = sin(2.0 * M_PI * freq * t) * amplitude;
            ptr[i] = static_cast<qint16>(v);
        }
        return ba;
    }
    QByteArray silence(int ms) {
        int samples = (m_sampleRate * ms) / 1000;
        QByteArray ba;
        ba.resize(samples * 2);
        memset(ba.data(), 0, ba.size());
        return ba;
    }
    // Composite patterns
    QByteArray waitingPattern() {
        // ringback: 1s tone 3s silence
        QByteArray out;
        out.append(sineTone(1000, 440.0, 4000.0));
        out.append(silence(3000));
        return out;
    }
    QByteArray busyPattern() {
        // busy: 480Hz + 620Hz alternating 500ms
        QByteArray out;
        out.append(sineTone(500, 480.0, 3500.0));
        out.append(sineTone(500, 620.0, 3500.0));
        return out;
    }
    QByteArray wrongNumberPattern() {
        QByteArray out;
        out.append(sineTone(200, 600.0, 4000.0));
        out.append(silence(100));
        out.append(sineTone(200, 600.0, 4000.0));
        return out;
    }
    QByteArray ringPattern() {
        // short ring bursts
        QByteArray out;
        out.append(sineTone(200, 440.0, 4000.0));
        out.append(silence(200));
        out.append(sineTone(200, 440.0, 4000.0));
        out.append(silence(2000));
        return out;
    }
private:
    int m_sampleRate;
};

// -----------------------------------------------------------------------------
// AlsaAudioDevice - minimal ALSA wrapper (blocking) - optional use
// -----------------------------------------------------------------------------
class AlsaAudioDevice {
public:
    AlsaAudioDevice(const std::string &device = "default", unsigned int rate = 8000, unsigned int channels = 1)
        : m_device(device), m_rate(rate), m_channels(channels), m_capture(nullptr), m_playback(nullptr) {}
    ~AlsaAudioDevice() { close(); }
    bool openCapture() {
        int err;
        if ((err = snd_pcm_open(&m_capture, m_device.c_str(), SND_PCM_STREAM_CAPTURE, 0)) < 0) {
            qWarning() << "ALSA capture open error:" << snd_strerror(err);
            return false;
        }
        snd_pcm_hw_params_t *params;
        snd_pcm_hw_params_malloc(&params);
        snd_pcm_hw_params_any(m_capture, params);
        snd_pcm_hw_params_set_access(m_capture, params, SND_PCM_ACCESS_RW_INTERLEAVED);
        snd_pcm_hw_params_set_format(m_capture, params, SND_PCM_FORMAT_S16_LE);
        snd_pcm_hw_params_set_channels(m_capture, params, m_channels);
        unsigned int r = m_rate;
        snd_pcm_hw_params_set_rate_near(m_capture, params, &r, 0);
        snd_pcm_hw_params(m_capture, params);
        snd_pcm_hw_params_free(params);
        snd_pcm_prepare(m_capture);
        return true;
    }
    bool openPlayback() {
        int err;
        if ((err = snd_pcm_open(&m_playback, m_device.c_str(), SND_PCM_STREAM_PLAYBACK, 0)) < 0) {
            qWarning() << "ALSA playback open error:" << snd_strerror(err);
            return false;
        }
        snd_pcm_hw_params_t *params;
        snd_pcm_hw_params_malloc(&params);
        snd_pcm_hw_params_any(m_playback, params);
        snd_pcm_hw_params_set_access(m_playback, params, SND_PCM_ACCESS_RW_INTERLEAVED);
        snd_pcm_hw_params_set_format(m_playback, params, SND_PCM_FORMAT_S16_LE);
        snd_pcm_hw_params_set_channels(m_playback, params, m_channels);
        unsigned int r = m_rate;
        snd_pcm_hw_params_set_rate_near(m_playback, params, &r, 0);
        snd_pcm_hw_params(m_playback, params);
        snd_pcm_hw_params_free(params);
        snd_pcm_prepare(m_playback);
        return true;
    }
    void close() {
        if (m_capture) { snd_pcm_close(m_capture); m_capture = nullptr; }
        if (m_playback) { snd_pcm_close(m_playback); m_playback = nullptr; }
    }
    ssize_t read(void *buf, size_t bytes) {
        if (!m_capture) return -1;
        snd_pcm_sframes_t frames = snd_pcm_readi(m_capture, buf, bytes / 2);
        if (frames < 0) frames = snd_pcm_recover(m_capture, frames, 0);
        if (frames < 0) return -1;
        return frames * 2;
    }
    ssize_t write(const void *buf, size_t bytes) {
        if (!m_playback) return -1;
        snd_pcm_sframes_t frames = snd_pcm_writei(m_playback, buf, bytes / 2);
        if (frames < 0) frames = snd_pcm_recover(m_playback, frames, 0);
        if (frames < 0) return -1;
        return frames * 2;
    }
private:
    std::string m_device;
    unsigned int m_rate;
    unsigned int m_channels;
    snd_pcm_t *m_capture;
    snd_pcm_t *m_playback;
};

// -----------------------------------------------------------------------------
// AudioEngine - uses QtMultimedia for cross-platform audio capture/playback
// includes simple AGC and device selection
// -----------------------------------------------------------------------------
class AudioEngine : public QObject {
    Q_OBJECT
public:
    AudioEngine(QObject *parent = nullptr)
        : QObject(parent), m_input(nullptr), m_output(nullptr), m_inputDevice(QAudioDeviceInfo::defaultInputDevice()),
          m_outputDevice(QAudioDeviceInfo::defaultOutputDevice()), m_sampleRate(8000), m_channels(1),
          m_agcEnabled(true), m_agcTargetRms(1000.0), m_agcGain(1.0), m_agcAttack(0.02), m_agcRelease(0.1),
          m_muted(false)
    {
        // default format
        m_format.setSampleRate(m_sampleRate);
        m_format.setChannelCount(m_channels);
        m_format.setSampleSize(16);
        m_format.setCodec("audio/pcm");
        m_format.setByteOrder(QAudioFormat::LittleEndian);
        m_format.setSampleType(QAudioFormat::SignedInt);
    }

    ~AudioEngine() override {
        stop();
    }

    QStringList availableInputDevices() {
        QStringList list;
        for (const QAudioDeviceInfo &d : QAudioDeviceInfo::availableDevices(QAudio::AudioInput)) {
            list << d.deviceName();
        }
        return list;
    }

    QStringList availableOutputDevices() {
        QStringList list;
        for (const QAudioDeviceInfo &d : QAudioDeviceInfo::availableDevices(QAudio::AudioOutput)) {
            list << d.deviceName();
        }
        return list;
    }

    void setInputDeviceByName(const QString &name) {
        for (const QAudioDeviceInfo &d : QAudioDeviceInfo::availableDevices(QAudio::AudioInput)) {
            if (d.deviceName() == name) {
                m_inputDevice = d;
                return;
            }
        }
    }

    void setOutputDeviceByName(const QString &name) {
        for (const QAudioDeviceInfo &d : QAudioDeviceInfo::availableDevices(QAudio::AudioOutput)) {
            if (d.deviceName() == name) {
                m_outputDevice = d;
                return;
            }
        }
    }

    bool start() {
        stop();
        if (!m_inputDevice.isFormatSupported(m_format)) {
            m_format = m_inputDevice.nearestFormat(m_format);
        }
        m_input = new QAudioInput(m_inputDevice, m_format, this);
        m_output = new QAudioOutput(m_outputDevice, m_format, this);
        m_inputBuffer = m_input->start();
        m_outputBuffer = m_output->start();
        connect(m_inputBuffer, &QIODevice::readyRead, this, &AudioEngine::onInputReady);
        return true;
    }

    void stop() {
        if (m_input) {
            m_input->stop();
            delete m_input;
            m_input = nullptr;
        }
        if (m_output) {
            m_output->stop();
            delete m_output;
            m_output = nullptr;
        }
        if (m_inputBuffer) { m_inputBuffer->close(); m_inputBuffer = nullptr; }
        if (m_outputBuffer) { m_outputBuffer->close(); m_outputBuffer = nullptr; }
    }

    void setAgcEnabled(bool on) { m_agcEnabled = on; }
    void setAgcTargetRms(double v) { m_agcTargetRms = v; }
    void setAgcAttack(double v) { m_agcAttack = v; }
    void setAgcRelease(double v) { m_agcRelease = v; }
    void setMuted(bool m) { m_muted = m; }

    // send PCM to playback (expects 16-bit LE mono)
    void playPcm(const QByteArray &pcm) {
        if (!m_outputBuffer) return;
        if (m_muted) return;
        m_outputBuffer->write(pcm);
    }

signals:
    void frameCaptured(const QByteArray &pcm);

private slots:
    void onInputReady() {
        if (!m_inputBuffer) return;
        QByteArray data = m_inputBuffer->readAll();
        if (data.isEmpty()) return;
        // apply AGC if enabled
        if (m_agcEnabled) data = applyAgc(data);
        emit frameCaptured(data);
    }

private:
    QByteArray applyAgc(const QByteArray &pcm) {
        if (pcm.isEmpty()) return pcm;
        int samples = pcm.size() / 2;
        const qint16 *in = reinterpret_cast<const qint16 *>(pcm.constData());
        QByteArray out;
        out.resize(pcm.size());
        qint16 *outPtr = reinterpret_cast<qint16 *>(out.data());
        double sum = 0.0;
        for (int i = 0; i < samples; ++i) {
            double s = static_cast<double>(in[i]);
            sum += s * s;
        }
        double rms = (samples > 0) ? sqrt(sum / samples) : 0.0;
        double desiredGain = 1.0;
        if (rms > 1e-6) desiredGain = m_agcTargetRms / rms;
        if (desiredGain > 10.0) desiredGain = 10.0;
        if (desiredGain < 0.1) desiredGain = 0.1;
        if (desiredGain > m_agcGain) {
            m_agcGain += (desiredGain - m_agcGain) * m_agcAttack;
        } else {
            m_agcGain += (desiredGain - m_agcGain) * m_agcRelease;
        }
        for (int i = 0; i < samples; ++i) {
            double v = static_cast<double>(in[i]) * m_agcGain;
            if (v > 32767.0) v = 32767.0;
            if (v < -32768.0) v = -32768.0;
            outPtr[i] = static_cast<qint16>(v);
        }
        return out;
    }

    QAudioDeviceInfo m_inputDevice;
    QAudioDeviceInfo m_outputDevice;
    QAudioFormat m_format;
    int m_sampleRate;
    int m_channels;
    QAudioInput *m_input;
    QAudioOutput *m_output;
    QIODevice *m_inputBuffer;
    QIODevice *m_outputBuffer;
    bool m_agcEnabled;
    double m_agcTargetRms;
    double m_agcGain;
    double m_agcAttack;
    double m_agcRelease;
    bool m_muted;
};

// -----------------------------------------------------------------------------
// CallManager - manages call lifecycle, tones, and integrates AudioEngine
// -----------------------------------------------------------------------------
class CallManager : public QObject {
    Q_OBJECT
public:
    CallManager(AudioEngine *audio, Logger *logger, QObject *parent = nullptr)
        : QObject(parent), m_audio(audio), m_logger(logger), m_active(false), m_tonePlaying(false),
          m_toneGen(8000), m_mockRemote(false)
    {
        if (m_audio) connect(m_audio, &AudioEngine::frameCaptured, this, &CallManager::onLocalFrame);
    }

    ~CallManager() override {
        stopCall();
    }

    void startCall(const QString &peerJid) {
        if (m_active) return;
        m_peer = peerJid;
        m_logger->log(QString("Starting call to %1").arg(peerJid));
        if (m_audio) m_audio->start();
        m_active = true;
        playRingback();
        emit callStarted(peerJid);
    }

    void stopCall() {
        if (!m_active) return;
        stopTone();
        if (m_audio) m_audio->stop();
        m_logger->log(QString("Stopped call with %1").arg(m_peer));
        emit callEnded(m_peer);
        m_active = false;
        m_peer.clear();
    }

    void hangup() { stopCall(); }

    void playRingback() {
        stopTone();
        m_tonePlaying = true;
        // schedule repeating ringback
        m_toneTimer = std::make_unique<QTimer>();
        connect(m_toneTimer.get(), &QTimer::timeout, this, [this]() {
            QByteArray p = m_toneGen.waitingPattern();
            if (m_audio) m_audio->playPcm(p);
        });
        // immediate play
        if (m_audio) m_audio->playPcm(m_toneGen.waitingPattern());
        m_toneTimer->start(4000);
    }

    void playBusy() {
        stopTone();
        m_tonePlaying = true;
        m_toneTimer = std::make_unique<QTimer>();
        connect(m_toneTimer.get(), &QTimer::timeout, this, [this]() {
            QByteArray p = m_toneGen.busyPattern();
            if (m_audio) m_audio->playPcm(p);
        });
        if (m_audio) m_audio->playPcm(m_toneGen.busyPattern());
        m_toneTimer->start(1000);
    }

    void playWrongNumber() {
        stopTone();
        m_tonePlaying = true;
        QByteArray p = m_toneGen.wrongNumberPattern();
        if (m_audio) m_audio->playPcm(p);
        QTimer::singleShot(1200, this, [this]() { this->m_tonePlaying = false; });
    }

    void playRing() {
        stopTone();
        m_tonePlaying = true;
        m_toneTimer = std::make_unique<QTimer>();
        connect(m_toneTimer.get(), &QTimer::timeout, this, [this]() {
            QByteArray p = m_toneGen.ringPattern();
            if (m_audio) m_audio->playPcm(p);
        });
        if (m_audio) m_audio->playPcm(m_toneGen.ringPattern());
        m_toneTimer->start(2600);
    }

    void stopTone() {
        m_tonePlaying = false;
        if (m_toneTimer) {
            m_toneTimer->stop();
            m_toneTimer.reset();
        }
    }

    void setMockRemote(bool on) { m_mockRemote = on; }

signals:
    void callStarted(const QString &jid);
    void callEnded(const QString &jid);
    void remoteFrame(const QByteArray &pcm);

private slots:
    void onLocalFrame(const QByteArray &pcm) {
        // Called when audio engine captures a frame
        if (!m_active) return;
        // In real implementation: encode and send via RTP
        // For mock mode: loop back or simulate remote
        if (m_mockRemote) {
            // simulate network jitter and echo
            QByteArray copy = pcm;
            // small delay
            QTimer::singleShot(50 + (QRandomGenerator::global()->bounded(50)), this, [this, copy]() {
                if (m_audio) m_audio->playPcm(copy);
                emit remoteFrame(copy);
            });
        } else {
            // loopback locally if no remote
            if (!m_tonePlaying && m_audio) m_audio->playPcm(pcm);
        }
    }

private:
    AudioEngine *m_audio;
    Logger *m_logger;
    bool m_active;
    QString m_peer;
    bool m_tonePlaying;
    std::unique_ptr<QTimer> m_toneTimer;
    ToneGenerator m_toneGen;
    bool m_mockRemote;
};

