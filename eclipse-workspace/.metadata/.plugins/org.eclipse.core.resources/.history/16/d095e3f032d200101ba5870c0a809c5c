/* bootx64.c
 * Standalone UEFI application WITHOUT including any EFI headers.
 * All needed EFI types and important function prototypes are defined here
 * so the file is self-contained.
 *
 * WARNING: This is low-level code that talks directly to firmware and PCI
 * devices. Use in QEMU/OVMF for testing. It is untested on real hardware.
 */

// ---------------------- Minimal EFI type definitions (self-contained) ----------------------
typedef unsigned long long UINT64;
typedef unsigned int       UINT32;
typedef unsigned short     UINT16;
typedef unsigned char      UINT8;
typedef unsigned long      UINTN; /* 64-bit on x86_64 when compiled appropriately */
typedef void               VOID;
typedef CHAR16             CHAR16; /* will define below */
typedef char               CHAR8;

/* Minimal CHAR16 for Unicode output */
typedef unsigned short CHAR16;

typedef VOID *EFI_HANDLE;
typedef UINT64 EFI_PHYSICAL_ADDRESS;
typedef UINT64 EFI_VIRTUAL_ADDRESS;

typedef UINT64 EFI_STATUS;
#define EFI_SUCCESS 0
#define EFI_BUFFER_TOO_SMALL 5

// Forward declarations
struct _EFI_BOOT_SERVICES;
struct _EFI_SYSTEM_TABLE;

/* Prototype types for key Boot Services functions we use */
typedef EFI_STATUS (*EFI_ALLOCATE_PAGES)(UINT32 Type, UINT32 MemoryType, UINTN Pages, EFI_PHYSICAL_ADDRESS *Memory);
typedef EFI_STATUS (*EFI_FREE_PAGES)(EFI_PHYSICAL_ADDRESS Memory, UINTN Pages);
typedef EFI_STATUS (*EFI_GET_MEMORY_MAP)(UINTN *MemoryMapSize, void *MemoryMap, UINTN *MapKey, UINTN *DescriptorSize, UINT32 *DescriptorVersion);
typedef EFI_STATUS (*EFI_EXIT_BOOT_SERVICES)(EFI_HANDLE ImageHandle, UINTN MapKey);
typedef EFI_STATUS (*EFI_LOCATE_HANDLE_BUFFER)(UINT32 SearchType, const void *Protocol, void *SearchKey, UINTN *NoHandles, EFI_HANDLE **Buffer);
typedef EFI_STATUS (*EFI_HANDLE_PROTOCOL)(EFI_HANDLE Handle, const void *Protocol, void **Interface);
typedef EFI_STATUS (*EFI_FREE_POOL)(void *Buffer);

/* Simple PCI IO Read prototype (we only need Uint8/Uint32 reads) */
typedef enum { EfiPciIoWidthUint8 = 0, EfiPciIoWidthUint32 = 3 } EFI_PCI_IO_WIDTH;
typedef struct {
    EFI_STATUS (*Read)(void *This, EFI_PCI_IO_WIDTH Width, UINTN Offset, UINTN Count, void *Buffer);
    EFI_STATUS (*Write)(void *This, EFI_PCI_IO_WIDTH Width, UINTN Offset, UINTN Count, void *Buffer);
} EFI_PCI_IO_PROTOCOL;

/* Graphics Output protocol (very small subset) */
typedef enum { PixelRedGreenBlueReserved8BitPerColor = 0 } EFI_GRAPHICS_PIXEL_FORMAT;
typedef struct {
    UINT32 HorizontalResolution;
    UINT32 VerticalResolution;
    UINT32 PixelsPerScanLine;
    EFI_GRAPHICS_PIXEL_FORMAT PixelFormat;
} GOP_MODE_INFO;
typedef struct {
    UINT64 FrameBufferBase;
    UINT64 FrameBufferSize;
    GOP_MODE_INFO *Info;
} GOP_MODE;
typedef struct {
    GOP_MODE *Mode;
} EFI_GRAPHICS_OUTPUT_PROTOCOL;

/* Simple text output protocol */
typedef struct {
    EFI_STATUS (*OutputString)(void *This, CHAR16 *String);
} SIMPLE_TEXT_OUTPUT_PROTOCOL;

/* Boot services (very small) */
typedef struct _EFI_BOOT_SERVICES {
    // many entries omitted; we only list the few we need in the proper order
    void *Hdr;
    EFI_ALLOCATE_PAGES AllocatePages;
    void *FreePages; // not used
    void *GetMemoryMap; // position placeholder
    EFI_GET_MEMORY_MAP GetMemoryMap_fn; // we'll set by offset when reading
    EFI_EXIT_BOOT_SERVICES ExitBootServices;
    EFI_LOCATE_HANDLE_BUFFER LocateHandleBuffer;
    EFI_HANDLE_PROTOCOL HandleProtocol;
    EFI_FREE_POOL FreePool;
    // Note: in real firmware the table layout is strict. This is simplified and
    // may need adjustments depending on the platform. In OVMF this generally works
    // if compiled with the same ABI and offsets matched.
} EFI_BOOT_SERVICES;

/* System Table */
typedef struct _EFI_SYSTEM_TABLE {
    CHAR16 *FirmwareVendor;
    UINT32 FirmwareRevision;
    void *ConsoleInHandle;
    SIMPLE_TEXT_OUTPUT_PROTOCOL *ConOut;
    void *ConIn; // omitted
    EFI_BOOT_SERVICES *BootServices;
} EFI_SYSTEM_TABLE;

// Minimal GUID placeholders (we only use pointers to protocol GUIDs for LocateHandleBuffer)
static const void *gEfiPciIoProtocolGuid = (const void*)0x01;
static const void *gEfiGraphicsOutputProtocolGuid = (const void*)0x02;

// ---------------------- Small helpers ----------------------
static inline VOID write_u16(CHAR16 *dst, const CHAR8 *s){
    while (*s) { *dst++ = (CHAR16)(*s++); }
    *dst = 0;
}

// Convert ASCII to CHAR16 and print via ConOut->OutputString
static VOID PrintAscii(EFI_SYSTEM_TABLE *ST, const CHAR8 *s){
    CHAR16 buf[512];
    write_u16(buf, s);
    if (ST && ST->ConOut && ST->ConOut->OutputString) ST->ConOut->OutputString(ST->ConOut, buf);
}

// ---------------------- NVMe & framebuffer code (same logic as before) ----------------------
#define NVME_REG_CAP 0x0000
#define NVME_REG_VS  0x0008
#define NVME_REG_CC  0x0014
#define NVME_REG_CSTS 0x001c
#define NVME_REG_AQA 0x0024
#define NVME_REG_ASQ 0x0028
#define NVME_REG_ACQ 0x0030
#define NVME_DOORBELL_OFFSET 0x1000
#define NVME_ADMIN_IDENTIFY 0x06
#define NVME_CMD_READ 0x02
#define PAGE_SIZE 4096
#define ADMIN_Q_ENTRIES 16

typedef struct {
    EFI_PHYSICAL_ADDRESS FrameBufferBase;
    UINT32 FrameBufferWidth;
    UINT32 FrameBufferHeight;
    UINT32 PixelsPerScanLine;
} FB_INFO;

typedef struct {
    EFI_PHYSICAL_ADDRESS NvmeBar;
    FB_INFO fb;
    EFI_PHYSICAL_ADDRESS AdminSqPhys;
    EFI_PHYSICAL_ADDRESS AdminCqPhys;
    EFI_PHYSICAL_ADDRESS DataBufPhys;
    VOID *AdminSqVirt;
    VOID *AdminCqVirt;
    VOID *DataBufVirt;
    UINTN MemMapSize;
    VOID *MemMap;
    UINTN MapKey;
    UINTN DescriptorSize;
    UINT32 DescriptorVersion;
} SAVED_STATE;

static SAVED_STATE S;

static VOID *my_memcpy(VOID *dst, const VOID *src, UINTN len){ UINT8 *d=dst; const UINT8 *s=src; while(len--) *d++=*s++; return dst; }
static VOID *my_memset(VOID *dst, int v, UINTN len){ UINT8 *d=dst; while(len--) *d++=(UINT8)v; return dst; }

static const UINT8 hex6x8[][6] = {
