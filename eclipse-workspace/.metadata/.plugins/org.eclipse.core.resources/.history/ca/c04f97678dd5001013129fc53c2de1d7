            return 0;
        }
        error("unsupported orps form");
        return -1;
    }
    return -1;
}

/* ===== High-level instruction emitter ===== */

static void emit_insn_from_table(struct insn *it)
{
    /* Very small matching/encoding: handle a few cases */
    if (!it) return;

    /* Special-case encodings */
    if (strcmp(it->mnemonic, "jmp") == 0) {
        if (nr_operands == 1 && operands[0].kind == OPERAND_IMM && operands[0].symbol) {
            encode_jmp_rel32(&operands[0]);
            return;
        }
    } else if (strcmp(it->mnemonic, "call") == 0) {
        if (nr_operands == 1 && operands[0].kind == OPERAND_IMM && operands[0].symbol) {
            encode_call_rel32(&operands[0]);
            return;
        }
    } else if (strcmp(it->mnemonic, "je") == 0 || strcmp(it->mnemonic, "jz") == 0) {
        if (nr_operands == 1 && operands[0].kind == OPERAND_IMM && operands[0].symbol) {
            encode_jcc_rel32(0x84);
            return;
        }
    } else if (strcmp(it->mnemonic, "jne") == 0 || strcmp(it->mnemonic, "jnz") == 0) {
        if (nr_operands == 1 && operands[0].kind == OPERAND_IMM && operands[0].symbol) {
            encode_jcc_rel32(0x85);
            return;
        }
    } else if (!strcmp(it->mnemonic, "ret")) {
        emit_byte(0xC3); return;
    } else if (!strcmp(it->mnemonic, "nop")) {
        emit_byte(0x90); return;
    } else if (!strcmp(it->mnemonic, "leave")) {
        emit_byte(0xC9); return;
    } else if (!strcmp(it->mnemonic, "syscall")) {
        emit_byte(0x0F); emit_byte(0x05); return;
    }

    /* Try SSE */
    if (try_encode_sse(it->mnemonic) == 0) return;

    /* Generic simple encodings for a few GPR ops */
    if (!strcmp(it->mnemonic, "movq")) {
        if (nr_operands==2 && operands[0].kind==OPERAND_REG && operands[1].kind==OPERAND_IMM) {
            /* mov reg, imm -> AT&T: $imm, %reg */
            encode_mov_r64_imm32(operands[0].reg, (unsigned)operands[1].offset);
            return;
        }
        if (nr_operands==2 && operands[0].kind==OPERAND_MEM && operands[1].kind==OPERAND_REG) {
            /* mov r64 -> m64 : opcode 89 /r (reg -> r/m) ; AT&T: src,dst so operands[0]=mem, operands[1]=reg */
            int reg = operands[1].reg;
            int rm = operands[0].reg >= 0 ? operands[0].reg : 0;
            int rex_r = (reg >> 3) & 1;
            int rex_b = (rm >> 3) & 1;
            emit_rex(1, rex_r, 0, rex_b);
            emit_byte(0x89);
            emit_modrm_mem_reg(reg, rm, operands[0].rip);
            return;
        }
        if (nr_operands==2 && operands[0].kind==OPERAND_REG && operands[1].kind==OPERAND_MEM) {
            /* mov m64 -> r64 : opcode 8B /r (r/m -> reg) ; AT&T: src,dst so operands[0]=reg, operands[1]=mem */
            int reg = operands[0].reg;
            int rm = operands[1].reg >= 0 ? operands[1].reg : 0;
            int rex_r = (reg >> 3) & 1;
            int rex_b = (rm >> 3) & 1;
            emit_rex(1, rex_r, 0, rex_b);
            emit_byte(0x8B);
            emit_modrm_mem_reg(reg, rm, operands[1].rip);
            return;
        }
    } else if (!strcmp(it->mnemonic, "addq")) {
        if (nr_operands==2 && operands[0].kind==OPERAND_MEM && operands[1].kind==OPERAND_REG) {
            int reg = operands[1].reg;
            int rm = operands[0].reg >= 0 ? operands[0].reg : 0;
            int rex_r = (reg >> 3) & 1;
            int rex_b = (rm >> 3) & 1;
            emit_rex(1, rex_r, 0, rex_b);
            emit_byte(0x01);
            emit_modrm_mem_reg(reg, rm, operands[0].rip);
            return;
        }
    } else if (!strcmp(it->mnemonic, "subq")) {
        if (nr_operands==2 && operands[0].kind==OPERAND_MEM && operands[1].kind==OPERAND_REG) {
            int reg = operands[1].reg;
            int rm = operands[0].reg >= 0 ? operands[0].reg : 0;
            int rex_r = (reg >> 3) & 1;
            int rex_b = (rm >> 3) & 1;
            emit_rex(1, rex_r, 0, rex_b);
            emit_byte(0x29);
            emit_modrm_mem_reg(reg, rm, operands[0].rip);
            return;
        }
    } else if (!strcmp(it->mnemonic, "cmpq")) {
        if (nr_operands==2 && operands[0].kind==OPERAND_MEM && operands[1].kind==OPERAND_REG) {
            int reg = operands[1].reg;
            int rm = operands[0].reg >= 0 ? operands[0].reg : 0;
            int rex_r = (reg >> 3) & 1;
            int rex_b = (rm >> 3) & 1;
            emit_rex(1, rex_r, 0, rex_b);
            emit_byte(0x39);
            emit_modrm_mem_reg(reg, rm, operands[0].rip);
            return;
        }
    } else if (!strcmp(it->mnemonic, "xorq")) {
        if (nr_operands==2 && operands[0].kind==OPERAND_MEM && operands[1].kind==OPERAND_REG) {
            int reg = operands[1].reg;
            int rm = operands[0].reg >= 0 ? operands[0].reg : 0;
            int rex_r = (reg >> 3) & 1;
            int rex_b = (rm >> 3) & 1;
            emit_rex(1, rex_r, 0, rex_b);
            emit_byte(0x31);
            emit_modrm_mem_reg(reg, rm, operands[0].rip);
            return;
        }
    }

    error("encoding for instruction '%s' not implemented or unsupported operand forms", it->mnemonic);
}

/* ===== Relocation resolution ===== */

static void resolve_relocs(void)
{
    for (int i = 0; i < relocs_count; ++i) {
        struct reloc *r = &relocs[i];
        if (!r->sym) { error("reloc with no symbol"); continue; }
        if (r->sym->segment == -1) {
            error("undefined symbol '%s' in relocation", r->sym->n->data);
            continue;
        }
        long sym_addr = (r->sym->segment == 1) ? (base_address + r->sym->offset) : (base_address + text_len + r->sym->offset);
        /* For simplicity assume all relocs are in .text and are rel32 relative to next instruction */
        long place = r->pos; /* position where displacement starts */
        long next_insn = place + r->size;
        long rel = (long)(sym_addr - (base_address + next_insn));
        /* patch into text_buf at r->pos */
        if (r->pos + r->size > text_len) { error("reloc out of range"); continue; }
        unsigned long val = (unsigned long)rel;
        for (int b = 0; b < r->size; ++b) {
            text_buf[r->pos + b] = (unsigned char)((val >> (8*b)) & 0xFF);
        }
    }
}

/* ===== Line parsing and assembly loop ===== */

static void process_line(const char *line)
{
    strncpy(input_line, line, INPUT_LINE_MAX-1);
    input_line[INPUT_LINE_MAX-1] = '\0';
    input_pos = input_line;
    next_token();

    /* Empty or comment */
    if (tkind == T_EOF) return;

    /* Label? */
    if (tkind == T_IDENT) {
        char saved[256]; strcpy(saved, tok_text);
        next_token();
        if (tkind == T_COLON) {
            /* define label */
            struct name *n = lookup_name(saved, (int)strlen(saved));
            struct obj_symbol *sym = ensure_symbol_for_name(n);
            sym->segment = segment ? segment : 1;
            sym->offset = (segment == 1) ? text_len : (segment == 2 ? data_len : data_bytes);
            next_token();
            return;
        } else {
            /* Not a label: treat as mnemonic */
            input_pos = (char *)line;
            strncpy(input_line, line, INPUT_LINE_MAX-1);
            input_pos = input_line;
            next_token();
        }
    }

    /* Directive or mnemonic */
    if (tkind == T_IDENT) {
        /* Pseudo-ops start with '.' or are names like 'text' depending on dialect; handle common ones */
        if (strcmp(tok_text, ".text") == 0 || strcmp(tok_text, "text") == 0) {
            pseudo_text(); next_token(); return;
        } else if (strcmp(tok_text, ".data") == 0 || strcmp(tok_text, "data") == 0) {
            pseudo_data(); next_token(); return;
        } else if (strcmp(tok_text, ".bss") == 0 || strcmp(tok_text, "bss") == 0) {
            pseudo_bss(); next_token(); return;
        } else if (strcmp(tok_text, ".global") == 0 || strcmp(tok_text, "global") == 0) {
            next_token();
            if (tkind == T_IDENT) {
                struct name *n = lookup_name(tok_text, (int)strlen(tok_text));
                name_token = n;
                pseudo_global();
                next_token();
            }
            return;
        } else if (strcmp(tok_text, ".byte") == 0 || strcmp(tok_text, "byte") == 0) {
            next_token();
            if (tkind == T_NUMBER) { number_token = tok_number; pseudo_byte(); next_token(); }
            return;
        } else if (strcmp(tok_text, ".ascii") == 0 || strcmp(tok_text, "ascii") == 0) {
            next_token();
            if (tkind == T_STRING) { name_token = lookup_name(tok_text, (int)strlen(tok_text)); pseudo_ascii(); next_token(); }
            return;
        } else if (strcmp(tok_text, ".align") == 0 || strcmp(tok_text, "align") == 0) {
            next_token();
            if (tkind == T_NUMBER) { number_token = tok_number; pseudo_align(); next_token(); }
            return;
        } else {
            /* Instruction mnemonic */
            char mnemonic[256]; strcpy(mnemonic, tok_text);
            next_token();
            /* parse operands separated by commas */
            nr_operands = 0;
            while (tkind != T_EOF && tkind != T_COLON) {
                if (nr_operands >= MAX_OPERANDS) { error("too many operands"); break; }
                if (parse_operand(&operands[nr_operands]) != 0) break;
                nr_operands++;
                if (tkind == T_COMMA) { next_token(); continue; }
                else break;
            }
            struct insn *it = NULL;
            if (match_insn(mnemonic, &it) == 0) {
                emit_insn_from_table(it);
            } else {
                error("unknown instruction '%s'", mnemonic);
            }
            return;
        }
    }
}

/* ===== Output dump ===== */

static void dump_hex(const unsigned char *buf, long len, const char *name)
{
    printf("section %s: %ld bytes\n", name, len);
    for (long i = 0; i < len; i += 16) {
        printf("%08lx  ", (unsigned long)i);
        for (int j = 0; j < 16; ++j) {
            if (i + j < len) printf("%02x ", buf[i+j]);
            else printf("   ");
        }
        printf(" ");
        for (int j = 0; j < 16; ++j) {
            if (i + j < len) {
                unsigned char c = buf[i+j];
                printf("%c", (c >= 32 && c < 127) ? c : '.');
            }
        }
        printf("\n");
    }
}

/* ===== Main and file handling ===== */

int main(int argc, char **argv)
{
    if (argc < 2) {
        fprintf(stderr, "usage: %s <asm-file>\n", argv[0]);
        return 1;
    }

    FILE *f = fopen(argv[1], "r");
    if (!f) { perror("fopen"); return 1; }

    segment = 1; /* default to text */
    text_len = 0; data_len = 0;
    line_number = 0;

    char line[INPUT_LINE_MAX];
    while (fgets(line, sizeof(line), f)) {
        line_number++;
        process_line(line);
    }
    fclose(f);

    /* Resolve relocations */
    resolve_relocs();

    /* Dump sections */
    dump_hex(text_buf, text_len, ".text");
    dump_hex(data_buf, data_len, ".data");

    /* Print symbol table */
    printf("\nSymbols (%d):\n", symbols_count);
    for (int i = 0; i < symbols_count; ++i) {
        struct obj_symbol *s = &symbols[i];
        printf(" %3d: %-20s seg=%d off=%ld glob=%d\n", i, s->n->data, s->segment, s->offset, s->is_global);
    }

    return 0;
}
