          [of] "=r" (of),
          [sf] "=r" (sf),
          [zf] "=r" (zf),
          [pf_byte] "=r" (pf_byte)
        : [rhs] "r" (rhs)
        : "rax", "cc"
    );
    unsigned char pf = (pf_byte >> 2) & 1;
    set_flag_bit(0, cf);
    set_flag_bit(2, pf);
    set_flag_bit(6, zf);
