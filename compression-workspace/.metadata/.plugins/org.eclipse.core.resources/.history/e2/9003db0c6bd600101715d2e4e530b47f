/*
 * compression helpers (extracted from lz4_comp)
 *
 * The comments below focus on the goal, invariants and a short example.
 */

/* write header (magic + original size), leave space for compressed size
 *
 * Goal: produce a compact self-describing header so the decoder can:
 *  - verify the magic tag,
 *  - read the original (decompressed) size,
 *  - locate the compressed payload and its length.
 *
 * Invariant: header is HDR_HDR_SIZE bytes; caller must later fill
 * the compressed-size field at HDR_CSIZE_OFF.
 *
 * Example:
 *  - orig_size = 16 -> header bytes: "LZ4B" + 0x10 0x00 0x00 0x00 + (4 bytes placeholder)
 */
static uint8_t *
comp_write_header(uint8_t *out, size_t orig_size)
{
    memcpy(out, HDR_MAGIC, HDR_MAGIC_LEN);
    out += HDR_MAGIC_LEN;
    memcpy(out, &orig_size, 4);
    out += 8; /* leave 4 bytes for compressed size */
    return out;
}

/* allocate and initialize hash table
 *
 * Goal: provide a fixed-size, fast lookup table for match candidates.
 * Invariant: returned table contains sentinel U32_EMPTY in every slot.
 * Failure: returns NULL on allocation failure; caller must handle it.
 */
static uint32_t *
comp_alloc_hash(void)
{
    uint32_t *ht;

    ht = calloc(HSH_SIZE, sizeof(uint32_t));
    if (ht == NULL)
        return NULL;
    memset(ht, U8_ALL_ONES, HSH_SIZE * sizeof(uint32_t));
    return ht;
}

/* emit literal length extension bytes and copy literal data
 *
 * Goal: encode literal lengths using a small token nibble and optional
 * extension bytes for long runs. This keeps the token compact for the
 * common short-literal case while allowing arbitrarily long literals.
 *
 * Example:
 *  - len = 3 -> token nibble stores 3, no extension bytes, copy 3 bytes.
 *  - len = 300 -> token nibble = 15, extension bytes: 255, 30, then copy.
 */
static void
comp_emit_literal(uint8_t **op, const uint8_t *anc, size_t len)
{
    size_t rem;

    rem = len >= TOKEN_MAX_NIBBLE ? len - TOKEN_MAX_NIBBLE : 0;
    if (len >= TOKEN_MAX_NIBBLE) {
        while (rem >= TOKEN_EXT_BYTE) {
            *(*op)++ = (uint8_t)TOKEN_EXT_BYTE;
            rem -= TOKEN_EXT_BYTE;
        }
        *(*op)++ = (uint8_t)rem;
    }
    memcpy(*op, anc, len);
    *op += len;
}

/* emit match offset and match-length extension bytes
 *
 * Goal: represent the match offset (fixed 16-bit) and extended match
 * length using the same extension scheme as literals. This yields a
 * compact representation for short matches and supports long matches.
 *
 * Example:
 *  - off=2, len=8 -> write offset (2 bytes), write len-4 in token nibble.
 */
static void
comp_emit_match(uint8_t **op, size_t off, size_t len)
{
    uint16_t o;
    size_t l;
    size_t rem;

    o = (uint16_t)off;
    *(*op)++ = (uint8_t)(o & 0xFF);
    *(*op)++ = (uint8_t)((o >> 8) & 0xFF);
    l = len - MIN_MAT;
    if (l >= TOKEN_MAX_NIBBLE) {
        rem = l - TOKEN_MAX_NIBBLE;
        while (rem >= TOKEN_EXT_BYTE) {
            *(*op)++ = (uint8_t)TOKEN_EXT_BYTE;
            rem -= TOKEN_EXT_BYTE;
        }
        *(*op)++ = (uint8_t)rem;
    }
}

/* find match length between ip and ref (bounded by end)
 *
 * Goal: compute the maximal run length where bytes match starting at ip
 * and ref. This is the core of the match extension step; it returns the
 * length m >= MIN_MAT that will be encoded as a match.
 *
 * Performance note: this loop is a hotspot and can be vectorized later.
 */
static size_t
comp_find_match_len(const uint8_t *ip, const uint8_t *ref, const uint8_t *end)
{
    const uint8_t *p1 = ip;
    const uint8_t *p2 = ref;

    while (p1 < end && *p1 == *p2) {
        p1++;
        p2++;
    }
    return (size_t)(p1 - ip);
}

/*
 * compression core (refactored)
 *
 * Goal: transform an input block I of length n into a compact encoded
 * block O that the decoder can invert exactly. The function is designed
 * for streaming: it writes a small header, then a sequence of tokens
 * (literal runs and matches). It favors speed (single-pass hash-based
 * matching) while providing reasonable compression.
 *
 * Mathematical description (short):
 *  - Input: I ∈ {0..255}^n.
 *  - Output: O = H || T where H is fixed header and T is a sequence
 *    of pairs (L_i, M_i) with L_i ∈ {literal bytes}, M_i = (off,len).
 *  - Decoding: decode(T) = I. The mapping is bijective for valid encodings.
 *
 * Example (illustrative):
 *  - I = "ABABABABCCCCDDDD" (n=16)
 *  - One valid encoding: token(match offset=2,len=8) then literal "CCCCDDDD".
 *  - O = HDR + token + offset(2) + literal-length + "CCCCDDDD"
 *
 * Invariants and failure semantics:
 *  - If memory allocation fails or 'cap' is too small, return 0.
 *  - Caller must ensure 'out' has capacity >= expected worst-case.
 */
static size_t
lz4_comp(const uint8_t *in, size_t n, uint8_t *out, size_t cap)
{
    const uint8_t *ip, *end, *anc;
    uint32_t *ht;
    uint8_t *op;
    uint32_t h, ref;
    size_t m_len, l_len;

    if (cap < HDR_HDR_SIZE)
        return (0);

    op = out;
    op = comp_write_header(op, n);

    ht = comp_alloc_hash();
    if (ht == NULL)
        return (0);

    ip = in;
    end = in + n;
    anc = ip;

    while (ip + MIN_MAT <= end) {
        /* compute hash and probe table */
        memcpy(&h, ip, 4);
        h = ((h * HASH_MULT) >> HSH_SFT) & (HSH_SIZE - 1);
        ref = ht[h];
        ht[h] = (uint32_t)(ip - in);

        /* candidate validation: ensure within window and matching */
        if (ref == U32_EMPTY || (ip - (in + ref)) > WIN_SIZE ||
            memcmp(in + ref, ip, MIN_MAT) != 0) {
            ip++;
            continue;
        }

        /* determine match and literal lengths */
        m_len = comp_find_match_len(ip, in + ref, end);
        l_len = ip - anc;

        /* emit token, literal, and match */
        *op++ = (uint8_t)((l_len >= TOKEN_MAX_NIBBLE ? TOKEN_MAX_NIBBLE : l_len) << 4 |
            (m_len - MIN_MAT >= TOKEN_MAX_NIBBLE ? TOKEN_MAX_NIBBLE : m_len - MIN_MAT));
        comp_emit_literal(&op, anc, l_len);
        comp_emit_match(&op, ip - (in + ref), m_len);

        /* advance to continue scanning after the match */
        ip += m_len;
        anc = ip;
    }

    /* emit final literal run */
    l_len = end - anc;
    *op++ = (uint8_t)((l_len >= TOKEN_MAX_NIBBLE ? TOKEN_MAX_NIBBLE : l_len) << 4);
    comp_emit_literal(&op, anc, l_len);

    /* write compressed size into header and return total bytes */
    {
        uint32_t c_sz = (uint32_t)(op - out - HDR_HDR_SIZE);
        memcpy(out + HDR_CSIZE_OFF, &c_sz, 4);
    }

    free(ht);
    return (size_t)(op - out);
}

/*
 * decompression helpers (extracted from lz4_dec)
 *
 * These helpers focus on the decoding contract and safety invariants.
 */

/* read extended length for literal or match
 *
 * Goal: decode the variable-length integer used for lengths. The helper
 * advances *ip and returns the decoded length. If input is truncated,
 * it returns 0 to indicate an error to the caller.
 */
static size_t
dec_read_ext_len(const uint8_t **ip, const uint8_t *end, size_t initial)
{
    size_t len = initial;
    uint8_t s;

    if (initial == TOKEN_MAX_NIBBLE) {
        do {
            if (*ip >= end) return 0;
            s = *(*ip)++;
            len += s;
        } while (s == TOKEN_EXT_BYTE);
    }
    return len;
}

/* copy match bytes handling overlap
 *
 * Goal: reconstruct a match region in the output buffer even when the
 * source and destination ranges overlap (typical in LZ-style codecs).
 * Returns 0 on success, -1 on invalid offset or capacity violation.
 */
static int
dec_copy_match(uint8_t *out, size_t opos, size_t off, size_t m_len, size_t cap)
{
    size_t ref = opos - off;
    size_t i;

    if (off == 0 || off > opos || opos + m_len > cap)
        return -1;
    for (i = 0; i < m_len; ++i)
        out[opos + i] = out[ref + i];
    return 0;
}

/*
 * decompression core (refactored)
 *
 * Goal: validate the compressed block header and reconstruct the exact
 * original input into 'out'. The function enforces bounds checks and
 * returns 0 on any format or capacity error.
 *
 * Mathematical summary:
 *  - Let O = H || T where H contains original size org.
 *  - The decoder processes T to produce I' and returns |I'| if I' == org.
 *  - Correctness: decode(encode(I)) = I.
 *
 * Example:
 *  - Given O produced from I = "ABABABABCCCCDDDD", lz4_dec(O, n, out, cap)
 *    will write the 16 original bytes into out and return 16.
 */
static size_t
lz4_dec(const uint8_t *in, size_t n, uint8_t *out, size_t cap)
{
    const uint8_t *ip, *end;
    uint32_t org, c_sz;
    size_t opos, l_len, m_len;
    uint8_t tok;
    uint16_t off;

    if (n < HDR_HDR_SIZE || memcmp(in, HDR_MAGIC, HDR_MAGIC_LEN) != 0)
        return (0);
    memcpy(&org, in + HDR_ORIG_OFF, 4);
    memcpy(&c_sz, in + HDR_CSIZE_OFF, 4);
    if (c_sz + HDR_HDR_SIZE != n)
        return (0);

    ip = in + HDR_HDR_SIZE;
    end = in + n;
    opos = 0;

    while (ip < end) {
        tok = *ip++;
        l_len = dec_read_ext_len(&ip, end, tok >> 4);
        if (l_len == 0 && (tok >> 4) == TOKEN_MAX_NIBBLE && ip > end)
            return 0;
        if (opos + l_len > cap)
            return (0);
        if ((size_t)(end - ip) < l_len)
            return 0;
        memcpy(out + opos, ip, l_len);
        ip += l_len;
        opos += l_len;
        if (ip >= end)
            break;

        if ((size_t)(end - ip) < 2) return 0;
        off = ip[0] | (ip[1] << 8);
        ip += 2;
        m_len = (tok & 0xF) + MIN_MAT;
        m_len = dec_read_ext_len(&ip, end, m_len - MIN_MAT) + MIN_MAT;
        if (dec_copy_match(out, opos, off, m_len, cap) != 0)
            return (0);
        opos += m_len;
    }
    return (opos == org ? opos : 0);
}

