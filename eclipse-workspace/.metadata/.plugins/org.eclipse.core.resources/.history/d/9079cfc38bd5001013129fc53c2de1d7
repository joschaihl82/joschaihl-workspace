 * asm.c — Minimal C99 assembler scaffold with ELF64 relocatable object file output.
 *
 * Implements:
 * - AT&T syntax parsing.
 * - Core x86-64 instruction encoding (movq, jmp).
 * - Symbol management and R_X86_64_PC32 relocation.
 * - Full ELF64 .o file generation (.text, .data, .bss, .rela.text, .symtab, .strtab, .shstrtab).
 * - Instruction matching uses a table-driven approach for extensibility.
 */

