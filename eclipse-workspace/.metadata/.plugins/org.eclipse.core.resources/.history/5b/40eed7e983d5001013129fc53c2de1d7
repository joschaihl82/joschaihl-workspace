    char *name;
    int len;
} keyword_entry;

// this array defines the keywords recognized by the compiler's tokenizer.
keyword_entry keywords[] = {
    {"return", 6}, {"if", 2}, {"else", 4}, {"while", 5}, {"for", 3},
    {"break", 5}, {"continue", 8}, {"switch", 6}, {"case", 4}, {"default", 7},
